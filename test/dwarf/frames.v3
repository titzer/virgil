// Checks that call frame information is good enough to unwind the stack: a
// debugger stopped in the innermost method must be able to walk back out
// through every caller and read their locals.
def leaf(n: int) -> int {
	var t = n * 2;
	return t;
}
def middle(n: int) -> int {
	var m = n + 1;
	return leaf(m) + m;
}
def outer(n: int) -> int {
	var o = n + 2;
	return middle(o) + o;
}
def deep(n: int) -> int {
	if (n <= 0) return leaf(0);
	return deep(n - 1) + 1;
}
def main() -> int {
	var r = outer(1);
	var d = deep(5);
	System.puts("frames\n");
	return r + d - 20;
}
