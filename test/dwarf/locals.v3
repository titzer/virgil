// Checks that local variables of every primitive kind are described with the
// right type and location, including variables that live in registers, on the
// stack, and that move between the two over their lifetime.
enum Color { RED, GREEN, BLUE }

def spin(n: int) -> int {
	var acc = 0;
	for (i < n) {
		var sq = i * i;
		acc = acc + sq;
	}
	return acc;
}
def check(i: int, l: long, b: bool, c: Color, f: float, d: double) -> int {
	return i + int.!(l) + (if(b, 1, 0)) + c.tag + int.!(f) + int.!(d);
}
def main() -> int {
	var i = 7;
	var l = 8L;
	var b = true;
	var c = Color.BLUE;
	var f = 9f;
	var d = 10d;
	var s = spin(4);
	var v = check(i, l, b, c, f, d) + s - 51;
	System.puts("locals\n");
	return v;
}
