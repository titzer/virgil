// Checks that every statement gets its own row in the DWARF line table and that
// the rows of a method start at the method's entry point, not in its prologue.
def add(x: int, y: int) -> int {
	var s = x + y;
	var d = x - y;
	return s * d;
}
def pick(x: int) -> int {
	if (x > 10) {
		return add(x, 3);
	}
	return add(x, 1);
}
def main() -> int {
	var a = pick(20);
	var b = pick(2);
	System.puts("lines\n");
	return a + b - 394;
}
