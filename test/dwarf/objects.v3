// Checks that class references and array references are described well enough
// for a debugger to follow them: a class is a pointer to a structure with the
// declared fields at their machine offsets, and an array is a pointer to a
// structure with a length and inline elements.
class Point {
	var x: int;
	var y: int;
	new(x, y) { }
	def dist2() -> int { return x * x + y * y; }
}
class Line {
	var a: Point;
	var b: Point;
	new(a, b) { }
	def len2() -> int {
		var dx = a.x - b.x, dy = a.y - b.y;
		return dx * dx + dy * dy;
	}
}
def total(a: Array<int>) -> int {
	var t = 0;
	for (i < a.length) t = t + a[i];
	return t;
}
def main() -> int {
	var p = Point.new(3, 4);
	var q = Point.new(6, 8);
	var l = Line.new(p, q);
	var a = [10, 20, 30, 40];
	var t = total(a);
	var s = "objects\n";
	System.puts(s);
	return p.dist2() + l.len2() + t - 150;
}
