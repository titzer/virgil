//@execute 0=100; 1=200; 2=600
// Closure with params passed to function (escape path)
enum E(x: int) { A(100), B(200), _; def scale(n: int) -> int { return x * n; } }
enum E.More { C(300); def scale(n: int) -> int { return x * n * 2; } }
def call(f: int -> int, arg: int) -> int { return f(arg); }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.More.C];
    if (i < 0 || i >= cases.length) return -1;
    var f = cases[i].scale;
    return call(f, 1);
}
