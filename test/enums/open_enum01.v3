//@execute 0=1; 1=2; 2=3; 3=3; 4=0
// Subtype enum: match on subtype name in parent match
enum E1 { A, B, _ }
enum E1.More { C, D }
def dispatch(e: E1) -> int {
    match (e) {
        A    => return 1;
        B    => return 2;
        More => return 3;  // range test: is e in More's tag range?
        _    => return 0;
    }
}
def main(x: int) -> int {
    var cases: Array<E1> = [E1.A, E1.B, E1.More.C, E1.More.D];
    if (x < 0 || x >= cases.length) return 0;
    return dispatch(cases[x]);
}
