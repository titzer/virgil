//@execute 0=0; 1=10; 2=20; 3=0; 4=40; 5=40
// Virtual dispatch through _ case at root and subtype levels
enum E {
	A { def m() -> int { return 10; } },
	B { def m() -> int { return 20; } },
	_;
	def m() -> int { return 0; }
}
enum E.More {
	C,
	_;
	def m() -> int { return 40; }
}
def dispatch(e: E) -> int { return e.m(); }
def main(arg: int) -> int {
	var all: Array<E> = [E.A, E.B, E.More.C];
	match (arg) {
		0 => return dispatch(E.A) + dispatch(E.B) - 30;	// named cases
		1 => return dispatch(all[0]);				// A via array
		2 => return dispatch(all[1]);				// B via array
		3 => return dispatch(all[2]) - 40;			// More.C uses More.m (default)
		4 => return dispatch(E.More.C);				// More.C static -> virtual
		5 => { var e: E = E.More.C; return e.m(); }		// virtual through E type
	}
	return -1;
}
