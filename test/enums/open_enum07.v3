//@execute 0=1; 1=2; 2=10; 3=10; 4=20; 5=0
// Open enum: multiple sibling subtype enums, match arm for each
enum E { A, B, _ }
enum E.Nums { N1, N2 }
enum E.Tens { T1 }
def main(x: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.Nums.N1, E.Nums.N2, E.Tens.T1];
    if (x < 0 || x >= cases.length) return 0;
    match (cases[x]) {
        A    => return 1;
        B    => return 2;
        Nums => return 10;
        Tens => return 20;
        _    => return 0;
    }
}
