//@execute 0=10; 1=22; 2=40; 3=10; 4=22; 5=40
// Combined: 3-level hierarchy + extra fields + method overrides + closures
enum E(x: int) { A(10), _; def compute() -> int { return x; } }
enum E.Mid(super, y: int) { B(20, 2), _; def compute() -> int { return x + y; } }
enum E.Mid.Leaf(super, z: int) { C(30, 3, 7); def compute() -> int { return x + y + z; } }
def apply(f: void -> int) -> int { return f(); }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.Mid.B;
    var c: E = E.Mid.Leaf.C;
    match (i) {
        0 => return a.compute();
        1 => return b.compute();
        2 => return c.compute();
        3 => return apply(a.compute);
        4 => return apply(b.compute);
        5 => return apply(c.compute);
    }
    return -1;
}
