//@execute 0=1; 1=0; 2=2
// Overridden method closure with virtual dispatch
enum E { A { def m() -> int { return 1; } }, B, C { def m() -> int { return 2; } }; def m() -> int { return 0; } }
def main(i: int) -> int {
    var e: E = if(i == 0, E.A, if(i == 1, E.B, E.C));
    var f = e.m;
    return f();
}
