//@execute 0=1; 1=2; 2=-1
// Enum method closure with subtype override
enum E { A, _; def m() -> int { return 1; } }
enum E.More { B; def m() -> int { return 2; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.More.B];
    if (i < 0 || i >= cases.length) return -1;
    var f = cases[i].m;
    return f();
}
