//@execute 0=10; 1=20; 2=11; 3=20; 4=-1
// Multiple methods: subtype overrides m1 but inherits m2
enum E { A, _; def m1() -> int { return 10; } def m2() -> int { return 20; } }
enum E.More { B; def m1() -> int { return 11; } }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.More.B;
    match (i) {
        0 => return a.m1();
        1 => return a.m2();
        2 => return b.m1();
        3 => return b.m2();
    }
    return -1;
}
