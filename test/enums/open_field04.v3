//@execute 0=10; 1=20
// Access field on subtype-typed variable
enum E(x: int) { A(1), _ }
enum E.S1(x: int) { C(10), D(20) }
def main(i: int) -> int {
    match (i) {
        0 => { var v: E.S1 = E.S1.C; return v.x; }
        1 => { var v: E.S1 = E.S1.D; return v.x; }
        _ => return -1;
    }
}
