//@execute 0=1; 1=2; 2=3; 3=1
// Match arm + subtype override dispatch
enum E { A, B, _; def val() -> int { return 1; } }
enum E.More { C; def val() -> int { return 3; } }
def test(e: E) -> int {
    match (e) {
        A => return 1;
        B => return 2;
        More => return e.val();
        _ => return 4;
    }
}
def main(i: int) -> int {
    match (i) {
        0 => return test(E.A);
        1 => return test(E.B);
        2 => return test(E.More.C);
        3 => { var e: E; return test(e); }
    }
    return -1;
}
