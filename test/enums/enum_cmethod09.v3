//@execute 0=0; 1=0; 2=2; 3=1
// Virtual dispatch through parent type
enum E { A, B, _; def m() -> int { return 0; } }
enum E.More { C { def m() -> int { return 2; } }, D; def m() -> int { return 1; } }
def call(e: E) -> int { return e.m(); }
def main(i: int) -> int {
    match (i) {
        0 => return call(E.A);
        1 => return call(E.B);
        2 => return call(E.More.C);
        3 => return call(E.More.D);
    }
    return -1;
}
