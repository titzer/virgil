//@execute 0=1; 1=2; 2=10; 3=20; 4=0
// Open enum: multi-level hierarchy (E.More has _ allowing E.More.Extra)
// DFS tags: A=0, B=1, More.C=2, More.Extra.D=3
enum E { A, B, _ }
enum E.More { C, _ }
enum E.More.Extra { D }
def main(x: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.More.C, E.More.Extra.D];
    if (x < 0 || x >= cases.length) return 0;
    match (cases[x]) {
        A    => return 1;
        B    => return 2;
        More => {
            if (E.More.Extra.?(cases[x])) return 20;  // More.Extra subrange
            return 10;                                  // More.C (in More but not Extra)
        }
        _ => return 0;
    }
}
