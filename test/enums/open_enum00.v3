//@execute 0=1; 1=2; 2=0; 3=0
// Open enum: basic match with default arm catches subtype cases
enum E { A, B, _ }
enum E.More { C, D }
def main(x: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.More.C, E.More.D];
    if (x < 0 || x >= cases.length) return 0;
    var e: E = cases[x];
    match (e) {
        A => return 1;
        B => return 2;
        _ => return 0;
    }
}
