//@execute 0=1; 1=0; 2=1; 3=0; 4=1; 5=3
// Set operations on 3-level hierarchy: cross-level union and intersection
enum E { A, B, _ }
enum E.Mid { C, D, _ }
enum E.Mid.Deep { G, H }
def main(i: int) -> int {
    var s: E.set = E.A | E.Mid.D | E.Mid.Deep.G;
    match (i) {
        0 => return if(s.A, 1, 0);
        1 => return if(s.B, 1, 0);
        2 => return if(s.D, 1, 0);
        3 => return if(s.C, 1, 0);
        4 => return if(s.G, 1, 0);
        5 => { var n = 0; for (e in s) n++; return n; }
    }
    return -1;
}
