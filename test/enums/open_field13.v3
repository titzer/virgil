//@execute 0=10; 1=100; 2=200
// Root-typed variable holding subtype value (Form 1+add), inherited field access
enum E(x: int) { A(10), _ }
enum E.S(x: int, y: int) { B(100, 150), C(200, 250) }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.S.B, E.S.C];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].x;
}
