//@execute 0=99; 1=88; 2=77; 3=66
// Empty subtype with fields, no named cases
enum E(x: int) { A(99), _ }
enum E.Mid(super) { _; }
enum E.Mid.Leaf(super, y: int) { B(88, 1), C(77, 2) }
enum E.Other(super) { D(66) }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.Mid.Leaf.B, E.Mid.Leaf.C, E.Other.D];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].x;
}
