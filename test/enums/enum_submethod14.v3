//@execute 0=0; 1=0; 2=1; 3=1
// Single-case subtype: dispatch, override, closure
enum E { A, B, _; def rank() -> int { return 0; } }
enum E.Special { X; def rank() -> int { return 1; } }
def call(f: void -> int) -> int { return f(); }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.Special.X, E.Special.X];
    if (i < 0 || i >= cases.length) return -1;
    if (i < 3) return cases[i].rank();
    return call(cases[3].rank);
}
