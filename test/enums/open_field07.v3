//@execute 0=10; 1=20; 2=100; 3=200
// Restate + add — access all fields
enum E(x: int) { A(10), B(20), _ }
enum E.S1(x: int, f: float) { C(100, 1.5f), D(200, 2.5f) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.x;
        1 => return E.B.x;
        2 => return E.S1.C.x;
        3 => return E.S1.D.x;
    }
    return -1;
}
