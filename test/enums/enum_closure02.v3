//@execute 0=10; 1=11; 2=20; 3=20; 4=-1
// Enum method closure: selective override + inherited method
enum E { A, _; def m1() -> int { return 10; } def m2() -> int { return 20; } }
enum E.More { B; def m1() -> int { return 11; } }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.More.B;
    match (i) {
        0 => { var f = a.m1; return f(); }
        1 => { var f = b.m1; return f(); }
        2 => { var f = a.m2; return f(); }
        3 => { var f = b.m2; return f(); }
    }
    return -1;
}
