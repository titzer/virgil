//@execute 0=10; 1=11; 2=20; 3=22
// Closures stored in array with selective override + params
enum E(x: int) { A(10), _; def m1() -> int { return x; } def m2() -> int { return x * 2; } }
enum E.More { B(11); def m1() -> int { return x; } }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.More.B;
    var closures: Array<void -> int> = [a.m1, b.m1, a.m2, b.m2];
    if (i < 0 || i >= closures.length) return -1;
    return closures[i]();
}
