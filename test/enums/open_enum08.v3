//@execute 0=2; 1=3; 2=0
// Open enum: variable declared as subtype enum type, .tag returns DFS global tag
enum E1 { A, B, _ }
enum E1.More { C, D }
def main(x: int) -> int {
    var e: E1.More;
    if (x == 0) e = E1.More.C;
    else if (x == 1) e = E1.More.D;
    else return 0;
    return e.tag;  // C=2, D=3
}
