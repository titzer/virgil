//@execute 0=1; 1=2; 2=20; 3=3; 4=25
// Multi-level (super) only — grandchild provides root + intermediate extras, no own extras
enum E(x: int) { A(1), _ }
enum E.S(super, y: int) { B(2, 20), _ }
enum E.S.T(super) { C(3, 25) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.x;
        1 => return E.S.B.x;
        2 => { var v: E.S = E.S.B; return v.y; }
        3 => return E.S.T.C.x;
        4 => { var v: E.S.T = E.S.T.C; return v.y; }
    }
    return -1;
}
