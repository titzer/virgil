//@execute 0=5; 1=99
// Enum with private method
enum E { A, B;
    def getVal() -> int { return helper(); }
    private def helper() -> int { return tag + 5; }
}
def main(i: int) -> int {
    match (i) {
        0 => return E.A.getVal();
        1 => { var e: E = E.B; return e.getVal() + 93; }
    }
    return -1;
}
