//@execute 0=10; 1=10; 2=10; 3=10
// Subtype enum cases inherit parent's method
enum E { A, B, _; def m() -> int { return 10; } }
enum E.More { C, D }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.m();
        1 => return E.B.m();
        2 => return E.More.C.m();
        3 => return E.More.D.m();
    }
    return -1;
}
