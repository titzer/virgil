//@execute 0=0; 1=10; 2=20
// Zero-init of open enum with method: default tag dispatches correctly
enum E { A, B, _; def val() -> int { return 0; } }
enum E.More { C, D, _; def val() -> int { return 10; } }
enum E.More.Deep { G; def val() -> int { return 20; } }
def main(i: int) -> int {
    match (i) {
        0 => { var e: E; return e.val(); }
        1 => { var e: E = E.More.C; return e.val(); }
        2 => { var e: E = E.More.Deep.G; return e.val(); }
    }
    return -1;
}
