//@execute 0=1; 1=1; 2=3; 3=10; 4=20; 5=20; 6=100; 7=200
// 4-level hierarchy with fields at each level
enum E(a: int) { R(1), _; def getA() -> int { return a; } }
enum E.L1(super, b: int) { X(10, 100), _ }
enum E.L1.L2(super, c: int) { Y(20, 200, 2000) }
def main(i: int) -> int {
    match (i) {
        0 => return E.R.a;
        1 => return E.R.getA();
        2 => { var e: E; return if(e == E.R, 3, 0); }
        3 => return E.L1.X.a;
        4 => { var e: E = E.L1.L2.Y; return e.getA(); }
        5 => { var e: E = E.L1.L2.Y; return e.a; }
        6 => { var v: E.L1 = E.L1.X; return v.b; }
        7 => { var v: E.L1.L2 = E.L1.L2.Y; return v.b; }
    }
    return -1;
}
