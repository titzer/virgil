//@execute 0=42; 1=7; 2=99
// Per-case override: static dispatch (E.A.m()) should use case override
enum E {
	A { def m() -> int { return 42; } },
	B { def m() -> int { return 7; } },
	C;
	def m() -> int { return 0; }
}
def main(arg: int) -> int {
	match (arg) {
		0 => return E.A.m();
		1 => return E.B.m();
		2 => return E.A.m() + E.B.m() + E.C.m() + 50;
	}
	return -1;
}
