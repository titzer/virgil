//@execute 0=5; 1=15; 2=25
// Closure of override method passed through higher-order function chain
enum E { A, B, _; def val() -> int { return 5; } }
enum E.Sub { C, _; def val() -> int { return 15; } }
enum E.Sub.Deep { G; def val() -> int { return 25; } }
def apply(f: void -> int) -> int { return f(); }
def wrap(f: void -> int) -> (void -> int) { return f; }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.Sub.C, E.Sub.Deep.G];
    if (i < 0 || i >= cases.length) return -1;
    var f = wrap(cases[i].val);
    return apply(f);
}
