//@execute 0=10; 1=20; 2=35; 3=35
// Subtype adds extra field; method accesses both inherited and new fields
enum E(x: int) { A(10), B(20), _; def val() -> int { return x; } }
enum E.More(super, y: int) { C(30, 5); def val() -> int { return x + y; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.val();
        1 => return E.B.val();
        2 => return E.More.C.val();
        3 => { var e: E = E.More.C; return e.val(); }
    }
    return -1;
}
