//@execute 0=42; 1=7; 2=99
// Basic enum-level methods: all cases share the same implementation
enum E { A, B, C; def m() -> int { return 42; } def n() -> int { return 7; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.m();
        1 => return E.B.n();
        2 => { var e: E = E.C; return e.m() + e.n() + 50; }
    }
    return -1;
}
