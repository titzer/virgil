//@execute 0=1; 1=2; 2=0
// Float extra field round-trip (cast to int to verify value)
enum E(x: int) { A(10), _ }
enum E.S(super, f: float) { B(20, 1.5f), C(30, 2.75f) }
def main(i: int) -> int {
    match (i) {
        0 => { var v: E.S = E.S.B; return int.truncf(v.f); }
        1 => { var v: E.S = E.S.C; return int.truncf(v.f); }
        2 => { var v: E.S = E.S.B; return int.truncf(v.f - 1.5f); }
    }
    return -1;
}
