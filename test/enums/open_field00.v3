//@execute 0=1; 1=17; 2=10; 3=20
// Form 1: explicit redecl — subtype cases provide field values
enum E(x: int) { A(1), B(17), _ }
enum E.S1(x: int) { C(10), D(20) }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.S1.C, E.S1.D];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].x;
}
