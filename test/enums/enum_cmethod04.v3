//@execute 0=100; 1=200; 2=0; 3=100; 4=200
// Per-case override with enum fields
enum E(x: int) {
	A(10) { def m() -> int { return x * 10; } },
	B(10) { def m() -> int { return x * 20; } },
	C(10);
	def m() -> int { return 0; }
}
def main(arg: int) -> int {
	var vals = [E.A, E.B, E.C];
	if (arg < 3) return vals[arg].m();
	if (arg == 3) return E.A.m();
	return E.B.m();
}
