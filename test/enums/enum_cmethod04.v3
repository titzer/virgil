//@execute 0=10; 1=0; 2=20; 3=0
// Virtual dispatch with multiple methods
enum E {
    A { def m() -> int { return 10; } },
    B,
    C { def m() -> int { return 20; } };
    def m() -> int { return 0; }
}
def callM(e: E) -> int { return e.m(); }
def main(i: int) -> int {
    match (i) {
        0 => return callM(E.A);
        1 => return callM(E.B);
        2 => return callM(E.C);
        3 => { var e: E = E.B; return e.m(); }
    }
    return -1;
}
