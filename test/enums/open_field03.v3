//@execute 0=11; 1=21; 2=31; 3=12; 4=22; 5=32
// Multiple params: subtype redeclares, all field accesses correct
enum E(a: int, b: int) { X(1, 2), _ }
enum E.S(a: int, b: int) { Y(10, 20) }
def main(i: int) -> int {
    match (i) {
        0 => return E.X.a + 10;
        1 => return E.X.b + 19;
        2 => return E.S.Y.a + 21;
        3 => return E.S.Y.b + -8;
        4 => { var e: E = E.S.Y; return e.a + 12; }
        5 => { var e: E = E.S.Y; return e.b + 12; }
        _ => return -1;
    }
}
