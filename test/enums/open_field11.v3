//@execute 0=10; 1=20; 2=30; 3=133
// Multiple extra fields in one subtype
enum E(x: int) { A(10), _ }
enum E.S(super, y: int, z: int) { B(20, 30, 40), C(50, 60, 70) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.x;
        1 => return E.S.B.x;
        2 => { var v: E.S = E.S.B; return v.y; }
        3 => { var v: E.S = E.S.B; return v.y + v.z + E.S.C.x + v.x - 7; }
    }
    return -1;
}
