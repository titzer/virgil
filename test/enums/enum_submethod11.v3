//@execute 0=1; 1=22; 2=333; 3=22; 4=333
// 3-level hierarchy with extra fields: closure accessing all fields
enum E(x: int) { A(1), _; def sum() -> int { return x; } }
enum E.Mid(super, y: int) { B(2, 20), _; def sum() -> int { return x + y; } }
enum E.Mid.Deep(super, z: int) { C(3, 30, 300); def sum() -> int { return x + y + z; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.sum();
        1 => return E.Mid.B.sum();
        2 => return E.Mid.Deep.C.sum();
        3 => { var f = E.Mid.B.sum; return f(); }
        4 => { var f = E.Mid.Deep.C.sum; return f(); }
    }
    return -1;
}
