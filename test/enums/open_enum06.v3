//@execute 0=10; 1=20; 2=30; 3=40; 4=0
// Open enum: subtype cases must provide params when root has params
enum E1(x: int) { A(10), B(20), _ }
enum E1.More { C(30), D(40) }
def main(x: int) -> int {
    var cases: Array<E1> = [E1.A, E1.B, E1.More.C, E1.More.D];
    if (x < 0 || x >= cases.length) return 0;
    var e: E1 = cases[x];
    return e.x;
}
