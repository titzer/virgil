//@execute 0=5; 1=1; 2=1
// Open enum set: multiple siblings share root set type
enum E { A, _ }
enum E.Nums { N1, N2 }
enum E.Tens { T1, T2 }
def main(x: int) -> int {
    // DFS tags: A=0, N1=1, N2=2, T1=3, T2=4
    var all = E.set.all;
    match (x) {
        0 => {
            var count = 0;
            for (e in all) count++;
            return count;
        }
        1 => {
            var s: E.set = E.Nums.N1 | E.Nums.N2;
            return if(s.N1, 1, 0);
        }
        2 => {
            var s: E.set = E.Tens.T1 | E.Tens.T2;
            return if(s.T2, 1, 0);
        }
    }
    return -1;
}
