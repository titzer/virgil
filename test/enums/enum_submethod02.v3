//@execute 0=1; 1=1; 2=2; 3=-1
// Partial override: E.Left overrides, E.Right inherits root
enum E { A, _; def m() -> int { return 1; } }
enum E.Left { B; def m() -> int { return 2; } }
enum E.Right { C }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.Left.B;
    var c: E = E.Right.C;
    match (i) {
        0 => return a.m();
        1 => return c.m();
        2 => return b.m();
    }
    return -1;
}
