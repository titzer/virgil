//@execute 0=1; 1=17; 2=10; 3=99
// Inherited method with extra fields: subtype does NOT override, method accesses parent fields
enum E(x: int) { A(1), B(17), _; def getX() -> int { return x; } }
enum E.Sub(super, y: int) { C(10, 99), D(20, 88) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.getX();
        1 => return E.B.getX();
        2 => { var e: E = E.Sub.C; return e.getX(); }
        3 => { var v: E.Sub = E.Sub.C; return v.y; }
    }
    return -1;
}
