//@execute 0=65; 1=66; 2=67; 3=68; 4=0
// Subtype enum: .shortName returns unqualified case names
enum E1 { A, B, _ }
enum E1.More { C, D }
def main(x: int) -> int {
    var cases: Array<E1> = [E1.A, E1.B, E1.More.C, E1.More.D];
    if (x < 0 || x >= cases.length) return 0;
    var e = cases[x];
    var n = e.shortName;  // "A", "B", "C", "D"
    return if(n.length > 0, n[0], 0);
}
