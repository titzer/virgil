//@execute 0=100; 1=600; 2=600; 3=1800
// Static dispatch closure vs virtual dispatch closure
enum E(x: int) { A(100), _; def scale(n: int) -> int { return x * n; } }
enum E.More { C(300); def scale(n: int) -> int { return x * n * 2; } }
def main(i: int) -> int {
    match (i) {
        0 => { var f = E.A.scale; return f(1); }
        1 => { var f = E.More.C.scale; return f(1); }
        2 => { var e: E = E.More.C; var f = e.scale; return f(1); }
        3 => { var e: E = E.More.C; var f = e.scale; return f(3); }
    }
    return -1;
}
