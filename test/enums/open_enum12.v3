//@execute 0=1; 1=2; 2=2; 3=3
// Type query narrowing + method dispatch
enum E { A, B, _; def val() -> int { return 1; } }
enum E.Sub { C, D, _; def val() -> int { return 2; } }
enum E.Sub.Deep { G; def val() -> int { return 3; } }
def dispatch(e: E) -> int {
    if (E.Sub.Deep.?(e)) return e.val();
    if (E.Sub.?(e)) return e.val();
    return e.val();
}
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.Sub.C, E.Sub.D, E.Sub.Deep.G];
    if (i < 0 || i >= cases.length) return -1;
    return dispatch(cases[i]);
}
