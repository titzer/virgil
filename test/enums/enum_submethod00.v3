//@execute 0=1; 1=1; 2=2; 3=2; 4=-1
// Subtype method override: E.More overrides E.m()
enum E { A, B, _; def m() -> int { return 1; } }
enum E.More { C, D; def m() -> int { return 2; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.More.C, E.More.D];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].m();
}
