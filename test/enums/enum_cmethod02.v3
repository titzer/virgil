//@execute 0=10; 1=20; 2=42; 3=7
// Multiple methods, some overridden
enum E {
    A { def m() -> int { return 10; } },
    B { def n() -> int { return 20; } },
    C;
    def m() -> int { return 42; }
    def n() -> int { return 7; }
}
def main(i: int) -> int {
    match (i) {
        0 => return E.A.m();
        1 => return E.B.n();
        2 => return E.C.m();
        3 => return E.C.n();
    }
    return -1;
}
