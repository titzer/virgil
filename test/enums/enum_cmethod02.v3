//@execute 0=10; 1=0; 2=20; 3=2
// Per-case method override with parameters
enum E {
	A { def m(x: int) -> int { return 10 + x; } },
	B,
	C { def m(x: int) -> int { return 20 + x; } };
	def m(x: int) -> int { return x; }
}
def main(arg: int) -> int {
	var vals = [E.A, E.B, E.C];
	if (arg < 3) return vals[arg].m(0);
	return vals[1].m(2);
}
