//@execute 0=10; 1=11; 2=20; 3=22
// Closure escape with selective override + params
enum E(x: int) { A(10), _; def m1() -> int { return x; } def m2() -> int { return x * 2; } }
enum E.More { B(11); def m1() -> int { return x; } }
def call(f: void -> int) -> int { return f(); }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.More.B];
    var a = cases[0];
    var b = cases[1];
    match (i) {
        0 => return call(a.m1);
        1 => return call(b.m1);
        2 => return call(a.m2);
        3 => return call(b.m2);
    }
    return -1;
}
