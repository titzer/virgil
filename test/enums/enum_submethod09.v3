//@execute 0=10; 1=120; 2=120
// Subtype adds extra field; method with params accesses both
enum E(x: int) { A(10), _; def calc(n: int) -> int { return x * n; } }
enum E.More(super, y: int) { B(20, 100); def calc(n: int) -> int { return x * n + y; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.calc(1);
        1 => return E.More.B.calc(1);
        2 => { var e: E = E.More.B; return e.calc(1); }
    }
    return -1;
}
