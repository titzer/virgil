//@execute 0=1; 1=1; 2=0; 3=0
// Open enum set: subtype cases in set, membership via .C and .D
enum E { A, B, _ }
enum E.More { C, D }
def main(x: int) -> int {
    var s: E.set = E.More.C | E.More.D;
    match (x) {
        0 => return if(s.C, 1, 0);
        1 => return if(s.D, 1, 0);
        2 => return if(s.A, 1, 0);
        3 => return if(s.B, 1, 0);
    }
    return -1;
}
