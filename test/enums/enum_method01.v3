//@execute 0=1; 1=17; 2=3
// Enum method accessing fields
enum E(x: int) { A(1), B(17), C(3); def getX() -> int { return x; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.getX();
        1 => return E.B.getX();
        2 => { var e: E = E.C; return e.getX(); }
    }
    return -1;
}
