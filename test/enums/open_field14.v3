//@execute 0=1; 1=2; 2=3; 3=20; 4=30
// Multi-level hierarchy: grandchild inherits intermediate extra field
enum E(x: int) { A(1), _ }
enum E.S(super, y: int) { B(2, 20), _ }
enum E.S.T(super, z: int) { C(3, 20, 30) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.x;
        1 => return E.S.B.x;
        2 => return E.S.T.C.x;
        3 => { var v: E.S.T = E.S.T.C; return v.y; }
        4 => { var v: E.S.T = E.S.T.C; return v.z; }
    }
    return -1;
}
