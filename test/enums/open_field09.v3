//@execute 0=10; 1=20; 2=100; 3=200
// Multiple subtypes with different extra fields
enum E(x: int) { A(10), _ }
enum E.S1(super, y: int) { B(20, 100) }
enum E.S2(super, z: int) { C(30, 200) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.x;
        1 => return E.S1.B.x;
        2 => { var v: E.S1 = E.S1.B; return v.y; }
        3 => { var v: E.S2 = E.S2.C; return v.z; }
    }
    return -1;
}
