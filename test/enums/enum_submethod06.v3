//@execute 0=1; 1=1; 2=-1
// Enum with _ case, method, but no subtypes: _ is unreachable,
// all reachable cases dispatch to root method.
enum E { A, B, _; def m() -> int { return 1; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.B];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].m();
}
