//@execute 0=0; 1=2; 2=2; 3=3; 4=2; 5=3
// Empty subtype (only _, no named cases) with method and deeper subtypes
enum E { A, _; def level() -> int { return 0; } }
enum E.Mid { _; def level() -> int { return 1; } }
enum E.Mid.Leaf { X, Y; def level() -> int { return 2; } }
enum E.Other { Z; def level() -> int { return 3; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.Mid.Leaf.X, E.Mid.Leaf.Y, E.Other.Z];
    match (i) {
        0 => return cases[0].level();
        1 => return cases[1].level();
        2 => return cases[2].level();
        3 => return cases[3].level();
        4 => { var e: E = E.Mid.Leaf.Y; return e.level(); }
        5 => { var f = cases[3].level; return f(); }
    }
    return -1;
}
