//@execute 0=4; 1=3; 2=1; 3=0; 4=1
// Combined: fields + methods + closures + sets in one hierarchy
enum E(x: int) { A(10), B(20), _; def val() -> int { return x; } }
enum E.Sub(super) { C(30), D(40); def val() -> int { return x + 1; } }
def main(i: int) -> int {
    match (i) {
        0 => {
            var s = E.set.all;
            var count = 0;
            for (c in s) count++;
            return count;
        }
        1 => {
            var s: E.set = E.A | E.Sub.C | E.Sub.D;
            var count = 0;
            for (c in s) count++;
            return count;
        }
        2 => {
            var s: E.set = E.Sub.C | E.Sub.D;
            return if(s.C && s.D && !s.A, 1, 0);
        }
        3 => {
            var e: E = E.Sub.C;
            var f = e.val;
            return if(f() == 31, 0, 1);
        }
        4 => {
            var cases: Array<E> = [E.A, E.B, E.Sub.C, E.Sub.D];
            var sum = 0;
            for (c in cases) sum += c.val();
            return if(sum == 10 + 20 + 31 + 41, 1, 0);
        }
    }
    return -1;
}
