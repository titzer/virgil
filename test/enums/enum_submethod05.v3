//@execute 0=100; 1=200; 2=600; 3=600
// Override method with parameters
enum E(x: int) { A(100), B(200), _; def scale(n: int) -> int { return x * n; } }
enum E.More { C(300); def scale(n: int) -> int { return x * n * 2; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.scale(1);
        1 => return E.B.scale(1);
        2 => return E.More.C.scale(1);
        3 => { var e: E = E.More.C; return e.scale(1); }
    }
    return -1;
}
