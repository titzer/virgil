//@execute 0=10; 1=11; 2=20; 3=22
// Selective override closures with params: inline f() calls
enum E(x: int) { A(10), _; def m1() -> int { return x; } def m2() -> int { return x * 2; } }
enum E.More { B(11); def m1() -> int { return x; } }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.More.B;
    match (i) {
        0 => { var f = a.m1; return f(); }
        1 => { var f = b.m1; return f(); }
        2 => { var f = a.m2; return f(); }
        3 => { var f = b.m2; return f(); }
    }
    return -1;
}
