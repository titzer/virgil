//@execute 0=0; 1=1; 2=2; 3=3; 4=0
// Subtype enum: .tag returns DFS-assigned global tag
enum E1 { A, B, _ }
enum E1.More { C, D }
def main(x: int) -> int {
    var cases: Array<E1> = [E1.A, E1.B, E1.More.C, E1.More.D];
    if (x < 0 || x >= cases.length) return 0;
    return cases[x].tag;  // 0, 1, 2, 3
}
