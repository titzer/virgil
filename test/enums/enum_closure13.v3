//@execute 0=10; 1=11; 2=20; 3=22
// Closure escape with selective override + params (exercises constant tag-0 boxing)
enum E(x: int) { A(10), _; def m1() -> int { return x; } def m2() -> int { return x * 2; } }
enum E.More { B(11); def m1() -> int { return x; } }
def call(f: void -> int) -> int { return f(); }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.More.B;
    match (i) {
        0 => return call(a.m1);
        1 => return call(b.m1);
        2 => return call(a.m2);
        3 => return call(b.m2);
    }
    return -1;
}
