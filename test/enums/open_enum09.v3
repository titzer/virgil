//@execute 0=0; 1=1; 2=1; 3=0
// Open enum: widening in function argument (E1.More -> E1), type query in called fn
enum E1 { A, _ }
enum E1.More { B, C }
def isMore(e: E1) -> int {
    return if(E1.More.?(e), 1, 0);
}
def main(x: int) -> int {
    var cases: Array<E1> = [E1.A, E1.More.B, E1.More.C];
    if (x < 0 || x >= cases.length) return 0;
    return isMore(cases[x]);
}
