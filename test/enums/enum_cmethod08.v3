//@execute 0=0; 1=0; 2=2; 3=1
// Case override in subtype + subtype-level override
enum E { A, B, _; def m() -> int { return 0; } }
enum E.More { C { def m() -> int { return 2; } }, D; def m() -> int { return 1; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.m();
        1 => return E.B.m();
        2 => return E.More.C.m();
        3 => return E.More.D.m();
    }
    return -1;
}
