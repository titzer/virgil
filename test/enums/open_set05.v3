//@execute 0=6; 1=4; 2=2; 3=1
// Set operations on 3-level hierarchy: counting and membership
enum E { A, B, _ }
enum E.Mid { C, D, _ }
enum E.Mid.Deep { X, Y }
def count(s: E.set) -> int { var n = 0; for (e in s) n++; return n; }
def main(i: int) -> int {
    match (i) {
        0 => return count(E.set.all);
        1 => { var s: E.set = E.Mid.C | E.Mid.D | E.Mid.Deep.X | E.Mid.Deep.Y; return count(s); }
        2 => { var s: E.set = E.Mid.Deep.X | E.Mid.Deep.Y; return count(s); }
        3 => { var s: E.set = E.A | E.Mid.Deep.X; return count(s & (E.A | E.B)); }
    }
    return -1;
}
