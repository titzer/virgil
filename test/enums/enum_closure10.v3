//@execute 0=1; 1=3; 2=3; 3=5; 4=27
// 3-level hierarchy closure with params + field access + escape
enum E(x: int) { A(1), _; def mul(n: int) -> int { return x * n; } }
enum E.Mid(super) { B(2), _; def mul(n: int) -> int { return x * n + 1; } }
enum E.Mid.Deep(super) { C(3); def mul(n: int) -> int { return x * n * n; } }
def call(f: int -> int, arg: int) -> int { return f(arg); }
def main(i: int) -> int {
    var a: E = E.A;
    var b: E = E.Mid.B;
    var c: E = E.Mid.Deep.C;
    match (i) {
        0 => return a.mul(1);
        1 => return b.mul(1);
        2 => return c.mul(1);
        3 => { var f = b.mul; return call(f, 2); }
        4 => { var f = c.mul; return call(f, 3); }
    }
    return -1;
}
