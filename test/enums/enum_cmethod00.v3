//@execute 0=1; 1=0; 2=0
// Per-case override returns different value
enum E { A { def m() -> int { return 1; } }, B, C; def m() -> int { return 0; } }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.m();
        1 => return E.B.m();
        2 => return E.C.m();
    }
    return -1;
}
