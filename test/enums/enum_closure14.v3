//@execute 0=10; 1=20; 2=30; 3=40
// Closures stored in array, dispatched from array
enum E(x: int) { A(10), B(20), _; def getX() -> int { return x; } }
enum E.More(super) { C(30), D(40) }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.B, E.More.C, E.More.D];
    var closures = Array<void -> int>.new(cases.length);
    for (j < cases.length) closures[j] = cases[j].getX;
    if (i < 0 || i >= closures.length) return -1;
    return closures[i]();
}
