//@execute 0=0; 1=0; 2=1; 3=1; 4=0
// Subtype enum: type query E1.More.?(e)
enum E1 { A, B, _ }
enum E1.More { C, D }
def main(x: int) -> int {
    var cases: Array<E1> = [E1.A, E1.B, E1.More.C, E1.More.D];
    if (x < 0 || x >= cases.length) return 0;
    var e = cases[x];
    return if(E1.More.?(e), 1, 0);
}
