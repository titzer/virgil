//@execute 0=0; 1=1; 2=2; 3=3
// 4-level hierarchy with method overrides at each level
enum E { A, _; def depth() -> int { return 0; } }
enum E.L1 { B, _; def depth() -> int { return 1; } }
enum E.L1.L2 { C, _; def depth() -> int { return 2; } }
enum E.L1.L2.L3 { D; def depth() -> int { return 3; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.L1.B, E.L1.L2.C, E.L1.L2.L3.D];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].depth();
}
