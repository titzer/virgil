//@execute 0=1; 1=-1
// Subtype with only _ case and an override method, but no subtypes of its
// own: E.More.m is unreachable (no named cases produce values in its range),
// so all values dispatch to the root method.
enum E { A, _; def m() -> int { return 1; } }
enum E.More { _; def m() -> int { return 2; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].m();
}
