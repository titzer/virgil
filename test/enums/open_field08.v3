//@execute 0=1; 1=2; 2=150; 3=250
// Access new field on subtype-typed variable, inherited on root-typed
enum E(x: int) { A(1), B(2), _ }
enum E.S1(super, y: int) { C(10, 150), D(20, 250) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.x;
        1 => return E.B.x;
        2 => { var v: E.S1 = E.S1.C; return v.y; }
        3 => { var v: E.S1 = E.S1.D; return v.y; }
    }
    return -1;
}
