//@execute 0=7; 1=7; 2=7; 3=7; 4=7
// Multi-level enum hierarchy with a root-level method.
// Exercises recursive subtype RaClass materialization; all cases (including
// deeply-nested ones) dispatch to the root method.
enum E { A, _; def m() -> int { return 7; } }
enum E.More { B, _ }
enum E.More.Deep { C }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.More.B, E.More.Deep.C];
    match (i) {
        0 => return E.A.m();
        1 => return E.More.B.m();
        2 => return E.More.Deep.C.m();
        3 => return cases[0].m();
        4 => return cases[2].m();
    }
    return -1;
}
