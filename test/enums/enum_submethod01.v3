//@execute 0=1; 1=2; 2=3; 3=-1
// Multi-level override: E.More overrides, E.More.Deep overrides further
enum E { A, _; def m() -> int { return 1; } }
enum E.More { B, _; def m() -> int { return 2; } }
enum E.More.Deep { C; def m() -> int { return 3; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.More.B, E.More.Deep.C];
    if (i < 0 || i >= cases.length) return -1;
    return cases[i].m();
}
