//@execute 0=15; 1=70; 2=300; 3=-1
// Closure with multiple params + subtype override + enum fields
enum E(x: int) { A(5), _; def calc(a: int, b: int) -> int { return x * a + b; } }
enum E.More { B(10); def calc(a: int, b: int) -> int { return x * (a + b); } }
enum E.Most { C(30); def calc(a: int, b: int) -> int { return x * a * b; } }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.More.B, E.Most.C];
    if (i < 0 || i >= cases.length) return -1;
    var f = cases[i].calc;
    return f(2, 5);
}
