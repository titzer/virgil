//@execute 0=4; 1=2; 2=2; 3=4; 4=0
// Open enum set: .all covers entire hierarchy; union and intersect
enum E { A, B, _ }
enum E.More { C, D }
def count(s: E.set) -> int {
    var n = 0;
    for (e in s) n++;
    return n;
}
def main(x: int) -> int {
    var all = E.set.all;
    var ab: E.set = E.A | E.B;
    var cd: E.set = E.More.C | E.More.D;
    match (x) {
        0 => return count(all);
        1 => return count(ab);
        2 => return count(cd);
        3 => return count(ab | cd);
        4 => return count(ab & cd);
    }
    return -1;
}
