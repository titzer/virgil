//@execute 0=4; 1=2
// Open enum set: for-in iteration yields correct count
enum E { A, B, _ }
enum E.More { C, D }
def main(x: int) -> int {
    var all = E.set.all;
    var cd: E.set = E.More.C | E.More.D;
    var s = if(x == 0, all, cd);
    var count = 0;
    for (e in s) count++;
    return count;
}
