//@execute 0=1; 1=0; 2=2
// Virtual dispatch through variable
enum E { A { def m() -> int { return 1; } }, B, C { def m() -> int { return 2; } }; def m() -> int { return 0; } }
def run(e: E) -> int {
    return e.m();
}
def main(i: int) -> int {
    match (i) {
        0 => return run(E.A);
        1 => return run(E.B);
        2 => return run(E.C);
    }
    return -1;
}
