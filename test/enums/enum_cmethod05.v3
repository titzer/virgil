//@execute 0=10; 1=20; 2=0; 3=10; 4=20
// Per-case override combined with subtype override
enum E {
	A { def m() -> int { return 10; } },
	B { def m() -> int { return 20; } },
	_;
	def m() -> int { return 0; }
}
enum E.More {
	C { def m() -> int { return 30; } },
	D;
	def m() -> int { return 40; }
}
def main(arg: int) -> int {
	match (arg) {
		0 => return E.A.m();
		1 => return E.B.m();
		2 => { var e: E = E.A; return E.More.D.m() - e.m() - E.B.m() - 10; }
		3 => { var vals: Array<E> = [E.A, E.B]; return vals[0].m(); }
		4 => { var vals: Array<E> = [E.A, E.B]; return vals[1].m(); }
	}
	return -1;
}
