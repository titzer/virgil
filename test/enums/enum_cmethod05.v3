//@execute 0=1; 1=0; 2=2; 3=0; 4=1; 5=0; 6=2
// Static dispatch: E.A.m() directly calls override (no dispatch table)
enum E {
    A { def m() -> int { return 1; } },
    B,
    C { def m() -> int { return 2; } };
    def m() -> int { return 0; }
}
def main(i: int) -> int {
    match (i) {
        0 => return E.A.m();
        1 => return E.B.m();
        2 => return E.C.m();
        3 => { var e: E = E.B; return e.m(); }
        4 => { var e: E = E.A; return e.m(); }
        5 => { var b = E.B; return b.m(); }
        6 => { var c = E.C; return c.m(); }
    }
    return -1;
}
