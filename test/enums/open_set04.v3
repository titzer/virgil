//@execute 0=1; 1=0; 2=1
// Open enum set: cross-level union E.A | E.More.C promotes to E.set
enum E { A, B, _ }
enum E.More { C, D }
def main(x: int) -> int {
    // DFS tags: A=0, B=1, C=2, D=3
    var s: E.set = E.A | E.More.C;
    match (x) {
        0 => return if(s.A, 1, 0);
        1 => return if(s.B, 1, 0);
        2 => return if(s.C, 1, 0);
    }
    return -1;
}
