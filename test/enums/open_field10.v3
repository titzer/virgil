//@execute 0=10; 1=100; 2=250
// Form 1+add: access both inherited and new fields
enum E(x: int) { A(10), _ }
enum E.S1(x: int, y: int) { C(100, 150), D(200, 250) }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.x;
        1 => { var v: E.S1 = E.S1.C; return v.x; }
        2 => { var v: E.S1 = E.S1.D; return v.y; }
    }
    return -1;
}
