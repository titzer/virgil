//@execute 0=10; 1=20; 2=30
// Enum method closure: store in variable, pass to function
enum E { A, _; def m() -> int { return 10; } }
enum E.More { B; def m() -> int { return 20; } }
enum E.Most { C; def m() -> int { return 30; } }
def call(f: void -> int) -> int { return f(); }
def main(i: int) -> int {
    var cases: Array<E> = [E.A, E.More.B, E.Most.C];
    if (i < 0 || i >= cases.length) return -1;
    var f = cases[i].m;
    return call(f);
}
