//@execute 0=11; 1=22; 2=33
// Enum method with multiple fields and expression body
enum E(x: int, y: int) { A(1, 10), B(2, 20), C(3, 30); def sum() => x + y; }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.sum();
        1 => return E.B.sum();
        2 => return E.C.sum();
    }
    return -1;
}
