//@execute 0=42; 1=42; 2=42
// Open enum: subtypes inherit root method
enum E { A, B, _; def m() -> int { return 42; } }
enum E.More { C, D }
def main(i: int) -> int {
    match (i) {
        0 => return E.A.m();
        1 => return E.More.C.m();
        2 => { var e: E = E.More.D; return e.m(); }
    }
    return -1;
}
