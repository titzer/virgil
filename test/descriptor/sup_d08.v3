//@execute 0=3; 1=12; 2=5
// SD has virtual combine(x,y); DA inherits (addition), DB overrides (multiplication).
// A.run() calls descriptor.combine(x, y); dispatch selects the right implementation.
class SD { def combine(x: int, y: int) -> int { return x + y; } }
class DA extends SD describes A {}
class DB extends DA describes B { def combine(x: int, y: int) -> int { return x * y; } }
class A(x: int, y: int) descriptor DA {
	def run() -> int { return this.descriptor.combine(x, y); }
}
class B extends A descriptor DB {
	new(x: int, y: int) super(x, y) {}
}

var objs: Array<A> = [A.new(DA.new(), 1, 2), B.new(DB.new(), 3, 4), A.new(DA.new(), 2, 3)];
def main(i: int) -> int {
	return objs[i].run();
}
