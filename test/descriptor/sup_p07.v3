//@execute 0=10; 1=20; 2=10; 3=20
// SD(n:int) superclass of DA<T> and DB<T>; A<T> and B<T> hierarchy.
// Tests that the SD field n is accessible via both the dynamic descriptor type
// and when the descriptor reference is stored in a DA<int>-typed variable.
class SD(n: int) {}
class DA<T> extends SD describes A<T> { new(n: int) super(n) {} }
class DB<T> extends DA<T> describes B<T> { new(n: int) super(n) {} }
class A<T> descriptor DA<T> {}
class B<T> extends A<T> descriptor DB<T> {}

var objs: Array<A<int>> = [A<int>.new(DA<int>.new(10)), B<int>.new(DB<int>.new(20))];
def main(i: int) -> int {
	match (i) {
		0 => return objs[0].descriptor.n;
		1 => return objs[1].descriptor.n;
		2 => {
			def d: DA<int> = objs[0].descriptor;
			return d.n;
		}
		3 => {
			def d: DA<int> = objs[1].descriptor;	// static DA<int>, runtime DB<int>
			return d.n;
		}
	}
	return -1;
}
