//@execute 0=42; 1=99
// SA<T>(item:T) is parametric; A is non-parametric, extending SA<int>.
// DA describes A (non-parametric); item field is inherited from SA<int>.
class SA<T>(item: T) {}
class DA describes A {}
class A extends SA<int> descriptor DA { new(x: int) super(x) {} }

var a1 = A.new(DA.new(), 42);
var a2 = A.new(DA.new(), 99);
def main(i: int) -> int {
	if (i == 0) return a1.item;
	return a2.item;
}
