//@execute 0=1; 1=1; 2=6; 3=1; 4=1
// Reference-typed descriptor fields: identity is preserved and mutation through the
// descriptor is visible, so the fields are real slots and not copies.
class E(v: int) { var w: int; }
class D(e: E, arr: Array<int>, s: string) describes A { }
class A descriptor D { }

def e = E.new(5);
def arr = [1, 2, 3];
def str = "xyz";
def d = D.new(e, arr, str);
def a = A.new(d);

def main(x: int) -> int {
	match (x) {
		0 => return if(a.descriptor.e == e, 1, 0);
		1 => return if(a.descriptor.arr == arr, 1, 0);
		2 => return a.descriptor.arr[0] + a.descriptor.arr[1] + a.descriptor.arr[2];
		3 => return if(a.descriptor.s == str, 1, 0);
		4 => {
			a.descriptor.e.w = 77;
			return if(e.w == 77, 1, 0);
		}
	}
	return -1;
}
