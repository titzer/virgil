//@execute 0=20; 1=30; 2=40
// SD(base:int) has virtual compute() returning base. DA, DB, DC each override
// compute() to return base * 2, base * 3, base * 4 respectively.
// Tests that the overriding methods can access the inherited field base.
class SD(base: int) {
	def compute() -> int { return base; }
}
class DA extends SD describes A {
	new(b: int) super(b) {}
	def compute() -> int { return base * 2; }
}
class DB extends DA describes B {
	new(b: int) super(b) {}
	def compute() -> int { return base * 3; }
}
class DC extends DA describes C {
	new(b: int) super(b) {}
	def compute() -> int { return base * 4; }
}
class A descriptor DA {}
class B extends A descriptor DB {}
class C extends A descriptor DC {}

var objs: Array<A> = [A.new(DA.new(10)), B.new(DB.new(10)), C.new(DC.new(10))];
def main(x: int) -> int {
	return objs[x].descriptor.compute();
}
