//@execute 0=1; 1=4; 2=9
// Double dispatch: A.m() passes 'this' to D.op(this), which calls
// this.descriptor.sq(a.size()) on the DD level. Both the A hierarchy
// (for size) and the DD hierarchy (for sq) contribute to the result.
class DD describes D {
	def sq(n: int) -> int { return n; }
}
class D descriptor DD describes A {
	def op(a: A) -> int { return this.descriptor.sq(a.size()); }
}
class A descriptor D {
	def size() -> int { return 1; }
	def m() -> int { return this.descriptor.op(this); }
}

class DDB extends DD describes DB {
	def sq(n: int) -> int { return n * 2; }  // 2*n
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {
	def size() -> int { return 2; }  // size=2, DDB.sq(2)=4
}

class DDC extends DD describes DC {
	def sq(n: int) -> int { return n * 3; }  // 3*n
}
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {
	def size() -> int { return 3; }  // size=3, DDC.sq(3)=9
}

var objs: Array<A> = [
	A.new(D.new(DD.new())),
	B.new(DB.new(DDB.new())),
	C.new(DC.new(DDC.new()))
];
def main(x: int) -> int { return objs[x].m(); }
