//@execute 0=true; 1=true; 2=true; 3=true
// Downcast B.!(b) from A-typed variable, then access fields through the
// two-level descriptor chain using the more precise static type.
class DD(z: int) describes D {}
class D(y: int) descriptor DD describes A {}
class A(x: int) descriptor D {}

class DDB extends DD describes DB  { new(v: int) super(v) {} }
class DB extends D descriptor DDB describes B { new(v: int) super(v) {} }
class B extends A descriptor DB { new(v: int) super(v) {} }

var a: A = A.new(D.new(DD.new(3), 2), 1);
var b: A = B.new(DB.new(DDB.new(30), 20), 10);

def main(x: int) -> bool {
	match (x) {
		0 => return a.x == 1 && a.descriptor.y == 2 && a.descriptor.descriptor.z == 3;
		1 => {
			def bb = B.!(b);  // downcast A -> B
			return bb.x == 10;
		}
		2 => {
			def bb = B.!(b);
			return bb.descriptor.y == 20;  // DB has static type DB; y is D's field
		}
		3 => {
			def bb = B.!(b);
			return bb.descriptor.descriptor.z == 30;  // DDB has static type DDB; z is DD's field
		}
	}
	return false;
}
