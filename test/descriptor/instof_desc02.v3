//@execute 0=true; 1=true; 2=false; 3=true
// Type queries on descriptor values in a two-level chain.
// Verifies that the inner descriptor (accessed via .descriptor.descriptor)
// reports the correct runtime type at the second level of the chain.
class DD describes D {}
class DDB extends DD describes DB {}
class D descriptor DD describes A {}
class DB extends D descriptor DDB describes B {}
class A descriptor D {}
class B extends A descriptor DB {}

var a = A.new(D.new(DD.new()));
var b = B.new(DB.new(DDB.new()));

def main(i: int) -> bool {
	match (i) {
		0 => return DD.?(a.descriptor.descriptor);	// DD is exact type
		1 => return DDB.?(b.descriptor.descriptor);	// DDB is exact type
		2 => return DDB.?(a.descriptor.descriptor);	// a's is DD, not DDB
		3 => return DD.?(b.descriptor.descriptor);	// DDB extends DD
	}
	return false;
}
