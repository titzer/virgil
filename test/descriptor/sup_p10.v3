//@execute 0=1; 1=0; 2=42
// SD<T>(key:T) is parametric; DA<T> extends SD<T>; A<T> descriptor DA<T>.
// Tests the parametric field key for both bool (true/false -> 1/0) and int instantiations.
class SD<T>(key: T) {}
class DA<T> extends SD<T> describes A<T> { new(k: T) super(k) {} }
class A<T> descriptor DA<T> {}

def main(i: int) -> int {
	var a_int = A<int>.new(DA<int>.new(42));
	var a_bool_t = A<bool>.new(DA<bool>.new(true));
	var a_bool_f = A<bool>.new(DA<bool>.new(false));
	match (i) {
		0 => return if(a_bool_t.descriptor.key, 1, 0);
		1 => return if(a_bool_f.descriptor.key, 1, 0);
		2 => return a_int.descriptor.key;
	}
	return -1;
}
