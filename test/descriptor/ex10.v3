//@execute 0=true; 1=!DescriptorCheckException; 2=!DescriptorCheckException; 3=true
// Two-level chain: checks fire independently at each constructor.
// Case 1: DDB used for D.new() (inner check). Case 2: DB used for A.new() (outer check).
class DD describes D {}
class DDB extends DD describes DB {}
class D descriptor DD describes A {}
class DB extends D descriptor DDB describes B {}
class A descriptor D {}
class B extends A descriptor DB {}

def main(i: int) -> bool {
	match (i) {
		0 => {
			var d = D.new(DD.new());
			return A.new(d) != null;
		}
		1 => {
			var d = D.new(DDB.new());   // DDB for D -- inner check fires
			return A.new(d) != null;
		}
		2 => {
			var d = D.new(DD.new());
			var db = DB.new(DDB.new());
			return A.new(db) != null;   // DB for A -- outer check fires
		}
		3 => {
			var db = DB.new(DDB.new());
			return B.new(db) != null;
		}
	}
	return false;
}
