//@execute 0=1; 1=1; 2=0; 3=0
// Singleton descriptor per class carries a boolean flag.
// WPCP folds this.descriptor to a constant, enabling the branch to be
// eliminated per class: always 1 for A (flag=true), always 0 for B (flag=false).
class DA(enabled: bool) describes A {}
class DB extends DA describes B { new(b: bool) super(b) {} }
class A descriptor DA {
	def check() -> int { if (this.descriptor.enabled) return 1; return 0; }
}
class B extends A descriptor DB {
	def check() -> int { if (this.descriptor.enabled) return 1; return 0; }
}

def da = DA.new(true);
def db = DB.new(false);
def as = [A.new(da), A.new(da), B.new(db), B.new(db)];

def main(x: int) -> int { return as[x].check(); }
