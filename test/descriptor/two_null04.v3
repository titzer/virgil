//@execute = 0
// Positive test: with a valid two-level chain, neither .descriptor nor
// .descriptor.descriptor is null, and no exception is thrown.
// Also tests the inherited two-level chain for B objects.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def dd = DD.new();
def d = D.new(dd);
def a = A.new(d);
def ddb = DDB.new();
def db = DB.new(ddb);
def b = B.new(db);

def main() -> int {
	var r = 0;
	if (a.descriptor == null)             r |= 1;
	if (a.descriptor.descriptor == null)  r |= 2;
	if (b.descriptor == null)             r |= 4;
	if (b.descriptor.descriptor == null)  r |= 8;
	var ba: A = b;
	if (ba.descriptor == null)            r |= 16;
	if (ba.descriptor.descriptor == null) r |= 32;
	return r;
}
