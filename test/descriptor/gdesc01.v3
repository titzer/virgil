//@execute 0=5; 1=5
// Described objects created at initialization time, reached only through a cast.
class SA<T> { }
class D<T>(n: int) describes A<T> { }
class A<T> extends SA<T> descriptor D<T> { }
def d = D<int>.new(5);
def objs: Array<SA<int>> = [A<int>.new(d), A<int>.new(d)];
def main(i: int) -> int {
	return A<int>.!(objs[i]).descriptor.n;
}
