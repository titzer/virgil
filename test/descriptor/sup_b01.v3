//@execute 0=11; 1=22
// SD has virtual tag(); SA has virtual kind(); both A/DA and B/DB override them.
// Returns kind()*10 + tag() to verify independent dispatch on both sides.
class SD { def tag() -> int { return 0; } }
class SA { def kind() -> int { return 0; } }
class DA extends SD describes A { def tag() -> int { return 1; } }
class DB extends DA describes B { def tag() -> int { return 2; } }
class A extends SA descriptor DA { def kind() -> int { return 1; } }
class B extends A descriptor DB { def kind() -> int { return 2; } }

var objs: Array<A> = [A.new(DA.new()), B.new(DB.new())];
def main(i: int) -> int {
	return objs[i].kind() * 10 + objs[i].descriptor.tag();
}
