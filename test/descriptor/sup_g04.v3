//@execute = 7
// Written from scratch: generic root class, described subclass, descriptor read through a
// local of the subclass type.
class Root<T> { }
class Desc<T>(n: int) describes Leaf<T> { }
class Leaf<T> extends Root<T> descriptor Desc<T> { }
def main() -> int {
	var l = Leaf<bool>.new(Desc<bool>.new(7));
	return l.descriptor.n;
}
