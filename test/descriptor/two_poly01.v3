//@execute 0=true; 1=true; 2=true; 3=true
// Polymorphic two-level chain: A<T> descriptor D<T>, D<T> descriptor DD<T>.
// Tests identity at both levels for two different type parameter instantiations.
class DD<T> describes D<T> {}
class D<T> descriptor DD<T> describes A<T> {}
class A<T> descriptor D<T> {}

def dd_int = DD<int>.new();
def d_int = D<int>.new(dd_int);
def a_int = A<int>.new(d_int);

def dd_bool = DD<bool>.new();
def d_bool = D<bool>.new(dd_bool);
def a_bool = A<bool>.new(d_bool);

def main(x: int) -> bool {
	match (x) {
		0 => return a_int.descriptor == d_int;
		1 => return a_int.descriptor.descriptor == dd_int;
		2 => return a_bool.descriptor == d_bool;
		3 => return a_bool.descriptor.descriptor == dd_bool;
	}
	return false;
}
