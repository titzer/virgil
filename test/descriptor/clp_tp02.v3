//@execute 0=1; 1=2; 2=3; 3=4
// Two type parameters with a described hierarchy: DA<T,U>/DB<T,U> and A<T,U>/B<T,U>.
// Verifies that both type params are correctly threaded through the hierarchy.
class DA<T, U> describes A<T, U> {}
class DB<T, U> extends DA<T, U> describes B<T, U> {}
class A<T, U>(x: T, y: U) descriptor DA<T, U> {}
class B<T, U> extends A<T, U> descriptor DB<T, U> {
	new(x: T, y: U) super(x, y) {}
}

var a = A<int, int>.new(DA<int, int>.new(), 1, 2);
var b = B<int, int>.new(DB<int, int>.new(), 3, 4);
def main(i: int) -> int {
	match (i) {
		0 => return a.x;
		1 => return a.y;
		2 => return b.x;
		3 => return b.y;
	}
	return -1;
}
