//@execute 0=0; 1=3; 2=4; 3=77
class DA describes A {}
class A descriptor DA { var a: int; }
class DB extends DA describes B {}
class B(b: int, c: int) extends A descriptor DB {}
def z = B.new(DB.new(), 3, 4);
def main(a: int) -> int {
	match(a) {
		0 => return z.a;
		1 => return z.b;
		2 => return z.c;
	}
	return 77;
}
