//@execute 0=50; 1=30
// SA(p:int, q:int) provides product() -> p*q; A and B inherit both fields and method.
// B also inherits the constructor shape, forwarding both fields to SA.
class SA(p: int, q: int) {
	def product() -> int { return p * q; }
}
class DA describes A {}
class DB extends DA describes B {}
class A extends SA descriptor DA { new(x: int, y: int) super(x, y) {} }
class B extends A descriptor DB { new(x: int, y: int) super(x, y) {} }

var a = A.new(DA.new(), 5, 10);
var b = B.new(DB.new(), 3, 10);
def main(i: int) -> int {
	var obj: A = if(i == 0, a, b);
	return obj.product();
}
