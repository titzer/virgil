//@execute 0=93; 1=94; 2=42
class DA(x: int) describes A {}
class DB extends DA describes B { new(x: int) super(x) { } }

class A descriptor DA {}
class B extends A descriptor DB {}

def ds: Array<A> = [B.new(DB.new(93)), B.new(DB.new(94)), null];

def main(x: int) -> int {
	var o = ds[x];
	if (B.?(o)) return get(null, B.!(o));
	return 42;
}

def get(a: A, b: B) -> int {
	var r = b.descriptor.x;
	if (a != null) r += a.descriptor.x;
	return r;
}
