//@execute 0=42; 1=11; 2=21; 3=12; 4=22; 5=42
class V<E, R> {
	def visitA(n: A, e: E) -> R;
	def visitB(n: B, e: E) -> R;
}
class I {
	def accept<E, R>(v: V<E, R>, e: E) -> R;
}
class DA describes A {}
class A extends I descriptor DA {
	def accept<E, R>(v: V<E, R>, e: E) -> R { return v.visitA(this, e); }
}
class DB describes B {}
class B extends I descriptor DB {
	def accept<E, R>(v: V<E, R>, e: E) -> R { return v.visitB(this, e); }
}
class DCtx describes Ctx {}
class Ctx(base: int) descriptor DCtx {}
class P extends V<Ctx, int> {
	def visitA(n: A, e: Ctx) -> int {
		return 1 + e.base;
	}
	def visitB(n: B, e: Ctx) -> int {
		return 2 + e.base;
	}
}
var af: (V<Ctx, int>, Ctx) -> int = A.new(DA.new()).accept;
var bf: (V<Ctx, int>, Ctx) -> int = B.new(DB.new()).accept;
var v: P = P.new();
var e1: Ctx = Ctx.new(DCtx.new(), 10);
var e2: Ctx = Ctx.new(DCtx.new(), 20);
def main(arg: int) -> int {
	if (arg == 1) return af(v, e1);
	if (arg == 2) return af(v, e2);
	if (arg == 3) return bf(v, e1);
	if (arg == 4) return bf(v, e2);
	return 42;
}
