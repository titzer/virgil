//@execute 0=1; 1=20; 2=3
// DB overrides D.op() while DDC just provides a value for D.op() to use.
// Tests that overriding op() in the D hierarchy takes priority over the default
// D.op() -> DD.val() chain for B objects, while C still uses the default path.
class DD(v: int) describes D { def sq() -> int { return v; } }
class D descriptor DD describes A { def op() -> int { return this.descriptor.sq(); } }
class A descriptor D { def m() -> int { return this.descriptor.op(); } }

class DDB extends DD describes DB {
	new(u: int) super(u) {}
	def sq() -> int { return v * 10; }
}
class DB extends D descriptor DDB describes B {
	def op() -> int { return this.descriptor.sq() * 2; }  // overrides D.op
}
class B extends A descriptor DB {}

class DDC extends DD describes DC {
	new(u: int) super(u) {}
}
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

// A: D.op() -> DD.sq() = 1
// B: DB.op() -> DDB.sq()*2 = (1*10)*2 = 20
// C: D.op() -> DDC.sq() = 3 (DDC inherits sq from DD)
var objs: Array<A> = [
	A.new(D.new(DD.new(1))),
	B.new(DB.new(DDB.new(1))),
	C.new(DC.new(DDC.new(3)))
];
def main(x: int) -> int { return objs[x].m(); }
