//@execute 0=false; 1=true; 2=false; 3=true; 4=true
// instanceof tests on descriptors: DB.?(x.descriptor) and DDB.?(x.descriptor.descriptor).
// Objects are held as A; their descriptors are accessed with static type D and DD.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}
class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

var a: A = A.new(D.new(DD.new()));
var b: A = B.new(DB.new(DDB.new()));

def main(x: int) -> bool {
	match (x) {
		0 => return DB.?(a.descriptor);               // a's D is not DB -> false
		1 => return DB.?(b.descriptor);               // b's descriptor is DB -> true
		2 => return DDB.?(a.descriptor.descriptor);   // a's DD is not DDB -> false
		3 => return DDB.?(b.descriptor.descriptor);   // b's D's descriptor is DDB -> true
		4 => return DD.?(b.descriptor.descriptor);    // DDB is a DD subtype -> true
	}
	return false;
}
