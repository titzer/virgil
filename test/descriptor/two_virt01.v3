//@execute 0=10; 1=20
// A.run() calls this.descriptor.m() (dispatch on D hierarchy).
// D.m() calls this.descriptor.op() (dispatch on DD hierarchy).
// B inherits A.run() and D.m(); DDB overrides DD.op().
// Both levels of dispatch are exercised through an A-typed array.
class DD(val: int) describes D { def op() -> int { return val; } }
class D descriptor DD describes A { def m() -> int { return this.descriptor.op(); } }
class A descriptor D { def run() -> int { return this.descriptor.m(); } }

class DDB extends DD describes DB {
	new(v: int) super(v) {}
	def op() -> int { return val * 2; }
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

var objs: Array<A> = [A.new(D.new(DD.new(10))), B.new(DB.new(DDB.new(10)))];
def main(x: int) -> int { return objs[x].run(); }
