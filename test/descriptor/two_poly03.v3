//@execute 0=10; 1=20
// Polymorphic two-level chain with virtual dispatch.
// D<T>.m() calls DD<T>.op(); DDB<T> overrides op() to multiply by 2.
// Tests that two-level dispatch works through generic instantiations.
class DD<T>(val: int) describes D<T> { def op() -> int { return val; } }
class D<T> descriptor DD<T> describes A<T> { def m() -> int { return this.descriptor.op(); } }
class A<T> descriptor D<T> { def run() -> int { return this.descriptor.m(); } }

class DDB<T> extends DD<T> describes DB<T> {
	new(v: int) super(v) {}
	def op() -> int { return val * 2; }
}
class DB<T> extends D<T> descriptor DDB<T> describes B<T> {}
class B<T> extends A<T> descriptor DB<T> {}

var a = A<int>.new(D<int>.new(DD<int>.new(10)));
var b = B<int>.new(DB<int>.new(DDB<int>.new(10)));

var objs: Array<A<int>> = [a, b];
def main(x: int) -> int { return objs[x].run(); }
