//@execute 0=35; 1=35; 2=47; 3=47
// Singleton descriptor per class with two fields (x, y).
// WPCP folds both descriptor loads to constants, then the arithmetic
// x*2+y becomes a compile-time constant per class.
class DA(x: int, y: int) describes A {}
class DB extends DA describes B { new(a: int, b: int) super(a, b) {} }
class A descriptor DA {
	def combined() -> int { return this.descriptor.x * 2 + this.descriptor.y; }
}
class B extends A descriptor DB {
	def combined() -> int { return this.descriptor.x * 2 + this.descriptor.y; }
}

def da = DA.new(10, 15);  // 10*2+15=35
def db = DB.new(17, 13);  // 17*2+13=47
def as = [A.new(da), A.new(da), B.new(db), B.new(db)];

def main(x: int) -> int { return as[x].combined(); }
