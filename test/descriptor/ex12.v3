//@execute 0=true; 1=!DescriptorCheckException
// The check fires even when the constructor call is inside a helper function.
// The static type of the parameter is DA, but the runtime type DB causes a failure.
class DA describes A {}
class DB extends DA describes B {}
class A descriptor DA {}
class B extends A descriptor DB {}

def make_a(d: DA) -> bool {
	return A.new(d) != null;
}

def ds: Array<DA> = [DA.new(), DB.new()];
def main(i: int) -> bool {
	return make_a(ds[i]);
}
