//@execute -7=false; 2=false; 3=true; 4=false; 983726=false
class D<T> describes C<T> {}
class C<T>(a: T, b: T, c: T) descriptor D<T> {
	def equals(that: C<T>) -> bool {
		return this.a == that.a && this.b == that.b && this.c == that.c;
	}
}
def dd = D<int>.new();
def main(a: int) -> bool {
	return C.new(dd, a, 3, 't').equals(C.new(dd, 3, 3, 't'));
}
