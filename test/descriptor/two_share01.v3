//@execute = 0
// Multiple A and B objects with distinct descriptor instances at each level.
// Tests that descriptors are per-object (not accidentally aliased) and that
// field values at both levels are independent across objects.
class DD(v: int) describes D {}
class D descriptor DD describes A {}
class A descriptor D {}
class DDB extends DD describes DB  { new(u: int) super(u) {} }
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def a1 = A.new(D.new(DD.new(1)));
def a2 = A.new(D.new(DD.new(2)));
def b1 = B.new(DB.new(DDB.new(3)));
def b2 = B.new(DB.new(DDB.new(4)));

def main() -> int {
	var r = 0;
	if (a1.descriptor == a2.descriptor)               r |= 1;   // distinct D instances
	if (b1.descriptor == b2.descriptor)               r |= 2;   // distinct DB instances
	if (a1.descriptor.descriptor.v != 1)              r |= 4;
	if (a2.descriptor.descriptor.v != 2)              r |= 8;
	if (b1.descriptor.descriptor.v != 3)              r |= 16;
	if (b2.descriptor.descriptor.v != 4)              r |= 32;
	return r;
}
