//@execute 0=42; 1=17; 2=1; 3=99; 4=7; 5=1
// A descriptor carrying fields of many different types, both references and non-references.
class E(v: int) { }
class D(i: int, b: byte, z: bool, l: long, f: float, e: E, s: string) describes A { }
class A descriptor D { }

def e = E.new(99);
def str = "abc";
def d = D.new(42, 17, true, 0x1_0000_0000L, 2.5f, e, str);
def a = A.new(d);

def main(x: int) -> int {
	match (x) {
		0 => return a.descriptor.i;
		1 => return a.descriptor.b;
		2 => return if(a.descriptor.z, 1, 0);
		3 => return a.descriptor.e.v;
		4 => return if(a.descriptor.s == str, 7, 0);
		5 => return if(a.descriptor.l == 0x1_0000_0000L && a.descriptor.f == 2.5f, 1, 0);
	}
	return -1;
}
