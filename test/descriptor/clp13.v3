//@execute 0=0; 1=1; 2=1; 3=13; 4=42
class D describes C {}
class C(a: int) descriptor D { }
var a: (C, C) -> bool = C.==;
var b: (C, C) -> bool = C.!=;
var c: C -> bool = C.?<C>;
var d: C -> C = C.!<C>;
def dd = D.new();
def main(arg: int) -> int {
	if (arg == 0) return val(a(C.new(dd, 1), C.new(dd, 2)));
	if (arg == 1) return val(b(C.new(dd, 3), C.new(dd, 4)));
	if (arg == 2) return val(c(C.new(dd, 5)));
	if (arg == 3) return d(C.new(dd, 13)).a;
	return 42;
}
def val(b: bool) -> int {
	if (b) return 1;
	return 0;
}

