//@execute 0=42; 1=11; 2=21; 3=31; 4=41; 5=32; 6=33; 7=42
class D<X, Y> describes C<X, Y> {}
class C<X, Y>(a: X, b: Y) descriptor D<X, Y> { }
var a = C<int, int>.new(D.new(), 11, 21);
var b = C<byte, int>.new(D.new(), 'c', 31);
var c = C<int, bool>.new(D.new(), 41, true);
var d = C<void -> int, void -> int>.new(D.new(), f32, f33);

def main(arg: int) -> int {
	if (arg == 1) return a.a;
	if (arg == 2) return a.b;
	if (arg == 3) return b.b;
	if (arg == 4) return c.a;
	if (arg == 5) return d.a();
	if (arg == 6) return d.b();
	return 42;
}

def f32() -> int { return 32; }
def f33() -> int { return 33; }
