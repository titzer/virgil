//@execute 0=10; 1=20
// B objects stored in an A-typed array. After retrieval and upcast,
// .descriptor has static type D but dispatches virtually to DB.m()
// which in turn dispatches on the DDB (DD subtype) descriptor.
class DD(val: int) describes D { def op() -> int { return val; } }
class D descriptor DD describes A { def m() -> int { return this.descriptor.op(); } }
class A descriptor D {}

class DDB extends DD describes DB {
	new(v: int) super(v) {}
	def op() -> int { return val * 2; }
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def a: A = A.new(D.new(DD.new(10)));
def b: A = B.new(DB.new(DDB.new(10)));  // B stored as A
var objs: Array<A> = [a, b];

def main(x: int) -> int {
	def o: A = objs[x];       // static type A
	def d: D = o.descriptor;  // static type D (may be DB at runtime)
	return d.m();              // virtual dispatch through D reference
}
