//@execute 0=true; 1=false; 2=false; 3=false
class D<T> describes A<T> { }
class A<T> descriptor D<T> { }

def check<T>() -> bool {
	return D<int>.?<D<T>>(A<T>.new(D<T>.new()).descriptor);
}

def main(a: int) -> bool {
	match (a) {
		0 => return check<int>();
		1 => return check<bool>();
		2 => return check<void>();
	}
	return false;
}
