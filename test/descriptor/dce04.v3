//@execute 0=-11; 1=11; 2=0
class DA describes A {}
class DB extends DA describes B {}

class S {}
class A extends S descriptor DA {}
class B extends A descriptor DB {} // never allocated

def ss = [S.new(), A.new(DA.new()), null];

def main(a: int) -> int {
	var o = ss[a];
	match (o) {
		null => return 0;
		x: B => return if(DB.?(x.descriptor), 33, 44);
		x: A => return if(DB.?(x.descriptor), 22, 11);
		_ => return -11;
	}
}
