//@execute = 42
// Descriptor class extends a superclass SD with an int field.
// Verifies that the inherited field is accessible via .descriptor.
class SD(val: int) {}
class DA extends SD describes A { new() super(42) {} }
class A descriptor DA {}

def main() -> int {
	var a = A.new(DA.new());
	return a.descriptor.val;
}
