//@execute 0=6; 1=18
// Loop over an array of A objects, summing results of two-level dispatch.
// 'aonly' array: 3 A objects each returning 2, sum=6.
// 'bonly' array: 3 B objects each returning 6 (2*3), sum=18.
class DD(val: int) describes D { def op() -> int { return val; } }
class D descriptor DD describes A { def m() -> int { return this.descriptor.op(); } }
class A descriptor D { def run() -> int { return this.descriptor.m(); } }

class DDB extends DD describes DB {
	new(v: int) super(v) {}
	def op() -> int { return val * 3; }
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

var aonly: Array<A> = [
	A.new(D.new(DD.new(2))),
	A.new(D.new(DD.new(2))),
	A.new(D.new(DD.new(2)))
];
var bonly: Array<A> = [
	B.new(DB.new(DDB.new(2))),
	B.new(DB.new(DDB.new(2))),
	B.new(DB.new(DDB.new(2)))
];

def main(x: int) -> int {
	var arr: Array<A> = if(x == 0, aonly, bonly);
	var sum = 0;
	for (o in arr) sum += o.run();
	return sum;
}
