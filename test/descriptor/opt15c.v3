//@execute 0=true; -888=true
class S { var xx: i48; }
class D(x: int) extends S describes A {
	new() { xx += x; }
}
class A extends S descriptor D {
	new() { xx += 44; }
}

def A_new(x: int) -> A {
	return A.new(D.new(x));
}

def main(x: int) -> bool {
	def a = A_new(x);
	return a.descriptor.x == a.descriptor.x;
}
