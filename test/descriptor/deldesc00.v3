//@execute 0=10; 1=20
// Delegate formed from a descriptor method; virtual dispatch is preserved
// through the delegate (DA.get() vs DB.get() dispatches correctly).
class DA(val: int) describes A {
	def get() -> int { return val; }
}
class DB extends DA describes B {
	new(v: int) super(v) {}
	def get() -> int { return val * 2; }
}
class A descriptor DA {}
class B extends A descriptor DB {}

var objs: Array<A> = [A.new(DA.new(10)), B.new(DB.new(10))];
def main(i: int) -> int {
	def f: () -> int = objs[i].descriptor.get;
	return f();
}
