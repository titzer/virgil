//@execute 0=5; 1=10; 2=15
// SD has virtual scale(); DA, DB, DC each override with a distinct constant.
// Three described subclasses each carry a different descriptor subclass.
class SD { def scale() -> int { return 1; } }
class DA extends SD describes A { def scale() -> int { return 5; } }
class DB extends DA describes B { def scale() -> int { return 10; } }
class DC extends DA describes C { def scale() -> int { return 15; } }
class A descriptor DA {}
class B extends A descriptor DB {}
class C extends A descriptor DC {}

var objs: Array<A> = [A.new(DA.new()), B.new(DB.new()), C.new(DC.new())];
def main(i: int) -> int {
	return objs[i].descriptor.scale();
}
