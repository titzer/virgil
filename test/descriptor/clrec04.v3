//@execute 0=0; 1=0; 2=1; 5=10

// A test of simple type recursion
class DA describes A {}
class A descriptor DA {
	var v: int;
	var a: A;
	new(v, a) {}
}

def da = DA.new();
def main(n: int) -> int {
	var a: A;
	for (i < n) {
		a = A.new(da, i, a);
	}
	var j = 0;
	while (a != null) {
		j += a.v;
		a = a.a;
	}
	return j;
}
