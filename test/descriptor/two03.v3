//@execute 0=33; 1=44; 2=92; 3=42
class S {
	var x: int;
	var y: int;
}
class DD(z: int) extends S describes D {}
class D(y: int) descriptor DD describes A {}
class A(x: int) descriptor D {}

def main(x: int) -> int {
	def dd = DD.new(55);
	dd.x = x + 11;
	dd.y = x + 22;
	def d = D.new(dd, 44);
	def a = A.new(d, 33);

	match (x) {
		0 => return a.x;
		1 => return a.descriptor.y;
		2 => {
			var t = a.descriptor.descriptor;
			return t.x + t.y + t.z;
		}
	}
	return 42;
}
