//@execute 0=7; 1=42
// Loop over a mixed array, dispatch through descriptor method each iteration.
// Tests that virtual dispatch through .descriptor works in a loop context.
class DA(x: int) describes A { def op() -> int { return x; } }
class DB extends DA describes B {
	new(y: int) super(y) {}
	def op() -> int { return x * 2; }
}
class A descriptor DA { def m() -> int { return this.descriptor.op(); } }
class B extends A descriptor DB {}
// mixed: [1, 2, 2, 2] -> sum=7
var mixed: Array<A> = [A.new(DA.new(1)), B.new(DB.new(1)), A.new(DA.new(2)), B.new(DB.new(1))];
// bonly: [14, 14, 14] -> sum=42
var bonly: Array<A> = [B.new(DB.new(7)), B.new(DB.new(7)), B.new(DB.new(7))];
def main(x: int) -> int {
	if (x == 0) {
		var sum = 0;
		for (o in mixed) sum += o.m();
		return sum;
	}
	var sum = 0;
	for (o in bonly) sum += o.m();
	return sum;
}
