//@execute = 55
// Two superclass levels above the descriptor: GSD(base) -> SD(offset) -> DA.
// DA.new() calls SD.new(50, 5) which calls GSD.new(50) and sets offset=5.
// Both inherited fields base and offset are accessible via .descriptor.
class GSD(base: int) {}
class SD extends GSD {
	var offset: int;
	new(b: int, o: int) super(b) { offset = o; }
}
class DA extends SD describes A { new() super(50, 5) {} }
class A descriptor DA {}

def main() -> int {
	var a = A.new(DA.new());
	return a.descriptor.base + a.descriptor.offset;
}
