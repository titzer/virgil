//@execute = 11
// Written from scratch: generic superclass with two type parameters, instantiated at a
// reference type, so the substitution has to carry both arguments.
class Pair<X, Y>(x: X, y: Y) { }
class E(v: int) { }
class Desc<X, Y>(n: int) describes Both<X, Y> { }
class Both<X, Y> extends Pair<X, Y> descriptor Desc<X, Y> { new(x: X, y: Y) super(x, y) { } }
def main() -> int {
	var b = Both<int, E>.new(Desc<int, E>.new(11), 1, E.new(2));
	return b.descriptor.n;
}
