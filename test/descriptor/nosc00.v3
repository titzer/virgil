//@execute 0=10; 1=20
// DX extends DA but declares no "describes" clause -- it is a plain subclass.
// DX instances are valid DA-typed values and can call inherited methods.
class DA(val: int) describes A {
	def doubled() -> int { return val * 2; }
}
class DX extends DA {
	new(v: int) super(v) {}
	def doubled() -> int { return val * 4; }	// override; DX is a normal subclass
}
class A descriptor DA {}

def dxs: Array<DA> = [DA.new(5), DX.new(5)];
def main(i: int) -> int {
	return dxs[i].doubled();
}
