//@execute 0=42; 1=11; 2=21; 3=31; 4=37; 5=42
class WD<T> describes W<T> {}
class VD describes V {}
class W<T>(val: T) descriptor WD<T> { }
class V(val: int) descriptor VD { }

var a = W<int>.new(WD.new(), 11);
var b = W<int>.new(WD.new(), 21);
var c = W<V>.new(WD.new(), V.new(VD.new(), 31));
var d = W<V>.new(WD.new(), V.new(VD.new(), 37));

def main(arg: int) -> int {
	if (arg == 1) return a.val;
	if (arg == 2) return b.val;
	if (arg == 3) return c.val.val;
	if (arg == 4) return d.val.val;
	return 42;
}

