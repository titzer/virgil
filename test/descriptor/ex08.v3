//@execute 0=true; 1=!DescriptorCheckException
// Two-level chain: A descriptor D, B extends A descriptor DB (DB extends D).
// DB is a subtype of D, so A.new(DB.new()) passes static type check.
// But the exact-type check for A requires D, so the DB instance fails at runtime.
class DD describes D {}
class DDB extends DD describes DB {}
class D descriptor DD describes A {}
class DB extends D descriptor DDB describes B {}
class A descriptor D {}
class B extends A descriptor DB {}

def ds: Array<D> = [D.new(DD.new()), DB.new(DDB.new())];
def main(i: int) -> bool {
	return A.new(ds[i]) != null;   // DB cannot be used for A
}
