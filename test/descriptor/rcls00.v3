//@execute 0=1; 1=10; 2=2; 3=20; 4=88
class DA describes A { }
class DB extends DA describes B { }
class A descriptor DA { }
class B extends A descriptor DB { }

def classify<T>(v: T) -> int {
	match (v) {
		x: DB => return 20;
		x: DA => return 10;
		x: B => return 2;
		x: A => return 1;
	}
	return -1;
}

def as = [A.new(DA.new()), B.new(DB.new())];

def main(a: int) -> int {
	match (a) {
		0 => return classify(as[0]);
		1 => return classify(as[0].descriptor);
		2 => return classify(as[1]);
		3 => return classify(as[1].descriptor);
	}
	return 88;
}