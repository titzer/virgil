//@execute 0=42; 1=!UnimplementedException; 2=21; 3=31; 4=42
class DA<T> describes A<T> {}
class A<T> descriptor DA<T> {
	def val() -> T;
}
class DB extends DA<int> describes B {}
class B extends A<int> descriptor DB {
	def val() -> int { return 21; }
}
class DC extends DA<int> describes C {}
class C extends A<int> descriptor DC {
	def val() -> int { return 31; }
}
var a: A<int> = A<int>.new(DA<int>.new());
var b: A<int> = B.new(DB.new());
var c: A<int> = C.new(DC.new());
def main(arg: int) -> int {
	if (arg == 1) return a.val();
	if (arg == 2) return b.val();
	if (arg == 3) return c.val();
	return 42;
}
