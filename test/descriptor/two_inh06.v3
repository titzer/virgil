//@execute 0=10; 1=20; 2=30; 3=100; 4=200; 5=300; 6=42
// Field access through an A-typed supertype slot for an A instance and a B instance.
// The A-level static type means .descriptor has static type D and
// .descriptor.descriptor has static type DD, but at runtime the values
// are DB and DDB respectively for the B object.
class DD(z: int) describes D {}
class D(y: int) descriptor DD describes A {}
class A(x: int) descriptor D {}

class DDB extends DD describes DB {
	new(v: int) super(v) {}
}
class DB extends D descriptor DDB describes B {
	new(v: int) super(v) {}
}
class B extends A descriptor DB {
	new(v: int) super(v) {}
}

def a = A.new(D.new(DD.new(30), 20), 10);
def b = B.new(DB.new(DDB.new(300), 200), 100);

def main(x: int) -> int {
	var objs: Array<A> = [a, b];
	match (x) {
		0 => return objs[0].x;
		1 => return objs[0].descriptor.y;
		2 => return objs[0].descriptor.descriptor.z;
		3 => return objs[1].x;
		4 => return objs[1].descriptor.y;                // static D, field y
		5 => return objs[1].descriptor.descriptor.z;     // static DD, field z
	}
	return 42;
}
