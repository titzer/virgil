//@seman
class DC describes C {}
class DD extends DC describes D {}
class DE<T> extends DC describes E<T> {}

class A {}
class B extends A {}
class C extends A descriptor DC {}
class D extends C descriptor DD {}
class E<T> extends C descriptor DE<T> {}

def a = A.new();
def b = B.new();

def dc = DC.new();
def dd = DD.new();
def de = DE<int>.new();

def c = C.new(dc);
def d = D.new(dd);
def e = E<int>.new(de);
