//@seman = DescriptorError @ 8:21

//   DA
//   |  \
//   DB  DC
class DA<T1> describes A<T1> { }
class DB<T2> extends DA<T2> describes B<T2> { }
class DC<T3> extends DA<T3> describes C<T3> { }

//   A
//   |
//   B
//   |
//   C
class A<U1> descriptor DA<U1> { }
class B<U2> extends A<U2> descriptor DB<U2> { }
class C<U3> extends B<U3> descriptor DC<U3> { } // should extend to A to match descriptor

