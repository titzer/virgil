class DC describes C {}
class DD extends DC describes D {}
class DE extends DC describes E {}

class A {}
class B extends A {}
class C extends A descriptor DC {}
class D extends C descriptor DD {}
class E extends C descriptor DE {}

def a = A.new();
def b = B.new();

def dc = DC.new();
def dd = DD.new();
def de = DE.new();

def c = C.new(dc);
def d = D.new(dd);
def e = E.new(de);
