class DA<T> describes A<T> { }
class DB<T> extends DA<T> describes B<T> { }
class DC<T> extends DB<T> describes C<T> { }
class DD<T> extends DC<T> describes D<T> { }

class A<T> descriptor DA<T> { }
class B<T> extends A<T> descriptor DB<T> { }
class C<T> extends B<T> descriptor DC<T> { }
class D<T> extends C<T> descriptor DD<T> { }
