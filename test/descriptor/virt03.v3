//@execute 0=1; 1=2; 2=3; 3=4
class DA describes A { def op() -> int { return 1; } }
class DB extends DA describes B { def op() -> int { return 2; } }
class DC extends DA describes C { def op() -> int { return 3; } }
class DD extends DA describes D { def op() -> int { return 4; } }
class A descriptor DA { def m() -> int { return this.descriptor.op(); } }
class B extends A descriptor DB {}
class C extends A descriptor DC {}
class D extends A descriptor DD {}
var objs: Array<A> = [A.new(DA.new()), B.new(DB.new()), C.new(DC.new()), D.new(DD.new())];
def main(x: int) -> int { return objs[x].m(); }
