//@execute 0=42; 1=11; 2=21; 3=12; 4=22; 5=42
class V<E> {
	def visitA(n: A, e: E);
	def visitB(n: B, e: E);
}
class I {
	def accept<E>(v: V<E>, e: E);
}
class DA describes A {}
class A extends I descriptor DA {
	def accept<E>(v: V<E>, e: E) { v.visitA(this, e); }
}
class DB describes B {}
class B extends I descriptor DB {
	def accept<E>(v: V<E>, e: E) { v.visitB(this, e); }
}
class DCtx describes Ctx {}
class Ctx(base: int) descriptor DCtx {}
class P extends V<Ctx> {
	def visitA(n: A, e: Ctx) {
		result = 1 + e.base;
	}
	def visitB(n: B, e: Ctx) {
		result = 2 + e.base;
	}
}
var result: int = 42;
var a: I = A.new(DA.new());
var b: I = B.new(DB.new());
var v: P = P.new();
var e1: Ctx = Ctx.new(DCtx.new(), 10);
var e2: Ctx = Ctx.new(DCtx.new(), 20);
def main(arg: int) -> int {
	result = 42;
	if (arg == 1) a.accept(v, e1);
	if (arg == 2) a.accept(v, e2);
	if (arg == 3) b.accept(v, e1);
	if (arg == 4) b.accept(v, e2);
	return result;
}
