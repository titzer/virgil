//@execute 0=11; 1=22; 2=33; 3=1; 4=1
// Fields at both levels of a descriptor chain, mixing references and non-references, so
// that each object's fields must not collide with the reserved descriptor metadata slots.
class DD(z: int, zl: long, zs: string) describes D { }
class D(y: int, yb: byte, ys: string) descriptor DD describes A { }
class A(x: int) descriptor D { }

def zstr = "zz";
def ystr = "yy";
def dd = DD.new(33, 0x2_0000_0003L, zstr);
def d = D.new(dd, 22, 7, ystr);
def a = A.new(d, 11);

def main(x: int) -> int {
	match (x) {
		0 => return a.x;
		1 => return a.descriptor.y;
		2 => return a.descriptor.descriptor.z;
		3 => return if(a.descriptor.ys == ystr && a.descriptor.descriptor.zs == zstr, 1, 0);
		4 => return if(a.descriptor.yb == 7 && a.descriptor.descriptor.zl == 0x2_0000_0003L, 1, 0);
	}
	return -1;
}
