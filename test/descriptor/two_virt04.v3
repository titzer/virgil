//@execute 0=1; 1=200; 2=3
// B overrides A.m() to skip D.op() and go directly to DD.sq() via
// this.descriptor.descriptor. C inherits A.m() and uses the full chain.
// Tests that an override can traverse both levels of the descriptor chain directly.
class DD(v: int) describes D { def sq() -> int { return v; } }
class D descriptor DD describes A { def op() -> int { return this.descriptor.sq(); } }
class A descriptor D { def m() -> int { return this.descriptor.op(); } }

class DDB extends DD describes DB {
	new(u: int) super(u) {}
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {
	// Accesses this.descriptor (static DB) then .descriptor (static DDB)
	def m() -> int { return this.descriptor.descriptor.sq() * 100; }
}

class DDC extends DD describes DC {
	new(u: int) super(u) {}
}
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

// A: D.op() -> DD.sq() = 1
// B: B.m() -> this.descriptor.descriptor.sq()*100 = DDB.sq()*100 = 2*100 = 200
// C: A.m() -> D.op() -> DDC.sq() = 3
var objs: Array<A> = [
	A.new(D.new(DD.new(1))),
	B.new(DB.new(DDB.new(2))),
	C.new(DC.new(DDC.new(3)))
];
def main(x: int) -> int { return objs[x].m(); }
