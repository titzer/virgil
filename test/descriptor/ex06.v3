//@execute 0=true; 1=!DescriptorCheckException
// Descriptor extracted from an array of B objects (static type DB).
// The second slot holds a C object; its descriptor has runtime type DC.
// B.new(d) where d has runtime type DC fails the exact-type check.
class DA describes A {}
class DB extends DA describes B {}
class DC extends DB describes C {}
class A descriptor DA {}
class B extends A descriptor DB {}
class C extends B descriptor DC {}

def bs: Array<B> = [B.new(DB.new()), C.new(DC.new())];
def main(i: int) -> bool {
	def d: DB = bs[i].descriptor;   // static DB; runtime may be DC
	return B.new(d) != null;
}
