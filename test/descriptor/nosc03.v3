//@execute 0=false; 1=false; 2=false
// Type queries on a plain subclass DX of DA.
// Using Array<DA> so .?(x) queries are valid downcasts from DA.
// DB and DX are siblings (both extend DA); neither instance is the other.
class DA describes A {}
class DX extends DA {}
class DB extends DA describes B {}
class A descriptor DA {}
class B extends A descriptor DB {}

def ds: Array<DA> = [DA.new(), DX.new(), DA.new()];
def main(i: int) -> bool {
	match (i) {
		0 => return DB.?(ds[0]);	// DA.new() is not DB
		1 => return DB.?(ds[1]);	// DX.new() is not DB (sibling branch)
		2 => return DX.?(ds[2]);	// DA.new() is not DX
	}
	return false;
}
