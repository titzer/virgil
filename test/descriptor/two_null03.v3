//@execute = !NullCheckException
// Accessing .descriptor on a null A reference throws NullCheckException.
// Tests null enforcement when the object itself (not the descriptor) is null.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def main() -> int {
	var a: A;               // null A
	var d = a.descriptor;   // NullCheckException: null dereference
	return 0;
}
