//@execute = 0
// As sup_g00, but without reading the inherited field.
class SA<T>(item: T) {}
class SD(factor: int) {}
class DA<T> extends SD describes A<T> { new(f: int) super(f) {} }
class A<T> extends SA<T> descriptor DA<T> { new(item: T) super(item) {} }
def main() -> int {
	var a = A<int>.new(DA<int>.new(0), 0);
	return a.descriptor.factor;
}
