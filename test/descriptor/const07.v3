//@execute 0=10; 1=20; 2=30; 3=40
// Four-class hierarchy; each class has exactly one singleton descriptor.
// WPCP can fold each class's descriptor to its constant, making m() return
// a distinct compile-time constant per class.
class DA(x: int) describes A {}
class DB extends DA describes B { new(y: int) super(y) {} }
class DC extends DA describes C { new(y: int) super(y) {} }
class DD extends DA describes D { new(y: int) super(y) {} }
class A descriptor DA { def m() -> int { return this.descriptor.x; } }
class B extends A descriptor DB { def m() -> int { return this.descriptor.x; } }
class C extends A descriptor DC { def m() -> int { return this.descriptor.x; } }
class D extends A descriptor DD { def m() -> int { return this.descriptor.x; } }

def da = DA.new(10);
def db = DB.new(20);
def dc = DC.new(30);
def dd = DD.new(40);
def as = [A.new(da), B.new(db), C.new(dc), D.new(dd)];

def main(x: int) -> int { return as[x].m(); }
