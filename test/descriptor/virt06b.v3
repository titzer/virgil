//@execute 0=10; 1=20
// Object held in supertype slot (static type A); .descriptor has static type DA.
// At runtime the descriptor is DB for B objects, so op() dispatches virtually.
class DA(x: int) describes A { def op() -> int { return x; } }
class DB extends DA describes B {
	new(y: int) super(y) {}
	def op() -> int { return x * 2; }
}
class S {}
class A extends S descriptor DA {}
class B extends A descriptor DB {}
def a: A = A.new(DA.new(10));
def b: A = B.new(DB.new(10));  // B stored as A
var objs: Array<A> = [a, b];
def main(x: int) -> int {
	def o: A = objs[x];       // static type: A
	def d: DA = o.descriptor;  // static type: DA (may be DB at runtime)
	return d.op();              // virtual dispatch on DA
}
