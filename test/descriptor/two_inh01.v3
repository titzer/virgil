//@execute 0=true; 1=true; 2=true; 3=true; 4=true; 5=true
// Two-level descriptor chain with one level of class inheritance.
// Verifies .descriptor and .descriptor.descriptor return the right objects
// for both own-type references and references upcasted to the supertype.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def dd = DD.new();
def d = D.new(dd);
def a = A.new(d);
def ddb = DDB.new();
def db = DB.new(ddb);
def b = B.new(db);

def main(x: int) -> bool {
	match (x) {
		0 => return a.descriptor == d;
		1 => return a.descriptor.descriptor == dd;
		2 => return b.descriptor == db;
		3 => return b.descriptor.descriptor == ddb;
	}
	var ba: A = b;
	match (x) {
		4 => return ba.descriptor == db;           // static type D, runtime type DB
		5 => return ba.descriptor.descriptor == ddb;   // static type DD, runtime type DDB
	}
	return false;
}
