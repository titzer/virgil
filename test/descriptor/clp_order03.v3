//@execute 0=33; 1=34; 2=35; 3=36; 4=42
var order = 33;
class DA describes A {}
class A(a: int) descriptor DA {
	var x = order++;
}
class DB extends DA describes B {}
class B(b: int) extends A(order++) descriptor DB {
	var y = order++;
}
def x = B.new(DB.new(), order++);
def main(a: int) -> int {
	match (a) {
		0 => return x.b;
		1 => return x.y;
		2 => return x.a;
		3 => return x.x;
	}
	return 42;
}
