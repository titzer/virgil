//@execute 0=true; 1=!DescriptorCheckException
// Two type parameters: DescriptorCheckException fires when a subtype descriptor
// is used for the supertype's class, even with two type parameters.
class DA<T, U> describes A<T, U> {}
class DB<T, U> extends DA<T, U> describes B<T, U> {}
class A<T, U> descriptor DA<T, U> {}
class B<T, U> extends A<T, U> descriptor DB<T, U> {}

def ds: Array<DA<int, bool>> = [DA<int, bool>.new(), DB<int, bool>.new()];
def main(i: int) -> bool {
	return A<int, bool>.new(ds[i]) != null;
}
