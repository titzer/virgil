//@execute 0=1; 1=0; 2=7; 3=13
// SA(flag:bool) superclass of described A; SD(score:int) superclass of descriptor DA.
// Tests mixed bool/int types on both sides of the hierarchy.
class SA(flag: bool) {}
class SD(score: int) {}
class DA extends SD describes A { new(s: int) super(s) {} }
class A extends SA descriptor DA { new(f: bool) super(f) {} }

var a_true = A.new(DA.new(7), true);
var a_false = A.new(DA.new(13), false);
def main(i: int) -> int {
	match (i) {
		0 => return if(a_true.flag, 1, 0);
		1 => return if(a_false.flag, 1, 0);
		2 => return a_true.descriptor.score;
		3 => return a_false.descriptor.score;
	}
	return -1;
}
