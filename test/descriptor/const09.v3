//@execute 0=100; 1=100; 2=200; 3=300
// Mixed: A has a singleton descriptor (da), B has two different descriptors
// (db1, db2). WPCP can constant-fold A's descriptor access to 100, but B's
// descriptor access must remain dynamic and return the actual stored value.
class DA(x: int) describes A {}
class DB extends DA describes B { new(y: int) super(y) {} }
class A descriptor DA { def m() -> int { return this.descriptor.x; } }
class B extends A descriptor DB { def m() -> int { return this.descriptor.x; } }

def da  = DA.new(100);
def db1 = DB.new(200);
def db2 = DB.new(300);
def as = [A.new(da), A.new(da), B.new(db1), B.new(db2)];

def main(x: int) -> int { return as[x].m(); }
