//@execute 0=11; 1=12; 3=42
class DA describes A {}
class A descriptor DA {
	def m<X, Y>(a: X, b: Y) -> X { return a; }
}
class DB extends DA describes B {}
class B extends A descriptor DB {
	def m<U, V>(u: U, v: V) -> U { return u; }
}
var a: (int, bool) -> int = A.new(DA.new()).m;
var b: (int, int) -> int = B.new(DB.new()).m;
def main(arg: int) -> int {
	if (arg == 0) return a(11, false);
	if (arg == 1) return b(12, -1);
	return 42;
}
