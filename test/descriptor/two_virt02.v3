//@execute 0=1; 1=4; 2=9
// Three siblings A, B, C with distinct DD subtypes returning distinct values.
// A.m() -> D.op() -> DD.val(); each DD subtype returns a different integer.
// Tests 3-way dispatch through the DD hierarchy.
class DD describes D { def val() -> int { return 1; } }
class D descriptor DD describes A { def op() -> int { return this.descriptor.val(); } }
class A descriptor D { def m() -> int { return this.descriptor.op(); } }

class DDB extends DD describes DB { def val() -> int { return 4; } }
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

class DDC extends DD describes DC { def val() -> int { return 9; } }
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

var objs: Array<A> = [
	A.new(D.new(DD.new())),
	B.new(DB.new(DDB.new())),
	C.new(DC.new(DDC.new()))
];
def main(x: int) -> int { return objs[x].m(); }
