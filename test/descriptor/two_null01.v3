//@execute = !NullCheckException
// Passing a null DD descriptor to D.new() throws NullCheckException.
// Tests null enforcement at the second level of the descriptor chain.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def main() -> int {
	var dd: DD;          // null DD
	var d = D.new(dd);   // NullCheckException: null descriptor not allowed
	return 0;
}
