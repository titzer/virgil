//@execute 0=1; 1=1; 2=1
// Mutable fields at both levels of a descriptor chain, written through the chain. Each
// level's slots must be distinct from the other's and from the metadata slots.
class E(v: int) { }
class DD describes D { var z: int; var ze: E; }
class D descriptor DD describes A { var y: int; var ye: E; }
class A descriptor D { var x: int; }

def e1 = E.new(1), e2 = E.new(2);
def dd = DD.new();
def d = D.new(dd);
def a = A.new(d);

def main(x: int) -> int {
	a.x = 100;
	a.descriptor.y = 200;
	a.descriptor.ye = e1;
	a.descriptor.descriptor.z = 300;
	a.descriptor.descriptor.ze = e2;
	match (x) {
		0 => return if(a.x == 100 && a.descriptor.y == 200 && a.descriptor.descriptor.z == 300, 1, 0);
		1 => return if(a.descriptor.ye == e1 && a.descriptor.descriptor.ze == e2, 1, 0);
		2 => {
			// Writing one level must not disturb the other.
			a.descriptor.y = 0;
			return if(a.x == 100 && a.descriptor.descriptor.z == 300 && a.descriptor.ye == e1, 1, 0);
		}
	}
	return -1;
}
