//@execute = 0
// Multiple D objects all share the same DD instance.
// Tests that accessing .descriptor.descriptor from A objects with different D
// descriptors (all sharing one DD) always returns the same shared DD.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def dd = DD.new();     // shared DD instance
def d1 = D.new(dd);
def d2 = D.new(dd);
def d3 = D.new(dd);

def a1 = A.new(d1);
def a2 = A.new(d2);
def a3 = A.new(d3);

def main() -> int {
	var r = 0;
	if (a1.descriptor == a2.descriptor)            r |= 1;  // distinct D instances
	if (a2.descriptor == a3.descriptor)            r |= 2;  // distinct D instances
	if (a1.descriptor.descriptor != dd)            r |= 4;  // all share dd
	if (a2.descriptor.descriptor != dd)            r |= 8;
	if (a3.descriptor.descriptor != dd)            r |= 16;
	return r;
}
