//@execute 0=10; 1=20; 2=-9999
class DA(val: int) describes A { def op() -> int { return val; } }
class DB extends DA describes B {
	new(v: int) super(v) {}
	def op() -> int { return val * 2; }
}
class S { def m() -> int { return -9999; } }
class A extends S descriptor DA {
	def m() -> int { return this.descriptor.op(); }
}
class B extends A descriptor DB {}
var objs: Array<S> = [A.new(DA.new(10)), B.new(DB.new(10)), S.new()];
def main(x: int) -> int { return objs[x].m(); }
