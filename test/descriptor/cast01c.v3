//@execute 0=!TypeCheckException; 1=true; 2=true; 3=!TypeCheckException; 4=!NullCheckException
class D(x: int) describes B {}
class A {}
class B extends A descriptor D {}

def as = [A.new(), B.new(D.new(666)), B.new(D.new(55)), A.new(), null];

def main(x: int) -> bool {
	var a = as[x];
	var b = B.!(a);
	return b.descriptor.x > 0;
}