//@execute 0=0; 1=5; 2=5
// Shared mutable descriptor: two A objects point to the same DA instance.
// A mutation through one object's .descriptor is immediately visible through
// the other object's .descriptor and through the original DA variable.
class DA describes A {
	var score: int;
}
class A descriptor DA {}

def da = DA.new();
def a1 = A.new(da);
def a2 = A.new(da);

def main(i: int) -> int {
	match (i) {
		0 => return da.score;
		1 => { a1.descriptor.score = 5; return a2.descriptor.score; }	// shared
		2 => { da.score = 5; return a1.descriptor.score; }		// and back
	}
	return -1;
}
