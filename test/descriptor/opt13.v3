//@execute 0=10; 1=20
// Descriptor access inside a loop; the load is loop-invariant and can be hoisted.
class S {
	var d: D;
}
class D(x: int) extends S describes A {
	new() { this.d = this; }
}
class A descriptor D {}
def a = A.new(D.new(1));
def b = A.new(D.new(2));
def main(z: int) -> int {
	def o = if(z == 0, a, b);
	var sum = 0;
	for (i < 5) sum += (o.descriptor.x + o.descriptor.d.x);
	return sum;
}
