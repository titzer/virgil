//@execute 0=42; 1=11; 2=21; 3=31; 4=42
class DA describes A {}
class A descriptor DA {
	def val() -> int { return 11; }
}
class DB extends DA describes B {}
class B extends A descriptor DB {
	def val() -> int { return 21; }
}
class DC extends DA describes C {}
class C extends A descriptor DC {
	def val() -> int { return 31; }
}
var a: A = A.new(DA.new());
var b: A = B.new(DB.new());
var c: A = C.new(DC.new());
def main(arg: int) -> int {
	if (arg == 1) return a.val();
	if (arg == 2) return b.val();
	if (arg == 3) return c.val();
	return 42;
}
