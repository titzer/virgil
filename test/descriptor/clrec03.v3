//@execute 0=0; 1=1; 3=9; 5=25

// A test of more complex type recursion
class DA describes A {}
class A descriptor DA {
	var v: int;
	var b: B;
	new(v, b) {}
}

class DB describes B {}
class B descriptor DB {
	var v: int;
	var a: A;
	new(v, a) {}
}

def da = DA.new();
def db = DB.new();
def main(n: int) -> int {
	var a: A;
	for (i < n) {
		var b = B.new(db, i, a);
		a = A.new(da, i+1, b);
	}
	var j = 0;
	while (a != null) {
		j += a.v + a.b.v;
		a = a.b.a;
	}
	return j;
}
