//@execute 0=1; 1=10; 2=2; 3=20; 4=3; 5=30
// SA(n:int) superclass of described A; SD(m:int) superclass of descriptor DA.
// Three distinct A objects with different n and m values; six field checks.
class SA(n: int) {}
class SD(m: int) {}
class DA extends SD describes A { new(m: int) super(m) {} }
class A extends SA descriptor DA { new(n: int) super(n) {} }

var objs: Array<A> = [
	A.new(DA.new(10), 1),
	A.new(DA.new(20), 2),
	A.new(DA.new(30), 3)
];
def main(i: int) -> int {
	match (i) {
		0 => return objs[0].n;
		1 => return objs[0].descriptor.m;
		2 => return objs[1].n;
		3 => return objs[1].descriptor.m;
		4 => return objs[2].n;
		5 => return objs[2].descriptor.m;
	}
	return -1;
}
