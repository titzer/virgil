//@execute 0=7; -7=-7; 10=27
class D<T> describes A<T> {}
class A<T>(x: T) descriptor D<T> {}

def d = D<(int, int)>.new();

def test<X, Y>(d: D<(X, Y)>, v: (X, Y)) -> (X, Y) {
	var t = (d, v);
	var a = A.new(t);
	return a.x;
}

def main(x: int) -> int {
	var t = test(d, (x + 3, x + 4));
	return t.0 + t.1;
}
