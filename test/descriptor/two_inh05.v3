//@execute 0=10; 1=20; 2=30; 3=42
// Two-level chain with fields at every level (A.x, D.y, DD.z).
// B inherits A, DB inherits D. DDB inherits DD. Field values are distinct
// at each level and verified through the full .descriptor.descriptor chain.
class DD(z: int) describes D {}
class D(y: int) descriptor DD describes A {}
class A(x: int) descriptor D {}

class DDB extends DD describes DB {
	new(v: int) super(v) {}
}
class DB extends D descriptor DDB describes B {
	new(v: int) super(v) {}
}
class B extends A descriptor DB {
	new(v: int) super(v) {}
}

def ddb = DDB.new(30);
def db = DB.new(ddb, 20);
def b = B.new(db, 10);

def main(x: int) -> int {
	match (x) {
		0 => return b.x;                          // A-level field
		1 => return b.descriptor.y;               // D-level field via DB
		2 => return b.descriptor.descriptor.z;    // DD-level field via DDB
	}
	return 42;
}
