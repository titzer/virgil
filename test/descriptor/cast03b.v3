//@execute 0=!TypeCheckException; 1=333333; 2=!TypeCheckException; 3=-99999; 4=!TypeCheckException; 5=!NullCheckException
class DS describes S { }
class DA(x: int) extends DS describes A {}
class DB(y: int) extends DS describes B {}

class S descriptor DS {}
class A extends S descriptor DA {}
class B extends S descriptor DB {}

def ss = [S.new(DS.new()), A.new(DA.new(333333)), B.new(DB.new(444444)), A.new(DA.new(-99999)), B.new(DB.new(-1111111)), null];

def main(x: int) -> int {
	def s = ss[x];
	return DA.!(s.descriptor).x;
}
