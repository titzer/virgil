//@execute 0=44; 1=55
// Two different fields of the descriptor read via two separate .descriptor loads.
// The optimizer can CSE both loads to a single one.
class D(x: int, y: int) describes A {}
class A descriptor D {
	def sum() -> int { return this.descriptor.x + this.descriptor.y; }
}
def a = A.new(D.new(22, 22));
def b = A.new(D.new(33, 22));
def main(z: int) -> int {
	if (z == 0) return a.sum();
	return b.sum();
}
