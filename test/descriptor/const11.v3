//@execute 0=11; 1=12; 2=13
class DA(x: int) describes A {}
class DB extends DA describes B { new(x: int) super(x) {} }
class DC extends DA describes C { new(x: int) super(x) {} }

class A descriptor DA {}
class B extends A descriptor DB {}
class C extends A descriptor DC {}

def da = DA.new(11);
def db = DB.new(12);
def dc = DC.new(13);

def getDA = A.descriptor;
def getDB = B.descriptor;
def getDC = C.descriptor;

def as = [A.new(da), B.new(db), C.new(dc)];

def main(x: int) -> int {
	var a = as[x];
	if (C.?(a)) return getDC(C.!(a)).x;
	if (B.?(a)) return getDB(B.!(a)).x;
	if (A.?(a)) return getDA(A.!(a)).x;
	return 42;
}
