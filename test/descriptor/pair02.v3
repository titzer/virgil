//@execute 0=42; 1=11; 2=21; 3=31; 4=32; 5=97; 6=42
class DP<X, Y> describes P<X, Y> {}
class P<X, Y>(a: X, b: Y) descriptor DP<X, Y> {}
class DI describes I {}
class I(val: int) descriptor DI {}
var a = P<int, P<bool, bool>>.new(DP.new(), 11, P<bool, bool>.new(DP.new(), true, false));
var b = P<int, I>.new(DP.new(), 21, I.new(DI.new(), 31));
var c = P<void -> int, byte>.new(DP.new(), f32, 'a');
def main(arg: int) -> int {
	if (arg == 1) return a.a;
	if (arg == 2) return b.a;
	if (arg == 3) return b.b.val;
	if (arg == 4) return c.a();
	if (arg == 5) return c.b;
	return 42;
}
def f32() -> int { return 32; }
