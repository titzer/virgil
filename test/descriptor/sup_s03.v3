//@execute 0=1; 1=2; 2=3
// SA has virtual kind() -> 0; A, B, C each override with 1, 2, 3.
// Objects stored in Array<SA>; dispatch through the SA vtable.
class SA {
	def kind() -> int { return 0; }
}
class DA describes A {}
class DB extends DA describes B {}
class DC extends DA describes C {}
class A extends SA descriptor DA { def kind() -> int { return 1; } }
class B extends A descriptor DB { def kind() -> int { return 2; } }
class C extends A descriptor DC { def kind() -> int { return 3; } }

var objs: Array<SA> = [A.new(DA.new()), B.new(DB.new()), C.new(DC.new())];
def main(i: int) -> int {
	return objs[i].kind();
}
