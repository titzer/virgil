//@execute 0=7; 1=1
// Two type parameters and two levels of generic superclass, with the descriptor reached
// only through a cast, so substitution must carry through every level.
class Top<X, Y> { }
class Mid<X, Y> extends Top<X, Y> { }
class D<X, Y>(n: int) describes Leaf<X, Y> { }
class Leaf<X, Y> extends Mid<X, Y> descriptor D<X, Y> { }
def objs: Array<Top<int, bool>> = [Leaf<int, bool>.new(D<int, bool>.new(7)), Top<int, bool>.new()];
def main(i: int) -> int {
	match (i) {
		0 => return Leaf<int, bool>.!(objs[0]).descriptor.n;
		1 => return if(Leaf<int, bool>.?(objs[0]) && !Leaf<int, bool>.?(objs[1]), 1, 0);
	}
	return -1;
}
