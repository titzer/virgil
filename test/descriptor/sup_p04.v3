//@execute 0=42; 1=99
// SD<T>(tag:T) is a parametric superclass; DA<T> extends SD<T>.
// Verifies that the type-parameter-typed field tag is correctly stored
// and retrieved for two different int-instantiated descriptors.
class SD<T>(tag: T) {}
class DA<T> extends SD<T> describes A<T> { new(t: T) super(t) {} }
class A<T> descriptor DA<T> {}

var a1 = A<int>.new(DA<int>.new(42));
var a2 = A<int>.new(DA<int>.new(99));
def main(i: int) -> int {
	if (i == 0) return a1.descriptor.tag;
	return a2.descriptor.tag;
}
