//@execute 0=true; 1=true; 2=true; 3=true
// Polymorphic two-level chain with inheritance.
// A<T> -> D<T> -> DD<T>, B<T> extends A<T> -> DB<T> extends D<T> -> DDB<T> extends DD<T>.
// Tests that the full two-level chain is correct for the instantiation B<int>.
class DD<T> describes D<T> {}
class D<T> descriptor DD<T> describes A<T> {}
class A<T> descriptor D<T> {}

class DDB<T> extends DD<T> describes DB<T> {}
class DB<T> extends D<T> descriptor DDB<T> describes B<T> {}
class B<T> extends A<T> descriptor DB<T> {}

def dd = DD<int>.new();
def d = D<int>.new(dd);
def a = A<int>.new(d);
def ddb = DDB<int>.new();
def db = DB<int>.new(ddb);
def b = B<int>.new(db);

def main(x: int) -> bool {
	match (x) {
		0 => return a.descriptor == d;
		1 => return a.descriptor.descriptor == dd;
		2 => return b.descriptor == db;
		3 => return b.descriptor.descriptor == ddb;
	}
	return false;
}
