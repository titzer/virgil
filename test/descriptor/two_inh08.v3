//@execute 0=true; 1=true; 2=true; 3=true
// A helper function receives A-typed parameter and verifies the descriptor chain.
// Tests that runtime descriptor values are correct despite static types being D and DD.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def ddb = DDB.new();
def db = DB.new(ddb);
def b = B.new(db);

// Accepts A; .descriptor has static type D, .descriptor.descriptor has static type DD.
def check(obj: A, ed: D, edd: DD) -> bool {
	return obj.descriptor == ed && obj.descriptor.descriptor == edd;
}

def main(x: int) -> bool {
	var dd = DD.new();
	var d = D.new(dd);
	var a = A.new(d);
	match (x) {
		0 => return check(a, d, dd);         // A object: correct D and DD
		1 => return check(b, db, ddb);       // B passed as A: correct DB and DDB
		2 => return check(a, d, dd) && check(b, db, ddb);
		3 => return !check(a, db, ddb);      // wrong descriptors -> false
	}
	return false;
}
