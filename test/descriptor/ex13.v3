//@execute 0=true; 1=!DescriptorCheckException
// DX extends DA but declares no "describes" clause. It is a valid subtype
// of DA statically but fails the exact-type check at runtime like any other subtype.
class DA describes A {}
class DX extends DA {}
class A descriptor DA {}

def ds: Array<DA> = [DA.new(), DX.new()];
def main(i: int) -> bool {
	return A.new(ds[i]) != null;
}
