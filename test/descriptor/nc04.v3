//@execute 0=true; 1=!NullCheckException
// Two-level chain: D.new(null) passes null for DD, which throws NullCheckException
// inside D's constructor before the A-level construction even begins.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def dds: Array<DD> = [DD.new(), null];
def main(i: int) -> bool {
	var d = D.new(dds[i]);
	return A.new(d) != null;
}
