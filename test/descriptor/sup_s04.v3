//@execute 0=15; 1=30
// SA has mutable fields xx and yy; A's constructor initializes them using
// the descriptor's mult field: xx = mult*5, yy = mult*10.
// sum xx+yy = mult*15; tested with mult=1 and mult=2.
class SA {
	var xx: int;
	var yy: int;
}
class DA(mult: int) describes A {}
class A extends SA descriptor DA {
	new() {
		xx = this.descriptor.mult * 5;
		yy = this.descriptor.mult * 10;
	}
}

var a1 = A.new(DA.new(1));
var a2 = A.new(DA.new(2));
def main(i: int) -> int {
	var a = if(i == 0, a1, a2);
	return a.xx + a.yy;
}
