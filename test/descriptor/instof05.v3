//@execute 0=false; 1=false; 2=false; 3=false; 4=true; 5=false; 6=false
class DA<X> describes A<X> {}
class A<X> descriptor DA<X> {}
class DB<X> extends DA<int> describes B<X> {}
class B<X> extends A<int> descriptor DB<X> {}
var a: A<int> = A<int>.new(DA<int>.new());
var b: A<int> = B<int>.new(DB<int>.new());
var c: A<int> = B<byte>.new(DB<byte>.new());
var d: A<int> = B<bool>.new(DB<bool>.new());
def m(x: A<int>) -> bool {
	return B<byte>.?(x);
}
def main(arg: int) -> bool {
	if (arg == 1) return m(null);
	if (arg == 2) return m(a);
	if (arg == 3) return m(b);
	if (arg == 4) return m(c);
	if (arg == 5) return m(d);
	return false;
}
