//@execute 0=true; 1=true; 2=false; 3=!DescriptorCheckException
// DX is an intermediate in the hierarchy: DA -> DX -> DB (DB describes B).
// DX describes nothing; DB can still be the descriptor for B.
// A.new(DX.new()) fails; A.new(DA.new()) and B.new(DB.new()) succeed.
// DB.?(DX.new()) is false: DX and DB are siblings (both extend DA), not related.
class DA describes A {}
class DX extends DA {}
class DB extends DX describes B {}
class A descriptor DA {}
class B extends A descriptor DB {}

def ds: Array<DA> = [DA.new(), DB.new(), DX.new(), DX.new()];
def main(i: int) -> bool {
	match (i) {
		0 => return A.new(ds[0]) != null;	// DA for A -- ok
		1 => return B.new(DB.new()) != null;	// DB for B -- ok
		2 => return DB.?(ds[2]);		// DX is not a DB -- false
		3 => return A.new(ds[3]) != null;	// DX for A -- DescriptorCheckException
	}
	return false;
}
