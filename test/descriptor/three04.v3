//@execute 0=true; 1=true; 2=true; 3=true
// Polymorphic three-level chain: A<T> descriptor D<T>, D<T> descriptor DD<T>,
// DD<T> descriptor DDD<T>. Identity checks at all three levels for A<int>.
class DDD<T> describes DD<T> {}
class DD<T> descriptor DDD<T> describes D<T> {}
class D<T> descriptor DD<T> describes A<T> {}
class A<T> descriptor D<T> {}

def ddd = DDD<int>.new();
def dd = DD<int>.new(ddd);
def d = D<int>.new(dd);
def a = A<int>.new(d);

def main(i: int) -> bool {
	match (i) {
		0 => return a.descriptor == d;
		1 => return a.descriptor.descriptor == dd;
		2 => return a.descriptor.descriptor.descriptor == ddd;
		3 => return a.descriptor.descriptor.descriptor != null;
	}
	return false;
}
