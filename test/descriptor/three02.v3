//@execute 0=1; 1=10; 2=100; 3=1000; 4=2; 5=20; 6=200; 7=2000
// Three-level chain extended with a full B/DB/DDB/DDDB subhierarchy.
// Each level carries a distinct field value; all eight are verified.
class DDD(w: int) describes DD {}
class DD(z: int) descriptor DDD describes D {}
class D(y: int) descriptor DD describes A {}
class A(x: int) descriptor D {}

class DDDB extends DDD describes DDB { new(v: int) super(v) {} }
class DDB extends DD descriptor DDDB describes DB { new(v: int) super(v) {} }
class DB extends D descriptor DDB describes B { new(v: int) super(v) {} }
class B extends A descriptor DB { new(v: int) super(v) {} }

def ddd = DDD.new(1000);
def dd = DD.new(ddd, 100);
def d = D.new(dd, 10);
def a = A.new(d, 1);
def dddb = DDDB.new(2000);
def ddb = DDB.new(dddb, 200);
def db = DB.new(ddb, 20);
def b = B.new(db, 2);

def main(i: int) -> int {
	match (i) {
		0 => return a.x;
		1 => return a.descriptor.y;
		2 => return a.descriptor.descriptor.z;
		3 => return a.descriptor.descriptor.descriptor.w;
		4 => return b.x;
		5 => return b.descriptor.y;
		6 => return b.descriptor.descriptor.z;
		7 => return b.descriptor.descriptor.descriptor.w;
	}
	return -1;
}
