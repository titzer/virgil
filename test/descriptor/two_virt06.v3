//@execute 0=0; 1=1; 2=2; 3=3
// Four siblings A, B, C, E each with a distinct DD subtype returning a unique id.
// Tests 4-way dispatch through the A -> D -> DD chain.
class DD describes D { def id() -> int { return 0; } }
class D descriptor DD describes A { def op() -> int { return this.descriptor.id(); } }
class A descriptor D { def m() -> int { return this.descriptor.op(); } }

class DDB extends DD describes DB { def id() -> int { return 1; } }
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

class DDC extends DD describes DC { def id() -> int { return 2; } }
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

class DDE extends DD describes DE { def id() -> int { return 3; } }
class DE extends D descriptor DDE describes E {}
class E extends A descriptor DE {}

var objs: Array<A> = [
	A.new(D.new(DD.new())),
	B.new(DB.new(DDB.new())),
	C.new(DC.new(DDC.new())),
	E.new(DE.new(DDE.new()))
];
def main(x: int) -> int { return objs[x].m(); }
