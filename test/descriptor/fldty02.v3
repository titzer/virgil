//@execute 0=1; 1=9; 2=1; 3=5
// A descriptor field that holds a described object from another hierarchy, so a descriptor
// pointer appears both as an object header and as an ordinary field value.
class DB(n: int) describes B { }
class B(m: int) descriptor DB { }
class DA(b: B, n: int) describes A { }
class A descriptor DA { }

def db = DB.new(9);
def b = B.new(db, 5);
def da = DA.new(b, 4);
def a = A.new(da);

def main(x: int) -> int {
	match (x) {
		0 => return if(a.descriptor.b == b, 1, 0);
		1 => return a.descriptor.b.descriptor.n;
		2 => return if(B.?(a.descriptor.b), 1, 0);
		3 => return a.descriptor.b.m;
	}
	return -1;
}
