//@execute 0=true; 1=true
// A virtual call on this between two .descriptor loads must not block CSE;
// virtual methods cannot write to the (immutable) descriptor field.
class DA describes A {}
class DB extends DA describes B {}
class A descriptor DA {
	def virt() -> int { return 1; }
	def same() -> bool {
		def d1 = this.descriptor;
		def v = this.virt();    // virtual call; descriptor is still the same
		def d2 = this.descriptor;
		return d1 == d2;
	}
}
class B extends A descriptor DB {
	def virt() -> int { return 2; }
}
var objs: Array<A> = [A.new(DA.new()), B.new(DB.new())];
def main(z: int) -> bool {
	return objs[z].same();
}
