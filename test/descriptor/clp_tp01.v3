//@execute 0=10; 1=20
// D<T, U> has fields of both type parameters. Verifies that both are
// correctly stored and retrieved through .descriptor.
class D<T, U>(first: T, second: U) describes C<T, U> {}
class C<T, U> descriptor D<T, U> {}

def c = C<int, int>.new(D<int, int>.new(10, 20));
def main(i: int) -> int {
	if (i == 0) return c.descriptor.first;
	return c.descriptor.second;
}
