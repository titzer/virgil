//@execute = true
// Both A.descriptor and D.descriptor used as function references.
// Tests chaining: getD extracts D from A, then getDD extracts DD from D.
// Verifies the chain works correctly for both A objects and B objects passed as A.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}
class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def dd = DD.new();
def d = D.new(dd);
def a = A.new(d);
def ddb = DDB.new();
def db = DB.new(ddb);
def b = B.new(db);

def getD  = A.descriptor;   // A -> D
def getDD = D.descriptor;   // D -> DD

def main() -> bool {
	return getD(a) == d              // a's first-level descriptor
		&& getDD(getD(a)) == dd      // a's second-level descriptor via chaining
		&& getD(b) == db             // b (B passed as A): first-level is DB
		&& getDD(getD(b)) == ddb;    // b's second-level via chaining: DDB
}
