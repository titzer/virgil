//@execute 0=11; 1=12; 2=13; 3=42
class D describes C {}
class C(a: int) descriptor D {
	def m() -> int { return a; }
}
var a: (D, int) -> C = C.new;
var b: C -> int = C.a;
var c: C -> int = C.m;
def main(arg: int) -> int {
	if (arg == 0) return a(D.new(), 11).a;
	if (arg == 1) return b(C.new(D.new(), 12));
	if (arg == 2) return c(C.new(D.new(), 13));
	return 42;
}

