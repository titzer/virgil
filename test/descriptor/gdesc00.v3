//@execute 0=1; 1=0
// The descriptor field is never read by the program; only a type query forces it live.
class SA<T> { }
class D<T> describes A<T> { }
class A<T> extends SA<T> descriptor D<T> { }
def objs: Array<SA<int>> = [A<int>.new(D<int>.new()), SA<int>.new()];
def main(i: int) -> int {
	return if(A<int>.?(objs[i]), 1, 0);
}
