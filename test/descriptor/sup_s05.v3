//@execute 0=10; 1=15; 2=25
// SA(n:int) is the superclass of A. DA(m:int) is the descriptor.
// A.total() returns n + descriptor.m, combining the inherited SA field with
// the descriptor field. B extends A and inherits total().
class SA(n: int) {}
class DA(m: int) describes A {}
class DB extends DA describes B { new(m: int) super(m) {} }
class A extends SA descriptor DA {
	new(n: int) super(n) {}
	def total() -> int { return n + this.descriptor.m; }
}
class B extends A descriptor DB {
	new(n: int) super(n) {}
}

var objs: Array<A> = [A.new(DA.new(3), 7), B.new(DB.new(5), 10), B.new(DB.new(15), 10)];
def main(i: int) -> int {
	return objs[i].total();
}
