//@execute 0=42; 1=11; 2=42
class D<X, Y> describes C<X, Y> {}
class C<X, Y>(a: X, b: Y) descriptor D<X, Y> { }

var a: C<int, C<bool, bool>> = make(11, make(true, false));

def main(arg: int) -> int {
	if (arg == 1) return getA(a);
	return 42;
}

def make<X, Y>(a: X, b: Y) -> C<X, Y> { return C<X, Y>.new(D.new(), a, b); }
def f32() -> int { return 32; }
def getA<X, Y>(p: C<X, Y>) -> X { return p.a; }
def getB<X, Y>(p: C<X, Y>) -> Y { return p.b; }

