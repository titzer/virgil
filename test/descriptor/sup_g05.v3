//@execute = 9
// Written from scratch: two levels of generic superclass above the described class.
class Top<T> { }
class Mid<T> extends Top<T> { }
class Desc<T>(n: int) describes Leaf<T> { }
class Leaf<T> extends Mid<T> descriptor Desc<T> { }
def main() -> int {
	var l = Leaf<int>.new(Desc<int>.new(9));
	return l.descriptor.n;
}
