//@execute 0=100; 1=-101
class D(x: int) describes A {}
class S {
	var xx: byte;
}
class A extends S descriptor D {}

def ds = [D.new(100), D.new(-101)];
def as = [A.new(ds[0]), A.new(ds[1])];

def main(a: int) -> int {
	as[a].xx += byte.view(a);
	as[a].xx -= byte.view(a);
	return as[a].descriptor.x;
}
