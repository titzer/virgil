//@execute 0=!TypeCheckException; 1=true; 2=true; 3=!TypeCheckException; 4=!TypeCheckException
class DA(x: int) describes A {}
class DB(x: int) describes B {}
class S {}
class A extends S descriptor DA {}
class B extends S descriptor DB {}

def ss = [S.new(), A.new(DA.new(33)), A.new(DA.new(44)), B.new(DB.new(55)), B.new(DB.new(66))];

def main(x: int) -> bool {
	var a = ss[x];
	var b = A.!(a);
	return b.descriptor.x > 0;
}
