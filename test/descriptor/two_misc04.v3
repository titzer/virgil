//@execute 0=true; 1=true; 2=false; 3=false
// Descriptor equality and inequality across objects with shared vs. distinct
// descriptor instances at both levels.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def dd1 = DD.new();
def d1 = D.new(dd1);
def a1 = A.new(d1);
def a2 = A.new(d1);   // shares d1 and dd1

def dd2 = DD.new();
def d2 = D.new(dd2);
def a3 = A.new(d2);   // different d2 and dd2

def main(x: int) -> bool {
	match (x) {
		0 => return a1.descriptor == a2.descriptor;            // same d1
		1 => return a1.descriptor.descriptor == a2.descriptor.descriptor; // same dd1
		2 => return a1.descriptor == a3.descriptor;            // d1 != d2
		3 => return a1.descriptor.descriptor == a3.descriptor.descriptor; // dd1 != dd2
	}
	return false;
}
