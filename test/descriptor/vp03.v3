//@execute 0=42; 1=11; 2=12; 3=13; 4=42
class DN describes N {}
class N descriptor DN {
	def id<X>(x: X) -> X;
}
class DM extends DN describes M {}
class M extends N descriptor DM {
	def id<X>(x: X) -> X {
		return x;
	}
}
var m1: N = M.new(DM.new());
var m2: int = m1.id(11);
var m3: int = m1.id(13);
def main(arg: int) -> int {
	if (arg == 1) return m2;
	if (arg == 2) return m1.id(12);
	if (arg == 3) return m1.id(m3);
	return 42;
}
