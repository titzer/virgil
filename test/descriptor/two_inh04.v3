//@execute 0=true; 1=true; 2=true; 3=true; 4=true; 5=true; 6=true; 7=true
// Two siblings B and C extend A, each with a distinct two-level descriptor chain.
// Tests that each object in an A-typed array returns its own correct descriptor
// chain, and that siblings' descriptors are distinct.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

class DDC extends DD describes DC {}
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

def dd = DD.new();
def d = D.new(dd);
def a = A.new(d);
def ddb = DDB.new();
def db = DB.new(ddb);
def b = B.new(db);
def ddc = DDC.new();
def dc = DC.new(ddc);
def c = C.new(dc);

var objs: Array<A> = [a, b, c];

def main(x: int) -> bool {
	match (x) {
		0 => return objs[0].descriptor == d;
		1 => return objs[0].descriptor.descriptor == dd;
		2 => return objs[1].descriptor == db;
		3 => return objs[1].descriptor.descriptor == ddb;
		4 => return objs[2].descriptor == dc;
		5 => return objs[2].descriptor.descriptor == ddc;
		6 => return objs[1].descriptor != objs[2].descriptor;
		7 => return objs[1].descriptor.descriptor != objs[2].descriptor.descriptor;
	}
	return false;
}
