//@execute 0=true; 1=!DescriptorCheckException
class DA describes A {}
class DB extends DA  describes B{}

class A descriptor DA {}
class B extends A descriptor DB{}

def as = [A.new(DA.new()), B.new(DB.new())];

def main(x: int) -> bool {
	var d = as[x].descriptor;
	var na = A.new(d); // descriptor DB cannot be used for A
	return na != null;
}
