//@execute 0=33; 1=33; 2=44; 3=55
class DA(x: int) describes A {}
class DB extends DA describes B { new(y: int) super(y) {} }

class A descriptor DA {}
class B extends A descriptor DB {}

def da0 = DA.new(33);
def db1 = DB.new(44);
def db2 = DB.new(55);

def as = [A.new(da0), A.new(da0), B.new(db1), B.new(db2)];

def main(x: int) -> int {
	match (as[x]) {
		y: B => return B.descriptor(y).x;
		y: A => return A.descriptor(y).x;
	}
	return 42;
}
