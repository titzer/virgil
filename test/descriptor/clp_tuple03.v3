//@execute -7=false; 2=false; 3=true; 4=false; 983726=false
class D<T> describes C<T> {}
class C<T>(a: T, b: T) descriptor D<T> {
	def equals(that: C<T>) -> bool {
		return this.a == that.a && this.b == that.b;
	}
}
def dd = D<int>.new();
def main(a: int) -> bool {
	return C.new(dd, a, 3).equals(C.new(dd, 3, 3));
}
