//@execute 0=33; 1=33; 2=44; 3=55; 4=66; 5=66
class DA(x: int) describes A {}
class DB extends DA describes B { new(y: int) super(y) {} }
class DC extends DA describes C { new(y: int) super(y) {} }

class A descriptor DA {}
class B extends A descriptor DB {}
class C extends A descriptor DC {}

def da0 = DA.new(33);
def db1 = DB.new(44);
def db2 = DB.new(55);
def dc1 = DC.new(66);
def dc2 = DC.new(77);

def as = [A.new(da0), A.new(da0), B.new(db1), B.new(db2), C.new(dc1), C.new(dc1)];

def main(x: int) -> int {
	return as[x].descriptor.x;
}
