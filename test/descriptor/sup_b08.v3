//@execute 0=11; 1=22; 2=33
// Three-level hierarchy A->B->C with SA superclass; DA->DB->DC with SD superclass.
// Both SA.level() and SD.rank() are virtual; each level overrides both.
// Returns level()*10 + rank() to verify independent dispatch at all three levels.
class SD { def rank() -> int { return 0; } }
class SA { def level() -> int { return 0; } }
class DA extends SD describes A { def rank() -> int { return 1; } }
class DB extends DA describes B { def rank() -> int { return 2; } }
class DC extends DB describes C { def rank() -> int { return 3; } }
class A extends SA descriptor DA { def level() -> int { return 1; } }
class B extends A descriptor DB { def level() -> int { return 2; } }
class C extends B descriptor DC { def level() -> int { return 3; } }

var objs: Array<A> = [A.new(DA.new()), B.new(DB.new()), C.new(DC.new())];
def main(i: int) -> int {
	return objs[i].level() * 10 + objs[i].descriptor.rank();
}
