//@execute 0=0; 1=1; 2=2; 3=!NullCheckException
class DA describes A {}
class A(val: int, next: A) descriptor DA {}
var chain: A = A.new(DA.new(), 0, A.new(DA.new(), 1, A.new(DA.new(), 2, null)));
def main(var arg: int) -> int {
	var c = chain;
	while (arg > 0) {
		c = c.next;
		arg = arg - 1;
	}
	return c.val;
}
