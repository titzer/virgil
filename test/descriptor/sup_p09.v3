//@execute 0=5; 1=10; 2=42; 3=42
// Full polymorphic hierarchy: SA<T>(item:T) and SD(base:int) as superclasses.
// DA<T> extends SD; A<T> extends SA<T>; B<T> extends A<T>; DB<T> extends DA<T>.
// Array dispatch verifies both item (from SA) and base (from SD) for both levels.
class SA<T>(item: T) {}
class SD(base: int) {}
class DA<T> extends SD describes A<T> { new(b: int) super(b) {} }
class DB<T> extends DA<T> describes B<T> { new(b: int) super(b) {} }
class A<T> extends SA<T> descriptor DA<T> { new(x: T) super(x) {} }
class B<T> extends A<T> descriptor DB<T> { new(x: T) super(x) {} }

var objs: Array<A<int>> = [
	A<int>.new(DA<int>.new(42), 5),
	B<int>.new(DB<int>.new(42), 10)
];
def main(i: int) -> int {
	match (i) {
		0 => return objs[0].item;
		1 => return objs[1].item;
		2 => return objs[0].descriptor.base;
		3 => return objs[1].descriptor.base;
	}
	return -1;
}
