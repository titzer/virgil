//@execute 0=false; 1=true; 2=false; 3=true
// Polymorphic instanceof checks on a two-level hierarchy.
// Tests that B<int>.? and DDB<int>.? work correctly when objects are stored
// in A<int>-typed variables.
class DD<T> describes D<T> {}
class D<T> descriptor DD<T> describes A<T> {}
class A<T> descriptor D<T> {}
class DDB<T> extends DD<T> describes DB<T> {}
class DB<T> extends D<T> descriptor DDB<T> describes B<T> {}
class B<T> extends A<T> descriptor DB<T> {}

var a: A<int> = A<int>.new(D<int>.new(DD<int>.new()));
var b: A<int> = B<int>.new(DB<int>.new(DDB<int>.new()));

def main(x: int) -> bool {
	match (x) {
		0 => return B<int>.?(a);
		1 => return B<int>.?(b);
		2 => return DDB<int>.?(a.descriptor.descriptor);
		3 => return DDB<int>.?(b.descriptor.descriptor);
	}
	return false;
}
