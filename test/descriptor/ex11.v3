//@execute 0=true; 1=true; 2=true; 3=!DescriptorCheckException
// The same DA instance can be reused for multiple A objects (ok).
// Using a DB instance for A.new() still fails regardless of prior successful uses.
class DA describes A {}
class DB extends DA describes B {}
class A descriptor DA {}
class B extends A descriptor DB {}

def da = DA.new();
def db = DB.new();

def main(i: int) -> bool {
	match (i) {
		0 => return A.new(da) != null;          // same da reused -- ok
		1 => return A.new(da) != null;          // same da again -- ok
		2 => return B.new(db) != null;
		3 => return A.new(db) != null;          // DB for A -- fails
	}
	return false;
}
