//@execute 0=42; 1=11; 2=21; 3=31; 4=37; 5=42
class DW<T> describes W<T> {}
class W<T>(val: T) descriptor DW<T> {}
var a = W<int>.new(DW.new(), 11);
var b = W<int>.new(DW.new(), 21);
var c = W<W<int>>.new(DW.new(), W<int>.new(DW.new(), 31));
var d = W<W<int>>.new(DW.new(), W<int>.new(DW.new(), 37));
def main(arg: int) -> int {
	if (arg == 1) return a.val;
	if (arg == 2) return b.val;
	if (arg == 3) return c.val.val;
	if (arg == 4) return d.val.val;
	return 42;
}
