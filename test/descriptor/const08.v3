//@execute 0=55; 1=55; 2=99; 3=99
// Two-level descriptor chain: A has descriptor D, D has descriptor Meta.
// All A objects use the same D object (singleton), and that D uses the same
// Meta object (singleton), so WPCP must chain two constant folds to reach .tag.
class Meta(tag: int) describes D {}
class Meta2 extends Meta describes E { new(t: int) super(t) {} }
class D descriptor Meta describes A {}
class E extends D descriptor Meta2 describes B {}
class A descriptor D {
	def m() -> int { return this.descriptor.descriptor.tag; }
}
class B extends A descriptor E {
	def m() -> int { return this.descriptor.descriptor.tag; }
}

def meta_a = Meta.new(55);
def meta_b = Meta2.new(99);
def d = D.new(meta_a);
def e = E.new(meta_b);
var as: Array<A> = [A.new(d), A.new(d), B.new(e), B.new(e)];

def main(x: int) -> int { return as[x].m(); }
