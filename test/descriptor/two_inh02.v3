//@execute 0=true; 1=true; 2=true; 3=true; 4=true; 5=true; 6=true
// Shared descriptors: multiple A and B objects all share the same D and DB.
// D and DB share their own DD and DDB instances respectively.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def dd = DD.new();
def d = D.new(dd);
def ddb = DDB.new();
def db = DB.new(ddb);

def a1 = A.new(d);
def a2 = A.new(d);
def b1 = B.new(db);
def b2 = B.new(db);

def main(x: int) -> bool {
	match (x) {
		0 => return a1.descriptor == d && a2.descriptor == d;
		1 => return a1.descriptor == a2.descriptor;
		2 => return a1.descriptor.descriptor == dd;
		3 => return b1.descriptor == db && b2.descriptor == db;
		4 => return b1.descriptor == b2.descriptor;
		5 => return b1.descriptor.descriptor == ddb;
		6 => return b2.descriptor.descriptor == ddb;
	}
	return false;
}
