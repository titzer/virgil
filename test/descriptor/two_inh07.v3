//@execute 0=11; 1=12; 2=21; 3=22; 4=31; 5=32; 6=42
// Array of A objects (one A, two B) with distinct field values at each level.
// Verifies that .descriptor.y and .descriptor.descriptor.z return per-object values
// and are not aliased across the array entries.
class DD(z: int) describes D {}
class D(y: int) descriptor DD describes A {}
class A(x: int) descriptor D {}

class DDB extends DD describes DB {
	new(v: int) super(v) {}
}
class DB extends D descriptor DDB describes B {
	new(v: int) super(v) {}
}
class B extends A descriptor DB {
	new(v: int) super(v) {}
}

var objs: Array<A> = [
	A.new(D.new(DD.new(12), 11), 0),
	B.new(DB.new(DDB.new(22), 21), 0),
	B.new(DB.new(DDB.new(32), 31), 0)
];

def main(x: int) -> int {
	match (x) {
		0 => return objs[0].descriptor.y;
		1 => return objs[0].descriptor.descriptor.z;
		2 => return objs[1].descriptor.y;
		3 => return objs[1].descriptor.descriptor.z;
		4 => return objs[2].descriptor.y;
		5 => return objs[2].descriptor.descriptor.z;
	}
	return 42;
}
