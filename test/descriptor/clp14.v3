//@execute 0=11; 1=12; 2=13; 3=42
class D describes C {}
class C(a: int) descriptor D {
	def m() -> int { return a; }
}
def d = D.new();
var a: int -> C = C.new(d, _);
var b: C -> int = C.a(_);
var c: C -> int = C.m(_);
def main(arg: int) -> int {
	if (arg == 0) return a(11).a;
	if (arg == 1) return b(C.new(d, 12));
	if (arg == 2) return c(C.new(d, 13));
	return 42;
}
