//@execute 0=99; 1=99; 2=42
class DA(x: int) describes A {}
class DB extends DA(99) describes B {}

class A descriptor DA {}
class B extends A descriptor DB {}

def ds: Array<A> = [B.new(DB.new()), B.new(DB.new()), null];

def main(x: int) -> int {
	var o = ds[x];
	if (B.?(o)) return get(null, B.!(o));
	return 42;
}

def get(a: A, b: B) -> int {
	var r = b.descriptor.x;
	if (a != null) r += a.descriptor.x;
	return r;
}
