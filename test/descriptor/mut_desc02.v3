//@execute 0=0; 1=10; 2=10
// Mutable field in DA, written through a DB descriptor (DB extends DA).
// The mutation is visible both through b.descriptor and through the original db variable.
class DA describes A {
	var value: int;
}
class DB extends DA describes B {}
class A descriptor DA {}
class B extends A descriptor DB {}

def db = DB.new();
def b = B.new(db);

def main(i: int) -> int {
	match (i) {
		0 => return b.descriptor.value;
		1 => { b.descriptor.value = 10; return b.descriptor.value; }
		2 => { b.descriptor.value = 10; return db.value; }	// same object
	}
	return -1;
}
