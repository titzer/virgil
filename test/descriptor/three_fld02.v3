//@execute 0=1; 1=1; 2=106
// A three-level descriptor chain where every descriptor also inherits fields from a
// superclass. The inherited fields must sit after the reserved metadata slots.
class E(v: int) { }
class SD(sd: int, sde: E) { }
class DDD extends SD describes DD { var w: int; new(w0: int, s: int, e: E) super(s, e) { w = w0; } }
class DD extends SD descriptor DDD describes D { var z: int; new(z0: int, s: int, e: E) super(s, e) { z = z0; } }
class D extends SD descriptor DD describes A { var y: int; new(y0: int, s: int, e: E) super(s, e) { y = y0; } }
class A(x: int) descriptor D { }

def e1 = E.new(1), e2 = E.new(2), e3 = E.new(3);
def ddd = DDD.new(4, 40, e3);
def dd = DD.new(ddd, 3, 30, e2);
def d = D.new(dd, 2, 20, e1);
def a = A.new(d, 1);

def main(x: int) -> int {
	def t = a.descriptor;
	match (x) {
		0 => return if(t.sd == 20 && t.descriptor.sd == 30 && t.descriptor.descriptor.sd == 40, 1, 0);
		1 => return if(t.sde == e1 && t.descriptor.sde == e2 && t.descriptor.descriptor.sde == e3, 1, 0);
		2 => return a.x + t.y + t.descriptor.z + t.descriptor.descriptor.w
			+ t.sd + t.descriptor.sd + t.descriptor.descriptor.sd
			+ t.sde.v + t.descriptor.sde.v + t.descriptor.descriptor.sde.v;
	}
	return -1;
}
