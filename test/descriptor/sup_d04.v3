//@execute = 70
// SD has two int fields a and b; DA extends SD, forwarding both via super().
// Verifies that both inherited fields are accessible via .descriptor.
class SD(a: int, b: int) {}
class DA extends SD describes A { new(a: int, b: int) super(a, b) {} }
class A descriptor DA {}

def main() -> int {
	var a = A.new(DA.new(30, 40));
	return a.descriptor.a + a.descriptor.b;
}
