//@execute 0=42; 1=0; 2=0; 3=!NullCheckException; 4=0; 5=42
class DW<T> describes W<T> {}
class W<T> descriptor DW<T> {
	var val: T;
}
var a: W<int> = W<int>.new(DW<int>.new());
var b: W<int> = W<int>.new(DW<int>.new());
var c: W<Array<int>> = W<Array<int>>.new(DW<Array<int>>.new());
var d: W<byte> = W<byte>.new(DW<byte>.new());
def main(arg: int) -> int {
	if (arg == 1) return a.val;
	if (arg == 2) return b.val;
	if (arg == 3) return c.val[0];
	if (arg == 4) return d.val;
	return 42;
}
