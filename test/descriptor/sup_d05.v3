//@execute 0=false; 1=true; 2=true; 3=false
// SD(positive:bool); DA and DB both extend SD and forward the bool via super().
// Verifies the inherited bool field in both descriptor subclasses.
class SD(positive: bool) {}
class DA extends SD describes A { new(p: bool) super(p) {} }
class DB extends DA describes B { new(p: bool) super(p) {} }
class A descriptor DA {}
class B extends A descriptor DB {}

var objs: Array<A> = [
	A.new(DA.new(false)),
	A.new(DA.new(true)),
	B.new(DB.new(true)),
	B.new(DB.new(false))
];
def main(i: int) -> bool {
	return objs[i].descriptor.positive;
}
