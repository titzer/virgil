//@execute 0=42; 1=11; 2=21; 3=42
class DS<T> describes S<T> {}
class S<T> descriptor DS<T> {
	var self: T;
}
class DW extends DS<W> describes W {}
class W extends S<W> descriptor DW {
	var val: int;
	new(v: int) {
		self = this;
		val = v;
	}
}
var f = W.new(DW.new(), 11);
var g = W.new(DW.new(), 21);

def main(arg: int) -> int {
	if (arg == 1) return f.self.val;
	if (arg == 2) return g.val;
	return 42;
}
