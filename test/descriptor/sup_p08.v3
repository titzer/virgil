//@execute 0=42; 1=99
// SA<T>(item:T) superclass of A<T>; B<T> extends A<T>; DB<T> extends DA<T>.
// Verifies that the SA-inherited item field is accessible from B instances.
class SA<T>(item: T) {}
class DA<T> describes A<T> {}
class DB<T> extends DA<T> describes B<T> {}
class A<T> extends SA<T> descriptor DA<T> { new(x: T) super(x) {} }
class B<T> extends A<T> descriptor DB<T> { new(x: T) super(x) {} }

var b1 = B<int>.new(DB<int>.new(), 42);
var b2 = B<int>.new(DB<int>.new(), 99);
def main(i: int) -> int {
	if (i == 0) return b1.item;
	return b2.item;
}
