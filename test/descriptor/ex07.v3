//@execute 0=true; 1=!DescriptorCheckException
// Two-level descriptor chain: DD describes D, D descriptor DD describes A.
// DDB (subtype of DD) cannot be used for the inner D.new() call.
class DD describes D {}
class DDB extends DD describes DB {}
class D descriptor DD describes A {}
class DB extends D descriptor DDB describes B {}
class A descriptor D {}
class B extends A descriptor DB {}

def dds: Array<DD> = [DD.new(), DDB.new()];
def main(i: int) -> bool {
	var d = D.new(dds[i]);   // DDB is too specific for D
	return A.new(d) != null;
}
