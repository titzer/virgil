//@execute 0=false; 1=true; 2=false; 3=true
// instanceof tests on DD-level descriptors across two sibling classes.
// DDB and DDC are both DD subtypes; tests that they don't cross-match.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}
class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}
class DDC extends DD describes DC {}
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

var objs: Array<A> = [
	A.new(D.new(DD.new())),
	B.new(DB.new(DDB.new())),
	C.new(DC.new(DDC.new()))
];

def main(x: int) -> bool {
	match (x) {
		// objs[0]'s descriptor is D; its DD descriptor is DD (not DDB)
		0 => return DDB.?(objs[0].descriptor.descriptor);
		// objs[1]'s descriptor is DB; its DD descriptor is DDB
		1 => return DDB.?(objs[1].descriptor.descriptor);
		// objs[2]'s descriptor is DC; its DD descriptor is DDC (not DDB)
		2 => return DDB.?(objs[2].descriptor.descriptor);
		// objs[2]'s DD descriptor is DDC
		3 => return DDC.?(objs[2].descriptor.descriptor);
	}
	return false;
}
