//@execute = 0
// As sup_g01, but the descriptor no longer has a superclass of its own.
class SA<T>(item: T) {}
class DA<T>(factor: int) describes A<T> {}
class A<T> extends SA<T> descriptor DA<T> { new(item: T) super(item) {} }
def main() -> int {
	var a = A<int>.new(DA<int>.new(0), 0);
	return a.descriptor.factor;
}
