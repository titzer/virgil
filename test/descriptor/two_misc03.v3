//@execute 0=1; 1=2; 2=3
// An array of D objects (D, DB, DC stored as D) dispatched through their
// DD-level descriptors. Tests virtual dispatch starting from a D reference
// rather than an A reference.
class DD describes D { def id() -> int { return 1; } }
class D descriptor DD describes A { def get() -> int { return this.descriptor.id(); } }
class A descriptor D {}

class DDB extends DD describes DB { def id() -> int { return 2; } }
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

class DDC extends DD describes DC { def id() -> int { return 3; } }
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

var ds: Array<D> = [D.new(DD.new()), DB.new(DDB.new()), DC.new(DDC.new())];

def main(x: int) -> int { return ds[x].get(); }
