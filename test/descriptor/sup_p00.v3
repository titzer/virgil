//@execute 0=42; 1=42
// Non-parametric SD(base:int); DA<T> extends SD with a fixed base value.
// Two distinct type instantiations (A<int> and A<bool>) both yield base=42.
class SD(base: int) {}
class DA<T> extends SD describes A<T> { new() super(42) {} }
class A<T> descriptor DA<T> {}

var a_int = A<int>.new(DA<int>.new());
var a_bool = A<bool>.new(DA<bool>.new());
def main(i: int) -> int {
	if (i == 0) return a_int.descriptor.base;
	return a_bool.descriptor.base;
}
