//@execute 0=10; 1=20; 2=30
// SD(offset:int); DA extends SD, forwarding offset via super().
// A has its own int field x; main returns x + descriptor.offset.
class SD(offset: int) {}
class DA extends SD describes A { new(o: int) super(o) {} }
class A(x: int) descriptor DA {}

var objs: Array<A> = [
	A.new(DA.new(5), 5),
	A.new(DA.new(10), 10),
	A.new(DA.new(15), 15)
];
def main(i: int) -> int {
	var a = objs[i];
	return a.x + a.descriptor.offset;
}
