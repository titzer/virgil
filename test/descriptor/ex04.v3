//@execute 0=true; 1=!DescriptorCheckException; 2=!DescriptorCheckException
// Three-level hierarchy. Tests three cases:
//   0: DB for B.new()  -- exact type, succeeds
//   1: DC for B.new()  -- DC is subtype of DB, passes static check, fails at runtime
//   2: DC for A.new()  -- DC is subtype of DA, passes static check, fails at runtime
class DA describes A {}
class DB extends DA describes B {}
class DC extends DB describes C {}
class A descriptor DA {}
class B extends A descriptor DB {}
class C extends B descriptor DC {}

def main(i: int) -> bool {
	match (i) {
		0 => return B.new(DB.new()) != null;
		1 => {
			def ds: Array<DB> = [DB.new(), DC.new()];
			return B.new(ds[1]) != null;
		}
		2 => {
			def ds: Array<DA> = [DA.new(), DC.new()];
			return A.new(ds[1]) != null;
		}
	}
	return false;
}
