//@execute 0=100; 1=200; 2=300
// Three-level class hierarchy A <- B <- C (C extends B extends A),
// each with a two-level descriptor chain. The full inheritance depth tests
// that the object header is correctly maintained through three levels.
class DD(v: int) describes D { def result() -> int { return v * 100; } }
class D descriptor DD describes A { def compute() -> int { return this.descriptor.result(); } }
class A descriptor D { def run() -> int { return this.descriptor.compute(); } }

class DDB extends DD describes DB {
	new(u: int) super(u) {}
	def result() -> int { return v * 100; }
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

class DDC extends DDB describes DC {
	new(u: int) super(u) {}
	def result() -> int { return v * 100; }
}
class DC extends DB descriptor DDC describes C {}
class C extends B descriptor DC {}

var objs: Array<A> = [
	A.new(D.new(DD.new(1))),
	B.new(DB.new(DDB.new(2))),
	C.new(DC.new(DDC.new(3)))
];
def main(x: int) -> int { return objs[x].run(); }
