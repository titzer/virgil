//@execute 0=false; 1=false; 2=true; 3=false; 4=true
// instanceof tests at the class level with a two-level descriptor hierarchy.
// Objects are stored in A-typed variables; tests distinguish A from B.
class DDA describes DA {}
class DA descriptor DDA describes A {}
class A descriptor DA {}
class DDB extends DDA describes DB {}
class DB extends DA descriptor DDB describes B {}
class B extends A descriptor DB {}

var a: A = A.new(DA.new(DDA.new()));
var b: A = B.new(DB.new(DDB.new()));

def main(x: int) -> bool {
	match (x) {
		0 => return B.?(a);       // a is A, not B -> false
		1 => return B.?<B>(null); // null is not B -> false
		2 => return B.?(b);       // b is B -> true
		3 => return A.?<A>(null); // null is not A -> false
		4 => return A.?(b);       // b is a subtype of A -> true
	}
	return false;
}
