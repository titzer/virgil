//@execute 0=11; 1=22; 2=33
// Descriptor stored in a local variable (static type DA), then method called on it.
// The virtual dispatch happens through the DA reference held in the local.
class DA(x: int) describes A { def op() -> int { return x; } }
class DB extends DA describes B {
	new(y: int) super(y) {}
	def op() -> int { return x * 2; }
}
class DC extends DA describes C {
	new(y: int) super(y) {}
	def op() -> int { return x * 3; }
}
class S { }
class A extends S descriptor DA {}
class B extends A descriptor DB {}
class C extends A descriptor DC {}
var objs: Array<A> = [A.new(DA.new(11)), B.new(DB.new(11)), C.new(DC.new(11))];
def main(x: int) -> int {
	def d: DA = objs[x].descriptor;  // static type DA, may be DB or DC at runtime
	return d.op();
}
