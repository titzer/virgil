//@execute 0=42; 1=21; 2=31; 3=41; 4=42
class DP<X, Y> describes P<X, Y> {}
class P<X, Y>(a: X, b: Y) descriptor DP<X, Y> {}
class DI describes I {}
class I(val: int) descriptor DI {}
var a = P<int, I>.new(DP.new(), 21, I.new(DI.new(), 31));
var b = I.new(DI.new(), 41);
def main(arg: int) -> int {
	if (arg == 1) return a.a;
	if (arg == 2) return a.b.val;
	if (arg == 3) return b.val;
	return 42;
}
