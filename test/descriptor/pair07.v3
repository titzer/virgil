//@execute 0=42; 1=11; 2=21; 3=31; 4=42
class DP<X, Y> describes P<X, Y> {}
class P<X, Y>(a: X, b: Y) descriptor DP<X, Y> {}
var a: Array<int> = [21, 31];
var b = P<int, Array<int>>.new(DP.new(), 11, a);
def main(arg: int) -> int {
	if (arg == 1) return b.a;
	if (arg == 2) return b.b[0];
	if (arg == 3) return b.b[1];
	return 42;
}
