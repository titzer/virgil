//@execute 0=0; 1=1; 2=2
// Mutable var field in a descriptor; write through .descriptor is valid.
// .descriptor itself is read-only, but fields OF the descriptor object are mutable.
class DA describes A {
	var count: int;
}
class A descriptor DA {}

def main(i: int) -> int {
	var da = DA.new();
	var a = A.new(da);
	match (i) {
		0 => return a.descriptor.count;
		1 => { a.descriptor.count = a.descriptor.count + 1; return a.descriptor.count; }
		2 => { a.descriptor.count += 2; return a.descriptor.count; }
	}
	return -1;
}
