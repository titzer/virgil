//@execute 0=1; 1=100; 2=3
// B overrides A.m() to multiply D.op() by 100. C inherits A.m().
// Tests that the override in the A hierarchy is correctly dispatched
// while still using the two-level D -> DD chain for the actual computation.
class DD(v: int) describes D { def val() -> int { return v; } }
class D descriptor DD describes A { def op() -> int { return this.descriptor.val(); } }
class A descriptor D { def m() -> int { return this.descriptor.op(); } }

class DDB extends DD describes DB {
	new(u: int) super(u) {}
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {
	def m() -> int { return this.descriptor.op() * 100; }  // B overrides m()
}

class DDC extends DD describes DC {
	new(u: int) super(u) {}
}
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

// A: D.op() -> DD.val() = 1
// B: B.m() -> DB.op()*100 -> DDB.val()*100 = 1*100 = 100
// C: A.m() -> DC.op() -> DDC.val() = 3
var objs: Array<A> = [
	A.new(D.new(DD.new(1))),
	B.new(DB.new(DDB.new(1))),
	C.new(DC.new(DDC.new(3)))
];
def main(x: int) -> int { return objs[x].m(); }
