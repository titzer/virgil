//@execute 0=true; 1=true; 2=true; 3=true; 4=true; 5=true; 6=true; 7=true
// Three-level class hierarchy A <- B <- C, each with a two-level descriptor chain.
// DC extends DB; DDC extends DDB. Tests descriptor access at all three levels,
// and tests the upcast path through an A-typed variable.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

class DDC extends DDB describes DC {}
class DC extends DB descriptor DDC describes C {}
class C extends B descriptor DC {}

def dd = DD.new();
def d = D.new(dd);
def a = A.new(d);
def ddb = DDB.new();
def db = DB.new(ddb);
def b = B.new(db);
def ddc = DDC.new();
def dc = DC.new(ddc);
def c = C.new(dc);

def main(x: int) -> bool {
	match (x) {
		0 => return a.descriptor == d;
		1 => return a.descriptor.descriptor == dd;
		2 => return b.descriptor == db;
		3 => return b.descriptor.descriptor == ddb;
		4 => return c.descriptor == dc;
		5 => return c.descriptor.descriptor == ddc;
	}
	var ca: A = c;
	match (x) {
		6 => return ca.descriptor == dc;           // static type D, runtime type DC
		7 => return ca.descriptor.descriptor == ddc;   // static type DD, runtime type DDC
	}
	return false;
}
