//@execute 0=false; 1=false; 2=false; 3=true; 4=true; 5=false
class DA<X> describes A<X> {}
class A<X> descriptor DA<X> {}
class DB<X> extends DA<X> describes B<X> {}
class B<X> extends A<X> descriptor DB<X> {}
var a: A<int> = A<int>.new(DA<int>.new());
var b: A<int> = B<int>.new(DB<int>.new());
var c: A<int> = B<int>.new(DB<int>.new());
def m(x: A<int>) -> bool {
	return B<int>.?(x);
}
def main(arg: int) -> bool {
	if (arg == 1) return m(null);
	if (arg == 2) return m(a);
	if (arg == 3) return m(b);
	if (arg == 4) return m(c);
	return false;
}
