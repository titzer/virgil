//@execute 0=10; 1=20
// D.descriptor function reference applied to a D-typed array containing both
// D and DB instances. Tests that the function reference correctly returns DD
// (for D) and DDB (for DB stored as D) with their respective field values.
class DD(z: int) describes D {}
class D descriptor DD describes A {}
class A descriptor D {}
class DDB extends DD describes DB  { new(v: int) super(v) {} }
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def getDD = D.descriptor;  // D -> DD (may return DDB at runtime)

var ds: Array<D> = [D.new(DD.new(10)), DB.new(DDB.new(20))];  // DB stored as D

def main(x: int) -> int {
	return getDD(ds[x]).z;  // DD.z=10 for D, DDB.z=20 for DB
}
