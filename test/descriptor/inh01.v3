//@execute -1=-10; 0=0; 4444=44440
class D<T> describes C<T> {}
class B(id: int) { }
class C<T> extends B descriptor D<T> {
	new(x: int) super(x * 10) { }
}

def d_int = D<int>.new();
def d_bool = D<(bool, int)>.new();

def newb_int = C<int>.new(d_int, _);
def newb_bool = C<(bool, int)>.new(d_bool, _);

def main(a: int) -> int {
	var f: int -> B = if(a > 0, newb_int, newb_bool);
	return f(a).id;
}
