//@execute 0=true; 1=true; -1=true
// First .descriptor load is used in a computation; second load of the same
// field should be CSE'd with the first since the field is immutable.
class D(x: int) describes A {}
class A descriptor D {
	def same() -> bool {
		def d1 = this.descriptor;
		def xVal = d1.x;           // use d1: compute from first load
		def d2 = this.descriptor;  // should be CSE'd with d1
		return d1 == d2 && d2.x == xVal;
	}
}
def main(z: int) -> bool {
	def a = A.new(D.new(z));
	return a.same();
}
