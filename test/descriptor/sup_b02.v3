//@execute 0=10; 1=20; 2=30; 3=40
// SA(n:int) superclass of described hierarchy A->B; SD(m:int) superclass of DA->DB.
// Four checks: SA field from A, SD field from A's descriptor, same from B.
class SA(n: int) {}
class SD(m: int) {}
class DA extends SD describes A { new(m: int) super(m) {} }
class DB extends DA describes B { new(m: int) super(m) {} }
class A extends SA descriptor DA { new(n: int) super(n) {} }
class B extends A descriptor DB { new(n: int) super(n) {} }

var objs: Array<A> = [A.new(DA.new(20), 10), B.new(DB.new(40), 30)];
def main(i: int) -> int {
	match (i) {
		0 => return objs[0].n;
		1 => return objs[0].descriptor.m;
		2 => return objs[1].n;
		3 => return objs[1].descriptor.m;
	}
	return -1;
}
