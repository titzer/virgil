//@execute 0=20; 1=60
// SA(n:int).compute(m:int) -> n*m; SD(factor:int) superclass of descriptor DA/DB.
// A.run() calls SA.compute(descriptor.factor), combining the SA field with the
// SD-inherited factor from the descriptor. B inherits run() from A.
class SA(n: int) {
	def compute(m: int) -> int { return n * m; }
}
class SD(factor: int) {}
class DA extends SD describes A { new(f: int) super(f) {} }
class DB extends DA describes B { new(f: int) super(f) {} }
class A extends SA descriptor DA {
	new(n: int) super(n) {}
	def run() -> int { return compute(this.descriptor.factor); }
}
class B extends A descriptor DB {
	new(n: int) super(n) {}
}

var objs: Array<A> = [A.new(DA.new(4), 5), B.new(DB.new(6), 10)];
def main(i: int) -> int {
	return objs[i].run();
}
