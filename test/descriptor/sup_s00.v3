//@execute 0=5; 1=10
// SA(n:int) is the superclass of the described hierarchy A -> B.
// Both A and B inherit n from SA; the descriptor hierarchy is DA -> DB.
class SA(n: int) {}
class DA describes A {}
class DB extends DA describes B {}
class A extends SA descriptor DA { new(x: int) super(x) {} }
class B extends A descriptor DB { new(x: int) super(x) {} }

var a = A.new(DA.new(), 5);
var b = B.new(DB.new(), 10);
def main(i: int) -> int {
	if (i == 0) return a.n;
	return b.n;
}
