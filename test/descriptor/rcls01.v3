//@execute 0=1; 1=10; 2=2; 3=20; 4=3; 5=30; 6=88
class DA describes A { }
class DB<T> extends DA describes B<T> { }
class A descriptor DA { }
class B<T> extends A descriptor DB<T> { }

def classify<T>(v: T) -> int {
	match (v) {
		x: DB<bool> => return 30;
		x: DB<int> => return 20;
		x: DA => return 10;
		x: B<bool> => return 3;
		x: B<int> => return 2;
		x: A => return 1;
	}
	return -1;
}

def as = [A.new(DA.new()), B<int>.new(DB<int>.new()), B<bool>.new(DB<bool>.new())];

def main(a: int) -> int {
	match (a) {
		0 => return classify(as[0]);
		1 => return classify(as[0].descriptor);
		2 => return classify(as[1]);
		3 => return classify(as[1].descriptor);
		4 => return classify(as[2]);
		5 => return classify(as[2].descriptor);
	}
	return 88;
}