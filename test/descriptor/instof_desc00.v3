//@execute 0=false; 1=true; 2=false; 3=true
// Type queries directly on descriptor values (not on the described objects).
// When objects are held in Array<A>, .descriptor has static type DA, allowing
// valid downcast queries DB.?(d) and DC.?(d).
class DA describes A {}
class DB extends DA describes B {}
class DC extends DA describes C {}
class A descriptor DA {}
class B extends A descriptor DB {}
class C extends A descriptor DC {}

var objs: Array<A> = [A.new(DA.new()), B.new(DB.new()), A.new(DA.new()), C.new(DC.new())];
def main(i: int) -> bool {
	match (i) {
		0 => return DB.?(objs[0].descriptor);	// DA -- not DB
		1 => return DB.?(objs[1].descriptor);	// DB -- yes
		2 => return DC.?(objs[1].descriptor);	// DB -- not DC (sibling)
		3 => return DC.?(objs[3].descriptor);	// DC -- yes
	}
	return false;
}
