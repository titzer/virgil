//@execute 0=1; 1=1; 2=1; 3=61
// A three-level descriptor chain where every level mixes reference and non-reference
// fields, so that each level's reference map must be independent of the others.
class E(v: int) { }
class DDD(w: int, we: E, ws: string) describes DD { }
class DD(z: long, ze: E) descriptor DDD describes D { }
class D(y: byte, ye: E, ys: string) descriptor DD describes A { }
class A(x: int) descriptor D { }

def e1 = E.new(1), e2 = E.new(2), e3 = E.new(3);
def s1 = "one", s3 = "three";
def ddd = DDD.new(40, e3, s3);
def dd = DD.new(ddd, 0x3_0000_0000L, e2);
def d = D.new(dd, 10, e1, s1);
def a = A.new(d, 5);

def main(x: int) -> int {
	def t = a.descriptor;
	match (x) {
		0 => return if(t.ye == e1 && t.descriptor.ze == e2 && t.descriptor.descriptor.we == e3, 1, 0);
		1 => return if(t.ys == s1 && t.descriptor.descriptor.ws == s3, 1, 0);
		2 => return if(t.descriptor.z == 0x3_0000_0000L, 1, 0);
		3 => return a.x + t.y + t.descriptor.descriptor.w + t.descriptor.descriptor.we.v + t.ye.v + t.descriptor.ze.v;
	}
	return -1;
}
