//@execute 0=100; 1=200
// Three-level cascading virtual dispatch: A.run() -> D.val() -> DD.val() -> DDD.val().
// Each D-level val() multiplies the result from the next level by 10.
// DDD.val()=1, so A chain returns 100; DDDB.val()=2, so B chain returns 200.
class DDD describes DD { def val() -> int { return 1; } }
class DDDB extends DDD describes DDB { def val() -> int { return 2; } }
class DD descriptor DDD describes D {
	def val() -> int { return this.descriptor.val() * 10; }
}
class DDB extends DD descriptor DDDB describes DB {}
class D descriptor DD describes A {
	def val() -> int { return this.descriptor.val() * 10; }
}
class DB extends D descriptor DDB describes B {}
class A descriptor D {
	def run() -> int { return this.descriptor.val(); }
}
class B extends A descriptor DB {}

var objs: Array<A> = [
	A.new(D.new(DD.new(DDD.new()))),
	B.new(DB.new(DDB.new(DDDB.new())))
];
def main(i: int) -> int {
	return objs[i].run();
}
