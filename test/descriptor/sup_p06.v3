//@execute 0=10; 1=20
// SA<T>(val:T).get() -> T; A<T> extends SA<T> and inherits both field and method.
// Verifies that the parametric get() method works correctly through A<int> objects.
class SA<T>(val: T) {
	def get() -> T { return val; }
}
class DA<T> describes A<T> {}
class A<T> extends SA<T> descriptor DA<T> { new(x: T) super(x) {} }

var a1 = A<int>.new(DA<int>.new(), 10);
var a2 = A<int>.new(DA<int>.new(), 20);
def main(i: int) -> int {
	if (i == 0) return a1.get();
	return a2.get();
}
