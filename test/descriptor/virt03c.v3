//@execute 0=1; 1=2; 2=3; 3=4; 4=!NullCheckException
class DA describes A { def op() => 1; }
class DB extends DA describes B { def op() => 2; }
class DC extends DA describes C { def op() => 3; }
class DD extends DA describes D { def op() => 4; }
class S { def m() => -5555; }
class A extends S descriptor DA { def m() => this.descriptor.op(); }
class B extends A descriptor DB {}
class C extends A descriptor DC {}
class D extends A descriptor DD {}
var objs: Array<S> = [A.new(DA.new()), B.new(DB.new()), C.new(DC.new()), D.new(DD.new()), null];
def main(x: int) -> int { return objs[x].m(); }
