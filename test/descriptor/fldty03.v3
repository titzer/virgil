//@execute 0=7; 1=1; 2=1; 3=8
// A generic descriptor with a type-parameter field, instantiated at both a primitive and a
// reference type, so the descriptor's layout differs per instantiation.
class E(v: int) { }
class DG<T>(t: T) describes AG<T> { }
class AG<T>(u: T) descriptor DG<T> { }

def e = E.new(3);
def gi = DG<int>.new(7);
def ai = AG<int>.new(gi, 8);
def ge = DG<E>.new(e);
def ae = AG<E>.new(ge, e);

def main(x: int) -> int {
	match (x) {
		0 => return ai.descriptor.t;
		1 => return if(ae.descriptor.t == e, 1, 0);
		2 => return if(ae.u == e, 1, 0);
		3 => return ai.u;
	}
	return -1;
}
