//@execute 0=0; 1=4; 2=6; 3=12
// Singleton descriptor provides a per-class multiplier applied to a method argument.
// WPCP folds this.descriptor.mult to a class-specific constant, turning
// scale(x) into a multiply-by-constant per class.
class DA(mult: int) describes A {}
class DB extends DA describes B { new(m: int) super(m) {} }
class A descriptor DA { def scale(x: int) -> int { return x * this.descriptor.mult; } }
class B extends A descriptor DB { def scale(x: int) -> int { return x * this.descriptor.mult; } }

def da = DA.new(3);  // A multiplies by 3
def db = DB.new(4);  // B multiplies by 4
var as: Array<A> = [A.new(da), B.new(db)];

// x=0: as[0]=A, scale(0)=0*3=0
// x=1: as[1]=B, scale(1)=1*4=4
// x=2: as[0]=A, scale(2)=2*3=6
// x=3: as[1]=B, scale(3)=3*4=12
def main(x: int) -> int {
	return as[x & 1].scale(x);
}
