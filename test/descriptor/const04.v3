//@execute 0=10; 1=10; 2=20; 3=20; 4=30; 5=30
// Singleton descriptor per class; each class's m() calls this.descriptor.op().
// WPCP folds this.descriptor to a constant, then devirtualizes .op().
class DA(x: int) describes A { def op() -> int { return x; } }
class DB extends DA describes B {
	new(y: int) super(y) {}
	def op() -> int { return x * 2; }
}
class DC extends DA describes C {
	new(y: int) super(y) {}
	def op() -> int { return x * 3; }
}
class A descriptor DA { def m() -> int { return this.descriptor.op(); } }
class B extends A descriptor DB { def m() -> int { return this.descriptor.op(); } }
class C extends A descriptor DC { def m() -> int { return this.descriptor.op(); } }

def da = DA.new(10);
def db = DB.new(10);
def dc = DC.new(10);
def as = [A.new(da), A.new(da), B.new(db), B.new(db), C.new(dc), C.new(dc)];

def main(x: int) -> int { return as[x].m(); }
