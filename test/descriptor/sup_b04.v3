//@execute 0=7; 1=42
// SA(x:int).double() -> x*2; SD(y:int).triple() -> y*3.
// Both superclass methods are callable on the same object: once via SA
// (on the described object) and once via SD (on the descriptor).
class SA(x: int) {
	def double() -> int { return x * 2; }
}
class SD(y: int) {
	def triple() -> int { return y * 3; }
}
class DA extends SD describes A { new(y: int) super(y) {} }
class A extends SA descriptor DA { new(x: int) super(x) {} }

def main(i: int) -> int {
	var a = A.new(DA.new(7), 7);
	if (i == 0) return a.double() - a.x;	// 14 - 7 = 7
	return a.descriptor.triple() * 2;		// 7*3*2 = 42
}
