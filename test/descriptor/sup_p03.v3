//@execute 0=5; 1=10
// SA<T>(item:T) superclass of A<T>; two-level hierarchy B<T> extends A<T>.
// Descriptor hierarchy DA<T> -> DB<T>; item field inherited from SA through both levels.
class SA<T>(item: T) {}
class DA<T> describes A<T> {}
class DB<T> extends DA<T> describes B<T> {}
class A<T> extends SA<T> descriptor DA<T> { new(x: T) super(x) {} }
class B<T> extends A<T> descriptor DB<T> { new(x: T) super(x) {} }

var a = A<int>.new(DA<int>.new(), 5);
var b = B<int>.new(DB<int>.new(), 10);
def main(i: int) -> int {
	if (i == 0) return a.item;
	return b.item;
}
