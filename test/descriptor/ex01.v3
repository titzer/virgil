//@execute 0=false; 1=!DescriptorCheckException
class DA describes A {}
class DB describes B extends DA {}

class A descriptor DA {}
class B descriptor DB extends A {}

def ds: Array<DA> = [DA.new(), DB.new()];

def main(a: int) -> bool {
	var na = A.new(ds[a]); // descriptor DB cannot be used for A
	return na != null;
}
