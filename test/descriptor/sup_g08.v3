//@execute = 6
// Contrast: a described generic class whose superclass is NOT generic. Must pass.
class SA(item: int) { }
class Desc<T>(n: int) describes A<T> { }
class A<T> extends SA descriptor Desc<T> { new(item: int) super(item) { } }
def main() -> int {
	var a = A<int>.new(Desc<int>.new(6), 0);
	return a.descriptor.n;
}
