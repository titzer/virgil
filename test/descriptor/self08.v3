//@execute = 11
class DS<T> describes S<T> {}
class S<T> descriptor DS<T> {
	var self: T;
}
class DW<T> extends DS<W<T>> describes W<T> {}
class W<T> extends S<W<T>> descriptor DW<T> {
	var val: T;
	new(v: T) {
		self = this;
		val = v;
	}
}
var f = W<int>.new(DW<int>.new(), 11);

def main() -> int {
	return f.self.val;
}
