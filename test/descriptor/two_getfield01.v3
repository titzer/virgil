//@execute = true
// D.descriptor used as a function reference to extract the DD from D instances.
// Applied to both a D and a DB instance (DB stored as D); verifies that
// the function reference correctly dispatches at the second level.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}
class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def dd = DD.new();
def d = D.new(dd);
def ddb = DDB.new();
def db = DB.new(ddb);

def getDD = D.descriptor;  // function: D -> DD

def main() -> bool {
	return getDD(d) == dd      // D's descriptor is dd
		&& getDD(db) == ddb;   // DB's descriptor (as D) is ddb (runtime DDB)
}
