//@execute 0=10; 1=20; 2=30
// Array of delegates each bound to a different descriptor instance's method.
// Each delegate captures the descriptor; calling them returns distinct values.
class DA(val: int) describes A {
	def doubled() -> int { return val * 2; }
}
class A descriptor DA {}

var ds = [DA.new(5), DA.new(10), DA.new(15)];
var objs = [A.new(ds[0]), A.new(ds[1]), A.new(ds[2])];
var funcs: Array<() -> int> = [
	objs[0].descriptor.doubled,
	objs[1].descriptor.doubled,
	objs[2].descriptor.doubled
];

def main(i: int) -> int {
	return funcs[i]();
}
