//@execute 3=9; 5=15; 7=21
// SD has a mutable var field count; DA extends SD and sets it in its constructor.
// Two independent DA instances each hold separate state; sum equals x + x*2 = 3*x.
class SD { var count: int; }
class DA extends SD describes A { new(c: int) { count = c; } }
class A descriptor DA {}

def main(x: int) -> int {
	var d1 = DA.new(x);
	var d2 = DA.new(x * 2);
	var a1 = A.new(d1);
	var a2 = A.new(d2);
	return a1.descriptor.count + a2.descriptor.count;
}
