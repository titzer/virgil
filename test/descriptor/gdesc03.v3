//@execute = 100
// A generic hierarchy whose descriptor is reached only through casts, mixed with objects
// of the plain superclass, so the query must tell them apart by type id.
class SA<T> { }
class D<T>(n: int) describes A<T> { }
class A<T> extends SA<T> descriptor D<T> { }
def d = D<int>.new(42);
var objs: Array<SA<int>>;
def main() -> int {
	objs = [A<int>.new(d), SA<int>.new(), A<int>.new(d)];
	if (!A<int>.?(objs[0])) return 1;
	if (A<int>.?(objs[1])) return 2;
	if (A<int>.!(objs[2]).descriptor.n != 42) return 3;
	return 100;
}
