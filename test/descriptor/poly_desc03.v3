//@execute 0=true; 1=false; 2=true; 3=false; 4=true; 5=false
class D<T> describes A<T> { }
class A<T> descriptor D<T> { }

def check<T, F>() -> bool {
	return D<F>.?<D<T>>(A<T>.new(D<T>.new()).descriptor);
}

def main(a: int) -> bool {
	match (a) {
		0 => return check<int, int>();
		1 => return check<bool, int>();
		2 => return check<bool, bool>();
		3 => return check<void, int>();
		4 => return check<void, void>();
	}
	return false;
}
