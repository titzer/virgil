//@execute 0 = 0
class DA describes A {}
class A descriptor DA {}
class DB<T> extends DA describes B<T> {}
class B<T> extends A descriptor DB<T> {}
class DH describes H {}
class H descriptor DH {
	var f: void -> A = m;
}
var f: H = H.new(DH.new());
def main(arg: int) -> int {
	f.f();
	return 0;
}
def m() -> B<int> {
	return B<int>.new(DB<int>.new());
}
