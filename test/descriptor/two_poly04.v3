//@execute 0=1; 1=2; 2=3; 3=42
// Polymorphic two-level chain with field access at the DD level.
// Instantiated at three different type parameters; each gets a distinct DD.z value.
class DD<T>(z: int) describes D<T> {}
class D<T> descriptor DD<T> describes A<T> {}
class A<T> descriptor D<T> {}

var a_int  = A<int>.new(D<int>.new(DD<int>.new(1)));
var a_bool = A<bool>.new(D<bool>.new(DD<bool>.new(2)));
var a_byte = A<byte>.new(D<byte>.new(DD<byte>.new(3)));

def main(x: int) -> int {
	match (x) {
		0 => return a_int.descriptor.descriptor.z;
		1 => return a_bool.descriptor.descriptor.z;
		2 => return a_byte.descriptor.descriptor.z;
	}
	return 42;
}
