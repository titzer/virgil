//@execute 0=1; 1=2
// SD has a virtual method tag(); DA overrides to return 1, DB overrides to return 2.
// Objects stored in Array<A>; dispatch through .descriptor.tag().
class SD { def tag() -> int { return 0; } }
class DA extends SD describes A { def tag() -> int { return 1; } }
class DB extends DA describes B { def tag() -> int { return 2; } }
class A descriptor DA {}
class B extends A descriptor DB {}

var objs: Array<A> = [A.new(DA.new()), B.new(DB.new())];
def main(i: int) -> int {
	return objs[i].descriptor.tag();
}
