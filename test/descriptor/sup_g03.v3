//@execute = 0
// Minimal: the generic superclass declares no fields at all, so only its presence as the
// declaring class of the hoisted descriptor field matters.
class SA<T> {}
class DA<T>(factor: int) describes A<T> {}
class A<T> extends SA<T> descriptor DA<T> {}
def main() -> int {
	var a = A<int>.new(DA<int>.new(0));
	return a.descriptor.factor;
}
