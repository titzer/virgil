//@execute 0=true; 1=true; 2=true; 3=true
// Three-level chain: identity checks at every level.
// Verifies that the descriptor instances are the exact objects passed in.
class DDD describes DD {}
class DD descriptor DDD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def ddd = DDD.new();
def dd = DD.new(ddd);
def d = D.new(dd);
def a = A.new(d);

def main(i: int) -> bool {
	match (i) {
		0 => return a.descriptor == d;
		1 => return a.descriptor.descriptor == dd;
		2 => return a.descriptor.descriptor.descriptor == ddd;
		3 => return a.descriptor.descriptor.descriptor != null;
	}
	return false;
}
