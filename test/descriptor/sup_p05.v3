//@execute 0=1; 1=2
// SD has virtual id(); DA<T> overrides to return 1, DB<T> overrides to return 2.
// A<T> and B<T> form a described hierarchy; dispatch is through DA<int>-typed variable.
class SD { def id() -> int { return 0; } }
class DA<T> extends SD describes A<T> { def id() -> int { return 1; } }
class DB<T> extends DA<T> describes B<T> { def id() -> int { return 2; } }
class A<T> descriptor DA<T> {}
class B<T> extends A<T> descriptor DB<T> {}

var objs: Array<A<int>> = [A<int>.new(DA<int>.new()), B<int>.new(DB<int>.new())];
def main(i: int) -> int {
	return objs[i].descriptor.id();
}
