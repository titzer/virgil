//@execute = 70
// SA(n:int) is superclass of described class A; SD(m:int) is superclass of descriptor DA.
// Verifies that both inherited fields are independently accessible.
class SA(n: int) {}
class SD(m: int) {}
class DA extends SD describes A { new(m: int) super(m) {} }
class A extends SA descriptor DA { new(n: int) super(n) {} }

def main() -> int {
	var da = DA.new(30);
	var a = A.new(da, 40);
	return da.m + a.n;
}
