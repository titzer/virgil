//@execute 0=42; 1=!DescriptorCheckException
// DX extends DA but describes nothing. A.new(DX.new()) passes the static
// type check (DX IS-A DA) but fails the exact-type check at runtime.
class DA(val: int) describes A {}
class DX extends DA { new(v: int) super(v) {} }
class A descriptor DA {}

def ds: Array<DA> = [DA.new(42), DX.new(99)];
def main(i: int) -> int {
	var a = A.new(ds[i]);
	return a.descriptor.val;
}
