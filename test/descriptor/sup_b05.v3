//@execute 0=0; 5=10; 10=20
// SA<T>(item:T) is parametric superclass of A<T>; SD(factor:int) is superclass of DA<T>.
// Both item (from SA) and factor (from SD) are accessible on each instance.
// result = item + factor; with item == factor == input, result == 2*input.
class SA<T>(item: T) {}
class SD(factor: int) {}
class DA<T> extends SD describes A<T> { new(f: int) super(f) {} }
class A<T> extends SA<T> descriptor DA<T> { new(item: T) super(item) {} }

def main(i: int) -> int {
	var a = A<int>.new(DA<int>.new(i), i);
	return a.item + a.descriptor.factor;
}
