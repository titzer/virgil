//@execute = true
// Multiple B objects share one DB instance, and that DB shares one DDB.
// The entire two-level descriptor chain is shared across all B instances.
// Also tests that an A created with the same DB instance shares the chain.
class DDA describes DA {}
class DA descriptor DDA describes A {}
class A descriptor DA {}
class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def ddb = DDB.new();
def dda = DDA.new();
def db = DB.new(ddb);
def da = DB.new(dda);
def b1 = B.new(db);
def b2 = B.new(db);
def b3 = B.new(db);
def a = A.new(da);   // A using the same DB as its D descriptor (DB is a D subtype)

def main() -> bool {
	return b1.descriptor == b2.descriptor
		&& b2.descriptor == b3.descriptor
		&& b1.descriptor.descriptor == ddb
		&& b2.descriptor.descriptor == ddb
		&& b3.descriptor.descriptor == ddb
		&& a.descriptor == da             // A-level view of the same DB
		&& a.descriptor.descriptor == dda; // second level is still ddb
}
