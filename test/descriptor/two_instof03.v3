//@execute 0=0; 1=1; 2=10; 3=20
// Downcast using B.?(x) predicate, and DDB.!(x.descriptor.descriptor) to access
// a field at the second level. Tests that downcast succeeds for B and gives
// access to DDB-level data.
class DD(v: int) describes D {}
class D descriptor DD describes A {}
class A descriptor D {}
class DDB extends DD describes DB {
	new(u: int) super(u) {}
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

var a: A = A.new(D.new(DD.new(10)));
var b: A = B.new(DB.new(DDB.new(20)));

def main(x: int) -> int {
	match (x) {
		0 => return if(B.?(a), 1, 0);
		1 => return if(B.?(b), 1, 0);
		2 => return DD.!(a.descriptor.descriptor).v;   // a's DD (not a downcast)
		3 => return DDB.!(b.descriptor.descriptor).v;  // b's DDB (downcast DD -> DDB)
	}
	return -1;
}
