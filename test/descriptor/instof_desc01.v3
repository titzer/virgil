//@execute 0=30; 1=!TypeCheckException
// Force cast (as) on a descriptor value. When the descriptor's runtime type
// matches the cast target, the extra method is accessible. Otherwise CastException.
class DA(val: int) describes A {}
class DB extends DA describes B {
	new(v: int) super(v) {}
	def extra() -> int { return val * 3; }
}
class A descriptor DA {}
class B extends A descriptor DB {}

var objs: Array<A> = [B.new(DB.new(10)), A.new(DA.new(10))];
def main(i: int) -> int {
	var d: DB = DB.!(objs[i].descriptor);
	return d.extra();
}
