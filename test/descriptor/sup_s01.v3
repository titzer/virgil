//@execute 0=4; 1=8; 2=12
// SA(n:int) provides method doubled() -> n*2; A and B inherit it.
// Verifies that the inherited method is callable through an A-typed array.
class SA(n: int) {
	def doubled() -> int { return n * 2; }
}
class DA describes A {}
class DB extends DA describes B {}
class A extends SA descriptor DA { new(x: int) super(x) {} }
class B extends A descriptor DB { new(x: int) super(x) {} }

var objs: Array<A> = [A.new(DA.new(), 2), B.new(DB.new(), 4), B.new(DB.new(), 6)];
def main(i: int) -> int {
	return objs[i].doubled();
}
