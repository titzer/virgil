//@execute 0=100; 1=-100; 2=200; 3=-200
// SD(magnitude:int, positive:bool); DA extends SD and adds value() using both fields.
// value() returns +magnitude or -magnitude based on the positive flag.
class SD(magnitude: int, positive: bool) {}
class DA extends SD describes A {
	new(m: int, p: bool) super(m, p) {}
	def value() -> int { return if(positive, magnitude, -magnitude); }
}
class A descriptor DA {}

var objs: Array<A> = [
	A.new(DA.new(100, true)),
	A.new(DA.new(100, false)),
	A.new(DA.new(200, true)),
	A.new(DA.new(200, false))
];
def main(i: int) -> int {
	return objs[i].descriptor.value();
}
