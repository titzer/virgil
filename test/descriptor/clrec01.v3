//@execute 0=0; 1=1; 3=9; 5=25

// A test of more complex type recursion with subtyping
class DA describes A {}
class A descriptor DA {
	var v: int;
	var b: B;
	new(v, b) {}
}

class DB extends DA describes B {}
class B extends A descriptor DB {
	var a: A;
	new(a, v: int, b: B) super(v, b) {}
}

def da = DA.new();
def db = DB.new();
def main(n: int) -> int {
	var a: A;
	var b: B;
	for (i < n) {
		b = B.new(db, a, i, b);
		a = A.new(da, i+1, b);
	}
	var j = 0;
	while (a != null) {
		j += a.v;
		a = a.b.a;
	}
	while (b != null) {
		j += b.v;
		b = b.b;
	}
	return j;
}
