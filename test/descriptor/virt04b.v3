//@execute 0=1; 1=4; 2=9
// Double dispatch: descriptor.op() calls back into the object via a.size().
// Dispatch 1: objs[x].m() hits A.m() (only A has it; B and C inherit).
// Dispatch 2: this.descriptor.op(this) dispatches on the DA hierarchy.
// Dispatch 3: a.size() inside op() dispatches on the A hierarchy.
class DA(factor: int) describes A { def op(a: A) -> int { return a.size() * factor; } }
class DB extends DA describes B {
	new(f: int) super(f) {}
	def op(a: A) -> int { return a.size() * factor * 2; }
}
class DC extends DA describes C {
	new(f: int) super(f) {}
	def op(a: A) -> int { return a.size() * factor * 3; }
}
class S { def m() -> int { return -99; } }
class A extends S descriptor DA {
	def size() -> int { return 1; }
	def m() -> int { return this.descriptor.op(this); }
}
class B extends A descriptor DB {
	def size() -> int { return 2; }
}
class C extends A descriptor DC {
	def size() -> int { return 3; }
}
var objs: Array<S> = [A.new(DA.new(1)), B.new(DB.new(1)), C.new(DC.new(1))];
def main(x: int) -> int { return objs[x].m(); }
