//@execute 0=7; 1=7
// SD(val:int); DA extends SD. Tests upcasting .descriptor to the supertype SD
// and reading the field through both the static type DA and the upcast type SD.
class SD(val: int) {}
class DA extends SD describes A { new(v: int) super(v) {} }
class A descriptor DA {}

def main(i: int) -> int {
	var da = DA.new(7);
	var a = A.new(da);
	if (i == 0) {
		def d: SD = a.descriptor;	// upcast to SD supertype
		return d.val;
	}
	return a.descriptor.val;
}
