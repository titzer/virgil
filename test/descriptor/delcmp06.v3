//@execute 0=false
class DC<T> describes C<T> {}
class C<T> descriptor DC<T> {
	def m<U>(a: T) -> U;
}
def main(arg: int) -> bool {
	var a: int -> int = C<int>.new(DC<int>.new()).m;
	var b: bool -> int = C<bool>.new(DC<bool>.new()).m;
	return cmp(a, b);
}
def cmp<A, B>(a: A, b: B) -> bool {
	return (B.?(a) && B.!(a) == b) || (A.?(b) && A.!(b) == a);
}
