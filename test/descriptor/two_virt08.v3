//@execute 0=10; 1=20; 2=30
// Descriptor stored in a local variable of static type D; then m() is called.
// The virtual dispatch happens through the D reference even though the static
// type is D. This is the two-level analog of virt05.v3.
class DD(val: int) describes D { def op() -> int { return val; } }
class D descriptor DD describes A { def m() -> int { return this.descriptor.op(); } }
class A descriptor D {}

class DDB extends DD describes DB {
	new(v: int) super(v) {}
	def op() -> int { return val * 2; }
}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

class DDC extends DD describes DC {
	new(v: int) super(v) {}
	def op() -> int { return val * 3; }
}
class DC extends D descriptor DDC describes C {}
class C extends A descriptor DC {}

var objs: Array<A> = [
	A.new(D.new(DD.new(10))),
	B.new(DB.new(DDB.new(10))),
	C.new(DC.new(DDC.new(10)))
];

def main(x: int) -> int {
	def d: D = objs[x].descriptor;  // static type D, runtime may be DB or DC
	return d.m();                     // virtual dispatch: D.m() -> DD.op() or override
}
