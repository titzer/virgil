//@execute 0=20; 1=30; 2=10; 3=15
// SA has mutable fields; SD(base:int) superclass of descriptor DA.
// A's constructor sets total = descriptor.base * 2, coupling the described
// class initialization to the descriptor's inherited SD field.
class SA {
	var total: int;
}
class SD(base: int) {}
class DA extends SD describes A { new(b: int) super(b) {} }
class A extends SA descriptor DA {
	new() {
		total = this.descriptor.base * 2;
	}
}

var objs: Array<A> = [A.new(DA.new(10)), A.new(DA.new(15))];
def main(i: int) -> int {
	match (i) {
		0 => return objs[0].total;
		1 => return objs[1].total;
		2 => return objs[0].descriptor.base;
		3 => return objs[1].descriptor.base;
	}
	return -1;
}
