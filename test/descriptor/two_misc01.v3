//@execute 0=10; 1=20; 2=30; 3=42
// Methods at different levels access their object's descriptor chain.
// D.ddz() reads this.descriptor.z (the DD field).
// A.ddz() calls this.descriptor.ddz() to retrieve it via D.
// Tests that method dispatch correctly resolves both levels.
class DD(z: int) describes D {}
class D descriptor DD describes A {
	def ddz() -> int { return this.descriptor.z; }
}
class A descriptor D {
	def ddz() -> int { return this.descriptor.ddz(); }
}

class DDB extends DD describes DB  { new(v: int) super(v) {} }
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

var objs: Array<A> = [
	A.new(D.new(DD.new(10))),
	A.new(D.new(DD.new(20))),
	B.new(DB.new(DDB.new(30)))
];

def main(x: int) -> int {
	match (x) {
		0 => return objs[0].ddz();  // A.ddz -> D.ddz -> DD.z = 10
		1 => return objs[1].ddz();  // A.ddz -> D.ddz -> DD.z = 20
		2 => return objs[2].ddz();  // A.ddz -> DB.ddz(inherited) -> DDB.z = 30
	}
	return 42;
}
