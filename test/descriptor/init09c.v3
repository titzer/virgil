//@execute 0=7; -7=-7; 10=27
class D<T> describes A<T> {}
class A<T>(x: (T, T)) descriptor D<T> {}

def d = D<int>.new();

def test<X>(d: D<X>, v: (X, X)) -> (X, X) {
	var t = (d, v.0, v.1);
	var a = A<X>.new(t);
	return a.x;
}

def main(x: int) -> int {
	var t = test(d, (x + 3, x + 4));
	return t.0 + t.1;
}
