//@execute = 32
class D(x: int) describes C {}
class A {}
class C extends A descriptor D {}

def a = A.new();
def cs = [C.new(D.new(32)), C.new(D.new(64))];

def main() -> int {
	var r = 0;
	if (a == null) r |= 1;
	var c = cs[r];
	if (c == null) r |= 2;
	if (c.descriptor == null) r |= 4;
	return c.descriptor.x + r;
}
