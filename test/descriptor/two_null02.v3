//@execute = !NullCheckException
// Passing a null D descriptor to A.new() throws NullCheckException.
// Even when the D object itself was validly created with a non-null DD,
// passing a null D to A.new() is not allowed.
class DD describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def main() -> int {
	var d: D;            // null D
	var a = A.new(d);    // NullCheckException: null descriptor not allowed
	return 0;
}
