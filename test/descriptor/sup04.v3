//@execute 64=128; 128=192
class D(x: int) describes C {}
class A {}
class C extends A descriptor D {}

def main(x: int) -> int {
	def a = A.new();
	def c = C.new(D.new(x + 64));
	var r = 0;
	if (a == null) r |= 1;
	if (c == null) r |= 2;
	if (c.descriptor == null) r |= 4;
	return c.descriptor.x + r;
}
