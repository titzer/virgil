//@execute 0=100; 1=200; 2=300; 3=400
// Full two-level hierarchy with superclasses on both sides: SA->A->B and SD->DA->DB.
// Four checks verify that SA and SD fields are correctly stored at each level.
class SA(n: int) {}
class SD(m: int) {}
class DA extends SD describes A { new(m: int) super(m) {} }
class DB extends DA describes B { new(m: int) super(m) {} }
class A extends SA descriptor DA { new(n: int) super(n) {} }
class B extends A descriptor DB { new(n: int) super(n) {} }

var objs: Array<A> = [
	A.new(DA.new(200), 100),
	B.new(DB.new(400), 300)
];
def main(i: int) -> int {
	match (i) {
		0 => return objs[0].n;
		1 => return objs[0].descriptor.m;
		2 => return objs[1].n;
		3 => return objs[1].descriptor.m;
	}
	return -1;
}
