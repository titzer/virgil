//@execute 0=33; 1=44; 2=55; 3=42
class DD(z: int) describes D {}
class D(y: int) descriptor DD describes A {}
class A(x: int) descriptor D {}

def dd = DD.new(55);
def d = D.new(dd, 44);
def a = A.new(d, 33);

def main(x: int) -> int {
	match (x) {
		0 => return a.x;
		1 => return a.descriptor.y;
		2 => return a.descriptor.descriptor.z;
	}
	return 42;
}
