//@execute 0=true; 1=!DescriptorCheckException
// Polymorphic hierarchy: DA<T> describes A<T>, DB<T> extends DA<T> describes B<T>.
// DB<int> cannot be used for A<int>.new(), even though the type parameter matches.
class DA<T> describes A<T> {}
class DB<T> extends DA<T> describes B<T> {}
class A<T> descriptor DA<T> {}
class B<T> extends A<T> descriptor DB<T> {}

def ds: Array<DA<int>> = [DA<int>.new(), DB<int>.new()];
def main(i: int) -> bool {
	var a = A<int>.new(ds[i]);  // DB<int> is not the exact type for A<int>
	return a != null;
}
