//@execute 0=10; 1=20; 2=30
// D.descriptor function reference applied to freshly-created D instances.
// Each D instance has a distinct DD with a distinct field value; verifies
// the function reference reads the correct DD for each D object.
class DD(z: int) describes D {}
class D descriptor DD describes A {}
class A descriptor D {}

def getDD = D.descriptor;  // D -> DD

def main(x: int) -> int {
	match (x) {
		0 => return getDD(D.new(DD.new(10))).z;
		1 => return getDD(D.new(DD.new(20))).z;
		2 => return getDD(D.new(DD.new(30))).z;
	}
	return -1;
}
