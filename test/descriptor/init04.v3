//@execute 0=333; -333=-666; 1000000=3000333
class D<T> describes A<T> {}
class A<T>(x: T) descriptor D<T> {}

def di = D<int>.new();
def dii = D<(int, int)>.new();

def main(x: int) -> int {
	var ai = A<int>.new(di, x + 3);
	var aii = A<(int, int)>.new(dii, x + 30, x + 300);
	return ai.x + aii.x.0 + aii.x.1;
}
