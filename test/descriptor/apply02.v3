//@execute 0=10
class DL<T> describes L<T> {}
class L<T>(head: T, tail: L<T>) descriptor DL<T> {}
var listA = L<int>.new(DL.new(), 10, null);
var listB = L<bool>.new(DL.new(), false, null);
def main(arg: int) -> int {
	apply(listA, print_int);
	apply(listB, print_bool);
	return 10;
}
def print_int(val: int) {
	// do nothing.
}
def print_bool(val: bool) {
	// do nothing.
}
def apply<T>(var list: L<T>, func: T -> void) {
	while (list != null) {
		func(list.head);
		list = list.tail;
	}
}
