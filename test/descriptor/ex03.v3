//@execute 0=true; 1=!DescriptorCheckException
// DC extends DB; DC is a valid subtype of DB statically, so B.new(DC.new()) compiles.
// But the exact-type check requires DB, so the DC instance at runtime fails.
class DA describes A {}
class DB extends DA describes B {}
class DC extends DB describes C {}
class A descriptor DA {}
class B extends A descriptor DB {}
class C extends B descriptor DC {}

def ds: Array<DB> = [DB.new(), DC.new()];
def main(i: int) -> bool {
	var b = B.new(ds[i]);  // DC cannot be used for B
	return b != null;
}
