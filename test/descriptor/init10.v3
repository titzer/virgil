//@execute 0=5; 1=5; 2=10
// A's constructor body reads this.descriptor.base. When constructing a B object,
// the descriptor is set to the DB instance BEFORE any constructor body runs,
// so A's body sees base=10 (from DB) rather than any default or DA value.
class DA(base: int) describes A {}
class DB extends DA describes B { new(b: int) super(b) {} }
class A descriptor DA {
	var from_d: int;
	new() {
		from_d = this.descriptor.base;
	}
}
class B extends A descriptor DB {}

def a = A.new(DA.new(5));
def b = B.new(DB.new(10));

def main(i: int) -> int {
	match (i) {
		0 => return a.from_d;		// A's constructor read DA.base = 5
		1 => return a.descriptor.base;
		2 => return b.from_d;		// A's constructor read DB.base = 10
	}
	return -1;
}
