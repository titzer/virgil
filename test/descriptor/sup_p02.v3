//@execute 0=10; 1=100; 2=20; 3=200
// SA<T>(item:T) superclass of A<T>; SD(factor:int) superclass of DA<T>.
// Both parametric (item from SA) and non-parametric (factor from SD) fields verified.
class SA<T>(item: T) {}
class SD(factor: int) {}
class DA<T> extends SD describes A<T> { new(f: int) super(f) {} }
class A<T> extends SA<T> descriptor DA<T> { new(x: T) super(x) {} }

var a1 = A<int>.new(DA<int>.new(10), 100);
var a2 = A<int>.new(DA<int>.new(20), 200);
def main(i: int) -> int {
	match (i) {
		0 => return a1.descriptor.factor;
		1 => return a1.item;
		2 => return a2.descriptor.factor;
		3 => return a2.item;
	}
	return -1;
}
