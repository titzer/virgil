//@execute 0=1; 1=1; 2=75
// A three-level chain whose middle descriptor declares no fields at all, so its reserved
// metadata slots are immediately followed by the next level's header.
class E(v: int) { }
class DDD(w: int, we: E, arr: Array<int>) describes DD { }
class DD descriptor DDD describes D { }
class D(y: int, ye: E) descriptor DD describes A { }
class A(x: int) descriptor D { }

def e1 = E.new(1), e3 = E.new(3);
def ddd = DDD.new(30, e3, [4, 5, 6]);
def dd = DD.new(ddd);
def d = D.new(dd, 20, e1);
def a = A.new(d, 10);

def main(x: int) -> int {
	def t = a.descriptor;
	match (x) {
		0 => return if(t.ye == e1 && t.descriptor.descriptor.we == e3, 1, 0);
		1 => return if(t.descriptor.descriptor.arr.length == 3, 1, 0);
		2 => {
			var arr = t.descriptor.descriptor.arr;
			return a.x + t.y + arr[0] + arr[1] + arr[2] + t.descriptor.descriptor.w;
		}
	}
	return -1;
}
