//@execute 0=11; 1=22; 2=33; 3=44; 4=110
// A three-level descriptor chain, with a field at every level.
class DDD(w: int) describes DD { }
class DD(z: int) descriptor DDD describes D { }
class D(y: int) descriptor DD describes A { }
class A(x: int) descriptor D { }

def ddd = DDD.new(44);
def dd = DD.new(ddd, 33);
def d = D.new(dd, 22);
def a = A.new(d, 11);

def main(x: int) -> int {
	match (x) {
		0 => return a.x;
		1 => return a.descriptor.y;
		2 => return a.descriptor.descriptor.z;
		3 => return a.descriptor.descriptor.descriptor.w;
		4 => return a.x + a.descriptor.y + a.descriptor.descriptor.z + a.descriptor.descriptor.descriptor.w;
	}
	return -1;
}
