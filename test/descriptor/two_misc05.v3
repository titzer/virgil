//@execute 0=true; 1=true; 2=false; 3=true; 4=true
class DDA describes DA {}
class DA descriptor DDA describes A {}
class A descriptor DA {}
class DDB extends DDA describes DB {}
class DB extends DA descriptor DDB describes B {}
class B extends A descriptor DB {}

def dda = DDA.new();
def ddb = DDB.new();
def db = DB.new(ddb);
def da = DA.new(dda);
def b = B.new(db);
def a = A.new(da);

def main(x: int) -> bool {
	match (x) {
		0 => return a.descriptor == da;
		1 => return b.descriptor == db;
		2 => return a.descriptor == b.descriptor;
		3 => return a.descriptor.descriptor == dda;
		4 => return b.descriptor.descriptor == ddb;
	}
	return false;	
}
