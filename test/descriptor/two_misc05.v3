//@execute = true
// An A object constructed with a DB instance (a D subtype) as its descriptor.
// Both A and B objects end up with the same DB and DDB in their chains.
// Tests that A's descriptor slot can hold a D subtype, and the chain is correct.
class DDA describes DA {}
class DA descriptor DDA describes A {}
class A descriptor DA {}
class DDB extends DD describes DB {}
class DB extends D descriptor DDB describes B {}
class B extends A descriptor DB {}

def dda = DDA.new();
def ddb = DDB.new();
def db = DB.new(ddb);
def da = DA.new(dda);
def b = B.new(db);
def a = A.new(da);    // A whose D slot holds a DB (valid: DB extends D)

def main() -> bool {
	// a.descriptor has static type D, runtime type DB
	// b.descriptor has static type DB
	// Both should refer to the same db object
	return a.descriptor == db
		&& b.descriptor == db
		&& a.descriptor == b.descriptor
		&& a.descriptor.descriptor == ddb    // static DD, runtime DDB
		&& b.descriptor.descriptor == ddb;
}
