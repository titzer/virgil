//@execute 0=true; 1=false; 2=false; 3=true
// Delegates to virtual methods on descriptor classes; dispatch is through the
// descriptor hierarchy. Stored in an array of function values and called later.
class DA describes A {
	def isSpecial() -> bool { return false; }
}
class DB extends DA describes B {
	def isSpecial() -> bool { return true; }
}
class A descriptor DA {}
class B extends A descriptor DB {}

var objs: Array<A> = [B.new(DB.new()), A.new(DA.new()), A.new(DA.new()), B.new(DB.new())];
var checks: Array<() -> bool> = [
	objs[0].descriptor.isSpecial,
	objs[1].descriptor.isSpecial,
	objs[2].descriptor.isSpecial,
	objs[3].descriptor.isSpecial
];
def main(i: int) -> bool {
	return checks[i]();
}
