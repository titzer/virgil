//@execute 0=true; 1=true; -1=true
// A non-aliasing allocation between two .descriptor loads must not block CSE,
// since the descriptor field is immutable.
class S {
	var d1: D;
	var d2: D;
	var d3: D;
}
class D(x: int) extends S describes A {
	new() {
		this.d1 = this;
		this.d2 = this;
		this.d3 = this;
	}
}

class A descriptor D {
	def check() -> bool {
		def d1 = this.descriptor;
		def arr = Array<int>.new(1);  // does not alias this.descriptor
		def d2 = this.descriptor;
		def d3 = this.descriptor.d1;
		def d4 = this.descriptor.d2;
		def d5 = this.descriptor.d3;
		return d1 == d2 && d2 == d3 && d3 == d4 && d4 == d5;
	}
}
def main(z: int) -> bool {
	def a = A.new(D.new(z));
	return a.check();
}
