//@execute 0=true; 1=true; 2=true; 3=false
class D<T> describes A<T> { }
class A<T> descriptor D<T> { }

def main(a: int) -> bool {
	match (a) {
		0 => return D<int>.?(A<int>.new(D<int>.new()).descriptor);
		1 => return D<bool>.?(A<bool>.new(D<bool>.new()).descriptor);
		2 => return D<long>.?(A<long>.new(D<long>.new()).descriptor);
	}
	return false;
}
