//@execute 0=0; 6=6; 44=44

def gArray = Array<byte>.new(44);
var gRange: Range<byte>;

def main(a: int) -> int {
	set(a);
	var r = get();
	var val = byte.view(0x66 + a);
	var count = 0;
	for (i < r.length) {
		if (r[i] != val) return -42;
		count++;
	}
	return count;
}

def set(a: int) {
	gRange = gArray[0 ... a];
	var val = byte.view(0x66 + a);
	for (i < gRange.length) gRange[i] = val;
}

def get() -> Range<byte> {
	return gRange;
}
