//@execute 0=11; 66666=11

var g: Ref<OneByte>;

def main(a: int) -> int {
	var p1 = Pointer.NULL + 0x4444_3333_2222 + a;
	set(p1);
	var p2 = get();
	if (p1 != p2) return -42;
	return 11;
}

def set(p: Pointer) {
	g = Ref<OneByte>.of(CiRuntime.forgeRange<byte>(p, 1));
}

def get() -> Pointer {
	return Pointer.atRef(g);
}

layout OneByte {
	+0	val:	u8;
	=1;
}
