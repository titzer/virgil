//@execute 0=11; 66666=11

var g: Range<byte>;

def main(a: int) -> int {
	var p1 = Pointer.NULL + 0x4444_3333_2222 + a;
	set(p1);
	var p2 = get();
	if (p1 != p2) return -42;
	return 11;
}

def set(p: Pointer) {
	g = CiRuntime.forgeRange<byte>(p, 1);
}

def get() -> Pointer {
	return Pointer.atElement(g, 0);
}
