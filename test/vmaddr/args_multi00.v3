//@execute (3,4,5)=12; (0,0,0)=0; (-1,1,100)=100
// Several arguments, each marshalled from its own embedded input table by the
// -test entry stub. Regression test for the table address being materialized
// with only its low 32 bits, which faulted once the image was loaded above 4GB.
def main(a: int, b: int, c: int) -> int {
	return a + b + c;
}
