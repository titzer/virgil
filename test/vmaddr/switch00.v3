//@execute 0=true
// Switch dispatch must be correct wherever the image is loaded. arm64 lowers
// this to a PC-relative jump table whose entries are offsets from the table
// itself, so nothing here depends on the absolute load address.
def sw(a: int) -> int {
	match (a) {
		0 => return 1;
		1 => return 4;
		2 => return 7;
		3 => return 10;
		4 => return 13;
		5 => return 16;
		6 => return 19;
		7 => return 22;
		8 => return 25;
		9 => return 28;
		10 => return 31;
		11 => return 34;
		12 => return 37;
		13 => return 40;
		14 => return 43;
		15 => return 46;
		16 => return 49;
		17 => return 52;
		18 => return 55;
		19 => return 58;
		20 => return 61;
		21 => return 64;
		22 => return 67;
		23 => return 70;
		24 => return 73;
		25 => return 76;
		26 => return 79;
		27 => return 82;
		28 => return 85;
		29 => return 88;
		30 => return 91;
		31 => return 94;
		32 => return 97;
		33 => return 100;
		34 => return 103;
		35 => return 106;
		36 => return 109;
		37 => return 112;
		38 => return 115;
		39 => return 118;
		_ => return -1;
	}
}
def main(x: int) -> bool {
	for (i = -3; i < 45; i++) {
		var expect = if(i >= 0 && i < 40, i * 3 + 1, -1);
		if (sw(i) != expect) return false;
	}
	return true;
}
