//@execute 0=5; 1=9; 2=13
// Partial application ('_' hole) of a user-defined generic function, with
// the type parameter explicitly instantiated at the call site.
def choose<T>(cond: bool, a: T, b: T) -> T {
	return if(cond, a, b);
}
def main(a: int) -> int {
	var pickBig = choose<int>(true, _, 0);
	return pickBig(5 + a * 4);
}
