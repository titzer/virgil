//@execute 0=2; 1=4; 5=12; 10=22; -1=0
// A higher-order function that returns a new closure composing two functions.
def compose<A, B, C>(f: A -> B, g: B -> C) -> A -> C {
	return fun(x: A) -> C => g(f(x));
}
def addOne(x: int) -> int { return x + 1; }
def double(x: int) -> int { return x * 2; }
def main(a: int) -> int {
	var h = compose(addOne, double);
	return h(a);
}
