//@execute 0=0; 1=10; 2=20; 3=30
// Each closure created in a loop iteration captures the value x has at
// closure-creation time; closures created in different iterations must not
// alias a single shared value.
def main(a: int) -> int {
	var fns = Array<void -> int>.new(4);
	for (i < 4) {
		var x = i * 10;
		fns[i] = fun => x;
	}
	return fns[a]();
}
