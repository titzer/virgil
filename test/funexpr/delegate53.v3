//@execute 6=21; 7=43
class A {
	def val() => 11;
}
class B extends A {
	def val() => 21;
}
class C extends A {
	def val() => 31;
}

var b: A = B.new();
var bm: void -> int = b.val;

def main(arg: int) => if (arg == 6, exec(b.val), exec(m42));

def exec(f: void -> int) -> int {
	if (f == bm) return 21;
	if (f != null) return 43;
	return f();
}
def m42() => 42;
