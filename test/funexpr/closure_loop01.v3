//@execute 0=5
// A closure captures a free local variable's value at the point the closure
// is created (by value), not a live reference: mutating the outer variable
// afterward must not change what a previously-created closure returns.
def main(a: int) -> int {
	var x = 5;
	var f: void -> int = fun => x;
	x = 999;
	return f();
}
