//@execute 0=41; 1=!TypeCheckException; 2=42; 3=42; 4=!TypeCheckException; 5=!TypeCheckException; 6=42; 7=41

class A {
}
class B extends A {
    var foo: int = 42;
}
class C extends B {
}

var a: A = A.new();
var b: A = B.new();
var c: A = C.new();

def main(arg: int) -> int {
	if (arg == 1) return B.!(a).foo;
	if (arg == 2) return B.!(b).foo;
	if (arg == 3) return B.!(c).foo;
	if (arg == 4) return C.!(a).foo;
	if (arg == 5) return C.!(b).foo;
	if (arg == 6) return C.!(c).foo;
	return 41;
}
