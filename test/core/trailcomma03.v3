//@execute 0=3; 1=3
// trailing commas in enum members, variant case params and match patterns
enum E { A, B, C, }
type V { case A(x: int, y: int,); case B; }
def main(i: int) -> int {
	if (i == 0) return E.count;
	var v: V = V.A(1, 2);
	match (v) {
		A(x, y,) => return x + y;
		B => return 0;
	}
}
