//@execute 0=42; 1=11; 2=21; 3=31; 4=37; 5=41; 6=42
class W<T> {
	var val: T;
	new(v: T) {
		val = v;
	}
}
var a: W<int> = W<int>.new(11);
var b: W<int> = W<int>.new(21);
var c: W<W<int>> = W<W<int>>.new(W<int>.new(31));
var d: W<W<int>> = W<W<int>>.new(W<int>.new(37));
var e: W<W<void -> int>> = W<W<void -> int>>.new(W<void -> int>.new(m41));
def main(arg: int) -> int {
	if (arg == 1) return a.val;
	if (arg == 2) return b.val;
	if (arg == 3) return c.val.val;
	if (arg == 4) return d.val.val;
	if (arg == 5) return e.val.val();
	return 42;
}
def m41() -> int {
	return 41;
}
