//@execute 0=42; 1=11; 2=21; 3=48; 4=97; 5=42
class S<T> {
	var self: T;
}
class W<T> extends S<W<T>> {
	var val: T;
	new(v: T) {
		self = this;
		val = v;
	}
}
var f: W<int> = W<int>.new(11);
var g: W<int> = W<int>.new(21);
var h: W<byte> = W<byte>.new('0');
var j: W<byte> = W<byte>.new('a');
def main(arg: int) -> int {
	if (arg == 1) return f.self.val;
	if (arg == 2) return g.val;
	if (arg == 3) return h.self.val;
	if (arg == 4) return j.val;
	return 42;
}
