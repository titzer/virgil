//@execute = 0
// The token `-0` is lexed as a *double* literal rather than as unary minus
// applied to the integer 0, and the value it produces is wrong: the bits are
// 0xC06FA000_00000000, i.e. -253.0, instead of -0.0.
//
// Reproduces identically on v3i, `-ra -ma=true`, and the jar backend.
//
// Related symptoms of the same mis-scan:
//   var x: int = -0;              // TypeError: expected int, got double
//   var a: Array<int> = [-0, 1];  // TypeError: expected int, got double
//   var x = -00;                  // ParseError: invalid octal literal
//   var x = -0L;                  // ParseError: ',' or ';' expected
// while all of these behave correctly:
//   var x = - 0;                  // int 0, with a space
//   var x = -0x0;                 // int 0
//   var x = -1;                   // int -1
//   var x = -0.0d;                // double -0.0
def main() -> int {
	var b = -0;
	return int.truncd(b);		// expected 0, actually -253
}
