//@execute 0=true; 1=false; 2=false
class A {
	def m<T>() -> T { var n: T; return n; }
}
class B extends A {
}
def main(arg: int) -> bool {
	var o = A.new();
	if (arg == 0) {
		var a: void -> int = o.m;
		var b: void -> int = o.m;
		return cmp(a, b);
	}
	if (arg == 1) {
		var a: void -> A = o.m;
		var b: void -> B = o.m;
		return cmp(a, b);
	}
	return false;
}
def cmp<X, Y>(a: X, b: Y) -> bool {
	return (Y.?(a) && Y.!(a) == b) || (X.?(b) && X.!(b) == a);
}
