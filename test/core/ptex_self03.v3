//@execute 0=42; 1=11; 2=21; 3=97; 4=42
class S<T> {
}
class M<T> extends S<S<M<T>>> {
	var val: T;
	new(v: T) {
		val = v;
	}
}
var f: M<int> = M<int>.new(11);
var g: M<int> = M<int>.new(21);
var h: M<byte> = M<byte>.new('a');
def main(arg: int) -> int {
	if (arg == 1) return f.val;
	if (arg == 2) return g.val;
	if (arg == 3) return h.val;
	return 42;
}
