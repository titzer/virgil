//@execute 0=42; 1=11; 2=21; 3=48; 4=97; 5=42
class S<T> {
	var self: T;
}
class I extends S<I> {
	var val: int;
	new(v: int) {
		self = this;
		val = v;
	}
}
class C extends S<C> {
	var val: byte;
	new(v: byte) {
		self = this;
		val = v;
	}
}
var f: I = I.new(11);
var g: I = I.new(21);
var h: C = C.new('0');
var j: C = C.new('a');
def main(arg: int) -> int {
	if (arg == 1) return f.self.val;
	if (arg == 2) return g.val;
	if (arg == 3) return h.self.val;
	if (arg == 4) return j.val;
	return 42;
}
