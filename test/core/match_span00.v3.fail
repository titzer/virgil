//@execute 0=2
// Compiler crash: `!TypeCheckException` in SsaCfOptimizer.tryBuildingSwitch()
// at aeneas/src/ssa/SsaOptimizer.v3:1735.
//
//	var diff = u32.!(max - min) + 1;
//
// When a `match` on int has >= 4 arms (the threshold for attempting a jump
// table) whose values span more than int.max, `max - min` overflows int to a
// negative value and the checked `u32.!` cast throws. The guard that was meant
// to reject an oversized table --
//
//	if (diff > int.max) return;  // table would be too large.
//
// -- sits *after* the overflow, so it never gets the chance to fire.
//
// Computing the span in a wider type, e.g. `long.!(max) - long.!(min)`, before
// narrowing would avoid it. Crashes on both v3i and `-ra -ma=true`.
def main(a: int) -> int {
	match (a) {
		-2147483648 => return 1;
		0 => return 2;
		1 => return 3;
		2147483647 => return 4;
		_ => return 0;
	}
}
