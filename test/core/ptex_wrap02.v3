//@execute 0=42; 1=11; 2=21; 3=31; 4=37; 5=42
class W<T> {
	var val: T;
	new(v: T) {
		val = v;
	}
}
var a: W<int> = W<int>.new(11);
var b: W<int> = W<int>.new(21);
var c: W<int> = W<int>.new(31);
var d: W<int> = W<int>.new(37);
def main(arg: int) -> int {
	if (arg == 1) return a.val;
	if (arg == 2) return b.val;
	if (arg == 3) return c.val;
	if (arg == 4) return d.val;
	return 42;
}
