//@execute 0=2; 1=3
// Subtype method reference: A.B.kind gives f: A.B -> int
type A {
    case _;
    def kind() -> int { return 1; }
}
type A.B {
    case P;
    case Q;
    def kind() -> int {
        match (this) {
            P => return 2;
            Q => return 3;
        }
    }
}
def main(arg: int) -> int {
    var b: A.B;
    if (arg == 1) b = A.B.Q;
    var f = A.B.kind;
    return f(b);
}
