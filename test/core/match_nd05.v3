//@execute 0=1; 1=2; 2=2; 3=2; 4=3; 5=4; 6=5
// Multi-level subtypes: A.B.C.D covered by B => in A-match; C => in B-match
type A {
	case X;
	case _;
}
type A.B {
	case Y;
	case Z;
	case _;
}
type A.B.C {
	case D;
	case E;
}
def classifyA(a: A) -> int {
	match (a) {
		X => return 1;
		B => return 2;
		_ => return 99;
	}
}
def classifyB(b: A.B) -> int {
	match (b) {
		Y => return 3;
		Z => return 4;
		C => return 5;
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return classifyA(A.X);
	if (arg == 1) return classifyA(A.B.Y);
	if (arg == 2) return classifyA(A.B.Z);
	if (arg == 3) return classifyA(A.B.C.D);
	if (arg == 4) return classifyB(A.B.Y);
	if (arg == 5) return classifyB(A.B.Z);
	return classifyB(A.B.C.E);
}
