//@execute 0=false; 1=false
// Aggregate equality over a float payload is BITWISE when constant-folded (and
// in the plain interpreter) but IEEE once normalized or compiled. Signed zero
// exposes this in the opposite direction from NaN:
//
//	0f == -0.0f			true  (IEEE, scalar -- correct)
//	(0f,1) == (-0.0f,1)  folded	false (bitwise)
//	(0f,1) == (-0.0f,1)  runtime	false on v3i, TRUE under -ra and on backends
//
// The same split hits variants (see test/variants/eq_nan*.v3.fail):
//	boxed/unboxed variant, -0.0 vs 0.0:  folded false, v3i false, backend TRUE
//	boxed/unboxed variant, NaN:          folded true,  v3i true,  backend FALSE
//
// So it is one defect -- aggregate structural equality is lowered to per-field
// IEEE `==`, while the folder and the interpreter compare bits -- with NaN and
// signed zero showing the two opposite symptoms.
//
// This test pins the bitwise answer, matching the folder, the interpreter, and
// the fact that `.?`-style structural equality elsewhere is reference/bit based.
// Whichever answer is chosen, folded and runtime must agree.
def ZS: Array<float> = [0f, -0.0f];
def main(a: int) -> bool {
	var lo = ZS[a], hi = ZS[1 - a];		// runtime values, not constants
	return (lo, 1) == (hi, 1);
}
