//@execute 0=3; 1=4
class A {
	def x: int;
	new(x) { }
}
class B extends A {
	new(x: int) super(x) { }
}
var a: (int, int -> A) = (1, alloca);
def main(arg: int) -> int {
	a = ('0', allocb);
	return a.1(arg).x;
}
def alloca(x: int) -> A {
	return A.new(x + 1);
}
def allocb(x: int) -> B {
	return B.new(x + 3);
}
