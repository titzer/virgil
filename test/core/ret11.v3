//@execute 0=1; 1=11; 2=111; 3=1111; 4=11111; 5=111111; 6=1111111; 7=11111111; 8=111111111; 9=1111111111; 10=-43
def main(a: int) -> int {
	match (a) {
		0 => return             1;
		1 => return            11;
		2 => return           111;
		3 => return         1_111;
		4 => return        11_111;
		5 => return       111_111;
		6 => return     1_111_111;
		7 => return    11_111_111;
		8 => return   111_111_111;
		9 => return 1_111_111_111;
	}
	return -43;
}