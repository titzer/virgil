//@execute 0=55; 1=65; 10=155
// Tuple parameters and tuple return values are flattened into scalars, so a
// tuple-returning method reverses ten stack slots at once.
def main(a: int) -> int {
	var x = foo((1 + a, 2 + a), (3 + a, 4 + a), (5 + a, 6 + a), (7 + a, 8 + a), (9 + a, 10 + a));
	return x.0.0 + x.0.1 + x.1.0 + x.1.1 + x.2.0 + x.2.1 + x.3.0 + x.3.1 + x.4.0 + x.4.1;
}
def foo(a: (int, int), b: (int, int), c: (int, int), d: (int, int), e: (int, int))
		-> ((int, int), (int, int), (int, int), (int, int), (int, int)) {
	return (e, d, c, b, a);
}
