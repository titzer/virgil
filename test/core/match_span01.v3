//@execute -2147483648=1; -2147483647=2; -2147483646=3; 0=4; 1=5; 2147483645=6; 2147483646=7; 2147483647=8; -99=99
def main(a: int) -> int {
	match (a) {
		-2147483648	=> return 1;
		-2147483647	=> return 2;
		-2147483646	=> return 3;
		0		=> return 4;
		1		=> return 5;
		2147483645	=> return 6;
		2147483646	=> return 7;
		2147483647	=> return 8;
		_ => return 99;
	}
}
