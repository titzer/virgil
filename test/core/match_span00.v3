//@execute 0=2
// Regression test: `match` on int with >= 4 arms (the threshold for attempting a
// jump table) whose values span more than int.max used to crash the compiler
// with `!TypeCheckException` in SsaCfOptimizer.tryBuildingSwitch():
//
//	var diff = u32.!(max - min) + 1;
//
// `max - min` overflowed int to a negative value, and the checked `u32.!` threw
// before the guard meant to reject an oversized table could fire. The span is
// now computed in long. Crashed on both v3i and `-ra -ma=true`.
def main(a: int) -> int {
	match (a) {
		-2147483648 => return 1;
		0 => return 2;
		1 => return 3;
		2147483647 => return 4;
		_ => return 0;
	}
}
