//@execute 0=11; 1=12; 3=42
class A {
	def m<X, Y>(a: X, b: Y) -> X { return a; }
}
class B extends A {
	def m<U, V>(u: U, v: V) -> U { return u; }
}
var a: (int, bool) -> int = A.new().m;
var b: (int, int) -> int = B.new().m;
def main(arg: int) -> int {
	if (arg == 0) return a(11, false);
	if (arg == 1) return b(12, -1);
	return 42;
}
