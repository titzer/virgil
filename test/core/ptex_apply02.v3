//@execute 0=10
class L<T> {
	def head: T;
	def tail: L<T>;
	new(head, tail) { }
}
var listA = L<int>.new(10, null);
var listB = L<bool>.new(false, null);
def main(arg: int) -> int {
	apply(listA, print_int);
	apply(listB, print_bool);
	return 10;
}
def print_int(val: int) {
	// do nothing.
}
def print_bool(val: bool) {
	// do nothing.
}
def apply<T>(var list: L<T>, func: T -> void) {
	while (list != null) {
		func(list.head);
		list = list.tail;
	}
}
