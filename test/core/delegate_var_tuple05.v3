//@execute 0=0; 1=1; 2=2; 3=3; 4=!NullCheckException
class A { }
class B extends A { }

def main(a: int) -> int {
	var x: (void -> A, void -> A);
	match(a) {
		0 => x = (A.new, A.new);
		1 => x = (A.new, B.new);
		2 => x = (B.new, A.new);
		3 => x = (B.new, B.new);
	}
	var a = if(B.?(x.0()), 2);
	var b = if(B.?(x.1()), 1);
	return a | b;
}
