//@execute 0=42; 1=99; 2=7
// The same generic class is instantiated with a primitive type, a class
// type, and a variant/ADT type in one test, exercising three different
// representations behind a single type parameter.
class Box<T>(v: T) {
	def get() -> T { return v; }
}
class Cell {
	var n: int;
	new(n: int) { this.n = n; }
}
type Opt {
	case Some(v: int);
	case None;
}
def boxInt = Box<int>.new(42);
def boxCell = Box<Cell>.new(Cell.new(99));
def boxOpt = Box<Opt>.new(Opt.Some(7));
def main(a: int) -> int {
	match (a) {
		0 => return boxInt.get();
		1 => return boxCell.get().n;
		_ => match (boxOpt.get()) {
			Some(v) => return v;
			None => return -1;
		}
	}
}
