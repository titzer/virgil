//@execute 0=42; 1=11; 2=21; 3=31; 4=42
class S<T> {
}
class M extends S<S<M>> {
	var val: int;
	new(v: int) {
		val = v;
	}
}
var f: M = M.new(11);
var g: M = M.new(21);
var h: M = M.new(31);
def main(arg: int) -> int {
	if (arg == 1) return f.val;
	if (arg == 2) return g.val;
	if (arg == 3) return h.val;
	return 42;
}
