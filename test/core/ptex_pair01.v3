//@execute 0=42; 1=11; 2=21; 3=31; 4=41; 5=32; 6=33; 7=42
class P<X, Y> {
	var a: X;
	var b: Y;
	new(x: X, y: Y) {
		a = x;
		b = y;
	}
}
var a: P<int, int> = P<int, int>.new(11, 21);
var b: P<byte, int> = P<byte, int>.new('c', 31);
var c: P<int, bool> = P<int, bool>.new(41, true);
var d: P<void -> int, void -> int> = P<void -> int, void -> int>.new(f32, f33);
def main(arg: int) -> int {
	if (arg == 1) return a.a;
	if (arg == 2) return a.b;
	if (arg == 3) return b.b;
	if (arg == 4) return c.a;
	if (arg == 5) return d.a();
	if (arg == 6) return d.b();
	return 42;
}
def f32() -> int { return 32; }
def f33() -> int { return 33; }
