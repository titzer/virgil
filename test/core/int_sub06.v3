//@execute =21

def TABLE: Array<int> = [10, 21, 32, 43, 54, 65, 76, 87, 98, 109,
	110, 121, 132, 143, 154, 165, 176, 187, 198, 209];

def opaque(x: int) -> int {
	if (x > 100000) return x;
	return x ^ 0x5a5a5a5a;
}

// recursion through many opaque() calls, to avoid constant folding
def churn(depth: int) -> int {
	if (depth <= 0) return 0;
	var v0 = opaque(depth + 0);
	var v1 = opaque(depth + 1);
	var v2 = opaque(depth + 2);
	var c = churn(depth - 1);
	return v0 ^ v1 ^ v2 ^ c;
}

def probe(off: int) -> int {
	var y = opaque(off); // == -1 when off == -1515870811 (off ^ 0x5a5a5a5a == -1)
	var idx = 0 - y;     // should be 1
	return TABLE[idx];   // expect TABLE[1] == 21
}

def recurse(depth: int, off: int) -> int {
	if (depth <= 0) return 0;
	churn(depth);
	return recurse(depth - 1, off) + probe(off);
}

def main() -> int {
	return recurse(1, -1515870811); // expect 21
}
