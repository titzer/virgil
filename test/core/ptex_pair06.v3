//@execute 0=42; 1=21; 2=31; 3=41; 4=42
class P<X, Y> {
	var a: X;
	var b: Y;
	new(x: X, y: Y) {
		a = x;
		b = y;
	}
}
class I {
	var val: int;
	new(v: int) {
		val = v;
	}
}
var a: P<int, I> = P<int, I>.new(21, I.new(31));
var b: I = I.new(41);
def main(arg: int) -> int {
	if (arg == 1) return a.a;
	if (arg == 2) return a.b.val;
	if (arg == 3) return b.val;
	return 42;
}
