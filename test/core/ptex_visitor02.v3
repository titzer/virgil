//@execute 0=42; 1=11; 2=21; 3=12; 4=22; 5=42
class V<E, R> {
	def visitA(n: A, e: E) -> R;
	def visitB(n: B, e: E) -> R;
}
class I {
	def accept<E, R>(v: V<E, R>, e: E) -> R;
}
class A extends I {
	def accept<E, R>(v: V<E, R>, e: E) -> R { return v.visitA(this, e); }
}
class B extends I {
	def accept<E, R>(v: V<E, R>, e: E) -> R { return v.visitB(this, e); }
}
class Ctx {
	var base: int;
	new(b: int) {
		base = b;
	}
}
class P extends V<Ctx, int> {
	def visitA(n: A, e: Ctx) -> int {
		return 1 + e.base;
	}
	def visitB(n: B, e: Ctx) -> int {
		return 2 + e.base;
	}
}
var a: I = A.new();
var b: I = B.new();
var v: P = P.new();
var e1: Ctx = Ctx.new(10);
var e2: Ctx = Ctx.new(20);
def main(arg: int) -> int {
	if (arg == 1) return a.accept(v, e1);
	if (arg == 2) return a.accept(v, e2);
	if (arg == 3) return b.accept(v, e1);
	if (arg == 4) return b.accept(v, e2);
	return 42;
}
