//@execute 0=42; 1=11; 2=21; 3=31; 4=32; 5=97; 6=42
class P<X, Y> {
	var a: X;
	var b: Y;
	new(x: X, y: Y) {
		a = x;
		b = y;
	}
}
class I {
	var val: int;
	new(v: int) {
		val = v;
	}
}
var a: P<int, P<bool, bool>> = P<int, P<bool, bool>>.new(11, P<bool, bool>.new(true, false));
var b: P<int, I> = P<int, I>.new(21, I.new(31));
var c: P<void -> int, byte> = P<void -> int, byte>.new(f32, 'a');
def main(arg: int) -> int {
	if (arg == 1) return a.a;
	if (arg == 2) return b.a;
	if (arg == 3) return b.b.val;
	if (arg == 4) return c.a();
	if (arg == 5) return c.b;
	return 42;
}
def f32() -> int { return 32; }
