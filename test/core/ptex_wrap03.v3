//@execute 0=42; 1=11; 2=21; 3=48; 4=97; 5=42
class W<T> {
	var val: T;
	new(v: T) {
		val = v;
	}
}
var a: W<int> = W<int>.new(11);
var b: W<int> = W<int>.new(21);
var c: W<byte> = W<byte>.new('0');
var d: W<byte> = W<byte>.new('a');
def main(arg: int) -> int {
	if (arg == 1) return a.val;
	if (arg == 2) return b.val;
	if (arg == 3) return c.val;
	if (arg == 4) return d.val;
	return 42;
}
