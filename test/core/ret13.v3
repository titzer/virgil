//@execute 0=2; 1=22; 2=222; 3=2222; 4=22222; 5=222222; 6=2222222; 7=22222222; 8=222222222; 9=2022222222; 10=-43
def main(a: int) -> int {
	match (a) {
		0 => return             2;
		1 => return            22;
		2 => return           222;
		3 => return         2_222;
		4 => return        22_222;
		5 => return       222_222;
		6 => return     2_222_222;
		7 => return    22_222_222;
		8 => return   222_222_222;
		9 => return 2_022_222_222;
	}
	return -43;
}