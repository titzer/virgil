//@execute 6=21; 7=43
class A {
	def val() -> int { return 11; }
}
class B extends A {
	def val() -> int { return 21; }
}
class C extends A {
	def val() -> int { return 31; }
}

var b: A = B.new();
var bm: void -> int = b.val;

def main(arg: int) -> int {
	if (arg == 6) return exec(b.val);
	return exec(m42);
}
def exec(f: void -> int) -> int {
	if (f == bm) return 21;
	if (f != null) return 43;
	return f();
}
def m42() -> int { return 42; }
