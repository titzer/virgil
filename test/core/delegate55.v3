//@execute =21
class A {
	def val() -> int { return 11; }
}
class B extends A {
	def val() -> int { return 21; }
}

var a: A = A.new();
var b: A = B.new();
var am: void -> int = a.val;
var bm: void -> int = b.val;

def main() -> int {
	return exec(b.val);
}
def exec(f: void -> int) -> int {
	if (f == am) return 11;
	if (f == bm) return 21;
	if (f != null) return 43;
	return f();
}
