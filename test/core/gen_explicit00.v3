//@execute 0=7; 1=7; 2=9; 3=9
// The same generic method is called once with an explicit type argument and
// once with the type argument inferred from its value argument; both paths
// must produce identical results.
def first<T>(a: T, b: T) -> T {
	return a;
}
def main(a: int) -> int {
	match (a) {
		0 => return first<int>(7, 8);
		1 => return first(7, 8);
		2 => return first<int>(9, 10);
		_ => return first(9, 10);
	}
}
