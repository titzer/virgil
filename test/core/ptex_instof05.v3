//@execute 0=false; 1=false; 2=false; 3=false; 4=true; 5=false; 6=false
class A<X> { }
class B<X> extends A<int> { }
var a: A<int> = A<int>.new();
var b: A<int> = B<int>.new();
var c: A<int> = B<byte>.new();
var d: A<int> = B<bool>.new();
def m(x: A<int>) -> bool {
	return B<byte>.?(x);
}
def main(arg: int) -> bool {
	if (arg == 1) return m(null);
	if (arg == 2) return m(a);
	if (arg == 3) return m(b);
	if (arg == 4) return m(c);
	if (arg == 5) return m(d);
	return false;
}
