//@execute 0=1; 1=2; 2=3
// Type method reference: var f = A.kind gives f: A -> int
type A {
    case X;
    case Y;
    case Z;
    def kind() -> int {
        match (this) {
            X => return 1;
            Y => return 2;
            Z => return 3;
        }
    }
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = A.Y;
    if (arg == 2) a = A.Z;
    var f = A.kind;
    return f(a);
}
