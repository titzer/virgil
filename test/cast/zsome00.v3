//@execute 0=0; 1=1; 255=255; -1=!TypeCheckException; -2=!TypeCheckException; -100=!TypeCheckException
type Holder<A> {
	case Some(a: A);
}
def check<B>(a: int) -> B {
	var t: Holder<B> = Holder.Some(B.!(a));
	match (t) {
		Some(a) => return a;
	}
}
def main(a: int) -> byte {
	return check<byte>(a);
}
