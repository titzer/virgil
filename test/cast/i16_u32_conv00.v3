//@execute 0=0; 32767=32767; -1=!TypeCheckException; -32768=!TypeCheckException
// i16 -> u32: checked cast throws for any negative i16, since u32 cannot
// represent negative values; non-negative values pass through unchanged.
def main(a: int) -> int {
	var x = i16.!(a);
	return int.view(u32.!(x));
}
