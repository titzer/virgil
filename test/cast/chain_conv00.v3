//@execute 0=true; 200=true; 255=true; 256=true; 511=true; -1=true
// A multi-step conversion chain (int -> byte -> u16 -> long), each step
// truncating/widening via .view or a checked cast, checked against the
// expected value computed by masking directly.
def main(a: int) -> bool {
	var step1 = byte.view(a);      // truncate to the low 8 bits
	var step2 = u16.!(step1);      // zero-extend to 16 bits (always fits)
	var step3 = long.!(step2);     // widen to 64 bits (always fits)
	var expected = long.!(a & 0xFF);
	return step3 == expected;
}
