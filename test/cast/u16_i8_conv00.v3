//@execute 0=0; 127=127; 128=!TypeCheckException; 255=!TypeCheckException; 256=!TypeCheckException; 65535=!TypeCheckException
// u16 -> i8: checked cast throws unless the value fits in i8's range (0-127
// here, since u16 is unsigned and i8's positive range tops out at 127).
def main(a: int) -> int {
	var x = u16.!(a);
	return i8.!(x);
}
