//@execute 0=0; 32767=32767; 32768=!TypeCheckException; 65535=!TypeCheckException; -1=!TypeCheckException
// u32 -> i16: checked cast throws unless the value fits in i16's range.
// (-1 is passed as the int arg bit pattern for u32.max via u32.view.)
def main(a: int) -> int {
	var x = u32.view(a);
	return i16.!(x);
}
