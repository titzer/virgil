//@execute 0=0; 1=667; 2=1334; 3=2001; -1=-667
// Regression (float register allocation): more simultaneously live doubles than
// there are floating point registers, with a call in the middle that clobbers
// all of them. Values must be spilled and reloaded, not silently corrupted.
def sink(x: double) -> double { return x * 1.0d; }
def main(k: int) -> int {
	var f = double.!(k);
	var v00 = f * 1d,  v01 = f * 2d,  v02 = f * 3d,  v03 = f * 4d;
	var v04 = f * 5d,  v05 = f * 6d,  v06 = f * 7d,  v07 = f * 8d;
	var v08 = f * 9d,  v09 = f * 10d, v10 = f * 11d, v11 = f * 12d;
	var v12 = f * 13d, v13 = f * 14d, v14 = f * 15d, v15 = f * 16d;
	var v16 = f * 17d, v17 = f * 18d, v18 = f * 19d, v19 = f * 20d;
	var v20 = f * 21d, v21 = f * 22d, v22 = f * 23d, v23 = f * 24d;
	var v24 = f * 25d, v25 = f * 26d, v26 = f * 27d, v27 = f * 28d;
	var v28 = f * 29d, v29 = f * 30d, v30 = f * 31d, v31 = f * 32d;
	var v32 = f * 33d, v33 = f * 34d, v34 = f * 35d, v35 = f * 36d;
	var acc = sink(f * 0.5d) * 2d; // clobbers every caller-saved float register
	acc = acc + v00 + v01 + v02 + v03 + v04 + v05 + v06 + v07 + v08;
	acc = acc + v09 + v10 + v11 + v12 + v13 + v14 + v15 + v16 + v17;
	acc = acc + v18 + v19 + v20 + v21 + v22 + v23 + v24 + v25 + v26;
	acc = acc + v27 + v28 + v29 + v30 + v31 + v32 + v33 + v34 + v35;
	return int.!(acc);
}
