//@execute 0=1800
def SEED: Array<float> = [0.5f, -1.25f, 2f, -0.75f];
def lvl4(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double {
	return a * 1f + b * 2f + c * 3f + d * 4f + e * 5f + f * 6f + g * 7f + h * 8f;
}
def main(n: int) -> int {
	var h = 0d;
	for (i < 4) {
		h = h + lvl4(SEED[(i + 0) % 4], SEED[(i + 1) % 4], SEED[(i + 2) % 4], SEED[(i + 3) % 4],
			     SEED[(i + 4) % 4], SEED[(i + 5) % 4], SEED[(i + 6) % 4], SEED[(i + 7) % 4]);
	}
	if (lvl4(1f, 0f, 0f, 0f, 0f, 0f, 0f, 0f) != 1d) h = -1d;
	return int.truncd(h * 100d);
}
