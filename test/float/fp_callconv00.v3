//@execute 0=5; 1=7; 2=42; 3=3; 4=35; 5=6
// Regression test for float/double values crossing Virgil call boundaries.
// A function returning a float/double must place its result where the caller
// reads it; a mixed int/float parameter list must not let a float argument
// alias the return value. (arm64 previously returned float args on the stack
// in a slot that did not coincide with the caller's return slot.)
def ret_d_with_fparam(x: double, y: float) -> double { return x; }
def ret_f_with_iparam(a: int, y: float) -> float { return y; }
def ret_d_from_bits(x: long, y: float) -> double { return double.view(x); }
def sum_mixed(a: int, x: double, b: int) -> double { return x + double.!(a) + double.!(b); }
def main(sel: int) -> int {
	match (sel) {
		0 => return int.!(ret_d_with_fparam(5.0d, 9.0f));            // x, not y
		1 => return int.!(ret_f_with_iparam(3, 7.0f));              // y survives
		2 => return int.!(ret_d_from_bits(long.view(42.0d), 1.0f)); // bits -> double
		3 => return int.!(ret_d_with_fparam(3.0d, 8.0f));
		4 => return int.!(sum_mixed(10, 5.0d, 20));                 // 35
		_ => return int.!(sum_mixed(1, 2.0d, 3));                   // 6
	}
}
