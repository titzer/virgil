//@execute = 4
var x1: Folder<float> = Folder.new(4f);

def defeat_early_constant_prop() {
	x1 = Folder.new(2.1f);
}
class Folder<T>(val: T) {
	def get() -> int {
		match (val) {
			x: int => return x;
			x: float => return -12;
			x: double => return -13;
		}
		return -49;
	}
}

def main() -> int {
	return x1.get();
}