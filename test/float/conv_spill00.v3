//@execute 0=715792389
//@heap-size=100000
// The long<->float conversion macros on 32-bit x86 move {esp} and then read
// their operands, which are addressed relative to {esp} when they live in spill
// slots. Four parallel arrays plus four live accumulators is enough pressure to
// put them there, which turned `double.roundi` and `long.truncd` into reads of
// the wrong slot.
def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixd(h: int, d: double) -> int {
	return mixl(h, long.view(d));
}
def mixf(h: int, f: float) -> int {
	return mix(h, int.view(f));
}
def main(a: int) -> int {
	var src = Array<long>.new(64);
	var asD = Array<double>.new(64);
	var asF = Array<float>.new(64);
	var back = Array<long>.new(64);
	for (i < src.length) {
		src[i] = 9007199254740980L + i;		// straddles the 2^53 boundary
		asD[i] = double.roundi(src[i]);
		asF[i] = float.roundd(asD[i]);
		back[i] = long.truncd(asD[i]);
	}
	var k = 0;
	for (i < src.length) {
		k = mixl(k, src[i]);
		k = mixd(k, asD[i]);
		k = mixf(k, asF[i]);
		k = mixl(k, back[i] - src[i]);
	}
	return k;
}
