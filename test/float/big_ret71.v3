//@execute 0=78; 1=90; 10=198
// Every scalar kind at once: each has its own register file and its own
// overflow onto the caller's stack.
def main(a: int) -> int {
	var f = float.!(a), d = double.!(a), l = long.!(a);
	var x = foo(1 + a, 2L + l, 3f + f, 4d + d, 5 + a, 6L + l, 7f + f, 8d + d,
		    9 + a, 10L + l, 11f + f, 12d + d);
	return x.0 + int.!(x.1) + int.!(x.2) + int.!(x.3) + x.4 + int.!(x.5) + int.!(x.6) + int.!(x.7)
		+ x.8 + int.!(x.9) + int.!(x.10) + int.!(x.11);
}
def foo(a: int, b: long, c: float, d: double, e: int, f: long, g: float, h: double,
	i: int, j: long, k: float, l: double)
		-> (int, long, float, double, int, long, float, double, int, long, float, double) {
	return (i, j, k, l, e, f, g, h, a, b, c, d);
}
