//@execute 0=3; 1=7; 7=31; 100=403; -3=-9
// Regression (float calling convention): a function returning a tuple that mixes
// int, double, and float. Each element must land in its own return location.
def t(x: int) -> (int, double, float) { return (x*2, double.!(x+5), float.!(x-2)); }
def main(x: int) -> int {
	var r = t(x);
	return r.0 + int.!(r.1) + int.!(r.2);
}
