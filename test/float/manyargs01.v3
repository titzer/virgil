//@execute 0=100; 1=201; 2=302; 3=405; 4=505; 5=605; 6=707; 7=806
def sel_a(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return a; }
def sel_b(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return b; }
def sel_c(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return c; }
def sel_d(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return e; }
def sel_e(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return e; }
def sel_f(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return f; }
def sel_g(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return g; }
def sel_h(a: float, b: float, c: float, d: float, e: float, f: float, g: float, h: float) -> double { return h; }

def funs = [sel_a, sel_b, sel_c, sel_d, sel_e, sel_f, sel_g, sel_g];

def main(x: int) -> int {
	var n = float.!(x);
	var a = 1.01f + n;
	var b = 1.02f + n;
	var c = 1.03f + n;
	var d = 1.04f + n;
	var e = 1.05f + n;
	var f = 1.06f + n;
	var g = 1.07f + n;
	var h = 1.08f + n;
	var r = funs[x](a, b, c, d, e, f, g, h);
	return int.truncd(r * 100d);
}
