//@execute 0=136; 1=152; 10=296
// Integers and floats are passed in different register files but overflow into
// the same caller stack area, so both kinds of parameter slot can be reused as
// return slots.
def main(a: int) -> int {
	var f = float.!(a);
	var x = foo(1 + a, 2f + f, 3 + a, 4f + f, 5 + a, 6f + f, 7 + a, 8f + f, 9 + a, 10f + f,
		    11 + a, 12f + f, 13 + a, 14f + f, 15 + a, 16f + f);
	return x.0 + int.!(x.1) + x.2 + int.!(x.3) + x.4 + int.!(x.5) + x.6 + int.!(x.7)
		+ x.8 + int.!(x.9) + x.10 + int.!(x.11) + x.12 + int.!(x.13) + x.14 + int.!(x.15);
}
def foo(a: int, b: float, c: int, d: float, e: int, f: float, g: int, h: float,
	i: int, j: float, k: int, l: float, m: int, n: float, o: int, p: float)
		-> (int, float, int, float, int, float, int, float,
		    int, float, int, float, int, float, int, float) {
	return (o, p, m, n, k, l, i, j, g, h, e, f, c, d, a, b);
}
