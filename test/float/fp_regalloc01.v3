//@execute 0=133; 1=145; 2=157; -1=121
// Regression (float calling convention): more float arguments than there are
// floating point argument registers, so the extras are passed in stack slots.
def twelve(a: double, b: double, c: double, d: double, e: double, f: double,
	   g: double, h: double, i: double, j: double, k: double, l: double) -> double {
	return a + b + c + d + e + f + g + h + i + j + k + l;
}
def mixed(a: int, b: double, c: int, d: float, e: int, f: double,
	  g: float, h: double, i: float, j: double) -> double {
	return double.!(a + c + e) + b + double.!(d) + f + double.!(g) + h + double.!(i) + j;
}
def main(k: int) -> int {
	var n = double.!(k);
	var x = twelve(1d + n, 2d + n, 3d + n, 4d + n, 5d + n, 6d + n,
		       7d + n, 8d + n, 9d + n, 10d + n, 11d + n, 12d + n);
	var y = mixed(1, 2d, 3, 4f, 5, 6d, 7f, 8d, 9f, 10d);
	return int.!(x) + int.!(y);
}
