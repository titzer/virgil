//@execute 0=7; 1=-7; 2=7; 3=-7; 8=7
// Regression (float register allocation): a recursive call that exchanges its two
// double arguments, which requires resolving a cycle in the parallel move with the
// floating point scratch register.
def swap(a: double, b: double, n: int) -> double {
	if (n == 0) return a - b;
	return swap(b, a, n - 1);
}
def main(n: int) -> int {
	return int.!(swap(10.5d, 3.5d, n));
}
