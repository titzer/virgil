//@execute 0=78; 1=90; 10=198
// Nested tuples of mixed kinds, returned in a rotated order.
def main(a: int) -> int {
	var f = float.!(a);
	var x = foo((1 + a, (2f + f, 3 + a)), (4 + a, (5f + f, 6 + a)), (7 + a, (8f + f, 9 + a)), (10 + a, (11f + f, 12 + a)));
	return x.0.0 + int.!(x.0.1.0) + x.0.1.1 + x.1.0 + int.!(x.1.1.0) + x.1.1.1
		+ x.2.0 + int.!(x.2.1.0) + x.2.1.1 + x.3.0 + int.!(x.3.1.0) + x.3.1.1;
}
def foo(a: (int, (float, int)), b: (int, (float, int)), c: (int, (float, int)), d: (int, (float, int)))
		-> ((int, (float, int)), (int, (float, int)), (int, (float, int)), (int, (float, int))) {
	return (d, a, b, c);
}
