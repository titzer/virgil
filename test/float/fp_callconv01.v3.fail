//@execute 0=330; 1=385; 7=715; 100=5830; -3=165
// Regression (float calling convention): a function with ten double parameters.
// The double result must be returned where the caller reads it even with many
// float/double arguments in play.
//
// Disabled (.v3.fail): passes at the default optimization level, but the global
// register allocator cannot allocate this function --
//   InternalError: near block #N in fp_callconv01.f: nothing available to spill
// -- so it fails under -O2, or under -global-regalloc at any level. That is a
// pre-existing x86-64 register allocator limitation, not specific to this test:
// it reproduces on master, and arm64-linux compiles and runs this correctly at
// -O2. Re-enable once the allocator handles this many live float values.
def f(a:double,b:double,c:double,d:double,e:double,f:double,g:double,h:double,i:double,j:double) -> double {
	return a*1.0 + b*2.0 + c*3.0 + d*4.0 + e*5.0 + f*6.0 + g*7.0 + h*8.0 + i*9.0 + j*10.0;
}
def main(x: int) -> int {
	var d = double.!(x);
	return int.!(f(d,d+1.0,d+2.0,d+3.0,d+4.0,d+5.0,d+6.0,d+7.0,d+8.0,d+9.0));
}
