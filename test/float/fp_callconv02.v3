//@execute 0=3; 1=10; 7=52; 100=703; -3=-18
// Regression (float calling convention): float parameters interleaved with int
// parameters, returning a float. A float argument must not alias the float return.
def mix(p:int, a:float, q:int, b:float, r:int, c:float) -> float {
	return a*2f + b + c + float.!(p + q + r);
}
def main(x: int) -> int {
	var v = float.!(x);
	return int.!(mix(x, v, x+1, v, x+2, v));
}
