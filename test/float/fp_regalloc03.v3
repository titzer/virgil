//@execute 0=0; 1=226; 2=452; 4=904
// Regression (float register allocation): high 32-bit float pressure, plus float
// fields loaded from and stored to the heap.
class Cell(var f: float, var d: double) { }
def main(k: int) -> int {
	var x = float.!(k);
	var a0 = x * 1f, a1 = x * 2f, a2 = x * 3f, a3 = x * 4f, a4 = x * 5f;
	var a5 = x * 6f, a6 = x * 7f, a7 = x * 8f, a8 = x * 9f, a9 = x * 10f;
	var b0 = x * 11f, b1 = x * 12f, b2 = x * 13f, b3 = x * 14f, b4 = x * 15f;
	var b5 = x * 16f, b6 = x * 17f, b7 = x * 18f, b8 = x * 19f, b9 = x * 20f;
	var cells = Array<Cell>.new(4);
	for (i < cells.length) cells[i] = Cell.new(x * float.!(i), double.!(x) * double.!(i + 1));
	var sum = 0f;
	for (i < cells.length) {
		cells[i].f = cells[i].f + float.!(cells[i].d);
		sum = sum + cells[i].f;
	}
	sum = sum + a0 + a1 + a2 + a3 + a4 + a5 + a6 + a7 + a8 + a9;
	sum = sum + b0 + b1 + b2 + b3 + b4 + b5 + b6 + b7 + b8 + b9;
	return int.!(sum);
}
