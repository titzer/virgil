//@execute 0=3; 1=10; 7=52; 100=703; -3=-18
// Regression (float calling convention): a double returned from one call feeds a
// second call whose other argument is a float. Return slots must not collide.
def g(a: double, k: int) -> double { return a * double.!(k); }
def h(a: double, b: float) -> double { return a + double.!(b); }
def main(x: int) -> int {
	var d = double.!(x);
	return int.!(h(g(d + 1.0, 3), float.!(x*4)));
}
