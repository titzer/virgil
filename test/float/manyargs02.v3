//@execute 0=101; 1=202; 2=303; 3=405; 4=505; 5=606; 6=707; 7=807
def sel_a(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return a; }
def sel_b(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return b; }
def sel_c(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return c; }
def sel_d(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return e; }
def sel_e(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return e; }
def sel_f(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return f; }
def sel_g(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return g; }
def sel_h(a: double, b: double, c: double, d: double, e: double, f: double, g: double, h: double) -> double { return h; }

def funs = [sel_a, sel_b, sel_c, sel_d, sel_e, sel_f, sel_g, sel_g];

def main(x: int) -> int {
	var n = double.!(x);
	var a = 1.01d + n;
	var b = 1.02d + n;
	var c = 1.03d + n;
	var d = 1.04d + n;
	var e = 1.05d + n;
	var f = 1.06d + n;
	var g = 1.07d + n;
	var h = 1.08d + n;
	var r = funs[x](a, b, c, d, e, f, g, h);
	return int.truncd(r * 100d);
}
