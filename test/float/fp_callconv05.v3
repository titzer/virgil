//@execute 0=true; 1=true; 2=true; 3=true; 100=true; -7=true
// Regression (float calling convention): arbitrary (non-integral) double and float
// bit patterns must survive being passed to and returned from a call where the
// other parameter is of the opposite float width.
def idD(a: double, b: float) -> double { return a; }
def idF(a: float, b: double) -> float { return a; }
def main(x: int) -> bool {
	var d = 1.5 * double.!(x) + 0.125;
	var f = 2.25f * float.!(x) + 0.5f;
	return idD(d, f) == d && idF(f, d) == f;
}
