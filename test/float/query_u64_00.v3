//@execute 0=1310023012
// `double.?(u64)` has no unsigned int-to-float instruction to lower to on x86-64,
// so it splits the block into an if-cascade. The cascade resumed at the *end* of
// the merge block, which put its own tail (the truncate-back and compare that
// produce the answer) after the instructions that had moved over the split and
// use it -- an SSA dominance violation that failed the whole compilation with
// "no replacement for @N". The rest of the block is what has to move over, so
// the calls below are load-bearing.
def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def U64S: Array<u64> = [
	0, 1, 65535, 16777217, 4294967296uL, 9007199254740993uL,
	9223372036854775808uL, 18446744073709551615uL
];
def main(a: int) -> int {
	var g = 0;
	for (i < U64S.length) {
		var v = U64S[i];
		g = mixb(g, double.?(v));
		g = mixl(g, long.view(v));
	}
	return g;
}
