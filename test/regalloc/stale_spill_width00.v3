//@execute =540

// a spilled 32-bit value can be read back at 64-bit width in pointer arithmetic, picking up 
// stale garbage in its high bits from a deeper call ("churn") that reused the same stack slot.
def churn(depth: int) -> long {
	if (depth <= 0) return 0;
	var v0: long = 0x1122334455667788L;
	var v1: long = 0x2233445566778811L;
	var v2: long = 0x3344556677881122L;
	var v3: long = 0x4455667788112233L;
	var v4: long = 0x5566778811223344L;
	var v5: long = 0x6677881122334455L;
	var v6: long = 0x7788112233445566L;
	var v7: long = 0x8811223344556677L;
	var v8: long = 0x99aabbccddeeff11L;
	var v9: long = 0xaabbccddeeff1122L;
	var v10: long = 0xbbccddeeff112233L;
	var v11: long = 0xccddeeff11223344L;
	var v12: long = 0xddeeff1122334455L;
	var v13: long = 0xeeff112233445566L;
	var v14: long = 0xff11223344556677L;
	var v15: long = 0x1122334455667788L;
	var v16: long = 0x2233445566778899L;
	var v17: long = 0x33445566778899aaL;
	var v18: long = 0x445566778899aabbL;
	var v19: long = 0x5566778899aabbccL;
	var c = churn(depth - 1);
	return v0 ^ v1 ^ v2 ^ v3 ^ v4 ^ v5 ^ v6 ^ v7 ^ v8 ^ v9 ^ v10 ^ v11 ^ v12 ^ v13 ^ v14 ^ v15 ^ v16 ^ v17 ^ v18 ^ v19 ^ c;
}

def probe(off: int) -> int {
	var buf: Array<byte> = [10, 11, 12, 13, 14, 15, 16, 17];
	var r = buf[off ... off + 4]; // Range<byte>: array_ref + int offset arithmetic
	var sum = 0;
	for (b in r) sum = sum + b;
	return sum;
}

// force churn's frame and probe's frame to reuse the same stack address
def recurse(depth: int, off: int) -> int {
	if (depth <= 0) return 0;
	churn(depth);
	return recurse(depth - 1, off) + probe(off);
}

def main() -> int {
	return recurse(10, 2);
}
