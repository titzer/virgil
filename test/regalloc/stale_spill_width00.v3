//@execute 0=10

def churn(p0: int, p1: int, p2: int, p3: int, p4: int, p5: int, garbage: long) -> long {
	return garbage;
}

def probe(p0: int, p1: int, p2: int, p3: int, p4: int, p5: int, off: int) -> int {
	var buf: Array<byte> = [10, 11];
	var r = buf[off ... off + 1]; // Range<byte>: array_ref + int offset arithmetic
	return r[0];
}

def main(a: int) -> int {
	churn(0, 0, 0, 0, 0, 0, 0x1122334455667788L);
	return probe(0, 0, 0, 0, 0, 0, 0);
}
