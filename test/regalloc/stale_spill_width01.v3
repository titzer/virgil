//@execute =9200

// use 20 competing range slices force a spill to fail GlobalRegAlloc

def opaque(x: int) -> int {
	if (x > 100000) return x; // never taken; defeats constant folding
	return x ^ 0x5a5a5a5a;
}
def opaqueL(x: int) -> long {
	return long.view(opaque(x)) << 32 | long.view(opaque(x + 1));
}

// Leaves non-foldable 64-bit garbage on the stack via opaque-derived
// longs that must stay live across the recursive call.
def churn(depth: int) -> long {
	if (depth <= 0) return 0;
	var v0 = opaqueL(depth + 0);
	var v1 = opaqueL(depth + 1);
	var v2 = opaqueL(depth + 2);
	var v3 = opaqueL(depth + 3);
	var v4 = opaqueL(depth + 4);
	var v5 = opaqueL(depth + 5);
	var v6 = opaqueL(depth + 6);
	var v7 = opaqueL(depth + 7);
	var v8 = opaqueL(depth + 8);
	var v9 = opaqueL(depth + 9);
	var v10 = opaqueL(depth + 10);
	var v11 = opaqueL(depth + 11);
	var v12 = opaqueL(depth + 12);
	var v13 = opaqueL(depth + 13);
	var v14 = opaqueL(depth + 14);
	var v15 = opaqueL(depth + 15);
	var v16 = opaqueL(depth + 16);
	var v17 = opaqueL(depth + 17);
	var v18 = opaqueL(depth + 18);
	var v19 = opaqueL(depth + 19);
	var c = churn(depth - 1);
	return v0 ^ v1 ^ v2 ^ v3 ^ v4 ^ v5 ^ v6 ^ v7 ^ v8 ^ v9 ^ v10 ^ v11 ^ v12 ^ v13 ^ v14 ^ v15 ^ v16 ^ v17 ^ v18 ^ v19 ^ c;
}

def probe(off: int) -> int {
	var buf: Array<byte> = [10, 11, 12, 13, 14, 15, 16, 17];

	var o0 = opaque(off);
	var o1 = opaque(off);
	var o2 = opaque(off);
	var o3 = opaque(off);
	var o4 = opaque(off);
	var o5 = opaque(off);
	var o6 = opaque(off);
	var o7 = opaque(off);
	var o8 = opaque(off);
	var o9 = opaque(off);
	var o10 = opaque(off);
	var o11 = opaque(off);
	var o12 = opaque(off);
	var o13 = opaque(off);
	var o14 = opaque(off);
	var o15 = opaque(off);
	var o16 = opaque(off);
	var o17 = opaque(off);
	var o18 = opaque(off);
	var o19 = opaque(off);

	var r0 = buf[o0 & 3 ... (o0 & 3) + 4];
	var r1 = buf[o1 & 3 ... (o1 & 3) + 4];
	var r2 = buf[o2 & 3 ... (o2 & 3) + 4];
	var r3 = buf[o3 & 3 ... (o3 & 3) + 4];
	var r4 = buf[o4 & 3 ... (o4 & 3) + 4];
	var r5 = buf[o5 & 3 ... (o5 & 3) + 4];
	var r6 = buf[o6 & 3 ... (o6 & 3) + 4];
	var r7 = buf[o7 & 3 ... (o7 & 3) + 4];
	var r8 = buf[o8 & 3 ... (o8 & 3) + 4];
	var r9 = buf[o9 & 3 ... (o9 & 3) + 4];
	var r10 = buf[o10 & 3 ... (o10 & 3) + 4];
	var r11 = buf[o11 & 3 ... (o11 & 3) + 4];
	var r12 = buf[o12 & 3 ... (o12 & 3) + 4];
	var r13 = buf[o13 & 3 ... (o13 & 3) + 4];
	var r14 = buf[o14 & 3 ... (o14 & 3) + 4];
	var r15 = buf[o15 & 3 ... (o15 & 3) + 4];
	var r16 = buf[o16 & 3 ... (o16 & 3) + 4];
	var r17 = buf[o17 & 3 ... (o17 & 3) + 4];
	var r18 = buf[o18 & 3 ... (o18 & 3) + 4];
	var r19 = buf[o19 & 3 ... (o19 & 3) + 4];

	var sum = 0;
	for (b in r0) sum = sum + b;
	for (b in r1) sum = sum + b;
	for (b in r2) sum = sum + b;
	for (b in r3) sum = sum + b;
	for (b in r4) sum = sum + b;
	for (b in r5) sum = sum + b;
	for (b in r6) sum = sum + b;
	for (b in r7) sum = sum + b;
	for (b in r8) sum = sum + b;
	for (b in r9) sum = sum + b;
	for (b in r10) sum = sum + b;
	for (b in r11) sum = sum + b;
	for (b in r12) sum = sum + b;
	for (b in r13) sum = sum + b;
	for (b in r14) sum = sum + b;
	for (b in r15) sum = sum + b;
	for (b in r16) sum = sum + b;
	for (b in r17) sum = sum + b;
	for (b in r18) sum = sum + b;
	for (b in r19) sum = sum + b;

	return sum;
}

// force churn's frame and probe's frame to reuse the same stack address
def recurse(depth: int, off: int) -> int {
	if (depth <= 0) return 0;
	churn(depth);
	return recurse(depth - 1, off) + probe(off);
}

def main() -> int {
	return recurse(10, 2);
}
