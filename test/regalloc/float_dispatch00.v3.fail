//@execute 0=1087489743; 1=1523518671; 2=1244905929
//@heap-size=200000
// Eight double accumulators live across a virtual call is more than the x86-32
// backend has XMM registers, and it gets one of them wrong: input 1, which reads
// s4..s7, returns -2122820383 instead of 1523518671 on x86-linux. Input 0
// (s0..s3) and input 2 (the closures) agree everywhere, and every target other
// than x86-linux agrees on all three, so this is the old x86 code generator's
// spilling of caller-saved SSE values, not the arithmetic.
//
// Narrowing shows s4 alone is wrong -- the accumulator whose call argument is a
// negated double -- but the failure needs all eight accumulators and the
// three-way class hierarchy to appear; dropping either makes it agree.
//
// This is what still keeps test/smoke/float02.v3 disabled.
def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def SEED: Array<float> = [
	0.5f, -1.25f, 2f, -0.75f, 3.5f, -4.25f, 0.125f, -8f,
	16f, -0.0625f, 7.75f, -2.5f, 1f, -1f, 0.25f, -32f
];
def DSEED: Array<double> = [
	0.5d, -1.25d, 2d, -0.75d, 3.5d, -4.25d, 0.125d, -8d,
	16d, -0.0625d, 7.75d, -2.5d, 1d, -1d, 0.25d, -32d
];
class Op {
	def apply(f: float, d: double) -> double { return f + d; }
}
class MulOp extends Op {
	def k: float;
	new(k) { }
	def apply(f: float, d: double) -> double { return f * k + d; }
}
class ChainOp extends Op {
	def a: Op;
	def b: Op;
	new(a, b) { }
	def apply(f: float, d: double) -> double { return a.apply(f, d) + b.apply(f, -d); }
}
def main(n: int) -> int {
	var ops = Array<Op>.new(24);
	for (i < ops.length) {
		if ((i % 3) == 0) ops[i] = Op.new();
		else if ((i % 3) == 1) ops[i] = MulOp.new(SEED[i % SEED.length]);
		else ops[i] = ChainOp.new(Op.new(), MulOp.new(SEED[(i + 5) % SEED.length]));
	}
	var s0 = 0d, s1 = 0d, s2 = 0d, s3 = 0d;
	var s4 = 0d, s5 = 0d, s6 = 0d, s7 = 0d;
	for (i < ops.length) {
		var o = ops[i];
		var f = SEED[i % SEED.length];
		var d = DSEED[i % DSEED.length];
		s0 += o.apply(f, d);
		s1 += o.apply(f * 2f, d);
		s2 += o.apply(f, d * 2d);
		s3 -= o.apply(-f, d);
		s4 += o.apply(f, -d);
		s5 -= o.apply(f * 0.5f, d * 0.5d);
		s6 += o.apply(f + 1f, d + 1d);
		s7 -= o.apply(f - 1f, d - 1d);
	}
	if (n == 0) return mixd(mixd(mixd(mixd(0, s0), s1), s2), s3);
	if (n == 1) return mixd(mixd(mixd(mixd(0, s4), s5), s6), s7);
	var fns = Array<(float, double) -> double>.new(16);
	for (i < fns.length) {
		var c = SEED[i], e = DSEED[i];
		fns[i] = fun (f: float, d: double) => f * c + d * e;
	}
	var h = 0;
	for (i < fns.length) for (j < 8) h = mixd(h, fns[i](SEED[j], DSEED[j]));
	return h;
}
