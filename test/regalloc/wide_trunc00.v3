//@execute 0=-1616805417
//@heap-size=300000
// `long.truncd` on 32-bit x86 calls a fixup stub and pops the two words of the
// result off the stack. Constraining those two defs to the GPR class is not
// enough: two class-constrained defs of one instruction can be handed the same
// register, and the sequence became `pop %eax; pop %eax`, discarding the low
// word. They are pinned to EAX:EDX now.
//
// The collision only happens under enough pressure to run out of preferred
// registers, hence the allocation loop and the pointer chase.
def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
class Cell(i: long, d: double, f: float, next: Cell) { }
def main(a: int) -> int {
	var head: Cell;
	var live = Array<Cell>.new(20);
	for (i < 2500) {
		var v = 9007199254740000L + i * 7;
		var d = double.roundi(v);
		head = Cell.new(v, d, float.roundd(d), head);
		if ((i % 73) == 0) live[(i / 73) % live.length] = head;
		if ((i % 9) == 0) head = null;
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mixl(h, p.i);
			h = mixl(h, long.truncd(p.d) - p.i);
			p = p.next;
			n++;
			if (n > 200000) return h;
		}
	}
	return mix(h, n);
}
