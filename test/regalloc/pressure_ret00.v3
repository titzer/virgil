//@execute 0=0; 1=0; 2=0
// Multi-value returns whose slots live in the caller's frame, mixed with float and
// integer values and with a parameter whose slot coincides with a return slot.
// Those values must be written to the caller's slots, not left in whatever register
// the allocator happened to choose for them.
def six(a: int, b: double) -> (int, int, double, int, double, int) {
	return (a, a + 1, b, a + 2, b * 2d, a + 3);
}
def nine(a: int, b: int, c: int, d: int, e: int, f: int, g: int, h: int, i: int)
	-> (int, int, int, int, int, int, int, int, int) {
	return (i, h, g, f, e, d, c, b, a); // reversed: return slots alias param slots
}
def main(k: int) -> int {
	var t = six(k, 1.5d);
	var err = 0;
	if (t.0 != k) err = err | 1;
	if (t.1 != k + 1) err = err | 2;
	if (t.2 != 1.5d) err = err | 4;
	if (t.3 != k + 2) err = err | 8;
	if (t.4 != 3.0d) err = err | 16;
	if (t.5 != k + 3) err = err | 32;
	var u = nine(k, k+1, k+2, k+3, k+4, k+5, k+6, k+7, k+8);
	if (u.0 != k + 8) err = err | 64;
	if (u.1 != k + 7) err = err | 128;
	if (u.2 != k + 6) err = err | 256;
	if (u.3 != k + 5) err = err | 512;
	if (u.4 != k + 4) err = err | 1024;
	if (u.5 != k + 3) err = err | 2048;
	if (u.6 != k + 2) err = err | 4096;
	if (u.7 != k + 1) err = err | 8192;
	if (u.8 != k) err = err | 16384;
	return err;
}
