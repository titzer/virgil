//@execute 0=312; 1=344; 2=376; -1=280
// Register pressure across the floating point register class: a function with more
// float parameters than there are float argument registers, called with many live
// float values around it. Exposes bogus interference edges when the register class
// is not listed in ascending register order.
def ten(a: double, b: double, c: double, d: double, e: double,
	f: double, g: double, h: double, i: double, j: double) -> double {
	return a + b + c + d + e + f + g + h + i + j;
}
def main(k: int) -> int {
	var n = double.!(k);
	var v00 = n + 1d,  v01 = n + 2d,  v02 = n + 3d,  v03 = n + 4d;
	var v04 = n + 5d,  v05 = n + 6d,  v06 = n + 7d,  v07 = n + 8d;
	var v08 = n + 9d,  v09 = n + 10d, v10 = n + 11d, v11 = n + 12d;
	var v12 = n + 13d, v13 = n + 14d, v14 = n + 15d, v15 = n + 16d;
	var v16 = n + 17d, v17 = n + 18d, v18 = n + 19d, v19 = n + 20d;
	var x = ten(v00, v01, v02, v03, v04, v05, v06, v07, v08, v09);
	var y = ten(v10, v11, v12, v13, v14, v15, v16, v17, v18, v19);
	var z = ten(v00, v10, v01, v11, v02, v12, v03, v13, v04, v14);
	return int.!(x + y + z + v05 + v15);
}
