//@execute 0=2700; 1=3060; 2=3420; 3=3780
// Simultaneous integer and floating point register pressure, with a call in the
// middle that clobbers both register files, so values of both classes must survive
// in spill slots and come back to registers for their uses. The values are loaded
// from arrays so they cannot be folded away, but only two objects are allocated:
// allocating one per value exhausts the small default heap of the wasm target.
def touch(x: int, y: double) -> double { return y * double.!(x); }
def main(k: int) -> int {
	var ia = Array<int>.new(12);
	var da = Array<double>.new(12);
	for (i < 12) { ia[i] = i + k; da[i] = double.!(i) + 0.5d; }
	var i00 = ia[0],  i01 = ia[1],  i02 = ia[2],  i03 = ia[3];
	var i04 = ia[4],  i05 = ia[5],  i06 = ia[6],  i07 = ia[7];
	var i08 = ia[8],  i09 = ia[9],  i10 = ia[10], i11 = ia[11];
	var d00 = da[0],  d01 = da[1],  d02 = da[2],  d03 = da[3];
	var d04 = da[4],  d05 = da[5],  d06 = da[6],  d07 = da[7];
	var d08 = da[8],  d09 = da[9],  d10 = da[10], d11 = da[11];
	var t = touch(i00 + i11, d00 + d11); // clobbers every caller-saved register
	var isum = i00 + i01 + i02 + i03 + i04 + i05 + i06 + i07 + i08 + i09 + i10 + i11;
	var dsum = d00 + d01 + d02 + d03 + d04 + d05 + d06 + d07 + d08 + d09 + d10 + d11;
	return int.!(t * 10d) + isum * 10 + int.!(dsum * 10d);
}
