//@execute 0=7265; 1=7666; 2=8085; 7=10450
// Register pressure: more simultaneously live integer values than there are
// allocatable general purpose registers, all consumed by arithmetic, comparisons,
// and memory operations. With a register allocator that can leave a value in a
// spill slot, every one of those operands must still reach the instruction in a
// register.
def main(k: int) -> int {
	var a = Array<int>.new(34);
	for (i < a.length) a[i] = i + k;
	var v00 = a[0] + 1,  v01 = a[1] + 2,  v02 = a[2] + 3,  v03 = a[3] + 4;
	var v04 = a[4] + 5,  v05 = a[5] + 6,  v06 = a[6] + 7,  v07 = a[7] + 8;
	var v08 = a[8] + 9,  v09 = a[9] + 10, v10 = a[10] + 11, v11 = a[11] + 12;
	var v12 = a[12] + 13, v13 = a[13] + 14, v14 = a[14] + 15, v15 = a[15] + 16;
	var v16 = a[16] + 17, v17 = a[17] + 18, v18 = a[18] + 19, v19 = a[19] + 20;
	var v20 = a[20] + 21, v21 = a[21] + 22, v22 = a[22] + 23, v23 = a[23] + 24;
	var v24 = a[24] + 25, v25 = a[25] + 26, v26 = a[26] + 27, v27 = a[27] + 28;
	var v28 = a[28] + 29, v29 = a[29] + 30, v30 = a[30] + 31, v31 = a[31] + 32;
	var v32 = a[32] + 33, v33 = a[33] + 34;
	// every value is still live here, and each use below needs a register
	var sum = v00 * v01 + v02 * v03 + v04 * v05 + v06 * v07;
	sum = sum + v08 * v09 + v10 * v11 + v12 * v13 + v14 * v15;
	sum = sum + v16 - v17 + v18 - v19 + v20 - v21 + v22 - v23;
	if (v24 < v25) sum = sum + v24 + v25;
	if (v26 <= v27) sum = sum + v26 + v27;
	if (v28 != v29) sum = sum + v28 - v29;
	if (v30 == v31) sum = sum + 1000;
	a[0] = v32;
	a[1] = v33;
	return sum + a[0] * a[1];
}
