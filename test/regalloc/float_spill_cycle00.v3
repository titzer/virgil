//@execute 0=-1330480103
// Sixteen live doubles is more than x86-32 has XMM registers, so resolving the
// parallel move at the loop back-edge needs a temporary to break a cycle. That
// temporary was the SSE scratch register -- which is also what the
// memory-to-memory move sequences use, so an unrelated move in the same parallel
// move destroyed the saved value. Ten accumulators is the threshold; sixteen
// makes it reliable.
def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixd(h: int, d: double) -> int { return mixl(h, long.view(d)); }
def DSEED: Array<double> = [
	0.5d, -1.25d, 2d, -0.75d, 3.5d, -4.25d, 0.125d, -8d,
	16d, -0.0625d, 7.75d, -2.5d, 1d, -1d, 0.25d, -32d
];
def main(n: int) -> int {
	var a0 = DSEED[0];
	var a1 = DSEED[1];
	var a2 = DSEED[2];
	var a3 = DSEED[3];
	var a4 = DSEED[4];
	var a5 = DSEED[5];
	var a6 = DSEED[6];
	var a7 = DSEED[7];
	var a8 = DSEED[8];
	var a9 = DSEED[9];
	var a10 = DSEED[10];
	var a11 = DSEED[11];
	var a12 = DSEED[12];
	var a13 = DSEED[13];
	var a14 = DSEED[14];
	var a15 = DSEED[15];
	for (i < 30) {
		var t = double.roundi(i) * 0.03125d;
		a0 = a0 * 0.5d + a15 - t;
		a1 = a1 * 0.5d + a0 + t;
		a2 = a2 * 0.5d + a1 - t;
		a3 = a3 * 0.5d + a2 + t;
		a4 = a4 * 0.5d + a3 - t;
		a5 = a5 * 0.5d + a4 + t;
		a6 = a6 * 0.5d + a5 - t;
		a7 = a7 * 0.5d + a6 + t;
		a8 = a8 * 0.5d + a7 - t;
		a9 = a9 * 0.5d + a8 + t;
		a10 = a10 * 0.5d + a9 - t;
		a11 = a11 * 0.5d + a10 + t;
		a12 = a12 * 0.5d + a11 - t;
		a13 = a13 * 0.5d + a12 + t;
		a14 = a14 * 0.5d + a13 - t;
		a15 = a15 * 0.5d + a14 + t;
	}
	var h = 0;
	h = mixd(h, a0);
	h = mixd(h, a1);
	h = mixd(h, a2);
	h = mixd(h, a3);
	h = mixd(h, a4);
	h = mixd(h, a5);
	h = mixd(h, a6);
	h = mixd(h, a7);
	h = mixd(h, a8);
	h = mixd(h, a9);
	h = mixd(h, a10);
	h = mixd(h, a11);
	h = mixd(h, a12);
	h = mixd(h, a13);
	h = mixd(h, a14);
	h = mixd(h, a15);
	return h;
}
