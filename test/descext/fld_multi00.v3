//@execute = 100
class E(v: int) { }
class D describes C { }
class C(a: int, e: E, b: int) descriptor D { }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 8 * Pointer.SIZE);
	var e = E.new(9);
	var c = C.new(d, 1, e, 2);
	if (c.a != 1) return 1;
	if (c.e.v != 9) return 2;
	if (c.b != 2) return 3;
	return 100;
}
