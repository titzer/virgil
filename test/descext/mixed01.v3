//@execute 0=66; 1=77; 2=55; 3=66; 4=99; 5=86
class D describes C { }
class C descriptor D {
	def set<T>(v: T) -> this {
		Pointer.atEnd(this).store<T>(v);
	}
	def get<T>() => Pointer.atEnd(this).load<T>();
}

def main(a: int) -> int {
	var result = 55L;
	match (a) {
		0 => result = do<byte>(66);
		1 => result = do<byte>(77);
		2 => result = do<int>(55555);
		3 => result = do<int>(66666);
		4 => result = do<long>(999_999_999_999L);
		5 => result = do<long>(888_888_888_888L);
	}
	return mod(result);
}

def do<T>(v: T) -> T {
	var d = D.new();
	var words = 8 / Pointer.SIZE;
	CiRuntime.setDescriptorExtension(d, 0b10 << u5.!(words), Pointer.SIZE * words + 2);
	var c = C.new(d);
	c.set(v);
	return c.get<T>();
}

def mod(v: long) -> int {
	return int.!((v >> 32 | v) % 100);
}
