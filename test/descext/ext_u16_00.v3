//@execute = 100
class D describes C { }
class C descriptor D { def at(i: int) => Pointer.atEnd(this) + i * 2; }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 6 * Pointer.SIZE);
	var c = C.new(d);
	for (i < 8) c.at(i).store<u16>(u16.view(i * 4369 + 1));
	for (i < 8) if (c.at(i).load<u16>() != u16.view(i * 4369 + 1)) return 1 + i;
	return 100;
}
