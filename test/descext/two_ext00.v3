//@execute = 100
// A two-level descriptor chain where the inner descriptor is branded with an extension.
// The descriptor itself has a descriptor, so its metadata slots must not collide with its
// own object header.
class DD(tag: int) describes D { }
class D descriptor DD describes A { }
class A descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }

def dd = DD.new(77);
def d = D.new(dd);

def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, (1 + 3) * Pointer.SIZE); // 1 header word + 3 ext words
	var a = A.new(d);
	for (i < 3) a.slot(i).store<int>(i * 11 + 1);
	for (i < 3) if (a.slot(i).load<int>() != i * 11 + 1) return 1 + i;
	if (a.descriptor != d) return 10;
	if (a.descriptor.descriptor.tag != 77) return 11;
	return 100;
}
