//@execute = 100
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 3 * Pointer.SIZE);
	var cs = Array<C>.new(8);
	for (i < cs.length) { cs[i] = C.new(d); cs[i].slot(0).store<int>(i * 100 + 1); }
	for (i < cs.length) if (cs[i].slot(0).load<int>() != i * 100 + 1) return 1 + i;
	return 100;
}
