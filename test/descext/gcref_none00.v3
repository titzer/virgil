//@execute = 100
//@heap-size=16384
class E(v: int) { }
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
var c: C;
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 4 * Pointer.SIZE); // refmap 0: no refs
	c = C.new(d);
	for (i < 3) c.slot(i).store<int>(i * 12345 + 1);
	churn();
	for (i < 3) if (c.slot(i).load<int>() != i * 12345 + 1) return 1 + i;
	return 100;
}
