//@execute = 100
// A three-level descriptor chain where every level is branded with its own extension. Each
// descriptor's metadata slots describe the level below it, while its own size comes from the
// level above, so the slots must be readable at the same offsets at every level.
//
// The base size of a described class is its static size, so it is measured from an
// unextended instance rather than hard-coded per target.
class DDD describes DD { }
class DD descriptor DDD describes D {
	def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE;
	def base() => int.!(Pointer.atEnd(this) - Pointer.atObject(this));
}
class D descriptor DD describes A {
	def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE;
	def base() => int.!(Pointer.atEnd(this) - Pointer.atObject(this));
}
class A descriptor D {
	def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE;
	def base() => int.!(Pointer.atEnd(this) - Pointer.atObject(this));
}

def ddd = DDD.new();

def main() -> int {
	// Brand ddd, so that DD objects get 1 extension word.
	CiRuntime.setDescriptorExtension(ddd, 0, DD.new(ddd).base() + 1 * Pointer.SIZE);
	var dd = DD.new(ddd);
	dd.slot(0).store<int>(1111);

	// Brand dd, so that D objects get 2 extension words.
	CiRuntime.setDescriptorExtension(dd, 0, D.new(dd).base() + 2 * Pointer.SIZE);
	var d = D.new(dd);
	d.slot(0).store<int>(2222);
	d.slot(1).store<int>(3333);

	// Brand d, so that A objects get 3 extension words.
	CiRuntime.setDescriptorExtension(d, 0, A.new(d).base() + 3 * Pointer.SIZE);
	var a = A.new(d);
	for (i < 3) a.slot(i).store<int>(i * 7 + 4444);

	if (dd.slot(0).load<int>() != 1111) return 1;
	if (d.slot(0).load<int>() != 2222) return 2;
	if (d.slot(1).load<int>() != 3333) return 3;
	for (i < 3) if (a.slot(i).load<int>() != i * 7 + 4444) return 4 + i;
	if (a.descriptor != d) return 10;
	if (a.descriptor.descriptor != dd) return 11;
	if (a.descriptor.descriptor.descriptor != ddd) return 12;
	return 100;
}
