//@execute = 100
//@heap-size=16384
class E(v: int) { }
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0x0000003E, (4 + 1) * Pointer.SIZE);
	var c = C.new(d);
	for (i < 4) c.slot(i).store<E>(E.new(i + 1));
	churn();
	for (i < 4) if (c.slot(i).load<E>().v != i + 1) return 1 + i;
	return 100;
}
