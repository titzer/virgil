//@execute = 100
class DA<T> describes A<T> { }
class A<T>(x: T) descriptor DA<T> { }
class DB<T> extends DA<T> describes B<T> { }
class B<T>(y: T) extends A<T>(y) descriptor DB<T> { }
def db = DB<int>.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(db, 0, 4 * Pointer.SIZE);
	var b = B<int>.new(db, 21);
	var a: A<int> = b;
	return if(a.x == 21, 100, 1);
}
