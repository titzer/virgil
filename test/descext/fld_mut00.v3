//@execute = 100
class D describes C { }
class C descriptor D { var x: int; var y: int; }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 8 * Pointer.SIZE);
	var c = C.new(d);
	c.x = 11; c.y = 22;
	if (c.x != 11) return 1;
	if (c.y != 22) return 2;
	c.x = c.x + c.y;
	return if(c.x == 33, 100, 3);
}
