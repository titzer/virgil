//@execute 0=100; 1=100; 5=100
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
def main(a: int) -> int {
	CiRuntime.setDescriptorExtension(d, 0, 4 * Pointer.SIZE);
	var arr = Array<C>.new(a);
	for (i < a) { arr[i] = C.new(d); arr[i].slot(0).store<int>(i * 7); }
	for (i < a) if (arr[i].slot(0).load<int>() != i * 7) return 1 + i;
	return 100;
}
