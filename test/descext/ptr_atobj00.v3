//@execute = 100
class D describes C { }
class C(x: int) descriptor D { }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 4 * Pointer.SIZE);
	var c = C.new(d, 99);
	var p = Pointer.atObject(c); // points at field 0 (the descriptor pointer)
	// the declared field x lives after the descriptor word
	var q = Pointer.atEnd(c);
	q.store<int>(55);
	if (c.x != 99) return 1;
	if (q.load<int>() != 55) return 2;
	return 100;
}
