//@execute = 100
//@heap-size=32768
// A three-level chain where the intermediate descriptors are themselves allocated on the
// heap and branded, so a collection must trace and relocate descriptors that serve as the
// object headers of other live objects.
class E(v: int) { }
class DDD describes DD { }
class DD descriptor DDD describes D {
	def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE;
	def base() => int.!(Pointer.atEnd(this) - Pointer.atObject(this));
}
class D descriptor DD describes A {
	def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE;
	def base() => int.!(Pointer.atEnd(this) - Pointer.atObject(this));
}
class A descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }

def ddd = DDD.new();
var dd: DD;
var d: D;
var a: A;
def churn() { for (i < 4000) { var junk = E.new(i); } }

// A described object's size must stay a multiple of the word size, or the collector will
// misalign every object it allocates after one. A descriptor that is itself described has
// an unaligned base size, since its metadata slots are three 4-byte words.
def align(n: int) => (n + Pointer.SIZE - 1) & (0 - Pointer.SIZE);

def main() -> int {
	// Extensions on the descriptor levels hold integers, since their base size need not be
	// reference-aligned; only the leaf objects hold references in their extension.
	CiRuntime.setDescriptorExtension(ddd, 0, align(DD.new(ddd).base()) + Pointer.SIZE);
	dd = DD.new(ddd);
	dd.slot(0).store<int>(4242);
	d = D.new(dd);

	// 1 header word + 1 extension word holding a reference: bit 1, terminator at bit 2.
	CiRuntime.setDescriptorExtension(d, 0x6, 2 * Pointer.SIZE);
	a = A.new(d);
	a.slot(0).store<E>(E.new(33));

	churn();

	if (a.slot(0).load<E>().v != 33) return 1;
	if (dd.slot(0).load<int>() != 4242) return 2;
	if (a.descriptor != d) return 3;
	if (a.descriptor.descriptor != dd) return 4;
	if (a.descriptor.descriptor.descriptor != ddd) return 5;
	return 100;
}
