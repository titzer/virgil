//@execute = 100
class D<T> describes C<T> { }
class C<T>(x: T) descriptor D<T> { }
def di = D<int>.new();
def db = D<bool>.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(di, 0, 4 * Pointer.SIZE);
	CiRuntime.setDescriptorExtension(db, 0, 4 * Pointer.SIZE);
	var ci = C<int>.new(di, 7);
	var cb = C<bool>.new(db, true);
	if (ci.x != 7) return 1;
	if (cb.x != true) return 2;
	return 100;
}
