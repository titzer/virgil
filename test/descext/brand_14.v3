//@execute 0=4242; 1=4242; 2=4242; 5=4242
class D describes C { }
class C descriptor D {
	def ptr(i: int) => Pointer.atEnd(this) + i * 4;
}

def EXT_SIZE = 19;
def refmap = -1 >>> u5.!(32 - EXT_SIZE);
def RANDOM = 0xAAEEBBCC;

def d = D.new();

def main(a: int) -> int {
	CiRuntime.setDescriptorExtension(d, refmap, Pointer.SIZE * EXT_SIZE);
	var s1 = Array<Array<u16>>.new(a);
	// Allocate some arrays before.
	for (i < s1.length) s1[i] = allocArray(i);
	// Allocate a new object with descriptor.
	var c = C.new(d);
	// Allocate some arrays after.
	var s2 = Array<Array<u16>>.new(a + 2);
	for (i < s2.length) s2[i] = allocArray(i);

	// Write magic into the extended object.
	writeMagic(c, 4);

	// Check arrays before and after were not overwritten.
	checkArrays(s1, a);
	checkArrays(s2, a + 2);

	return 4242;
}

def writeMagic(c: C, i: int) {
	for (j < EXT_SIZE) c.ptr(j).store<int>((j + i) * RANDOM);
}

def allocArray(a: int) -> Array<u16> {
	// Allocate some arrays before.
	var s = Array<u16>.new(a);
	for (i < s.length) s[i] = u16.view(a + i);
	return s;
}

def checkArrays(s: Array<Array<u16>>, a: int) -> int {
	if (s.length != a) return -2;
	for (i < s.length) if (checkArray(s[i], i) < 0) return -4;
	return 0;
}

def checkArray(s: Array<u16>, len: int) -> int {
	var a = s.length;
	if (a != len) return -1;
	for (i < a) if (s[i] != u16.view(a + i)) return -2;
	return 0;
}