//@execute 0=4242; 1=4242; 2=4242; 15=4242
// 64-bit only: the extension mixes references and full 64-bit integers, one per word,
// so the reference map must mark exactly the even extension words.
class D describes C { }
class C descriptor D {
	// The descriptor pointer occupies exactly one word, so the extension starts at word 1.
	def headerSize() => int.!(Pointer.atEnd(this) - Pointer.atObject(this));
	def word(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE;
	def writeMixed(len: int) {
		for (i < len) {
			if ((i & 1) == 0) word(i).store<string>(if((i & 2) == 0, FOO, BAR));
			else word(i).store<long>(MAGIC * (i + 1));
		}
	}
	def checkMixed(len: int) {
		for (i < len) {
			if ((i & 1) == 0) {
				if (word(i).load<string>() != (if((i & 2) == 0, FOO, BAR))) void(1/0);
			} else {
				if (word(i).load<long>() != MAGIC * (i + 1)) void(1/0);
			}
		}
	}
}

def EXT_WORDS = 13;
def refmap = 0x2AAA; // bit 0 is the descriptor; even extension words (bits 1, 3, ...) are refs
def RANDOM = 0xAAEEBBCC;
def MAGIC = 0xAAEEBBCC11224488L;
def FOO = "foo";
def BAR = "bar";

def d = D.new();

def main(a: int) -> int {
	CiRuntime.setDescriptorExtension(d, refmap, (EXT_WORDS + 1) * Pointer.SIZE); // +1 word for the descriptor header
	// Allocate arrays before.
	var s1 = allocArray(a + 1), s2 = allocArray(a + 2);
	// Allocate a new object with descriptor.
	var c = C.new(d);
	if (c.headerSize() != 8) return c.headerSize();
	// Allocate arrays after.
	var s3 = allocArray(a + 3), s4 = allocArray(a + 4);

	// Write mixed references and 64-bit integers into the object extension.
	if ((a & 1) != 0) {
		c.writeMixed(EXT_WORDS);
		c.checkMixed(EXT_WORDS);
	}

	// Check arrays before and after were not overwritten.
	assertArray(s1, a + 1);
	assertArray(s2, a + 2);
	assertArray(s3, a + 3);
	assertArray(s4, a + 4);

	return 4242;
}

def allocArray(a: int) -> Array<u16> {
	// Allocate some arrays before.
	var s = Array<u16>.new(a);
	for (i < s.length) s[i] = u16.view(RANDOM * (i + a));
	return s;
}

def assertArray(s: Array<u16>, len: int) {
	var a = s.length;
	if (a != len) return void(1/0);
	for (i < s.length) if (s[i] != u16.view(RANDOM * (i + a))) void(1/0);
}
