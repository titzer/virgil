//@execute = 100
//@heap-size=16384
// A two-level descriptor chain whose described objects hold references in their extension.
// The collector must find them through the descriptor's reference map, and must also trace
// the descriptor chain itself.
class E(v: int) { }
class DD(tag: int) describes D { }
class D descriptor DD describes A { }
class A descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }

def dd = DD.new(99);
def d = D.new(dd);
var a: A;
def churn() { for (i < 4000) { var junk = E.new(i); } }

def main() -> int {
	// 1 header word + 2 extension words, both references: bits 1 and 2, terminator at bit 3.
	CiRuntime.setDescriptorExtension(d, 0xE, 3 * Pointer.SIZE);
	a = A.new(d);
	a.slot(0).store<E>(E.new(11));
	a.slot(1).store<E>(E.new(22));
	churn();
	if (a.slot(0).load<E>().v != 11) return 1;
	if (a.slot(1).load<E>().v != 22) return 2;
	if (a.descriptor != d) return 3;
	if (a.descriptor.descriptor.tag != 99) return 4;
	return 100;
}
