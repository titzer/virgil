//@execute = 100
//@heap-size=16384
class E(v: int) { }
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
var c: C;
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	// refs at slots 0,3,7 -> words 1,4,8 -> bits 1,4,8 + terminator bit9
	CiRuntime.setDescriptorExtension(d, (1<<1)|(1<<4)|(1<<8)|(1<<9), 9 * Pointer.SIZE);
	c = C.new(d);
	c.slot(0).store<E>(E.new(10));
	c.slot(3).store<E>(E.new(40));
	c.slot(7).store<E>(E.new(80));
	c.slot(1).store<int>(111); c.slot(2).store<int>(222); // non-refs interleaved
	churn();
	if (c.slot(0).load<E>().v != 10) return 1;
	if (c.slot(3).load<E>().v != 40) return 2;
	if (c.slot(7).load<E>().v != 80) return 3;
	if (c.slot(1).load<int>() != 111) return 4;
	return 100;
}
