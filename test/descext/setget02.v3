//@execute 0=0; 1=111111; 2=222222; 5=555555; 9=999999
class D describes C { }
class C descriptor D { }

def main(a: int) -> int {
	var isRef = Array<bool>.new(a);

	var d = D.new();
	CiRuntime.setDescriptorExtension(d, 1 << u5.!(a), (1 + a) * 4); // add N non-ref fields
	var c1 = C.new(d);
	var c2 = C.new(d);

	var sum = 0;

	for (i < a) {
		var p1 = Pointer.atEnd(c1) + 4 * i; // point at Nth integer field
		p1.store<int>(111000 + a);

		var p2 = Pointer.atEnd(c2) + 4 * i; // point at Nth integer field
		p2.store<int>(   111 - a);

		var l1 = p1.load<int>();
		var l2 = p2.load<int>();

		sum += (l1 + l2);
	}

	return sum;
}
