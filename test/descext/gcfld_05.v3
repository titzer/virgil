//@execute = 100
//@heap-size=16384
class E(v: int) { }
class D describes C { }
class C( e0: E, e1: E, e2: E, e3: E, e4: E) descriptor D { }
def d = D.new();
var c: C;
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0x0000007E, (5 + 1) * Pointer.SIZE);
	c = C.new(d, E.new(1), E.new(2), E.new(3), E.new(4), E.new(5));
	churn();
	 if (c.e0.v != 1) return 1; if (c.e1.v != 2) return 2; if (c.e2.v != 3) return 3; if (c.e3.v != 4) return 4; if (c.e4.v != 5) return 5;
	return 100;
}
