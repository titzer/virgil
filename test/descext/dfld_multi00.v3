//@execute = 100
class D(tag: int, name: string, k: int) describes C { }
class C descriptor D { }
def nm = "xyz";
def d = D.new(7, nm, 9);
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 2 * Pointer.SIZE);
	if (d.tag != 7) return 1;
	if (d.name != nm) return 2;
	if (d.k != 9) return 3;
	return 100;
}
