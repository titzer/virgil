//@execute = 100
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d1 = D.new();
def d2 = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d1, 0, 2 * Pointer.SIZE);
	CiRuntime.setDescriptorExtension(d2, 0, 6 * Pointer.SIZE);
	var a = C.new(d1);
	var b = C.new(d2);
	a.slot(0).store<int>(11);
	for (i < 5) b.slot(i).store<int>(100 + i);
	if (a.slot(0).load<int>() != 11) return 1;
	for (i < 5) if (b.slot(i).load<int>() != 100 + i) return 2 + i;
	return 100;
}
