//@execute = 100
class DA describes A { }
class A(x: int) descriptor DA { }
class DB extends DA describes B { }
class B extends A(2) descriptor DB { def y: int = 5; }
class DC extends DB describes Cc { }
class Cc extends B descriptor DC { }
def dc = DC.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(dc, 0, 4 * Pointer.SIZE);
	var c = Cc.new(dc);
	if (c.x != 2) return 1;
	if (c.y != 5) return 2;
	var a: A = c;
	return if(a.x == 2, 100, 3);
}
