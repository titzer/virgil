//@execute = 100
//@heap-size=16384
class E(v: int) { }
class D describes C { }
class C( e0: E) descriptor D { }
def d = D.new();
var c: C;
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0x00000006, (1 + 1) * Pointer.SIZE);
	c = C.new(d, E.new(1));
	churn();
	 if (c.e0.v != 1) return 1;
	return 100;
}
