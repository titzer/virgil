//@execute 0=55555; 1=55655; 2=55756; 55=!BoundsCheckException
class D describes C { }
class C descriptor D {
	def get() -> (int, string) {
		var p = Pointer.atObject(this);
		return (p.load<int>(), (p + Pointer.SIZE).load<string>());
	}
	def set(x: int, y: string) -> this {
		var p = Pointer.atObject(this);
		p.store<int>(x);
		(p + Pointer.SIZE).store<string>(y);
	}
}


def d = D.new();

def strings = ["foo", "bar", "baz"];

def main(a: int) -> int {
	CiRuntime.setDescriptorExtension(d, 0b1101, 3 * Pointer.SIZE); // one primitive word and one reference word

	var cs = Array<C>.new(a);
	for (i < a) {
		cs[i] = C.new(d);
	}

	for (i < cs.length) {
		var c = cs[i];
		c.set(i + 100, strings[i]);
	}

	var sum = 0;
	for (i < cs.length) {
		var c = cs[i];
		var expected = (i + 100, strings[i]);
		var got = c.get();
		if (expected != got) return -33 - i;
		sum += expected.0;
	}
	return 55555 + sum;
}
