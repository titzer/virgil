//@execute = 100
class D describes C { }
class C descriptor D { def at(i: int) => Pointer.atEnd(this) + i; }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 6 * Pointer.SIZE);
	var c = C.new(d);
	for (i < 16) c.at(i).store<byte>(byte.view(i * 17 + 3));
	for (i < 16) if (c.at(i).load<byte>() != byte.view(i * 17 + 3)) return 1 + i;
	return 100;
}
