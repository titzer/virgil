//@execute = 100
//@heap-size=16384
class E(v: int) { }
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
var c: C;
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	// slot0=int(w1), slot1=ref(w2), slot2=int(w3), slot3=ref(w4): refs bits 2,4 term bit5
	CiRuntime.setDescriptorExtension(d, (1<<2)|(1<<4)|(1<<5), 5 * Pointer.SIZE);
	c = C.new(d);
	c.slot(0).store<int>(1234);
	c.slot(1).store<E>(E.new(11));
	c.slot(2).store<int>(5678);
	c.slot(3).store<E>(E.new(22));
	churn();
	if (c.slot(0).load<int>() != 1234) return 1;
	if (c.slot(1).load<E>().v != 11) return 2;
	if (c.slot(2).load<int>() != 5678) return 3;
	if (c.slot(3).load<E>().v != 22) return 4;
	return 100;
}
