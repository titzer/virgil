//@execute = 100
class D describes C { }
class C descriptor D { def at(i: int) => Pointer.atEnd(this) + i * 8; }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 10 * Pointer.SIZE);
	var c = C.new(d);
	for (i < 4) c.at(i).store<long>(0x1111000022220000L * (i + 1));
	for (i < 4) if (c.at(i).load<long>() != 0x1111000022220000L * (i + 1)) return 1 + i;
	return 100;
}
