//@execute 0=1000; 1=1001; 2=1002; 47=1047
class D describes C { }
class C descriptor D {
	def ptr(i: int) => Pointer.atEnd(this) + i * 4;
}

def EXT_SIZE = 10;
def refmap = -1 >>> u5.!(32 - EXT_SIZE);
def MAGIC = 0x99EEBBCC;

def d = D.new();

def main(a: int) -> int {
	CiRuntime.setDescriptorExtension(d, refmap, EXT_SIZE * Pointer.SIZE);
	var cs = Array<C>.new(a);
	// Allocate a number of new C objects and write data into their extensions.
	for (i < a) {
		var c = C.new(d);
		cs[i] = c;
		writeMagic(c, i);
	}
	// Check the data in the extensions was not overwritten by allocations.
	for (i < a) {
		var c = cs[i];
		var got = checkMagic(c, i);
		if (got < 0) return got;
	}
	// Write magic into objects again to check writes do not overlap other objects.
	for (i < a) {
		var c = C.new(d);
		cs[i] = c;
		writeMagic(c, i);
	}
	// Check the data in the extensions was not overwritten by second writes.
	var ok = 1000;
	for (i < a) {
		var c = cs[i];
		var got = checkMagic(c, i);
		if (got < 0) return got;
		ok++;
	}
	return ok;
}

def writeMagic(c: C, i: int) {
	for (j < EXT_SIZE) c.ptr(j).store<int>((j + i) * MAGIC);
}

def checkMagic(c: C, i: int) -> int {
	var sum = 0;
	for (j < EXT_SIZE) {
		var m = c.ptr(j).load<int>();
		var expected = (j + i) * MAGIC;
		if (m != expected) return -1 - (j + i);
		sum += expected;
	}
	return sum & 0x7FFF_FFFF;
}
