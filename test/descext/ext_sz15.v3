//@execute = 100
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def N = 15;
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, (N + 1) * Pointer.SIZE);
	var c = C.new(d);
	for (i < N) c.slot(i).store<int>(i * 0x01010101 + 7);
	for (i < N) if (c.slot(i).load<int>() != i * 0x01010101 + 7) return 1 + i;
	return 100;
}
