//@execute = 100
//@heap-size=16384
class E(v: int) { }
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
var c: C;
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0x00000006, (0 + 2) * Pointer.SIZE);
	c = C.new(d);
	c.slot(0).store<E>(E.new(777));
	churn();
	return if(c.slot(0).load<E>().v == 777, 100, 1);
}
