//@execute 0=777777; 2=777779
class D describes C { }
class C descriptor D { }

def main(a: int) -> int {
	var d = D.new();
	CiRuntime.setDescriptorExtension(d, 0b100, 3 * Pointer.SIZE); // add a single non-ref field
	var c1 = C.new(d);
	var c2 = C.new(d);

	var p1 = Pointer.atEnd(c1);
	p1.store<int>(333333 + a);

	var p2 = Pointer.atEnd(c2);
	p2.store<int>(444444);

	var l1 = p1.load<int>();
	var l2 = p2.load<int>();

	return l1 + l2;
}
