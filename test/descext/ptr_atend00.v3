//@execute = 100
class D describes C { }
class C descriptor D { }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 4 * Pointer.SIZE);
	var c = C.new(d);
	var p = Pointer.atEnd(c);
	p.store<int>(0xABCD);
	(p + Pointer.SIZE).store<int>(0x1234);
	if (p.load<int>() != 0xABCD) return 1;
	if ((p + Pointer.SIZE).load<int>() != 0x1234) return 2;
	return 100;
}
