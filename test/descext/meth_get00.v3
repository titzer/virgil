//@execute = 100
class D describes C { }
class C descriptor D {
	def set(v: int) { Pointer.atEnd(this).store<int>(v); }
	def get() -> int { return Pointer.atEnd(this).load<int>(); }
}
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 3 * Pointer.SIZE);
	var c = C.new(d);
	c.set(4242);
	return if(c.get() == 4242, 100, 1);
}
