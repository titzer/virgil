//@execute = 100
//@heap-size=16384
class E(v: int) { }
class Meta(tag: int) { }
class D(m: Meta) describes C { }
class C descriptor D { }
def meta = Meta.new(9999);
def d = D.new(meta);
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 2 * Pointer.SIZE);
	var c = C.new(d);
	churn();
	return if(d.m.tag == 9999, 100, 1);
}
