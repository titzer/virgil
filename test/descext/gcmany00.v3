//@execute = 100
//@heap-size=32768
class E(v: int) { }
class D describes C { }
class C descriptor D { def slot(i: int) => Pointer.atEnd(this) + i * Pointer.SIZE; }
def d = D.new();
def N = 20;
var cs = Array<C>.new(N);
def churn() { for (i < 4000) { var junk = E.new(i); } }
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0x6, 2 * Pointer.SIZE); // 1 ref at slot 0
	for (i < N) { var c = C.new(d); cs[i] = c; c.slot(0).store<E>(E.new(i + 1)); }
	churn();
	for (i < N) if (cs[i].slot(0).load<E>().v != i + 1) return 1 + i;
	return 100;
}
