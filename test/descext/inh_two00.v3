//@execute = 100
class DA describes A { }
class A(x: int) descriptor DA { }
class DB extends DA describes B { }
class B extends A(20) descriptor DB { }
def da = DA.new();
def db = DB.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(da, 0, 4 * Pointer.SIZE);
	CiRuntime.setDescriptorExtension(db, 0, 4 * Pointer.SIZE);
	var a = A.new(da, 10);
	var b = B.new(db);
	if (a.x != 10) return 1;
	if (b.x != 20) return 2;
	var ab: A = b;
	return if(ab.x == 20, 100, 3);
}
