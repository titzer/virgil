//@execute = 100
class D describes C { }
class C descriptor D { def at(i: int) => Pointer.atEnd(this) + i * 4; }
def d = D.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(d, 0, 6 * Pointer.SIZE);
	var c = C.new(d);
	for (i < 5) c.at(i).store<float>(float.view(i) + 0.5f);
	for (i < 5) if (c.at(i).load<float>() != float.view(i) + 0.5f) return 1 + i;
	return 100;
}
