//@execute = 100
class DA describes A { }
class A(x: int) descriptor DA { }
class DB extends DA describes B { }
class B(y: int) extends A(7) descriptor DB { }
def db = DB.new();
def main() -> int {
	CiRuntime.setDescriptorExtension(db, 0, 8 * Pointer.SIZE);
	var b = B.new(db, 30);
	if (b.x != 7) return 1;
	if (b.y != 30) return 2;
	return 100;
}
