//@execute 0=1; 1=2; 2=2; 3=99
// B => in match on A correctly matches any A.B.* value (range test on tag)
type A {
	case X;
	case Q;
	case _;
}
type A.B {
	case Y;
	case Z;
}
def classify(a: A) -> int {
	match (a) {
		X => return 1;
		B => return 2;
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return classify(A.X);
	if (arg == 1) return classify(A.B.Y);
	if (arg == 2) return classify(A.B.Z);
	return classify(A.Q);
}
