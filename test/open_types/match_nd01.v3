//@execute 0=1; 1=2; 2=2; 3=99
type A {
	case X;
	case Q;
	case _;
}
type B extends A {
	case Y;
	case Z;
}
def classify(a: A) -> int {
	match (a) {
		X => return 1;
		x: B => return 2;
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return classify(A.X);
	if (arg == 1) return classify(B.Y);
	if (arg == 2) return classify(B.Z);
	return classify(A.Q);
}
