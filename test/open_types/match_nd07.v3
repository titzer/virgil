//@execute 0=99; 1=2; 2=2; 3=2; 4=99
// Types with no named cases: zero-initialized A is A.$default (tag 0), falls to _ =>
type A {
	case _;
}
type A.B {
	case P;
	case Q;
}
def classify(a: A) -> int {
	match (a) {
		B => return 2;
		_ => return 99;
	}
}
def main(arg: int) -> int {
	var a: A;				// zero-initialized: A.$default (tag 0), not in B's range
	if (arg == 0) return classify(a);		// $default → 99
	if (arg == 1) { a = A.B.P; return classify(a); }	// P ∈ B range → 2
	if (arg == 2) { a = A.B.Q; return classify(a); }	// Q ∈ B range → 2
	if (arg == 3) return classify(A.B.P);		// direct → 2
	return classify(a);				// zero-init fallthrough → 99
}
