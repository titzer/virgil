//@seman = UnresolvedMember @ 24:40
type A {
	case X;
	case _;
}
type B extends A {
	case Y;
	case Z;
}
def takesB(b: A.B) -> int {
	match (b) {
		Y => return 10;
		Z => return 20;
	}
}
def process(a: A) -> int {
	match (a) {
		x: B => return takesB(x);
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return process(A.B.Y);
	if (arg == 1) return process(A.B.Z);
	return process(A.X);
}
