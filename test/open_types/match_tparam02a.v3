//@execute =10
// Shorthand form: type Tree.Branch<T> (no qualifier type args)
type Tree<T> {
    case Leaf(v: T);
    case _;
}
type Branch<T> extends Tree<T> {
    case Node(v: T);
}
def main() -> int {
	var t: Tree<int> = Tree.Leaf<int>(10);
	match (t) {
	    Leaf(v) => return v;
	    b: Branch<int> => return -1;
	    _ => return -2;
	}
}
