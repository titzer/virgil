//@execute 0=5; 1=5; 2=9; 3=12
type Base {
	def t() => 0;

	case A { def t() => 0; }
	case B { def t() => 1; }
	case _;
}

type Ext<T> extends Base {
	case C  { def t() => 2; }
	case D  { def t() => 3; }
	case E  { def t() => 4; }
	case F  { def t() => 5; }
}

def f_CD<T>(f: Base -> void) => void(f(Ext<T>.C), f(Ext<T>.D));
def f_CDE<T>(f: Base -> void) => void(f(Ext<T>.C), f(Ext<T>.D), f(Ext<T>.E));
def f_DEF<T>(f: Base -> void) => void(f(Ext<T>.D), f(Ext<T>.E), f(Ext<T>.F));

var sum = 0;
def accum(b: Base) => void(sum += b.t());

def main(a: int) -> int {
	sum = 0;
	match (a) {
		0 => f_CD<int>(accum);
		1 => f_CD<bool>(accum);
		2 => f_CDE<int>(accum);
		3 => f_DEF<bool>(accum);
	}
	return sum;
}
