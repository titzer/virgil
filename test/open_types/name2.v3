//@execute 0=11; 1=11; 2=14; 3=15
// Check length of name when assigned to variable
type A {
    case X;
    case _;
}
type A.BB {
    case Y;
}
type A.CCC {
    case Z;
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = A.X;
    if (arg == 2) a = A.BB.Y;
    if (arg == 3) a = A.CCC.Z;
    return 10 + a.name.length;
}
