//@execute 0=1; 1=2; 2=3
// Type method ref with subtype virtual dispatch: A.kind dispatches to overrides
type A {
    case _;
    def kind() -> int { return 1; }
}
type A.B {
    case P;
    def kind() -> int { return 2; }
}
type A.C {
    case R;
    def kind() -> int { return 3; }
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = A.B.P;
    if (arg == 2) a = A.C.R;
    var f = A.kind;
    return f(a);
}
