//@execute 0=1025; 1=2050; 2=4; 3=16; 4=32768; 5=!BoundsCheckException
type Base {
	case A;
	case B;
	case _;
}
type Ext<T> extends Base {
	case C;
	case D;
	case E;
	case F;
}

def doQueries<T>(v: Base) -> int {
	var result = 0;
	if (Base.A.?(v))   result |=  1;
	if (Base.B.?(v))   result |=  2;
	if (Ext<T>.C.?(v)) result |=  4;
	if (Ext<T>.D.?(v)) result |=  8;
	if (Ext<T>.E.?(v)) result |= 16;
	if (Ext<T>.F.?(v))  result |= 32;
	return result;
}

def vs: Array<Base> = [
	Base.A,
	Base.B,
	Ext<int>.C,
	Ext<int>.E,
	Ext<bool>.F
];

def main(a: int) -> int {
	var v = vs[a];
	var result = doQueries<int>(v) | doQueries<bool>(v) << 10;
	return result;
}