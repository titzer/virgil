//@execute 0=1; 1=2; 2=3; 3=5; 4=10; 5=!BoundsCheckException
type Base {
	case A;
	case B;
	case _;
}
type Ext<T> extends Base {
	case C;
	case D;
	case E;
	case F;
}

def vs: Array<Base> = [
	Base.A,
	Base.B,
	Ext<int>.C,
	Ext<int>.E,
	Ext<bool>.F
];

def f1  = Base.A.?<Base>;
def f2  = Base.B.?<Base>;
def f3  = Ext<int>.C.?<Base>;
def f4  = Ext<int>.D.?<Base>;
def f5  = Ext<int>.E.?<Base>;
def f6  = Ext<int>.F.?<Base>;
def f7  = Ext<bool>.C.?<Base>;
def f8  = Ext<bool>.D.?<Base>;
def f9  = Ext<bool>.E.?<Base>;
def f10 = Ext<bool>.F.?<Base>;

def main(a: int) -> int {
	var v = vs[a];
	if (f3(v)) 	return 3;
	if (f4(v)) 	return 4;
	if (f7(v)) 	return 7;
	if (f8(v)) 	return 8;
	if (f1(v))	return 1;
	if (f2(v))   	return 2;
	if (f9(v)) 	return 9;
	if (f10(v)) 	return 10;
	if (f5(v)) 	return 5;
	if (f6(v)) 	return 6;
	return 0;
}
