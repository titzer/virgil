//@execute 0=1; 1=2; 2=3; 3=5; 4=10; 5=!BoundsCheckException
type Base {
	case A;
	case B;
	case _;
}
type Ext<T> extends Base {
	case C;
	case D;
	case E;
	case F;
}

def vs: Array<Base> = [
	Base.A,
	Base.B,
	Ext<int>.C,
	Ext<int>.E,
	Ext<bool>.F
];

def main(a: int) -> int {
	var v = vs[a];
	if (Base.A.?(v))	return 1;
	if (Base.B.?(v))   	return 2;
	if (Ext<int>.C.?(v)) 	return 3;
	if (Ext<int>.D.?(v)) 	return 4;
	if (Ext<int>.E.?(v)) 	return 5;
	if (Ext<int>.F.?(v)) 	return 6;
	if (Ext<bool>.C.?(v)) 	return 7;
	if (Ext<bool>.D.?(v)) 	return 8;
	if (Ext<bool>.E.?(v)) 	return 9;
	if (Ext<bool>.F.?(v)) 	return 10;
	return 0;
}
