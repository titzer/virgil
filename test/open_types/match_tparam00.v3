//@execute 0=42; 1=99; 2=0
// Construction and field access with parameterized subtype
type Foo<T> {
    case A(v: T);
    case _;
}
type Foo<T>.Bar<T> {
    case B(v: T);
}
def main(arg: int) -> int {
    if (arg == 0) {
        var x: Foo<int> = Foo<int>.Bar.B(42);
        match (x) {
            A(v) => return v;
            b: Bar => match (b) {
                B(v) => return v;
            }
            _ => return -1;
        }
    }
    if (arg == 1) {
        var x: Foo<int> = Foo.A<int>(99);
        match (x) {
            A(v) => return v;
            b: Bar => return -1;
            _ => return -1;
        }
    }
    return 0;
}
