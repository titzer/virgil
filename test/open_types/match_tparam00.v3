//@execute 0=42; 1=99; 2=0
// Construction and field access with parameterized subtype
type Foo<T> {
	case A(v: T);
	case _;
}
type Bar<T> extends Foo<T> {
	case B(v: T);
}
def main(arg: int) -> int {
	if (arg == 0) {
		var x: Foo<int> = Bar<int>.B(42);
		match (x) {
			A(v) => return v;
			b: Bar<int> => match (b) {
				B(v) => return v;
			}
			_ => return -1;
		}
	}
	if (arg == 1) {
		var x: Foo<int> = Foo<int>.A(99);
		match (x) {
			A(v) => return v;
			b: Bar<int> => return -1;
			_ => return -1;
		}
	}
	return 0;
}
