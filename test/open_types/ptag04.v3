//@execute 0=42; 1=42; 2=42
type Base<T> {
	case A;
	case B;
	case _;
}
type C<T> extends Base<T> {
	case CA;
	case CB;
}
type D<T> extends Base<T> {
	case DA;
	case DB;
}

class Tagger {
	def get(i: int) -> int;
}

class TaggerOf<T> extends Tagger {
	def d = [Base<T>.A, Base<T>.B, C<T>.CA, C<T>.CB, D<T>.DA, D<T>.DB];
	def get(i: int) -> int {
		return d[i].tag;
	}
}

def ts: Array<Tagger> = [TaggerOf<int>.new(), TaggerOf<byte>.new(), TaggerOf<void>.new()];

def main(a: int) -> int {
	var t = ts[a];
	for (i < 6) {
		if (t.get(i) != i) return 0 - i;
	}
	return 42;
}
