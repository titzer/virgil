//@execute 0=1025; 1=2050; 2=4; 3=16; 4=32768; 5=!BoundsCheckException
type Base {
	case A;
	case B;
	case _;
}
type Ext<T> extends Base {
	case C;
	case D;
	case E;
	case F;
}

def qt<T>() -> Array<Base -> bool> {
	return [
		Base.A.?,
		Base.B.?,
		Ext<T>.C.?,
		Ext<T>.D.?,
		Ext<T>.E.?,
		Ext<T>.F.?
	];
}

def qi = qt<int>();
def qz = qt<bool>();

def vs: Array<Base> = [
	Base.A,
	Base.B,
	Ext<int>.C,
	Ext<int>.E,
	Ext<bool>.F
];

def doQueries(v: Base, q: Array<Base -> bool>) -> int {
	var result = 0;
	for (i < q.length) {
		if (q[i](v)) result |= (1 << byte.!(i));
	}
	return result;
}

def main(a: int) -> int {
	var v = vs[a];
	var result = doQueries(v, qi) | doQueries(v, qz) << 10;
	return result;
}