//@execute 0=true; 1=true; 2=false; 3=false
type Base {
	def m() -> int;

	case _;
}

type One<T>(x: T) extends Base {
	def m() => 1;
}
type Two(x: int, y: int) extends Base {
	def m() => x + y;
}

def bs = [Two(10, 22), Two(30, 3), One<int>(20), One<bool>(false)];

def main(a: int) => Two.?(bs[a]);
