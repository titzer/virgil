//@execute 0=148; 1=156
type Base {
	def m<T>(a: T) -> T { return a; }
	case _;
}
type Ext extends Base {
	case A {
		def m<T>(a: T) -> T {
			match (a) {
				x: byte => return T.!(x + 5u8);
				x: int => return T.!(x + 11);
				x: string => return T.!("bad");
			}
			return a;
		}
	}
}

def d: Base;
def bs: Array<Base> = [d, Ext.A];

def main(a: int) -> int {
	var v = bs[a];
	return v.m<int>(44) + v.m<byte>(99) + v.m<string>("blarg").length;
}
