//@execute 0=10; 1=20; 2=30
// Shorthand form: type Tree.Branch<T> (no qualifier type args)
type Tree<T> {
    case Leaf(v: T);
    case _;
}
type Tree.Branch<T> {
    case Node(v: T);
}
def main(arg: int) -> int {
    if (arg == 0) {
        var t: Tree<int> = Tree.Leaf<int>(10);
        match (t) {
            Leaf(v) => return v;
            b: Branch => return -1;
            _ => return -2;
        }
    }
    if (arg == 1) {
        var t: Tree<int> = Tree<int>.Branch.Node(20);
        match (t) {
            Leaf(v) => return v;
            b: Branch => match (b) {
                Node(v) => return v;
            }
            _ => return -2;
        }
    }
    if (arg == 2) {
        var t = Tree<int>.Branch.Node(30);
        match (t) {
            Node(v) => return v;
        }
    }
    return 0;
}
