//@execute 0=42; 1=7
// Parameterized subtype with method
type Result<T> {
    case Ok(v: T);
    case _;
}
type Result<T>.Err<T> {
    case Error(code: int);
}
def unwrap<T>(r: Result<T>, fallback: T) -> T {
    match (r) {
        Ok(v) => return v;
        e: Err => match (e) {
            Error(code) => return fallback;
        }
        _ => return fallback;
    }
}
def main(arg: int) -> int {
    if (arg == 0) return unwrap(Result.Ok<int>(42), 0);
    if (arg == 1) return unwrap(Result<int>.Err.Error(404), 7);
    return 0;
}
