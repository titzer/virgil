//@execute 0=1; 1=2; 2=3
type A {
    case _;
    def kind() -> int { return 1; }
}
type B extends A {
    case P;
    case Q;
    def kind() -> int { return 2; }
}
type C extends A {
    case R;
    def kind() -> int { return 3; }
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 0) return a.kind();
    if (arg == 1) a = B.P;
    else a = C.R;
    return a.kind();
}
