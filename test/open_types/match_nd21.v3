//@execute 0=1; 1=2; 2=3; 3=4
// Type method ref through multi-level hierarchy with virtual dispatch
type A {
    case _;
    def kind() -> int { return 1; }
}
type B extends A {
    case P;
    case _;
    def kind() -> int { return 2; }
}
type C extends B {
    case Q;
    def kind() -> int { return 3; }
}
type D extends A {
    case R;
    def kind() -> int { return 4; }
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = B.P;
    if (arg == 2) a = C.Q;
    if (arg == 3) a = D.R;
    var f = A.kind;
    return f(a);
}
