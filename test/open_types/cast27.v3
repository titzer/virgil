//@execute 0=11; 1=0; 2=0; 3=11
type X<T> {
	def m() => -999;
	case _;
}
type A<T>(x: int) extends X<T> {
	def m() => x;
}
def main(a: int) -> int {
	if (a == 1) return cast_byte<byte>().m();
	if (a == 2) return cast_int<int>().m();
	return 11;
}
def cast_byte<T>() -> X<T> {
	var d: X<byte> = A<byte>(0);
	return X<T>.!(d);
}
def cast_int<T>() -> X<T> {
	var d: X<int> = A<int>(0);
	return X<T>.!(d);
}
