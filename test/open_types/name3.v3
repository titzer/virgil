//@execute 0=11; 1=11; 2=12; 3=13
// Check length of shortName when assigned to variable
type A {
    case X;
    case _;
}
type A.BB {
    case YY;
}
type A.CCC {
    case ZZZ;
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = A.X;
    if (arg == 2) a = A.BB.YY;
    if (arg == 3) a = A.CCC.ZZZ;
    return 10 + a.shortName.length;
}
