//@execute 0=1; 1=11; 2=11; 3=12
// Check length of shortName
type A {
    case X;
    case _;
}
type A.BB {
    case Y;
}
type A.CCC {
    case ZZ;
}
def main(arg: int) -> int {
    var a = A.BB.Y;
    if (arg == 1) return 10 + A.X.shortName.length;
    if (arg == 2) return 10 + A.BB.Y.shortName.length;
    if (arg == 3) return 10 + A.CCC.ZZ.shortName.length;
    return 1;
}
