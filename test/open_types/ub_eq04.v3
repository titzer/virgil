//@execute 0=true;1=false;2=true;3=false;4=true;5=false
type A #unboxed {
	case X(b: B);
	case _;
}
type S extends A #unboxed {
	case Y;
}

type B {
	case X(x: int);
	case Y(y: int);
}

def arr1 = [A.X(B.X(12)), A.X(B.X(12)), A.X(B.Y(34)), A.X(B.Y(56)), S.Y, S.Y];
def arr2 = [A.X(B.X(12)), A.X(B.X(34)), A.X(B.Y(34)), S.Y, S.Y, A.X(B.X(7))];

def main(a: int) -> bool {
	return arr1[a] == arr2[a];
}