//@execute 0=10; 1=20; 2=99
// x: B => binds x as A.B, allowing it to be used where A.B is expected
type A {
	case X;
	case _;
}
type A.B {
	case Y;
	case Z;
}
def takesB(b: A.B) -> int {
	match (b) {
		Y => return 10;
		Z => return 20;
	}
}
def process(a: A) -> int {
	match (a) {
		x: B => return takesB(x);
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return process(A.B.Y);
	if (arg == 1) return process(A.B.Z);
	return process(A.X);
}
