//@execute 0=4; 1=5; 2=6; 3=!BoundsCheckException
type Base<T> {
	case A;
	case _;
}
type Ext_int extends Base<int> {
	case B;
	case C;
}
type Ext_bool extends Base<bool> {
	case D;
	case E;
}

def ci: Array<Base<int>> = [
	Base<int>.A,
	Ext_int.B,
	Ext_int.C
];
def cb: Array<Base<bool>> = [
	Ext_bool.E,
	Ext_bool.E,
	Ext_bool.E
];

def main(a: int) -> int {
	return int.view(ci[a].tag) + int.view(cb[a].tag);
}