//@execute =0
type A #unboxed {
	case X;
	case _;
}
type B extends A #unboxed {
	case Y(x: int);
}

def eq = A.==;

def f() -> A {
	return A.X;
}

def main() -> int {
	var x: A = A.X;
	if (!eq(x, A.X)) return -1;

	x = B.Y(14);
	if (eq(x, A.X)) return -2;
	if (!eq(x, B.Y(14))) return -3;

	x = f();
	if (!eq(x, A.X)) return -4;

	return 0;
}
