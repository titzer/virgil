//@execute 0=10; 1=20; 2=10; 3=20; 4=1
// A.B values stored in A-typed variables; x: B => retrieves them as A.B
type A {
	case X;
	case _;
}
type A.B {
	case Y;
	case Z;
}
def takesB(b: A.B) -> int {
	match (b) {
		Y => return 10;
		Z => return 20;
	}
}
def main(arg: int) -> int {
	var a: A;
	if (arg == 0) a = A.B.Y;
	else if (arg == 1) a = A.B.Z;
	else if (arg == 2) { var b: A.B = A.B.Y; a = b; }
	else if (arg == 3) { var b: A.B = A.B.Z; a = b; }
	else a = A.X;
	match (a) {
		x: B => return takesB(x);
		_ => return 1;
	}
}
