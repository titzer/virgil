//@execute 0=11; 1=22; 2=33
// Closure stored in array, dispatching through subtype overrides
type A {
    case _;
    def kind() -> int { return 11; }
}
type B extends A {
    case P;
    def kind() -> int { return 22; }
}
type C extends A {
    case R;
    def kind() -> int { return 33; }
}
def getClosures() -> Array<void -> int> {
    var a0: A;
    var a1: A = B.P;
    var a2: A = C.R;
    return [a0.kind, a1.kind, a2.kind];
}
def main(arg: int) -> int {
    return getClosures()[arg]();
}
