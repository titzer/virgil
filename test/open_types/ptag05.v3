//@execute (0,0)=0; (0,1)=1; (0,3)=0; (1,0)=0; (1,1)=1; (1, 3)=3; (1,5)=0; (2,0)=0; (2,1)=0; (2,2)=0; (2,3)=3
type Base<T> {
	case A;
	case B;
	case _;
}
type C<T> extends Base<T> {
	case CA;
	case CB;
}
type D<T> extends Base<T> {
	case DA;
	case DB;
}

class Tagger {
	def get(i: int) -> int;
	def del(i: int) -> this;
}

class TaggerOf<T> extends Tagger {
	def d = [Base<T>.A, Base<T>.B, C<T>.CA, C<T>.CB, D<T>.DA, D<T>.DA];
	def get(i: int) -> int {
		return d[i].tag;
	}
	def del(i: int) -> this {
		d[i] = Base<T>.A;
	}
}

def t1: Tagger = TaggerOf<int>.new().del(3);
def t2: Tagger = TaggerOf<byte>.new().del(4).del(5);
def t3: Tagger = TaggerOf<void>.new().del(1).del(2);

def ts = [t1, t2, t3];

def main(a: int, i: int) => ts[a].get(i);
