//@execute 0=42; 1=99; 2=0
type Foo<T> {
	case A(v: T);
	case _;
}
type Bar<T> extends Foo<T> {
	case B(v: T);
}
def m1(y: Foo<int>) -> int {
	match (y) {
		A(v) => return v;
		b: Bar<int> => match (b) {
			B(v) => return v;
		}
		_ => return -1;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return m1(Bar<int>.B(42));
	if (arg == 1) return m1(Foo<int>.A(99));
	return 0;
}
