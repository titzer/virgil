//@execute 0=1; 1=2; 2=3
// Type method ref with case _ body override and subtype inheritance
type A {
    case X;
    case _ {
        def kind() -> int { return 2; }
    }
    def kind() -> int { return 1; }
}
type A.B {
    case Y;
    def kind() -> int { return 3; }
}
type A.C {
    case Z;
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = A.C.Z;
    if (arg == 2) a = A.B.Y;
    var f = A.kind;
    return f(a);
}
