//@execute 0=42; 1=14; 2=30
def shared<T>(t: int) -> int {
	return t;
}
def array<T>(t: int) -> int {
	return Array<T>.new(t).length;
}
type A<T> {
	def m() -> int { return shared<T>(1); }
	def n() -> int { return array<T>(2); }
	def o() -> int { return shared<T>(3); }
	case X;
	case _;
}
type B<T> extends A<T> {
	def m() -> int { return shared<T>(11); }
	def n() -> int { return array<T>(12); }
	def o() -> int { return shared<T>(13); }
	case Y;
}
def main(a: int) -> int {
	match (a) {
		0 => return x(0) + x(1);
		1 => return y(0) + y(1);
	} else return z(0) + z(1);
}
def x(i: int) -> int {
	var o = if(i == 0, A<byte>.X, B<byte>.Y);
	return o.m() + o.n() + o.o();
}
def y(i: int) -> int {
	var o = if(i == 0, A<bool>.X, B<bool>.Y);
	return o.n();
}
def z(i: int) -> int {
	var o = if(i == 0, A<int>.X, B<int>.Y);
	return o.n() + o.o();
}
