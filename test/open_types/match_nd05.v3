//@execute 0=1; 1=2; 2=2; 3=2; 4=3; 5=4; 6=5
// Multi-level subtypes: A.B.C.D covered by B => in A-match; C => in B-match
type A {
	case X;
	case _;
}
type B extends A {
	case Y;
	case Z;
	case _;
}
type C extends B {
	case D;
	case E;
}
def classifyA(a: A) -> int {
	match (a) {
		X => return 1;
		x: B => return 2;
		_ => return 99;
	}
}
def classifyB(b: B) -> int {
	match (b) {
		Y => return 3;
		Z => return 4;
		x: C => return 5;
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return classifyA(A.X);
	if (arg == 1) return classifyA(B.Y);
	if (arg == 2) return classifyA(B.Z);
	if (arg == 3) return classifyA(C.D);
	if (arg == 4) return classifyB(B.Y);
	if (arg == 5) return classifyB(B.Z);
	return classifyB(C.E);
}
