//@execute 0=1; 1=11; 2=14; 3=15
// Check length of name
type A {
    case X;
    case _;
}
type A.BB {
    case Y;
}
type A.CCC {
    case Z;
}
def main(arg: int) -> int {
    var a = A.BB.Y;
    if (arg == 1) return 10 + A.X.name.length;
    if (arg == 2) return 10 + A.BB.Y.name.length;
    if (arg == 3) return 10 + A.CCC.Z.name.length;
    return 1;
}
