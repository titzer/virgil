//@execute 0=878082218; 1=1; 2=2; 3=3; 4=878082234; 5=1; 6=2; 7=3; 8=878016682; 9=1; 10=2; 11=3; 12=!BoundsCheckException
type X #unboxed {
	def m() => 0;

	case A(v: u30) { def m() => int.!(v); }
	case _;
}
type Y<T> extends X #unboxed {
	case B(v: u30);
	case C(v: u30);
	case D(v: u30);
}

def vs: Array<X> = [
	X.A(0x345678AA), Y<void>.B(0x3F00FF0A), Y<void>.C(1000000), Y<void>.D(4000000),
	X.A(0x345678BA), Y<byte>.B(0x3F00EF0A), Y<byte>.C(2000000), Y<byte>.D(5000000),
	X.A(0x345578AA), Y<byte>.B(0x3E00FF0A), Y<long>.C(3000000), Y<long>.D(6000000)
];

def main(a: int) -> int {
	var v = vs[a];
	return v.tag + v.m();
}