//@execute 0=1025; 1=2050; 2=4; 3=16; 4=32768
type Base {
	case A;
	case B;
	case _;
}
type Ext<T> extends Base {
	case C(x: int);
	case D;
	case E;
	case F;
}

def qt<T>() -> Array<Base -> bool> {
	return [
		Base.A.?,
		Base.B.?,
		Ext<T>.C.?,
		Ext<T>.D.?,
		Ext<T>.E.?,
		Ext<T>.F.?
	];
}

def qi = qt<int>();
def qz = qt<bool>();

def vs: Array<Base> = [
	Base.A,
	Base.B,
	Ext<int>.C(22),
	Ext<int>.E,
	Ext<bool>.F
];

def main(a: int) -> int {
	var v = vs[a];
	var result = 0;
	for (i < qi.length) {
		if (qi[i](v)) result |= (1 << byte.!(i));
	}
	for (i < qz.length) {
		if (qz[i](v)) result |= (1 << byte.!(i + 10));
	}
	return result;
}