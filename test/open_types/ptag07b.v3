//@execute 0=11000; 1=11000; 2=111000; 3=1110000
type Base {
	def t() => 1;

	case A { def t() => 10; }
	case B { def t() => 100; }
	case _;
}

type Ext<T> extends Base {
	case C  { def t() => 1000; }
	case D  { def t() => 10000; }
	case E  { def t() => 100000; }
	case F  { def t() => 1000000; }
}

def f_CD<T>(f: Base -> void) => void(f(Ext<T>.C), f(Ext<T>.D));
def f_CDE<T>(f: Base -> void) => void(f(Ext<T>.C), f(Ext<T>.D), f(Ext<T>.E));
def f_DEF<T>(f: Base -> void) => void(f(Ext<T>.D), f(Ext<T>.E), f(Ext<T>.F));

var sum = 0;
def accum(b: Base) => void(sum += b.t());

def main(a: int) -> int {
	sum = 0;
	match (a) {
		0 => f_CD<int>(accum);
		1 => f_CD<bool>(accum);
		2 => f_CDE<int>(accum);
		3 => f_DEF<bool>(accum);
	}
	return sum;
}
