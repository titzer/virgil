//@execute 0=11; 1=21; 2=31; 3=41; 4=!BoundsCheckException
type A {
	case X;
	case Y;
	case _;
}
type B extends A {
	case Z;
	case W;
}
def cases = [A.X, A.Y, B.Z, B.W];
def main(arg: int) -> int {
	match (cases[arg]) {
		x: A.X => return 11;
		x: A.Y => return 21;
		x: B.Z => return 31;
		x: B.W => return 41;
		x: _ => return 42;
	}
}
