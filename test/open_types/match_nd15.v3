//@execute 0=1; 1=2; 2=3
// Closure of variant method: case _ body, subtype override, subtype inherit
type A {
    case X;
    case _ {
        def kind() -> int { return 2; }
    }
    def kind() -> int { return 1; }
}
type B extends A {
    case Y;
    def kind() -> int { return 3; }
}
type C extends A {
    case Z;
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = C.Z;
    if (arg == 2) a = B.Y;
    var f = a.kind;
    return f();
}
