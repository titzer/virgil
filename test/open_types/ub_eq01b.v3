//@execute =0
type A #unboxed {
	case X;
	case _;
}
type B extends A #unboxed {
	case Y(x: int);
}

def f() -> A {
	return A.X;
}

def main() -> int {
	var x: A = A.X;
	if (x != A.X) return -1;

	x = B.Y(12);
	if (x == A.X) return -2;
	if (x != B.Y(12)) return -3;

	x = f();
	if (x != A.X) return -4;

	return 0;
}
