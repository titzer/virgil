//@execute 0=1; 1=2; 2=3; 3=5; 4=10; 5=!BoundsCheckException
type Base {
	case A;
	case B;
	case _;
}
type Ext<T> extends Base {
	case C;
	case D;
	case E;
	case F;
}

def vs: Array<Base> = [
	Base.A,
	Base.B,
	Ext<int>.C,
	Ext<int>.E,
	Ext<bool>.F
];

def f1(v: Base)  => Base.A.?(v);
def f2(v: Base)  => Base.B.?(v);
def f3(v: Base)  => Ext<int>.C.?(v);
def f4(v: Base)  => Ext<int>.D.?(v);
def f5(v: Base)  => Ext<int>.E.?(v);
def f6(v: Base)  => Ext<int>.F.?(v);
def f7(v: Base)  => Ext<bool>.C.?(v);
def f8(v: Base)  => Ext<bool>.D.?(v);
def f9(v: Base)  => Ext<bool>.E.?(v);
def f10(v: Base) => Ext<bool>.F.?(v);

def main(a: int) -> int {
	var v = vs[a];
	if (f3(v)) 	return 3;
	if (f4(v)) 	return 4;
	if (f7(v)) 	return 7;
	if (f8(v)) 	return 8;
	if (f1(v))	return 1;
	if (f2(v))   	return 2;
	if (f9(v)) 	return 9;
	if (f10(v)) 	return 10;
	if (f5(v)) 	return 5;
	if (f6(v)) 	return 6;
	return 0;
}
