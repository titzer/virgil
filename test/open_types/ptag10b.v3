//@execute 0=0; 1=1; 2=2; 3=3; 4=0; 5=1; 6=2; 7=3; 8=0; 9=1; 10=2; 11=3; 12=!BoundsCheckException
type X #unboxed {
	case A(v: i30);
	case _;
}
type Y<T> extends X #unboxed {
	case B(v: i30);
	case C(v: i30);
	case D(v: i30);
}

def vs: Array<X> = [
	X.A(0xF45678AA), Y<void>.B(0xFF00FF0A), Y<void>.C(-1), Y<void>.D(-1),
	X.A(0xF45678BA), Y<byte>.B(0xFF00EF0A), Y<byte>.C(-1), Y<byte>.D(-1),
	X.A(0xF45578AA), Y<byte>.B(0xFE00FF0A), Y<long>.C(-1), Y<long>.D(-1)
];

def main(a: int) -> int {
	return vs[a].tag;
}