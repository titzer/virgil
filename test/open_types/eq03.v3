//@execute 0=0; 1=1; 2=2; 3=3; 4=4; 5=!BoundsCheckException
type T {
	case A(x: int);
	case _;
}
type U extends T {
	case B(x: int);
	case C(x: int);
}

def vs = [
	T.A(11), T.A(22), U.B(33), U.C(44), U.B(55)
];

def main(j: int) -> int {
	var v = vs[j];
	for (i < vs.length) {
		if (vs[i] == v) return i;
	}
	return -11;
}
