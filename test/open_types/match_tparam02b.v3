//@execute = 20
// Shorthand form: type Tree.Branch<T> (no qualifier type args)
type Tree<T> {
    case Leaf(v: T);
    case _;
}
type Branch<T> extends Tree<T> {
    case Node(v: T);
}
def main() -> int {
	var t: Tree<int> = Branch<int>.Node(20);
	match (t) {
	    Leaf(v) => return v;
	    b: Branch<int> => match (b) {
		Node(v) => return v;
	    }
	    _ => return -2;
	}
}
