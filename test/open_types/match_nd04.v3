//@execute 0=1; 1=2; 2=2; 3=3; 4=99
// B => and C => dispatch to sibling subtypes; tags are non-overlapping ranges
type A {
	case X;
	case _;
}
type A.B {
	case Y;
	case Z;
}
type A.C {
	case W;
}
def classify(a: A) -> int {
	match (a) {
		X => return 1;
		B => return 2;
		C => return 3;
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return classify(A.X);
	if (arg == 1) return classify(A.B.Y);
	if (arg == 2) return classify(A.B.Z);
	if (arg == 3) return classify(A.C.W);
	return 99;
}
