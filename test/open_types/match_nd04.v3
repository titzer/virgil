//@execute 0=1; 1=2; 2=2; 3=3; 4=99
// B => and C => dispatch to sibling subtypes; tags are non-overlapping ranges
type A {
	case X;
	case _;
}
type B extends A {
	case Y;
	case Z;
}
type C extends A {
	case W;
}
def classify(a: A) -> int {
	match (a) {
		X => return 1;
		x: B => return 2;
		x: C => return 3;
		_ => return 99;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return classify(A.X);
	if (arg == 1) return classify(B.Y);
	if (arg == 2) return classify(B.Z);
	if (arg == 3) return classify(C.W);
	return 99;
}
