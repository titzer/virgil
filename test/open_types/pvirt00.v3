//@execute 0=-33; 1=11; 2=22; 3=33
type Base {
	def m() => -33;
	case _;
}
type Ext<T> extends Base {
	def m() -> int {
		match (this) {
			x: Ext<int> => return 11;
			x: Ext<bool> => return 22;
			x: Ext<void> => return 33;
//			_ => return -99;
		}
	}
}

def b: Base;
def e_int: Ext<int>;
def e_bool: Ext<bool>;
def e_void: Ext<void>;

def cs = [b, e_int, e_bool, e_void];

def main(a: int) -> int {
	return cs[a].m();
}