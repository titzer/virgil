//@execute 0=42; 1=1; 2=99
// Multiple instantiations of same parameterized subtype
type Opt<T> {
    case None;
    case Some(v: T);
    case _;
}
type Cached<T> extends Opt<T> {
    case Hit(v: T);
}
def main(arg: int) -> int {
    if (arg == 0) {
        var x: Opt<int> = Cached.Hit(42);
        match (x) {
            None => return -1;
            Some(v) => return v;
            c: Cached<int> => match (c) {
                Hit(v) => return v;
            }
            _ => return -2;
        }
    }
    if (arg == 1) {
        var x: Opt<bool> = Cached.Hit(true);
        match (x) {
            None => return 0;
            Some(v) => return -1;
            c: Cached<bool> => match (c) {
                Hit(v) => if (v) return 1; else return 0;
            }
            _ => return -2;
        }
    }
    if (arg == 2) {
        var x: Opt<int> = Opt.Some<int>(99);
        match (x) {
            None => return -1;
            Some(v) => return v;
            c: Cached<int> => return -2;
            _ => return -3;
        }
    }
    return 0;
}
