//@execute 0=1025; 1=2050; 2=4; 3=16; 4=32768; 5=!BoundsCheckException
type Base {
	case A;
	case B;
	case _;
}
type Ext<T> extends Base {
	case C;
	case D;
	case E;
	case F;
}

def doQueries<T>(v: Base, shift: u5) {
	if (Base.A.?(v))   result |=  (1 << shift);
	if (Base.B.?(v))   result |=  (2 << shift);
	if (Ext<T>.C.?(v)) result |=  (4 << shift);
	if (Ext<T>.D.?(v)) result |=  (8 << shift);
	if (Ext<T>.E.?(v)) result |= (16 << shift);
	if (Ext<T>.F.?(v)) result |= (32 << shift);
}

def vs: Array<Base> = [
	Base.A,
	Base.B,
	Ext<int>.C,
	Ext<int>.E,
	Ext<bool>.F
];

var result = 0;
def main(a: int) -> int {
	result = 0;
	var v = vs[a];
	doQueries<int>(v, 0);
	doQueries<bool>(v, 10);
	return result;
}
