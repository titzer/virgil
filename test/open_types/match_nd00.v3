//@execute 0=11; 1=22; 2=33
// x: _ binds the matched value to x; verify x holds the correct value by re-matching it
type Color {
	case Red;
	case Green;
	case Blue;
}
def getValue(c: Color) -> int {
	match (c) {
		Red => return 11;
		x: _ => return getOther(x);
	}
}
def getOther(c: Color) -> int {
	match (c) {
		Green => return 22;
		_ => return 33;
	}
}
def main(arg: int) -> int {
	if (arg == 0) return getValue(Color.Red);
	if (arg == 1) return getValue(Color.Green);
	return getValue(Color.Blue);
}
