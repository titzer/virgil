//@execute 0=42; 1=42; 2=-200; 3=-300; 4=-9000; 5=-8000
type T #unboxed {
	case A;
	case _;
}
type V<E> extends T #unboxed {
	case B(x: i31);
}

def vs = [
	T.A, T.A, V<void>.B(-200), V<void>.B(-300), V<byte>.B(-9000), V<byte>.B(-8000)
];

def main(a: int) -> int {
	match (vs[a]) {
		x: T.A => return 42;
		x: V<void>.B => return x.x;
		x: V<byte>.B => return x.x;
		_ => return 44;
	}
}
