//@execute 0=11; 1=33; 2=11
type X<T> {
	case _;
	def m() -> int {
		match(this) {
			x: A<T> => return int.!(x.x);
			_ => return -999;
		}
	}
}
type A<T>(x: T) extends X<T> { }
def main(a: int) -> int {
	if (a == 1) return cast<byte>().m();
	return 11;
}
def cast<T>() -> X<T> {
	var d: X<byte> = A<byte>(33);
	return X<T>.!(d);
}
