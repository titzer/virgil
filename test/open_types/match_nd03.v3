//@execute 0=10; 1=20; 2=10; 3=20
// Qualified construction A.B.Y/A.B.Z; function with A.B parameter and return type
type A {
	case None;
	case _;
}
type A.B {
	case Y;
	case Z;
}
def takesB(b: A.B) -> int {
	match (b) {
		Y => return 10;
		Z => return 20;
	}
}
def makeB(which: int) -> A.B {
	if (which == 0) return A.B.Y;
	return A.B.Z;
}
def main(arg: int) -> int {
	if (arg == 0) return takesB(A.B.Y);
	if (arg == 1) return takesB(A.B.Z);
	if (arg == 2) return takesB(makeB(0));
	return takesB(makeB(1));
}
