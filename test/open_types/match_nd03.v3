//@execute 0=10; 1=20; 2=10; 3=20
// Qualified construction A.B.Y/A.B.Z; function with A.B parameter and return type
type A {
	case None;
	case _;
}
type B extends A {
	case Y;
	case Z;
}
def takesB(b: B) -> int {
	match (b) {
		Y => return 10;
		Z => return 20;
	}
}
def makeB(which: int) -> B {
	if (which == 0) return B.Y;
	return B.Z;
}
def main(arg: int) -> int {
	if (arg == 0) return takesB(B.Y);
	if (arg == 1) return takesB(B.Z);
	if (arg == 2) return takesB(makeB(0));
	return takesB(makeB(1));
}
