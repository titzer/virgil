//@execute 0=true;1=false;2=false;3=true;4=true;5=true
type T #unboxed {
	case A(x: bool) { def f() -> int { return if(x, 123, 456); } }
	case B(x: int) { def f() -> int { return x; } }
	case _;

	def f() -> int;
}

type U extends T #unboxed {
	case C(x: long) { def f() -> int { return int.view(x) * 2; } }
}

def arr = [
	T.A(true),
	T.A(false),
	T.A(true),
	T.A(false),
	T.B(12),
	U.C(34l)
];

def arr2 = [
	T.A(true),
	T.A(true),
	T.A(false),
	T.A(false),
	T.B(12),
	U.C(34l)
];

def main(a: int) -> bool {
	return arr[a] == arr2[a];
}