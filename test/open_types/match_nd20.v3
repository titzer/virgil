//@execute 0=2; 1=3
// Subtype method reference: A.B.kind gives f: A.B -> int
type A {
    case _;
    def kind() -> int { return 1; }
}
type B extends A {
    case P;
    case Q;
    def kind() -> int {
        match (this) {
            P => return 2;
            Q => return 3;
        }
    }
}
def main(arg: int) -> int {
    var b: B;
    if (arg == 1) b = B.Q;
    var f = B.kind;
    return f(b);
}
