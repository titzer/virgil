//@execute 0=0; 1=1; 2=2; 3=3; 4=0; 5=1; 6=2; 7=3; 8=0; 9=1; 10=2; 11=3; 12=!BoundsCheckException
type X {
	case A;
	case _;
}
type Y<T> extends X {
	case B;
	case C;
	case D;
}

def vs: Array<X> = [
	X.A, Y<void>.B, Y<void>.C, Y<void>.D,
	X.A, Y<byte>.B, Y<byte>.C, Y<byte>.D,
	X.A, Y<long>.B, Y<long>.C, Y<long>.D
];

def main(a: int) -> int {
	return vs[a].tag;
}