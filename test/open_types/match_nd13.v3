//@execute 0=1; 1=2
// Closure of variant method with subtype override
type A {
    case _;
    def kind() -> int { return 1; }
}
type A.B {
    case P;
    def kind() -> int { return 2; }
}
def main(arg: int) -> int {
    var a: A;
    if (arg == 1) a = A.B.P;
    var f = a.kind;
    return f();
}
