//@execute = 0
type B {
	case A;
	case _;
}
type X extends B {
	case C;
	case D;
}

def bs: Array<B> = [];

def sum(bs: Array<B>) -> int {
	var sum = 0;
	for (b in bs) {
		match (b) {
			x: X.C => sum += 10;
			x: X.D => sum += 20;
			x: B.A => sum += 30;
			_ => sum += 1;
		}
	}
	return sum;
}

def main() -> int {
	return sum(bs);
}
