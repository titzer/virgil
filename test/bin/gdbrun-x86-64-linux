#!/usr/bin/env bash
# Runs gdb on an x86-64-linux binary natively; serves both the static and the
# run tier, since a native gdb can ptrace the inferior.
#
# Usage: gdbrun-x86-64-linux <dir> <binary> <gdb-script>
#
# The working directory of gdb is <dir>, which is where the compiled test
# binaries live. All output (stdout and stderr) goes to stdout.

DIR=$1
BINARY=$2
SCRIPT=$3

exec gdb -batch -nx -iex 'set confirm off' -iex 'set pagination off' \
     -iex "cd $DIR" -x "$SCRIPT" "$BINARY" 2>&1
