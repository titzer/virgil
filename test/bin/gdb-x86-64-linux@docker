#!/usr/bin/env bash
# Runs gdb on an x86-64-linux binary inside a linux/amd64 container.
#
# Usage: gdb-x86-64-linux@docker <dir> <binary> <gdb-script>
#
# Note that on hosts that emulate linux/amd64 (e.g. Apple silicon), gdb can
# read the binary but usually cannot ptrace it. The dwarf test suite probes for
# this and only runs the static tests in that case.

VIRGIL_LOC="${VIRGIL_LOC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
IMAGE=virgil-gdb-x86-64-linux

DIR=$1
BINARY=$2
SCRIPT=$3

# Build the image on first use; subsequent builds hit the docker layer cache.
if ! docker image inspect $IMAGE >/dev/null 2>&1; then
    docker build --platform linux/amd64 -q -t $IMAGE - >/dev/null 2>&1 <<'EOF'
FROM alpine:3.20
RUN apk add --no-cache gdb
EOF
    if [ $? != 0 ]; then
	echo "gdb-x86-64-linux@docker: could not build $IMAGE image" 1>&2
	exit 1
    fi
fi

exec docker run --rm --platform linux/amd64 \
     --cap-add=SYS_PTRACE --security-opt seccomp=unconfined \
     -v "$DIR:$DIR" -v "$VIRGIL_LOC:$VIRGIL_LOC:ro" --workdir "$DIR" \
     $IMAGE \
     gdb -batch -nx -iex 'set confirm off' -iex 'set pagination off' \
	 -x "$SCRIPT" "$BINARY" 2>&1
