#!/usr/bin/env bash
VIRGIL_LOC="${VIRGIL_LOC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
OUT=$1
shift

exec docker run --rm \
  --platform linux/arm64 \
  -v "$VIRGIL_LOC:$VIRGIL_LOC:ro" \
  -v "$OUT:$OUT" \
  --workdir "$PWD" \
  alpine:latest \
  "$VIRGIL_LOC/test/bin/test-arm64-linux" "$OUT" "$@"
