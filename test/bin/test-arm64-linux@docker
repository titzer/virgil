#!/usr/bin/env bash
BIN="$( cd -P "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
VIRGIL_LOC="${VIRGIL_LOC:-$(cd "$BIN/../.." && pwd)}"
OUT=$1
shift

exec docker run --rm \
  --platform linux/arm64 \
  -v "$VIRGIL_LOC:$VIRGIL_LOC:ro" \
  -v "$OUT:$OUT" \
  alpine:latest \
  "$BIN/test-arm64-linux" "$OUT" "$@"
