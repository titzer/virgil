#!/usr/bin/env bash
# Runs gdb against an x86-64-linux binary executing under qemu's user-mode
# emulator, inside a container native to the host architecture.
#
# Usage: gdbrun-x86-64-linux@qemu <dir> <binary> <gdb-script>
#
# This exists because emulating x86-64 is not enough on its own: gdb has to
# ptrace the inferior, and neither Rosetta nor qemu-user supports that, so a
# plain linux/amd64 container can read the debug info but cannot run under it.
# qemu's built-in gdb stub sidesteps ptrace entirely -- qemu itself serves the
# debug protocol -- which makes the runtime tests work on non-x86 hosts.
#
# The stub starts the program already loaded and stopped at its entry point, so
# gdb's "run" is replaced by "continue"; everything else in a script behaves the
# same as against a native gdb.
#
# The stub accepts exactly one connection, so this waits with a plain sleep
# rather than probing the port: a probe that opens a socket is taken for the
# debugger, and qemu then runs the program to completion unattended.

VIRGIL_LOC="${VIRGIL_LOC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
IMAGE=virgil-qemu-gdb
PORT=1234

DIR=$1
BINARY=$2
SCRIPT=$3

if ! docker image inspect $IMAGE >/dev/null 2>&1; then
    docker build -q -t $IMAGE - >/dev/null 2>&1 <<'EOF'
FROM debian:trixie-slim
RUN apt-get update -qq && apt-get install -y -qq qemu-user gdb-multiarch \
    && rm -rf /var/lib/apt/lists/*
EOF
    if [ $? != 0 ]; then
	echo "gdbrun-x86-64-linux@qemu: could not build $IMAGE image" 1>&2
	exit 1
    fi
fi

BASE=$(basename $BINARY)
STUB=$SCRIPT.stub
sed 's/^run$/continue/' "$SCRIPT" > "$STUB"

exec docker run --rm \
     -v "$DIR:$DIR" -v "$VIRGIL_LOC:$VIRGIL_LOC:ro" --workdir "$DIR" \
     $IMAGE \
     bash -c "qemu-x86_64 -g $PORT '$BINARY' & \
	      sleep 1; \
	      gdb-multiarch -batch -nx \
		  -iex 'set confirm off' -iex 'set pagination off' \
		  -iex 'set architecture i386:x86-64' \
		  -iex 'set sysroot /' \
		  -iex 'target remote localhost:$PORT' \
		  -x '$STUB' '$BINARY'" 2>&1 | grep -v '^qemu-x86_64: '
