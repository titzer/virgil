#!/usr/bin/env bash
# Runs the x86-linux tests under docker's linux/386 platform, which on a non-x86
# host means qemu-i386 user-mode emulation.
#
# CAVEAT: qemu-i386 does not deliver SIGSEGV or SIGFPE to the guest's own
# handler, so every trap Virgil implements as a signal -- null checks, bounds
# checks that fault, divide-by-zero -- shows up as "unexpected signal 11" or
# "unexpected signal 8" instead of the expected exception. Hundreds of tests in
# test/core and test/fsi32 fail that way here and pass on real hardware. Value
# mismatches and compiler errors reported by this runner are real; signal
# failures are not.
VIRGIL_LOC="${VIRGIL_LOC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
OUT=$1
shift

# Compute the container workdir by rebasing $PWD onto $VIRGIL_LOC using physical paths,
# so it is always inside the mounted volume regardless of symlinks in the host path.
PHYS_CWD="$(cd -P . && pwd)"
PHYS_VLOC="$(cd -P "$VIRGIL_LOC" && pwd)"
WORKDIR="${VIRGIL_LOC}${PHYS_CWD#${PHYS_VLOC}}"

exec docker run --rm \
  --platform linux/386 \
  -v "$VIRGIL_LOC:$VIRGIL_LOC:ro" \
  -v "$OUT:$OUT" \
  --workdir "$WORKDIR" \
  i386/alpine:3.20 \
  "$VIRGIL_LOC/test/bin/test-x86-linux" "$OUT" "$@"
