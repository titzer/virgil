#!/usr/bin/env bash
VIRGIL_LOC="${VIRGIL_LOC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
OUT=$1
shift

# Compute the container workdir by rebasing $PWD onto $VIRGIL_LOC using physical paths,
# so it is always inside the mounted volume regardless of symlinks in the host path.
PHYS_CWD="$(cd -P . && pwd)"
PHYS_VLOC="$(cd -P "$VIRGIL_LOC" && pwd)"
WORKDIR="${VIRGIL_LOC}${PHYS_CWD#${PHYS_VLOC}}"

exec docker run --rm \
  --platform linux/amd64 \
  -v "$VIRGIL_LOC:$VIRGIL_LOC:ro" \
  -v "$OUT:$OUT" \
  --workdir "$WORKDIR" \
  alpine:3.20 \
  "$VIRGIL_LOC/test/bin/test-x86-64-linux" "$OUT" "$@"
