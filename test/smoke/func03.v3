//@execute 0=1194784489; 1=593145758; 2=-218313954; 3=2105158201; 4=1236228389; 5=602992492; 6=103017908; 7=-1222856541; 8=-1030617742
//@heap-size=400000
// Smoke test: generics and higher-order code.
// Polymorphic methods with several type parameters, generic methods calling
// other generic methods, instantiated generic functions stored in arrays,
// tuples, globals and class fields, generic containers whose fields hold
// functions, generic variants, generic class hierarchies, and one generic
// function instantiated at int, long, float, bool, string, a class, a tuple
// and a variant in the same program. Results are mixed into a running CRC that
// main() returns, so nothing can be deleted as dead code. Interleaved are
// assert()s over compile-time constants, which the optimizer is expected to
// fold away; a folding bug sets the failure flag instead.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data and payload types
//======================================================================
def INTS: Array<int> = [0, 1, -1, 3, -7, 31, 255, -256, 65535, -1000000, 2147483647];
def LONGS: Array<long> = [0, 1, -1, 1024, -4096, 4294967296L, -9007199254740993L, 77L];
def FLOATS: Array<float> = [0f, 1f, -1f, 0.5f, -2.25f, 64f, -1024f];
def BOOLS: Array<bool> = [true, false, true, true, false];
def STRS: Array<string> = ["", "a", "gen", "polymorph", "xyzzy"];

class Obj {
	def id: int;
	var tag: int;
	new(id) { tag = id * 3; }
	def score() -> int { return id * 7 + tag; }
}
type Col {
	case Red;
	case Green(shade: int);
	case Blue(shade: int, label: string);
}
def colScore(c: Col) -> int {
	match (c) {
		Red => return 1;
		Green(s) => return 100 + s;
		Blue(s, l) => return 200 + s + l.length;
	}
}

//======================================================================
// Section 1: polymorphic methods with several type parameters
//======================================================================
def ident<T>(x: T) -> T { return x; }
def dup<T>(x: T) -> (T, T) { return (x, x); }
def pick<T>(c: bool, a: T, b: T) -> T { return if(c, a, b); }
def pairUp<A, B>(a: A, b: B) -> (A, B) { return (a, b); }
def swap2<A, B>(t: (A, B)) -> (B, A) { return (t.1, t.0); }
def rot3<A, B, C>(t: (A, B, C)) -> (C, A, B) { return (t.2, t.0, t.1); }
def apply2<A, B, C>(f: (A, B) -> C, a: A, b: B) -> C { return f(a, b); }
def flip<A, B, C>(f: (A, B) -> C) -> ((B, A) -> C) {
	return fun (b: B, a: A) => f(a, b);
}
def constf<A, B>(a: A) -> (B -> A) {
	return fun (b: B) => a;
}
def sub(a: int, b: int) -> int { return a - b; }
def cat(a: int, s: string) -> int { return a * 10 + s.length; }
def multitype() {
	var h = 0;
	for (i < INTS.length) {
		var d = dup(INTS[i]);
		h = mix(h, d.0 + d.1);
		h = mix(h, pick((i & 1) == 0, INTS[i], -INTS[i]));
		var p = pairUp(INTS[i], STRS[i % STRS.length]);
		h = mix(h, p.0);
		h = mixs(h, p.1);
		var s = swap2(p);
		h = mixs(h, s.0);
		h = mix(h, s.1);
		var r = rot3((INTS[i], LONGS[i % LONGS.length], BOOLS[i % BOOLS.length]));
		h = mixb(h, r.0);
		h = mix(h, r.1);
		h = mixl(h, r.2);
	}
	acci(h);

	var g = 0;
	var fsub: (int, int) -> int = sub;
	var fflip = flip(fsub);
	var fcat = flip<int, string, int>(cat);
	for (i < INTS.length) for (j < INTS.length) {
		g = mix(g, apply2(fsub, INTS[i], INTS[j]));
		g = mix(g, apply2(fflip, INTS[i], INTS[j]));
	}
	for (i < STRS.length) g = mix(g, fcat(STRS[i], i));
	var k7 = constf<int, string>(7);
	var kt = constf<string, int>("konst");
	for (i < STRS.length) g = mix(g, k7(STRS[i]));
	for (i < INTS.length) g = mixs(g, kt(INTS[i]));
	acci(g);

	if (ident(42) != 42) fail_assert(101);
	if (dup(5).0 != 5) fail_assert(102);
	if (dup(5).1 != 5) fail_assert(103);
	if (pick(true, 3, 4) != 3) fail_assert(104);
	if (pick(false, 3, 4) != 4) fail_assert(105);
	if (pick<long>(true, 3L, 4L) != 3L) fail_assert(106);
	if (pairUp(3, true).0 != 3) fail_assert(107);
	if (pairUp(3, true).1 != true) fail_assert(108);
	if (swap2((3, 4L)).0 != 4L) fail_assert(109);
	if (rot3((1, 2L, true)).0 != true) fail_assert(110);
	if (rot3((1, 2L, true)).1 != 1) fail_assert(111);
	if (rot3((1, 2L, true)).2 != 2L) fail_assert(112);
	if (apply2(sub, 10, 3) != 7) fail_assert(113);
	if (flip(sub)(10, 3) != -7) fail_assert(114);
	if (constf<int, string>(7)("anything") != 7) fail_assert(115);
	if (cat(4, "ab") != 42) fail_assert(116);
}

//======================================================================
// Section 2: generic methods calling other generic methods
//======================================================================
def mapg<A, B>(f: A -> B, a: Array<A>) -> Array<B> {
	var r = Array<B>.new(a.length);
	for (i < a.length) r[i] = f(a[i]);
	return r;
}
def foldg<A, B>(f: (B, A) -> B, init: B, a: Array<A>) -> B {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def zipWith<A, B, C>(f: (A, B) -> C, a: Array<A>, b: Array<B>) -> Array<C> {
	var n = if(a.length < b.length, a.length, b.length);
	var r = Array<C>.new(n);
	for (i < n) r[i] = f(a[i], b[i]);
	return r;
}
// generic on top of generic
def mapfold<A, B, C>(f: A -> B, g: (C, B) -> C, init: C, a: Array<A>) -> C {
	return foldg(g, init, mapg(f, a));
}
def sumBy<T>(a: Array<T>, f: T -> int) -> int {
	return foldg(fun (acc: int, x: T) => acc * 31 + f(x), 0, a);
}
def revg<T>(a: Array<T>) -> Array<T> {
	var r = Array<T>.new(a.length);
	for (i < a.length) r[i] = a[a.length - 1 - i];
	return r;
}
def concatg<T>(a: Array<T>, b: Array<T>) -> Array<T> {
	var r = Array<T>.new(a.length + b.length);
	for (i < a.length) r[i] = a[i];
	for (i < b.length) r[a.length + i] = b[i];
	return r;
}
// three layers of generic calls, each adding a type parameter
def layer3<A, B, C>(f: A -> B, g: B -> C, a: Array<A>) -> Array<C> {
	return mapg(g, layer2(f, a));
}
def layer2<A, B>(f: A -> B, a: Array<A>) -> Array<B> {
	return mapg(f, layer1(a));
}
def layer1<A>(a: Array<A>) -> Array<A> {
	return revg(concatg(a, a));
}
def strlen(s: string) -> int { return s.length; }
def objScore(o: Obj) -> int { return o.score(); }
def nested() {
	var h = 0;
	var doubled = mapg(fun (x: int) => x * 2, INTS);
	var lens = mapg(strlen, STRS);
	var tags = mapg(fun (s: string) => s.length * 3, STRS);
	for (i < doubled.length) h = mix(h, doubled[i]);
	for (i < lens.length) h = mix(h, lens[i]);
	h = mix(h, foldg(int.+, 0, lens));
	h = mix(h, foldg(int.^, -1, doubled));
	h = mix(h, mapfold(strlen, int.+, 0, STRS));
	h = mix(h, mapfold(fun (x: int) => x & 0xFF, int.*, 1, INTS));
	for (i < tags.length) h = mix(h, tags[i]);
	acci(h);

	var g = 0;
	var z1 = zipWith(fun (a: int, b: string) => a + b.length, INTS, STRS);
	var z2 = zipWith(fun (a: string, b: long) => long.!(a.length) + b, STRS, LONGS);
	var z3 = zipWith(pairUp<int, string>, INTS, STRS);
	for (i < z1.length) g = mix(g, z1[i]);
	for (i < z2.length) g = mixl(g, z2[i]);
	for (i < z3.length) { g = mix(g, z3[i].0); g = mixs(g, z3[i].1); }
	g = mix(g, sumBy(INTS, ident<int>));
	g = mix(g, sumBy(STRS, strlen));
	g = mix(g, sumBy(FLOATS, fun (f: float) => int.view(f)));
	acci(g);

	var k = 0;
	var l3 = layer3(strlen, fun (x: int) => x * x, STRS);
	for (i < l3.length) k = mix(k, l3[i]);
	var l3b = layer3(fun (x: int) => long.!(x), fun (x: long) => x * 3, INTS);
	for (i < l3b.length) k = mixl(k, l3b[i]);
	var objs = Array<Obj>.new(8);
	for (i < objs.length) objs[i] = Obj.new(i - 3);
	var scores = layer2(objScore, objs);
	for (i < scores.length) k = mix(k, scores[i]);
	k = mix(k, sumBy(objs, objScore));
	acci(k);

	if (mapg(strlen, ["a", "bb", "ccc"])[2] != 3) fail_assert(201);
	if (foldg(int.+, 0, [1, 2, 3, 4]) != 10) fail_assert(202);
	if (foldg(int.*, 1, [1, 2, 3, 4]) != 24) fail_assert(203);
	if (mapfold(strlen, int.+, 0, ["a", "bb", "ccc"]) != 6) fail_assert(204);
	if (zipWith(int.+, [1, 2, 3], [10, 20]).length != 2) fail_assert(205);
	if (zipWith(int.+, [1, 2, 3], [10, 20])[1] != 22) fail_assert(206);
	if (revg([1, 2, 3])[0] != 3) fail_assert(207);
	if (concatg([1, 2], [3])[2] != 3) fail_assert(208);
	if (concatg([1, 2], [3]).length != 3) fail_assert(209);
	if (layer1([1, 2]).length != 4) fail_assert(210);
	if (layer1([1, 2])[0] != 2) fail_assert(211);		// reverse of [1,2,1,2]
	if (layer1([1, 2])[1] != 1) fail_assert(212);
	// sumBy folds h = h*31 + f(x)
	if (sumBy([1, 2, 3], ident<int>) != 1 * 961 + 2 * 31 + 3) fail_assert(213);
	if (sumBy(["ab"], strlen) != 2) fail_assert(214);
}

//======================================================================
// Section 3: instantiated generic functions stored in data structures
//======================================================================
def firstOr<T>(a: Array<T>, d: T) -> T { return if(a.length > 0, a[0], d); }
def lastOr<T>(a: Array<T>, d: T) -> T { return if(a.length > 0, a[a.length - 1], d); }
def midOr<T>(a: Array<T>, d: T) -> T { return if(a.length > 0, a[a.length / 2], d); }
class Holder {
	var pi: int -> int;
	var ps: string -> string;
	var sel: (Array<int>, int) -> int;
}
var gpick: (bool, int, int) -> int;
var gtuple: (int -> int, string -> string, (Array<int>, int) -> int);
def stored() {
	gpick = null;			// reset globals written by this section
	gtuple = (null, null, null);

	def SELS: Array<(Array<int>, int) -> int> = [firstOr<int>, lastOr<int>, midOr<int>];
	def SELS2: Array<(Array<string>, string) -> string> =
		[firstOr<string>, lastOr<string>, midOr<string>];
	var slices = Array<Array<int>>.new(6);
	for (i < slices.length) {
		slices[i] = Array<int>.new(i);
		for (j < i) slices[i][j] = j * 11 - i;
	}
	var h = 0;
	for (k < SELS.length) for (i < slices.length) h = mix(h, SELS[k](slices[i], -99));
	for (k < SELS2.length) h = mixs(h, SELS2[k](STRS, "none"));
	acci(h);

	var hold = Holder.new();
	hold.pi = ident<int>;
	hold.ps = ident<string>;
	hold.sel = firstOr<int>;
	var g = 0;
	for (i < INTS.length) g = mix(g, hold.pi(INTS[i]));
	for (i < STRS.length) g = mixs(g, hold.ps(STRS[i]));
	for (i < slices.length) g = mix(g, hold.sel(slices[i], -1));
	hold.pi = fun (x: int) => -x;
	hold.sel = lastOr<int>;
	for (i < INTS.length) g = mix(g, hold.pi(INTS[i]));
	for (i < slices.length) g = mix(g, hold.sel(slices[i], -1));
	acci(g);

	gpick = pick<int>;
	gtuple = (ident<int>, ident<string>, midOr<int>);
	var k = 0;
	for (i < INTS.length) {
		k = mix(k, gpick((i & 1) == 0, INTS[i], -1));
		k = mix(k, gtuple.0(INTS[i]));
	}
	for (i < STRS.length) k = mixs(k, gtuple.1(STRS[i]));
	for (i < slices.length) k = mix(k, gtuple.2(slices[i], 0));
	// arrays of tuples of instantiated generic functions
	var pairs = Array<(int -> int, (Array<int>, int) -> int)>.new(3);
	pairs[0] = (ident<int>, firstOr<int>);
	pairs[1] = (fun (x: int) => x + 1, lastOr<int>);
	pairs[2] = (fun (x: int) => x * 2, midOr<int>);
	for (i < pairs.length) for (j < slices.length) {
		k = mix(k, pairs[i].0(j));
		k = mix(k, pairs[i].1(slices[j], -5));
	}
	gpick = null;
	gtuple = (null, null, null);
	acci(k);

	if (firstOr([7, 8, 9], -1) != 7) fail_assert(301);
	if (lastOr([7, 8, 9], -1) != 9) fail_assert(302);
	if (midOr([7, 8, 9], -1) != 8) fail_assert(303);
	if (firstOr(Array<int>.new(0), -1) != -1) fail_assert(304);
	if (lastOr(Array<int>.new(0), -1) != -1) fail_assert(305);
	if (midOr([7, 8], -1) != 8) fail_assert(306);		// length/2 == 1
	var f: (Array<int>, int) -> int = firstOr<int>;
	if (f([3, 4], 0) != 3) fail_assert(307);
	var fs: (Array<string>, string) -> string = lastOr<string>;
	if (fs(["a", "bb"], "") .length != 2) fail_assert(308);
	var hh = Holder.new();
	hh.pi = ident<int>;
	if (hh.pi(5) != 5) fail_assert(309);
	if (hh.ps != null) fail_assert(310);
}

//======================================================================
// Section 4: generic containers with function-valued fields
//======================================================================
class Stepper<T> {
	var v: T;
	var f: T -> T;
	new(v, f) { }
	def step() -> T { v = f(v); return v; }
	def stepN(n: int) -> T {
		for (i < n) v = f(v);
		return v;
	}
}
class Transformer<A, B> {
	def f: A -> B;
	new(f) { }
	def all(a: Array<A>) -> Array<B> { return mapg(f, a); }
	def one(a: A) -> B { return f(a); }
}
class Reducer<A, B> {
	var acc: B;
	def f: (B, A) -> B;
	new(acc, f) { }
	def add(x: A) -> B { acc = f(acc, x); return acc; }
	def addAll(a: Array<A>) -> B {
		for (i < a.length) acc = f(acc, a[i]);
		return acc;
	}
}
def containers() {
	var si = Stepper<int>.new(1, fun (x: int) => x * 3 + 1);
	var sl = Stepper<long>.new(1L, fun (x: long) => x * 5 - 2L);
	var sf = Stepper<float>.new(1f, fun (x: float) => x * 0.5f);
	var ss = Stepper<string>.new("a", fun (s: string) => if(s.length > 6, "a", s));
	var sb = Stepper<bool>.new(true, fun (b: bool) => !b);
	var h = 0;
	for (i < 12) {
		h = mix(h, si.step());
		h = mixl(h, sl.step());
		h = mixf(h, sf.step());
		h = mixs(h, ss.step());
		h = mixb(h, sb.step());
	}
	h = mix(h, si.stepN(5));
	h = mixl(h, sl.stepN(3));
	acci(h);

	var t1 = Transformer<string, int>.new(strlen);
	var t2 = Transformer<int, long>.new(fun (x: int) => long.!(x) * 1000L);
	var t3 = Transformer<Obj, int>.new(objScore);
	var t4 = Transformer<int, (int, int)>.new(dup<int>);
	var objs = Array<Obj>.new(6);
	for (i < objs.length) objs[i] = Obj.new(i * 2 - 5);
	var g = 0;
	var a1 = t1.all(STRS);
	for (i < a1.length) g = mix(g, a1[i]);
	var a2 = t2.all(INTS);
	for (i < a2.length) g = mixl(g, a2[i]);
	var a3 = t3.all(objs);
	for (i < a3.length) g = mix(g, a3[i]);
	var a4 = t4.all(INTS);
	for (i < a4.length) g = mix(g, a4[i].0 - a4[i].1);
	g = mix(g, t1.one("hello"));
	acci(g);

	var r1 = Reducer<int, int>.new(0, int.+);
	var r2 = Reducer<string, int>.new(0, fun (b: int, s: string) => b * 2 + s.length);
	var r3 = Reducer<int, string>.new("", fun (b: string, x: int) => if(x > 0, "pos", b));
	var r4 = Reducer<Obj, long>.new(0L, fun (b: long, o: Obj) => b + o.score());
	var k = 0;
	for (i < INTS.length) k = mix(k, r1.add(INTS[i]));
	k = mix(k, r2.addAll(STRS));
	k = mixs(k, r3.addAll(INTS));
	k = mixl(k, r4.addAll(objs));
	k = mix(k, r1.acc);
	acci(k);

	var q = Stepper<int>.new(2, fun (x: int) => x * x);
	if (q.step() != 4) fail_assert(401);
	if (q.step() != 16) fail_assert(402);
	if (q.v != 16) fail_assert(403);
	var q2 = Stepper<int>.new(1, fun (x: int) => x + 3);
	if (q2.stepN(4) != 13) fail_assert(404);
	if (q2.stepN(0) != 13) fail_assert(405);
	var tt = Transformer<string, int>.new(strlen);
	if (tt.one("abcd") != 4) fail_assert(406);
	if (tt.all(["a", "bb"])[1] != 2) fail_assert(407);
	var rr = Reducer<int, int>.new(100, int.-);
	if (rr.add(1) != 99) fail_assert(408);
	if (rr.addAll([1, 2, 3]) != 93) fail_assert(409);
	if (rr.acc != 93) fail_assert(410);
	if (Reducer<int, int>.new(0, int.+).addAll([1, 2, 3, 4]) != 10) fail_assert(411);
}

//======================================================================
// Section 5: one generic function at many instantiations
//======================================================================
def summarize<T>(a: Array<T>, f: T -> int) -> int {
	var h = 0;
	for (i < a.length) h = h * 31 + f(a[i]);
	return h;
}
def countIf<T>(a: Array<T>, p: T -> bool) -> int {
	var n = 0;
	for (i < a.length) if (p(a[i])) n++;
	return n;
}
def fill<T>(n: int, v: T) -> Array<T> {
	var r = Array<T>.new(n);
	for (i < n) r[i] = v;
	return r;
}
def instantiations() {
	var objs = Array<Obj>.new(5);
	for (i < objs.length) objs[i] = Obj.new(i - 2);
	def COLS: Array<Col> = [
		Col.Red, Col.Green(3), Col.Blue(4, "b"), Col.Green(-1), Col.Red
	];
	var tups = Array<(int, int)>.new(6);
	for (i < tups.length) tups[i] = (i, i * i - 3);

	// the same generic function at eight different instantiations
	var h = 0;
	h = mix(h, summarize(INTS, ident<int>));
	h = mix(h, summarize(LONGS, fun (x: long) => int.view(u32.view(x))));
	h = mix(h, summarize(FLOATS, fun (x: float) => int.view(x)));
	h = mix(h, summarize(BOOLS, fun (b: bool) => if(b, 1, 0)));
	h = mix(h, summarize(STRS, strlen));
	h = mix(h, summarize(objs, objScore));
	h = mix(h, summarize(tups, fun (t: (int, int)) => t.0 * 100 + t.1));
	h = mix(h, summarize(COLS, colScore));
	acci(h);

	var g = 0;
	g = mix(g, countIf(INTS, fun (x: int) => x > 0));
	g = mix(g, countIf(LONGS, fun (x: long) => x < 0));
	g = mix(g, countIf(FLOATS, fun (x: float) => x == 0f));
	g = mix(g, countIf(BOOLS, ident<bool>));
	g = mix(g, countIf(STRS, fun (s: string) => s.length > 2));
	g = mix(g, countIf(objs, fun (o: Obj) => o.id >= 0));
	g = mix(g, countIf(tups, fun (t: (int, int)) => t.1 > t.0));
	g = mix(g, countIf(COLS, fun (c: Col) => Col.Green.?(c)));
	acci(g);

	// fill/dup/pick at the same eight types
	var k = 0;
	for (i < fill(4, 9).length) k = mix(k, fill(4, 9)[i]);
	k = mixl(k, fill(3, 77L)[2]);
	k = mixf(k, fill(3, 0.25f)[0]);
	k = mixb(k, fill(3, true)[1]);
	k = mixs(k, fill(3, "fill")[1]);
	k = mix(k, fill(3, objs[0])[2].score());
	k = mix(k, fill(3, (5, 6))[1].0);
	k = mix(k, colScore(fill<Col>(3, Col.Blue(1, "z"))[0]));
	k = mix(k, dup(7).0);
	k = mixl(k, dup(7L).1);
	k = mixf(k, dup(0.5f).0);
	k = mixb(k, dup(false).1);
	k = mixs(k, dup("d").0);
	k = mix(k, dup(objs[1]).0.score());
	k = mix(k, dup((1, 2)).1.1);
	k = mix(k, colScore(dup<Col>(Col.Green(5)).0));
	k = mix(k, pick(true, 1, 2));
	k = mixl(k, pick(false, 1L, 2L));
	k = mixf(k, pick(true, 1f, 2f));
	k = mixb(k, pick(false, true, false));
	k = mixs(k, pick(true, "a", "b"));
	k = mix(k, pick(false, objs[0], objs[1]).score());
	k = mix(k, pick(true, (1, 2), (3, 4)).0);
	k = mix(k, colScore(pick<Col>(false, Col.Red, Col.Green(9))));
	acci(k);

	if (summarize([1, 2, 3], ident<int>) != 1 * 961 + 2 * 31 + 3) fail_assert(501);
	if (summarize(["ab"], strlen) != 2) fail_assert(502);
	if (countIf([1, -1, 2], fun (x: int) => x > 0) != 2) fail_assert(503);
	if (countIf(Array<int>.new(0), fun (x: int) => true) != 0) fail_assert(504);
	if (fill(3, 9)[2] != 9) fail_assert(505);
	if (fill(3, 9).length != 3) fail_assert(506);
	if (fill(0, 9).length != 0) fail_assert(507);
	if (fill(2, 7L)[1] != 7L) fail_assert(508);
	if (fill(2, "s")[0].length != 1) fail_assert(509);
	if (dup(0.5f).0 != 0.5f) fail_assert(510);
	if (dup((1, 2)).1.0 != 1) fail_assert(511);
	if (colScore(Col.Red) != 1) fail_assert(512);
	if (colScore(Col.Green(3)) != 103) fail_assert(513);
	if (colScore(Col.Blue(4, "bb")) != 206) fail_assert(514);
	if (Obj.new(2).score() != 20) fail_assert(515);		// 2*7 + 2*3
}

//======================================================================
// Section 6: generic variants and generic recursive data
//======================================================================
type Opt<T> {
	case Some(v: T);
	case None;
}
type Lst<T> {
	case Nil;
	case Cons(hd: T, tl: Lst<T>);
}
def getOr<T>(o: Opt<T>, d: T) -> T {
	match (o) {
		Some(v) => return v;
		None => return d;
	}
}
def mapOpt<A, B>(f: A -> B, o: Opt<A>) -> Opt<B> {
	match (o) {
		Some(v) => return Opt<B>.Some(f(v));
		None => return Opt<B>.None;
	}
}
def lenOf<T>(l: Lst<T>) -> int {
	var n = 0, p = l;
	while (true) {
		match (p) {
			Nil => return n;
			Cons(hd, tl) => { n++; p = tl; }
		}
	}
	return n;
}
def foldl<A, B>(f: (B, A) -> B, init: B, l: Lst<A>) -> B {
	var acc = init, p = l;
	while (true) {
		match (p) {
			Nil => return acc;
			Cons(hd, tl) => { acc = f(acc, hd); p = tl; }
		}
	}
	return acc;
}
def fromArray<T>(a: Array<T>) -> Lst<T> {
	var l: Lst<T> = Lst<T>.Nil;
	for (i < a.length) l = Lst<T>.Cons(a[a.length - 1 - i], l);
	return l;
}
def generics() {
	var oi: Opt<int> = Opt<int>.Some(5);
	var on: Opt<int> = Opt<int>.None;
	var os: Opt<string> = Opt<string>.Some("opt");
	var oo: Opt<Obj> = Opt<Obj>.Some(Obj.new(3));
	var h = 0;
	h = mix(h, getOr(oi, -1));
	h = mix(h, getOr(on, -1));
	h = mixs(h, getOr(os, "d"));
	h = mix(h, getOr(oo, Obj.new(0)).score());
	h = mix(h, getOr(mapOpt(fun (x: int) => x * 3, oi), -1));
	h = mix(h, getOr(mapOpt(fun (x: int) => x * 3, on), -1));
	h = mix(h, getOr(mapOpt(strlen, os), -1));
	h = mixl(h, getOr(mapOpt(fun (x: int) => long.!(x) * 7L, oi), -1L));
	for (i < INTS.length) {
		var o: Opt<int> = if((i & 1) == 0, Opt<int>.Some(INTS[i]), Opt<int>.None);
		h = mix(h, getOr(o, -7));
		h = mix(h, o.tag);
		h = mixl(h, getOr(mapOpt(fun (x: int) => long.!(x), o), -1L));
	}
	acci(h);

	var li = fromArray(INTS);
	var ls = fromArray(STRS);
	var lo = fromArray(LONGS);
	var g = 0;
	g = mix(g, lenOf(li));
	g = mix(g, lenOf(ls));
	g = mix(g, lenOf(lo));
	g = mix(g, lenOf(Lst<int>.Nil));
	g = mix(g, foldl(int.+, 0, li));
	g = mix(g, foldl(fun (b: int, s: string) => b * 3 + s.length, 0, ls));
	g = mixl(g, foldl(fun (b: long, x: long) => b ^ x, 0L, lo));
	g = mixs(g, foldl(fun (b: string, s: string) => if(s.length > b.length, s, b), "", ls));
	acci(g);

	// lists of lists, and lists of options
	var k = 0;
	var lls = Array<Lst<int>>.new(6);
	for (i < lls.length) {
		var buf = Array<int>.new(i);
		for (j < i) buf[j] = j * 5 - i;
		lls[i] = fromArray(buf);
	}
	var outer = fromArray(lls);
	k = mix(k, lenOf(outer));
	k = mix(k, foldl(fun (b: int, l: Lst<int>) => b + lenOf(l), 0, outer));
	k = mix(k, foldl(fun (b: int, l: Lst<int>) => b ^ foldl(int.+, 0, l), 0, outer));
	var opts = Array<Opt<int>>.new(INTS.length);
	for (i < opts.length) opts[i] = if((i % 3) == 0, Opt<int>.None, Opt<int>.Some(INTS[i]));
	k = mix(k, summarize(opts, fun (o: Opt<int>) => getOr(o, 1000)));
	k = mix(k, countIf(opts, fun (o: Opt<int>) => Opt<int>.None.?(o)));
	acci(k);

	if (getOr(Opt<int>.Some(5), -1) != 5) fail_assert(601);
	if (getOr(Opt<int>.None, -1) != -1) fail_assert(602);
	if (getOr(mapOpt(fun (x: int) => x + 1, Opt<int>.Some(5)), -1) != 6) fail_assert(603);
	if (getOr(mapOpt(fun (x: int) => x + 1, Opt<int>.None), -1) != -1) fail_assert(604);
	if (Opt<int>.Some(1).tag != 0) fail_assert(605);
	if (Opt<int>.None.tag != 1) fail_assert(606);
	if (lenOf(Lst<int>.Nil) != 0) fail_assert(607);
	if (lenOf(fromArray([1, 2, 3])) != 3) fail_assert(608);
	if (foldl(int.+, 0, fromArray([1, 2, 3])) != 6) fail_assert(609);
	if (foldl(int.-, 0, fromArray([1, 2, 3])) != -6) fail_assert(610);
	// fromArray preserves order: head is a[0]
	if (foldl(fun (b: int, x: int) => b * 10 + x, 0, fromArray([1, 2, 3])) != 123)
		fail_assert(611);
	if (lenOf(fromArray(["a"])) != 1) fail_assert(612);
}

//======================================================================
// Section 7: generic class hierarchies and virtual generic methods
//======================================================================
class GBase<T> {
	def transform(x: T) -> T { return x; }
	def label() -> string { return "base"; }
	def twice(x: T) -> T { return transform(transform(x)); }
}
class GApply<T> extends GBase<T> {
	def f: T -> T;
	new(f) { }
	def transform(x: T) -> T { return f(x); }
	def label() -> string { return "apply"; }
}
class GInt extends GBase<int> {
	var bias: int;
	new(bias) { }
	def transform(x: int) -> int { return x * 2 + bias; }
	def label() -> string { return "int"; }
}
class GStr extends GBase<string> {
	def transform(s: string) -> string { return if(s.length == 0, "e", s); }
	def label() -> string { return "str"; }
}
def hierarchy() {
	var ints: Array<GBase<int>> = [
		GBase<int>.new(), GApply<int>.new(fun (x: int) => x - 5),
		GInt.new(3), GInt.new(-1), GApply<int>.new(fun (x: int) => x ^ 0xFF)
	];
	var h = 0;
	for (k < ints.length) {
		var b = ints[k];
		h = mixs(h, b.label());
		for (i < INTS.length) {
			h = mix(h, b.transform(INTS[i]));
			h = mix(h, b.twice(INTS[i]));
		}
		h = mixb(h, GInt.?(b));
		h = mixb(h, GApply<int>.?(b));
	}
	acci(h);

	var strs: Array<GBase<string>> = [
		GBase<string>.new(), GStr.new(),
		GApply<string>.new(fun (s: string) => if(s.length > 2, "long", s))
	];
	var g = 0;
	for (k < strs.length) {
		g = mixs(g, strs[k].label());
		for (i < STRS.length) {
			g = mixs(g, strs[k].transform(STRS[i]));
			g = mixs(g, strs[k].twice(STRS[i]));
		}
	}
	// the same generic base at two more instantiations
	var lb = GApply<long>.new(fun (x: long) => x * 3L + 1L);
	var fb = GApply<float>.new(fun (x: float) => x * 0.5f);
	var ob = GApply<Obj>.new(fun (o: Obj) => Obj.new(o.id + 1));
	for (i < LONGS.length) g = mixl(g, lb.twice(LONGS[i]));
	for (i < FLOATS.length) g = mixf(g, fb.twice(FLOATS[i]));
	for (i < 6) g = mix(g, ob.twice(Obj.new(i)).score());
	acci(g);

	// transform delegates pulled out of the objects and stored as values
	var fs = Array<int -> int>.new(ints.length);
	for (i < ints.length) fs[i] = ints[i].transform;
	var k = 0;
	for (i < fs.length) for (j < INTS.length) k = mix(k, fs[i](INTS[j]));
	acci(k);

	if (GBase<int>.new().transform(5) != 5) fail_assert(701);
	if (GBase<int>.new().twice(5) != 5) fail_assert(702);
	if (GInt.new(3).transform(5) != 13) fail_assert(703);
	if (GInt.new(3).twice(5) != 29) fail_assert(704);	// (5*2+3)*2+3
	if (GApply<int>.new(fun (x: int) => x - 5).transform(5) != 0) fail_assert(705);
	if (GApply<int>.new(fun (x: int) => x - 5).twice(5) != -5) fail_assert(706);
	if (GStr.new().transform("").length != 1) fail_assert(707);
	if (GStr.new().transform("ab").length != 2) fail_assert(708);
	var b: GBase<int> = GInt.new(0);
	if (!GInt.?(b)) fail_assert(709);
	if (GApply<int>.?(b)) fail_assert(710);
	if (b.transform(3) != 6) fail_assert(711);
	var d: int -> int = b.transform;
	if (d(3) != 6) fail_assert(712);
}

//======================================================================
// Section 8: allocation churn over generic containers
//======================================================================
def churn() {
	var steppers = Array<Stepper<int>>.new(32);
	for (i < steppers.length) {
		var k = i + 1;
		steppers[i] = Stepper<int>.new(i, fun (x: int) => (x * k + 1) & 0xFFFF);
	}
	var h = 0;
	for (r < 12) for (i < steppers.length) h = mix(h, steppers[i].step());
	acci(h);

	// generic lists rebuilt repeatedly; most become garbage immediately
	var keep = Array<Lst<int>>.new(8);
	for (i < keep.length) keep[i] = Lst<int>.Nil;
	var g = 0;
	for (i < 600) {
		var buf = Array<int>.new(i % 17);
		for (j < buf.length) buf[j] = i * j - 5;
		var l = fromArray(buf);
		if ((i % 37) == 0) keep[(i / 37) % keep.length] = l;
		if ((i % 53) == 0) g = mix(g, foldl(int.+, 0, l));
	}
	for (i < keep.length) {
		g = mix(g, lenOf(keep[i]));
		g = mix(g, foldl(int.^, 0, keep[i]));
	}
	acci(g);

	var reds = Array<Reducer<int, int>>.new(16);
	for (i < reds.length) {
		var w = i - 8;
		reds[i] = Reducer<int, int>.new(0, fun (b: int, x: int) => b + x * w);
	}
	var k = 0;
	for (r < 6) for (i < reds.length) k = mix(k, reds[i].addAll(INTS));
	var opts = Array<Opt<Obj>>.new(64);
	for (i < opts.length) {
		opts[i] = if((i % 5) == 0, Opt<Obj>.None, Opt<Obj>.Some(Obj.new(i)));
	}
	var dflt = Obj.new(-1);
	for (i < opts.length) k = mix(k, getOr(opts[i], dflt).score());
	k = mix(k, countIf(opts, fun (o: Opt<Obj>) => Opt<Obj>.None.?(o)));
	acci(k);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) multitype();
	if (a == 0 || a == 2) nested();
	if (a == 0 || a == 3) stored();
	if (a == 0 || a == 4) containers();
	if (a == 0 || a == 5) instantiations();
	if (a == 0 || a == 6) generics();
	if (a == 0 || a == 7) hierarchy();
	if (a == 0 || a == 8) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
