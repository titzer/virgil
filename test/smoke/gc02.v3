//@execute 0=-283071101; 1=-1140248189; 2=164636879; 3=-1011054712; 4=-1222701777; 5=1188886026; 6=829156720
//@heap-size=3000000
// Smoke test: references held live across deep call frames.
// Allocation is driven from the bottom of deep recursions while references are
// pinned in caller frames, in spilled locals, in tuples, in arrays, in variant
// payloads and in globals -- so a collection triggered at depth must find and
// forward every one of them. Each section verifies that its live objects are
// unchanged after the churn and mixes the results into a running CRC that
// main() returns. Interleaved are assert()s over compile-time constants, which
// the optimizer is expected to fold away; a folding bug sets the failure flag
// instead. Input selects the section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

//======================================================================
// Types. Objects carry a checkable fingerprint so that a mis-forwarded
// reference shows up as a wrong value rather than a crash.
//======================================================================
class Obj {
	def id: int;
	var a: int;
	var b: long;
	var link: Obj;
	var data: Array<int>;
	new(id) {
		a = id * 3 + 1;
		b = long.!(id) * 0x1234_5678L;
		data = Array<int>.new(1 + (id % 7));
		for (i < data.length) data[i] = id * 100 + i;
	}
	def check() -> int {
		var s = id ^ a;
		for (i < data.length) s = s ^ (data[i] * (i + 1));
		return s ^ int.view(u32.view(b)) ^ int.view(u32.view(b >> 32));
	}
}
type Payload {
	case One(o: Obj);
	case Two(o: Obj, p: Obj);
	case Arr(a: Array<Obj>);
	case Nothing;
}

// A big allocation burst, called from the bottom of a recursion.
def burn(n: int) -> int {
	var s = 0;
	for (i < n) {
		var o = Obj.new(i);
		s = s + o.a;
		if ((i % 5) == 0) {
			var junk = Array<Obj>.new(4);
			for (j < 4) junk[j] = Obj.new(i + j);
			s = s ^ junk[i % 4].check();
		}
	}
	return s;
}

//======================================================================
// Section 1: a reference pinned in every frame of a deep recursion
//======================================================================
def deepHold(d: int, o: Obj) -> int {
	if (d == 0) {
		acci(mix(0, burn(400)));
		return o.check();
	}
	var mine = Obj.new(d);			// live across the recursive call
	var got = deepHold(d - 1, o);
	// both the parameter and the local must have survived
	if (mine.id != d) fail_assert(101);
	if (mine.a != d * 3 + 1) fail_assert(102);
	return got ^ mine.a ^ mine.check();
}
def pinnedFrames() {
	srand(0x6C01);
	var root = Obj.new(999);
	var before = root.check();
	var h = mix(0, deepHold(120, root));
	h = mix(h, root.check());
	h = mixb(h, root.check() == before);
	h = mix(h, root.data.length);
	for (i < root.data.length) h = mix(h, root.data[i]);
	acci(h);
	if (root.id != 999) fail_assert(103);
	if (root.check() != before) fail_assert(104);
	// a fresh Obj has a fully determined fingerprint
	var o5 = Obj.new(5);
	if (o5.a != 16) fail_assert(105);
	if (o5.data.length != 6) fail_assert(106);
	if (o5.data[0] != 500) fail_assert(107);
	if (o5.data[5] != 505) fail_assert(108);
	if (o5.b != 5L * 0x1234_5678L) fail_assert(109);
	if (Obj.new(5).check() != o5.check()) fail_assert(110);
	if (Obj.new(6).check() == o5.check()) fail_assert(111);
	if (o5.link != null) fail_assert(112);
}

//======================================================================
// Section 2: many simultaneously-live locals in one deep frame
//======================================================================
def deepMany(d: int, seedv: int) -> int {
	if (d == 0) {
		acci(mix(0, burn(300)));
		return seedv;
	}
	// enough live references to force spilling on every backend
	var o0 = Obj.new(d * 16 + 0), o1 = Obj.new(d * 16 + 1);
	var o2 = Obj.new(d * 16 + 2), o3 = Obj.new(d * 16 + 3);
	var o4 = Obj.new(d * 16 + 4), o5 = Obj.new(d * 16 + 5);
	var o6 = Obj.new(d * 16 + 6), o7 = Obj.new(d * 16 + 7);
	var a0 = Array<int>.new(3); a0[0] = d; a0[1] = d * 2; a0[2] = d * 3;
	var t0 = (o0, o1, d);
	var p0: Payload = Payload.Two(o2, o3);

	var got = deepMany(d - 1, seedv ^ d);

	var s = got;
	s = s ^ o0.check() ^ o1.check() ^ o2.check() ^ o3.check();
	s = s ^ o4.check() ^ o5.check() ^ o6.check() ^ o7.check();
	s = s ^ a0[0] ^ a0[1] ^ a0[2];
	s = s ^ t0.0.check() ^ t0.1.check() ^ t0.2;
	match (p0) {
		Two(x, y) => { s = s ^ x.check() ^ y.check(); }
		_ => { s = s ^ -1; }
	}
	if (o0.id != d * 16 + 0) fail_assert(201);
	if (o7.id != d * 16 + 7) fail_assert(202);
	return s;
}
def manyLive() {
	srand(0x6C02);
	acci(deepMany(60, 12345));
}

//======================================================================
// Section 3: references reachable only through globals
//======================================================================
var gObj: Obj;
var gArr: Array<Obj>;
var gTup: (Obj, Obj, int);
var gPay: Payload;
var gNest: Array<Array<Obj>>;

def deepGlobal(d: int) {
	if (d == 0) { acci(mix(0, burn(500))); return; }
	deepGlobal(d - 1);
}
def globalRoots() {
	srand(0x6C03);
	gObj = Obj.new(11);
	gArr = Array<Obj>.new(32);
	for (i < gArr.length) gArr[i] = Obj.new(i + 200);
	gTup = (Obj.new(21), Obj.new(22), 23);
	gPay = Payload.Arr(gArr);
	gNest = Array<Array<Obj>>.new(8);
	for (i < gNest.length) {
		gNest[i] = Array<Obj>.new(4);
		for (j < 4) gNest[i][j] = Obj.new(i * 4 + j + 300);
	}
	// build a long chain reachable only from gObj
	var p = gObj;
	for (i < 200) {
		var n = Obj.new(i + 400);
		p.link = n;
		p = n;
	}

	deepGlobal(80);

	var h = mix(0, gObj.check());
	for (i < gArr.length) h = mix(h, gArr[i].check());
	h = mix(h, gTup.0.check());
	h = mix(h, gTup.1.check());
	h = mix(h, gTup.2);
	match (gPay) {
		Arr(a) => { h = mixb(h, a == gArr); for (i < a.length) h = mix(h, a[i].check()); }
		_ => h = mix(h, -1);
	}
	for (i < gNest.length) for (j < 4) h = mix(h, gNest[i][j].check());
	var q = gObj;
	var n = 0;
	while (q != null) { h = mix(h, q.check()); q = q.link; n++; }
	h = mix(h, n);
	acci(h);
	if (n != 201) fail_assert(301);				// gObj plus a 200-long chain
	if (gTup.2 != 23) fail_assert(302);
	if (gArr.length != 32) fail_assert(303);
	if (gObj.id != 11) fail_assert(304);

	// drop the globals and make sure a later section is unaffected
	gObj = null;
	gArr = null;
	gTup = (null, null, 0);
	gPay = Payload.Nothing;
	gNest = null;
}

//======================================================================
// Section 4: allocation inside the arguments of a pending call
//======================================================================
def combine4(a: Obj, b: Obj, c: Obj, d: Obj) -> int {
	var s = burn(200);
	return s ^ a.check() ^ b.check() ^ c.check() ^ d.check();
}
def alloc(id: int) -> Obj {
	// allocating here can collect while earlier arguments are already evaluated
	var o = Obj.new(id);
	var junk = Array<Obj>.new(8);
	for (i < junk.length) junk[i] = Obj.new(id + i);
	o.link = junk[id % junk.length];
	return o;
}
def pendingArgs() {
	srand(0x6C04);
	var h = 0;
	for (i < 40) {
		h = mix(h, combine4(alloc(i), alloc(i + 1), alloc(i + 2), alloc(i + 3)));
	}
	// nested: each argument itself makes a call that allocates
	for (i < 20) {
		h = mix(h, combine4(alloc(i), alloc(i * 2), grow(i).0, grow(i).1));
	}
	acci(h);
	// argument evaluation order and identity are unaffected by collection
	var a = alloc(3);
	if (a.id != 3) fail_assert(401);
	if (a.link == null) fail_assert(402);
	if (a.link.id != 3 + (3 % 8)) fail_assert(403);
	var g = grow(1);
	if (g.0.id != 51) fail_assert(404);
	if (g.1.id != 61) fail_assert(405);
}
def grow(id: int) -> (Obj, Obj) {
	var a = Obj.new(id + 50);
	var b = Obj.new(id + 60);
	acci(mix(0, burn(50)));
	return (a, b);
}

//======================================================================
// Section 5: a live object graph rewritten while garbage is produced
//======================================================================
def mazeRounds() {
	srand(0x6C05);
	var size = 24;
	var master = Array<Array<Obj>>.new(size);
	for (i < size) {
		master[i] = Array<Obj>.new(size);
		for (j < size) master[i][j] = Obj.new(i * size + j);
	}
	var h = 0;
	for (round < 300) {
		var i = randn(size), j = randn(size);
		match (round % 4) {
			0 => {
				// replace a whole row; the old row becomes garbage
				var row = Array<Obj>.new(size);
				for (k < size) row[k] = Obj.new(round * 7 + k);
				master[i] = row;
			}
			1 => {
				// swap two entries
				var t = master[i][j];
				master[i][j] = master[j][i];
				master[j][i] = t;
			}
			2 => {
				// link entries into a chain, keeping older objects live
				master[i][j].link = master[j][i];
			}
			_ => {
				h = mix(h, burn(60));
			}
		}
		if ((round % 25) == 0) h = mix(h, master[i][j].check());
	}
	acci(h);
	var total = 0;
	for (i < size) for (j < size) {
		var o = master[i][j];
		total = total ^ o.check();
		var p = o.link;
		var hops = 0;
		while (p != null && hops < 8) { total = total ^ p.check(); p = p.link; hops++; }
	}
	acci(total);
	// every slot still holds a live, self-consistent object
	var bad = 0;
	for (i < size) for (j < size) {
		var o = master[i][j];
		if (o == null) bad++;
		else if (o.check() != o.check()) bad++;
	}
	if (bad != 0) fail_assert(501);
	if (size != 24) fail_assert(502);
}

//======================================================================
// Section 6: long-lived objects surviving many collections
//======================================================================
def survivors() {
	srand(0x6C06);
	var old = Array<Obj>.new(64);
	for (i < old.length) old[i] = Obj.new(i + 1000);
	var fingerprints = Array<int>.new(old.length);
	for (i < old.length) fingerprints[i] = old[i].check();

	var h = 0;
	for (round < 12) {
		h = mix(h, burn(400));
		// verify every long-lived object after each burst
		for (i < old.length) {
			if (old[i].check() != fingerprints[i]) fail_assert(601);
			if (old[i].id != i + 1000) fail_assert(602);
		}
	}
	for (i < old.length) h = mix(h, old[i].check());
	acci(h);
	// promote some of them into a variant payload and burn again
	var pays = Array<Payload>.new(old.length);
	for (i < old.length) {
		match (i % 3) {
			0 => pays[i] = Payload.One(old[i]);
			1 => pays[i] = Payload.Two(old[i], old[(i + 1) % old.length]);
			_ => pays[i] = Payload.Arr(old);
		}
	}
	var g = mix(0, burn(600));
	for (i < pays.length) {
		match (pays[i]) {
			One(o) => g = mix(g, o.check());
			Two(o, p) => { g = mix(g, o.check()); g = mix(g, p.check()); }
			Arr(a) => { g = mixb(g, a == old); g = mix(g, a.length); }
			Nothing => g = mix(g, -1);
		}
	}
	acci(g);
	// the long-lived objects survived every collection unchanged
	for (i < old.length) {
		if (old[i].check() != fingerprints[i]) fail_assert(603);
	}
	if (old.length != 64) fail_assert(604);
	if (Payload.One(old[0]).tag != 0) fail_assert(605);
	if (Payload.Nothing.tag != 3) fail_assert(606);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) pinnedFrames();
	if (a == 0 || a == 2) manyLive();
	if (a == 0 || a == 3) globalRoots();
	if (a == 0 || a == 4) pendingArgs();
	if (a == 0 || a == 5) mazeRounds();
	if (a == 0 || a == 6) survivors();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
