//@execute 0=-1551268052; 1=283691726; 2=-1588886687; 3=-1193818964; 4=340558144; 5=733628537; 6=862489539; 7=2096720538; 8=-354194791; 9=-60295089; 10=-2061091154
//@heap-size=1000000
// Smoke test: floating-point register pressure and data movement.
// float01.v3 covers what the float operators mean; this file is about where the
// values live. Each section keeps many float and double locals simultaneously
// live -- far more than any target has floating-point registers -- across loops,
// deep call chains, recursion, allocation and virtual dispatch, so the register
// allocator has to spill and reload them and the GC has to walk stack maps that
// contain both floating-point and reference slots. Everything observed is folded
// into a running CRC that main() returns, so no value can be deleted as dead;
// interleaved assert()s over compile-time constants encode results the optimizer
// is expected to fold away.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
// NaN bit patterns are not guaranteed identical across backends, so all NaNs
// mix in one canonical marker; every other value mixes exact bits (which
// distinguishes 0.0 from -0.0).
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def SEED: Array<float> = [
	0.5f, -1.25f, 2f, -0.75f, 3.5f, -4.25f, 0.125f, -8f,
	16f, -0.0625f, 7.75f, -2.5f, 1f, -1f, 0.25f, -32f
];
def DSEED: Array<double> = [
	0.5d, -1.25d, 2d, -0.75d, 3.5d, -4.25d, 0.125d, -8d,
	16d, -0.0625d, 7.75d, -2.5d, 1d, -1d, 0.25d, -32d
];

//======================================================================
// Section 1: sixteen simultaneously live float locals
//======================================================================
def manyFloats() {
	var a0 = SEED[0], a1 = SEED[1], a2 = SEED[2], a3 = SEED[3];
	var a4 = SEED[4], a5 = SEED[5], a6 = SEED[6], a7 = SEED[7];
	var a8 = SEED[8], a9 = SEED[9], a10 = SEED[10], a11 = SEED[11];
	var a12 = SEED[12], a13 = SEED[13], a14 = SEED[14], a15 = SEED[15];
	// Every iteration reads and writes all sixteen, so none of them can be
	// held in a register across the loop on any real target.
	for (i < 300) {
		var t = float.roundi(i) * 0.03125f;
		a0 = a0 * 0.5f + a15 - t;
		a1 = a1 * 0.5f + a0 + t;
		a2 = a2 * 0.5f + a1 - t;
		a3 = a3 * 0.5f + a2 + t;
		a4 = a4 * 0.5f + a3 - t;
		a5 = a5 * 0.5f + a4 + t;
		a6 = a6 * 0.5f + a5 - t;
		a7 = a7 * 0.5f + a6 + t;
		a8 = a8 * 0.5f + a7 - t;
		a9 = a9 * 0.5f + a8 + t;
		a10 = a10 * 0.5f + a9 - t;
		a11 = a11 * 0.5f + a10 + t;
		a12 = a12 * 0.5f + a11 - t;
		a13 = a13 * 0.5f + a12 + t;
		a14 = a14 * 0.5f + a13 - t;
		a15 = a15 * 0.5f + a14 + t;
	}
	var h = mixf(0, a0);
	h = mixf(h, a1); h = mixf(h, a2); h = mixf(h, a3);
	h = mixf(h, a4); h = mixf(h, a5); h = mixf(h, a6);
	h = mixf(h, a7); h = mixf(h, a8); h = mixf(h, a9);
	h = mixf(h, a10); h = mixf(h, a11); h = mixf(h, a12);
	h = mixf(h, a13); h = mixf(h, a14); h = mixf(h, a15);
	acci(h);

	// the same shape, but with a call in the middle of the live range so that
	// every live float has to survive a call boundary
	var b0 = SEED[0], b1 = SEED[1], b2 = SEED[2], b3 = SEED[3];
	var b4 = SEED[4], b5 = SEED[5], b6 = SEED[6], b7 = SEED[7];
	var b8 = SEED[8], b9 = SEED[9], b10 = SEED[10], b11 = SEED[11];
	for (i < 200) {
		var t = clobber(float.roundi(i));
		b0 = b0 + t * 0.001f;
		b1 = b1 - b0 * 0.25f;
		b2 = b2 + b1 * 0.125f;
		b3 = b3 - b2 * 0.0625f;
		b4 = b4 + b3 * 0.5f;
		b5 = b5 - b4 * 0.25f;
		b6 = b6 + b5 * 0.125f;
		b7 = b7 - b6 * 0.0625f;
		b8 = b8 + b7 * 0.5f;
		b9 = b9 - b8 * 0.25f;
		b10 = b10 + b9 * 0.125f;
		b11 = b11 - b10 * 0.0625f;
	}
	var g = mixf(0, b0);
	g = mixf(g, b1); g = mixf(g, b2); g = mixf(g, b3);
	g = mixf(g, b4); g = mixf(g, b5); g = mixf(g, b6);
	g = mixf(g, b7); g = mixf(g, b8); g = mixf(g, b9);
	g = mixf(g, b10); g = mixf(g, b11);
	acci(g);

	if (clobber(0f) != 0f) fail_assert(101);
	if (clobber(2f) != 6f) fail_assert(102);
	if (SEED.length != 16) fail_assert(103);
}
// A callee that itself uses several float registers, so it really does clobber.
def clobber(x: float) -> float {
	var p = x * 2f, q = x * 3f, r = x * 4f, s = x * 5f;
	return p + q + r - s - x * 1f;
}

//======================================================================
// Section 2: sixteen simultaneously live double locals
//======================================================================
def manyDoubles() {
	var a0 = DSEED[0], a1 = DSEED[1], a2 = DSEED[2], a3 = DSEED[3];
	var a4 = DSEED[4], a5 = DSEED[5], a6 = DSEED[6], a7 = DSEED[7];
	var a8 = DSEED[8], a9 = DSEED[9], a10 = DSEED[10], a11 = DSEED[11];
	var a12 = DSEED[12], a13 = DSEED[13], a14 = DSEED[14], a15 = DSEED[15];
	for (i < 300) {
		var t = double.roundi(i) * 0.03125d;
		a0 = a0 * 0.5d + a15 - t;
		a1 = a1 * 0.5d + a0 + t;
		a2 = a2 * 0.5d + a1 - t;
		a3 = a3 * 0.5d + a2 + t;
		a4 = a4 * 0.5d + a3 - t;
		a5 = a5 * 0.5d + a4 + t;
		a6 = a6 * 0.5d + a5 - t;
		a7 = a7 * 0.5d + a6 + t;
		a8 = a8 * 0.5d + a7 - t;
		a9 = a9 * 0.5d + a8 + t;
		a10 = a10 * 0.5d + a9 - t;
		a11 = a11 * 0.5d + a10 + t;
		a12 = a12 * 0.5d + a11 - t;
		a13 = a13 * 0.5d + a12 + t;
		a14 = a14 * 0.5d + a13 - t;
		a15 = a15 * 0.5d + a14 + t;
	}
	var h = mixd(0, a0);
	h = mixd(h, a1); h = mixd(h, a2); h = mixd(h, a3);
	h = mixd(h, a4); h = mixd(h, a5); h = mixd(h, a6);
	h = mixd(h, a7); h = mixd(h, a8); h = mixd(h, a9);
	h = mixd(h, a10); h = mixd(h, a11); h = mixd(h, a12);
	h = mixd(h, a13); h = mixd(h, a14); h = mixd(h, a15);
	acci(h);

	// a long dependency chain with no reuse, which stresses the other extreme:
	// almost nothing is live at once, but every value moves
	var x = DSEED[0];
	for (i < 2000) x = x * 0.9999d + 0.001d;
	acci(mixd(0, x));

	// interleave two independent chains so the scheduler has slack to fill
	var u = 1d, v = -1d;
	for (i < 1000) {
		u = u * 0.999d + double.roundi(i) * 1e-6d;
		v = v * 0.998d - double.roundi(i) * 1e-6d;
	}
	acci(mixd(mixd(0, u), v));

	if (DSEED.length != 16) fail_assert(201);
	if (DSEED[0] != 0.5d) fail_assert(202);
}

//======================================================================
// Section 3: floats and doubles live at the same time
//======================================================================
def mixedLive() {
	var f0 = SEED[0], f1 = SEED[1], f2 = SEED[2], f3 = SEED[3];
	var f4 = SEED[4], f5 = SEED[5], f6 = SEED[6], f7 = SEED[7];
	var d0 = DSEED[0], d1 = DSEED[1], d2 = DSEED[2], d3 = DSEED[3];
	var d4 = DSEED[4], d5 = DSEED[5], d6 = DSEED[6], d7 = DSEED[7];
	var i0 = 1, i1 = -2, i2 = 3, i3 = -4;
	var l0: long = 5, l1: long = -6;
	for (i < 400) {
		// float and double results feed each other, so values cross between the
		// two representations inside the live range
		f0 = f0 * 0.5f + float.roundd(d7 * 0.25d);
		f1 = f1 * 0.5f + f0;
		f2 = f2 * 0.5f - f1;
		f3 = f3 * 0.5f + f2;
		d0 = d0 * 0.5d + f3;			// implicit widening
		d1 = d1 * 0.5d - d0;
		d2 = d2 * 0.5d + d1;
		d3 = d3 * 0.5d - d2;
		f4 = f4 * 0.5f + float.roundd(d3);
		f5 = f5 * 0.5f - f4;
		f6 = f6 * 0.5f + f5;
		f7 = f7 * 0.5f - f6;
		d4 = d4 * 0.5d + f7;
		d5 = d5 * 0.5d - d4;
		d6 = d6 * 0.5d + d5;
		d7 = d7 * 0.5d - d6;
		i0 = i0 + (int.view(u32.view(long.view(d0))) & 0xFF);
		i1 = i1 - i0;
		i2 = i2 ^ i1;
		i3 = i3 + i2;
		l0 = l0 * 3 + i3;
		l1 = l1 - l0;
	}
	var h = mixf(0, f0);
	h = mixf(h, f1); h = mixf(h, f2); h = mixf(h, f3);
	h = mixf(h, f4); h = mixf(h, f5); h = mixf(h, f6); h = mixf(h, f7);
	h = mixd(h, d0); h = mixd(h, d1); h = mixd(h, d2); h = mixd(h, d3);
	h = mixd(h, d4); h = mixd(h, d5); h = mixd(h, d6); h = mixd(h, d7);
	h = mix(h, i0); h = mix(h, i1); h = mix(h, i2); h = mix(h, i3);
	h = mixl(h, l0); h = mixl(h, l1);
	acci(h);

	if (float.roundd(0.5d) != 0.5f) fail_assert(301);
	var w: double = 0.5f;
	if (w != 0.5d) fail_assert(302);
}

//======================================================================
// Section 4: floats through deep call chains
//======================================================================
def lvl4(a: float, b: float, c: float, d: float, e: float, f: float,
	 g: float, h: float, i: double, j: double) -> double {
	return (a + b * 2f + c * 3f + d * 4f) + (e + f * 2f + g * 3f + h * 4f) + i * 5d + j * 6d;
}
def lvl3(a: float, b: float, c: float, d: float, e: float, f: float,
	 g: float, h: float, i: double, j: double) -> double {
	var s = lvl4(h, g, f, e, d, c, b, a, j, i);
	return s + lvl4(a, b, c, d, e, f, g, h, i, j) * 0.5d;
}
def lvl2(a: float, b: float, c: float, d: float, e: float, f: float,
	 g: float, h: float, i: double, j: double) -> double {
	// the two calls' results are both live while the second one runs
	var x = lvl3(a, b, c, d, e, f, g, h, i, j);
	var y = lvl3(b, c, d, e, f, g, h, a, j, i);
	return x - y * 0.25d;
}
def lvl1(n: int, a: float, b: float, c: float, d: float, acc: double) -> double {
	if (n <= 0) return acc;
	var v = lvl2(a, b, c, d, a + b, b + c, c + d, d + a, acc, acc * 0.5d);
	// a, b, c, d all stay live across the recursive call
	var r = lvl1(n - 1, b, c, d, a, acc + v * 1e-6d);
	return r + a + b * 2f + c * 3f + d * 4f;
}
def deepCalls() {
	var h = 0;
	for (i < SEED.length) {
		var a = SEED[i], b = SEED[(i + 1) % SEED.length];
		var c = SEED[(i + 2) % SEED.length], d = SEED[(i + 3) % SEED.length];
		h = mixd(h, lvl2(a, b, c, d, a, b, c, d, DSEED[i], DSEED[15 - i]));
	}
	acci(h);
	var g = 0;
	for (i < 8) {
		g = mixd(g, lvl1(20, SEED[i], SEED[i + 1], SEED[i + 2], SEED[i + 3], DSEED[i]));
	}
	acci(g);

	if (lvl4(1f, 0f, 0f, 0f, 0f, 0f, 0f, 0f, 0d, 0d) != 1d) fail_assert(401);
	if (lvl4(0f, 1f, 0f, 0f, 0f, 0f, 0f, 0f, 0d, 0d) != 2d) fail_assert(402);
	if (lvl4(0f, 0f, 0f, 0f, 0f, 0f, 0f, 0f, 1d, 0d) != 5d) fail_assert(403);
	if (lvl4(0f, 0f, 0f, 0f, 0f, 0f, 0f, 0f, 0d, 1d) != 6d) fail_assert(404);
	if (lvl1(0, 1f, 2f, 3f, 4f, 7d) != 7d) fail_assert(405);
}

//======================================================================
// Section 5: large arrays of floats
//======================================================================
def bigFloatArrays() {
	var n = 4096;
	var a = Array<float>.new(n);
	var b = Array<float>.new(n);
	for (i < n) {
		a[i] = float.roundi(i) * 0.0009765625f - 2f;
		b[i] = float.roundi(n - i) * 0.001953125f;
	}
	// a strided dot-product-like reduction with four accumulators live at once
	var s0 = 0f, s1 = 0f, s2 = 0f, s3 = 0f;
	for (i < n / 4) {
		s0 += a[4 * i + 0] * b[4 * i + 0];
		s1 += a[4 * i + 1] * b[4 * i + 1];
		s2 += a[4 * i + 2] * b[4 * i + 2];
		s3 += a[4 * i + 3] * b[4 * i + 3];
	}
	acci(mixf(mixf(mixf(mixf(0, s0), s1), s2), s3));

	// in-place transform through a range view
	var r: Range<float> = a;
	var lo = r[0 ... n / 2];
	var hi = r[n / 2 ...];
	for (i < lo.length) lo[i] = lo[i] * 2f + hi[i];
	var h = 0;
	for (i < n) if ((i % 37) == 0) h = mixf(h, a[i]);
	acci(h);

	// a scatter that keeps a float and an index live together
	var idx = Array<int>.new(n);
	for (i < n) idx[i] = (i * 2657) % n;
	var out = Array<float>.new(n);
	for (i < n) out[idx[i]] = a[i] + b[i];
	var g = 0;
	for (i < n) if ((i % 53) == 0) g = mixf(g, out[i]);
	acci(g);

	if (a.length != 4096) fail_assert(501);
	if (lo.length != 2048) fail_assert(502);
	if (hi.length != 2048) fail_assert(503);
	if (b[0] != float.roundi(4096) * 0.001953125f) fail_assert(504);
	if (float.roundi(4096) * 0.001953125f != 8f) fail_assert(505);
}

//======================================================================
// Section 6: large arrays of (float, double) tuples
//======================================================================
def bigTupleArrays() {
	var n = 2048;
	var t = Array<(float, double)>.new(n);
	for (i < n) t[i] = (float.roundi(i) * 0.5f, double.roundi(i) * 0.25d);
	// reading a tuple element keeps both halves live even though only one is used
	var sf = 0f, sd = 0d;
	for (i < n) {
		var e = t[i];
		sf += e.0 * 0.001f;
		sd += e.1 * 0.001d;
	}
	acci(mixf(mixd(0, sd), sf));

	// rewrite in place, swapping the roles of the two components
	for (i < n) {
		var e = t[i];
		t[i] = (float.roundd(e.1) * 0.5f, e.0 + 1d);
	}
	var h = 0;
	for (i < n) if ((i % 61) == 0) {
		var e = t[i];
		h = mixf(h, e.0);
		h = mixd(h, e.1);
	}
	acci(h);

	// wider tuples, mixing references in with the floating-point payload
	var w = Array<(float, double, int, string)>.new(256);
	def NAMES: Array<string> = ["a", "bb", "ccc", "dddd"];
	for (i < w.length) w[i] = (float.roundi(i) * 1.5f, double.roundi(i) * 1.5d, i, NAMES[i % 4]);
	var g = 0;
	for (i < w.length) {
		var e = w[i];
		g = mixf(g, e.0);
		g = mixd(g, e.1);
		g = mix(g, e.2);
		g = mix(g, e.3.length);
	}
	acci(g);

	if (t.length != 2048) fail_assert(601);
	if (w.length != 256) fail_assert(602);
	if (NAMES[3].length != 4) fail_assert(603);
}

//======================================================================
// Section 7: floats surviving allocation churn
//======================================================================
class FNode(f: float, d: double, next: FNode) { }
def allocChurn() {
	// Sixteen floats and eight doubles stay live in this frame while the loop
	// allocates; a collection triggered inside the loop must not disturb them.
	var k0 = SEED[0], k1 = SEED[1], k2 = SEED[2], k3 = SEED[3];
	var k4 = SEED[4], k5 = SEED[5], k6 = SEED[6], k7 = SEED[7];
	var k8 = SEED[8], k9 = SEED[9], k10 = SEED[10], k11 = SEED[11];
	var k12 = SEED[12], k13 = SEED[13], k14 = SEED[14], k15 = SEED[15];
	var m0 = DSEED[0], m1 = DSEED[1], m2 = DSEED[2], m3 = DSEED[3];
	var m4 = DSEED[4], m5 = DSEED[5], m6 = DSEED[6], m7 = DSEED[7];

	var head: FNode;
	var live = Array<FNode>.new(32);
	for (i < 4000) {
		var f = float.roundi(i) * 0.25f - 500f;
		head = FNode.new(f, f * 2d, head);
		if ((i % 41) == 0) live[(i / 41) % live.length] = head;
		if ((i % 7) == 0) head = null;
		// touch a few of the live floats so they cannot be rematerialized cheaply
		k0 = k0 * 0.999f + f * 1e-6f;
		m0 = m0 * 0.999d + f * 1e-6d;
	}
	var h = mixf(0, k0);
	h = mixf(h, k1); h = mixf(h, k2); h = mixf(h, k3);
	h = mixf(h, k4); h = mixf(h, k5); h = mixf(h, k6); h = mixf(h, k7);
	h = mixf(h, k8); h = mixf(h, k9); h = mixf(h, k10); h = mixf(h, k11);
	h = mixf(h, k12); h = mixf(h, k13); h = mixf(h, k14); h = mixf(h, k15);
	h = mixd(h, m0); h = mixd(h, m1); h = mixd(h, m2); h = mixd(h, m3);
	h = mixd(h, m4); h = mixd(h, m5); h = mixd(h, m6); h = mixd(h, m7);
	acci(h);

	var g = 0;
	var count = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			g = mixf(g, p.f);
			g = mixd(g, p.d);
			p = p.next;
			count++;
			if (count > 200000) { acci(g); return; }
		}
	}
	acci(mix(g, count));

	// the untouched locals must still hold their seeds
	if (k15 != SEED[15]) fail_assert(701);
	if (m7 != DSEED[7]) fail_assert(702);
	if (SEED[15] != -32f) fail_assert(703);
	if (DSEED[7] != -8d) fail_assert(704);
}

//======================================================================
// Section 8: floats across virtual dispatch and closures
//======================================================================
class Op {
	def apply(f: float, d: double) -> double { return f + d; }
}
class MulOp extends Op {
	def k: float;
	new(k) { }
	def apply(f: float, d: double) -> double { return f * k + d; }
}
class ChainOp extends Op {
	def a: Op;
	def b: Op;
	new(a, b) { }
	def apply(f: float, d: double) -> double { return a.apply(f, d) + b.apply(f, -d); }
}
def dispatch() {
	var ops = Array<Op>.new(24);
	for (i < ops.length) {
		if ((i % 3) == 0) ops[i] = Op.new();
		else if ((i % 3) == 1) ops[i] = MulOp.new(SEED[i % SEED.length]);
		else ops[i] = ChainOp.new(Op.new(), MulOp.new(SEED[(i + 5) % SEED.length]));
	}
	// eight accumulators live across every dispatch
	var s0 = 0d, s1 = 0d, s2 = 0d, s3 = 0d;
	var s4 = 0d, s5 = 0d, s6 = 0d, s7 = 0d;
	for (i < ops.length) {
		var o = ops[i];
		var f = SEED[i % SEED.length];
		var d = DSEED[i % DSEED.length];
		s0 += o.apply(f, d);
		s1 += o.apply(f * 2f, d);
		s2 += o.apply(f, d * 2d);
		s3 -= o.apply(-f, d);
		s4 += o.apply(f, -d);
		s5 -= o.apply(f * 0.5f, d * 0.5d);
		s6 += o.apply(f + 1f, d + 1d);
		s7 -= o.apply(f - 1f, d - 1d);
	}
	acci(mixd(mixd(mixd(mixd(0, s0), s1), s2), s3));
	acci(mixd(mixd(mixd(mixd(0, s4), s5), s6), s7));

	// closures capturing floats; the captured values live in the heap
	var fns = Array<(float, double) -> double>.new(16);
	for (i < fns.length) {
		var c = SEED[i], e = DSEED[i];
		fns[i] = fun (f: float, d: double) => f * c + d * e;
	}
	var h = 0;
	for (i < fns.length) for (j < 8) h = mixd(h, fns[i](SEED[j], DSEED[j]));
	acci(h);

	if (Op.new().apply(1f, 2d) != 3d) fail_assert(801);
	if (MulOp.new(3f).apply(2f, 1d) != 7d) fail_assert(802);
	if (ChainOp.new(Op.new(), Op.new()).apply(1f, 2d) != 2d) fail_assert(803);
	// (2*2 + 1) + (2*3 + -1) = 5 + 5
	if (ChainOp.new(MulOp.new(2f), MulOp.new(3f)).apply(2f, 1d) != 10d) fail_assert(804);
	if (fns.length != 16) fail_assert(805);
}

//======================================================================
// Section 9: floats in globals under pressure
//======================================================================
var gs: Array<float>;
var gd: Array<double>;
component Bank {
	var f0: float; var f1: float; var f2: float; var f3: float;
	var d0: double; var d1: double; var d2: double; var d3: double;
	var n: int;
	def reset() {
		f0 = 0f; f1 = 0f; f2 = 0f; f3 = 0f;
		d0 = 0d; d1 = 0d; d2 = 0d; d3 = 0d;
		n = 0;
	}
	def step(f: float, d: double) {
		f0 = f0 * 0.5f + f; f1 = f1 * 0.5f + f0;
		f2 = f2 * 0.5f + f1; f3 = f3 * 0.5f + f2;
		d0 = d0 * 0.5d + d; d1 = d1 * 0.5d + d0;
		d2 = d2 * 0.5d + d1; d3 = d3 * 0.5d + d2;
		n++;
	}
}
def globalsUnderPressure() {
	Bank.reset();
	gs = Array<float>.new(512);
	gd = Array<double>.new(512);
	for (i < gs.length) {
		gs[i] = float.roundi(i) * 0.125f - 32f;
		gd[i] = double.roundi(i) * 0.125d - 32d;
	}
	// locals and globals both live; the global stores act as barriers that keep
	// the local accumulators from being kept purely in registers
	var l0 = 0f, l1 = 0f, l2 = 0d, l3 = 0d;
	for (i < gs.length) {
		Bank.step(gs[i], gd[i]);
		l0 += gs[i] * 0.001f;
		l1 -= gs[i] * 0.0005f;
		l2 += gd[i] * 0.001d;
		l3 -= gd[i] * 0.0005d;
	}
	var h = mixf(0, Bank.f0);
	h = mixf(h, Bank.f1); h = mixf(h, Bank.f2); h = mixf(h, Bank.f3);
	h = mixd(h, Bank.d0); h = mixd(h, Bank.d1);
	h = mixd(h, Bank.d2); h = mixd(h, Bank.d3);
	h = mix(h, Bank.n);
	h = mixf(h, l0); h = mixf(h, l1); h = mixd(h, l2); h = mixd(h, l3);
	acci(h);

	var g = 0;
	for (i < gs.length) if ((i % 29) == 0) { g = mixf(g, gs[i]); g = mixd(g, gd[i]); }
	acci(g);

	if (Bank.n != 512) fail_assert(901);
	if (gs.length != 512) fail_assert(902);
	if (gs[0] != -32f) fail_assert(903);
	if (gd[0] != -32d) fail_assert(904);
	if (gs[256] != 0f) fail_assert(905);
}

//======================================================================
// Section 10: floats in variant payloads across spills
//======================================================================
type Vec #unboxed {
	case Two(x: float, y: float);
	case Four(x: float, y: float, z: float, w: float);
	case Wide(x: double, y: double);
	case Empty;
}
def norm(v: Vec) -> double {
	match (v) {
		Two(x, y) => return double.sqrt(x * x + y * y);
		Four(x, y, z, w) => return double.sqrt(x * x + y * y + z * z + w * w);
		Wide(x, y) => return double.sqrt(x * x + y * y);
		Empty => return 0d;
	}
}
def combine(a: Vec, b: Vec) -> Vec {
	match (a) {
		Two(x, y) => match (b) {
			Two(p, q) => return Vec.Four(x, y, p, q);
			Four(p, q, r, s) => return Vec.Four(x + p, y + q, r, s);
			Wide(p, q) => return Vec.Wide(x + p, y + q);
			Empty => return a;
		}
		Four(x, y, z, w) => return Vec.Four(x, y, z, w);
		Wide(x, y) => return Vec.Wide(x, y);
		Empty => return b;
	}
}
def variantPressure() {
	var vs = Array<Vec>.new(64);
	for (i < vs.length) {
		var f = SEED[i % SEED.length];
		match (i % 4) {
			0 => vs[i] = Vec.Two(f, f + 1f);
			1 => vs[i] = Vec.Four(f, f + 1f, f + 2f, f + 3f);
			2 => vs[i] = Vec.Wide(DSEED[i % DSEED.length], f);
			_ => vs[i] = Vec.Empty;
		}
	}
	// four accumulators plus a live Vec across each call
	var s0 = 0d, s1 = 0d, s2 = 0d, s3 = 0d;
	for (i < vs.length) {
		var a = vs[i], b = vs[(i + 1) % vs.length];
		var c = combine(a, b);
		s0 += norm(a);
		s1 += norm(b);
		s2 += norm(c);
		s3 += norm(combine(c, a));
	}
	acci(mixd(mixd(mixd(mixd(0, s0), s1), s2), s3));

	var h = 0;
	for (i < vs.length) {
		h = mix(h, vs[i].tag);
		h = mixd(h, norm(vs[i]));
		h = mixb(h, Vec.Four.?(vs[i]));
	}
	acci(h);

	if (norm(Vec.Two(3f, 4f)) != 5d) fail_assert(1001);
	if (norm(Vec.Four(1f, 2f, 2f, 4f)) != 5d) fail_assert(1002);
	if (norm(Vec.Wide(3d, 4d)) != 5d) fail_assert(1003);
	if (norm(Vec.Empty) != 0d) fail_assert(1004);
	if (norm(combine(Vec.Two(1f, 2f), Vec.Two(2f, 4f))) != 5d) fail_assert(1005);
	if (Vec.Empty.tag != 3) fail_assert(1006);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) manyFloats();
	if (a == 0 || a == 2) manyDoubles();
	if (a == 0 || a == 3) mixedLive();
	if (a == 0 || a == 4) deepCalls();
	if (a == 0 || a == 5) bigFloatArrays();
	if (a == 0 || a == 6) bigTupleArrays();
	if (a == 0 || a == 7) allocChurn();
	if (a == 0 || a == 8) dispatch();
	if (a == 0 || a == 9) globalsUnderPressure();
	if (a == 0 || a == 10) variantPressure();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
