//@execute 0=-1773447125; 1=1954375582; 2=270506320; 3=-904247921; 4=769436462; 5=-458174945; 6=-1556219127; 7=778703183; 8=-1219399876; 9=1668519574
//@heap-size=200000
// Smoke test: enums and enum sets.
// Declarations with and without parameters, `.tag` / `.name` / `.count`,
// iteration over an enum and over a set, enums as array indices, the full set
// algebra (union, intersection, difference, subset, superset, membership),
// enums in match statements, and enums stored in class fields, variants, tuples
// and globals. Results are mixed into a running CRC that main() returns, so no
// computation can be deleted as dead. Interleaved are assert()s over
// compile-time constants, which the optimizer is expected to fold away; a
// folding bug sets the failure flag instead. Input selects the section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

//======================================================================
// The enums
//======================================================================
// eight cases: the set fits in a byte
enum Color { RED, GREEN, BLUE, CYAN, MAGENTA, YELLOW, BLACK, WHITE }
// sixteen cases: the set needs a wider representation
enum Bit {
	B0, B1, B2, B3, B4, B5, B6, B7,
	B8, B9, B10, B11, B12, B13, B14, B15
}
// a parameterized enum: each case carries values
enum Op(prec: int, sym: string, commutes: bool) {
	ADD(1, "+", true),
	SUB(1, "-", false),
	MUL(2, "*", true),
	DIV(2, "/", false),
	MOD(2, "%", false),
	POW(3, "^", false)
}
// a single-case enum
enum Only { SOLE }

def COLORS: Array<Color> = [
	Color.RED, Color.GREEN, Color.BLUE, Color.CYAN,
	Color.MAGENTA, Color.YELLOW, Color.BLACK, Color.WHITE
];
def OPS: Array<Op> = [Op.ADD, Op.SUB, Op.MUL, Op.DIV, Op.MOD, Op.POW];
def NUMS: Array<int> = [7, 2, 9, 4, 1, 8, 3, 6, 5, 0, 11, 12];

//======================================================================
// Section 1: declarations, tags, names and parameters
//======================================================================
def decls() {
	var h = 0;
	for (i < COLORS.length) {
		h = mix(h, COLORS[i].tag);
		h = mixs(h, COLORS[i].name);
		h = mix(h, COLORS[i].name.length);
	}
	for (i < OPS.length) {
		h = mix(h, OPS[i].tag);
		h = mixs(h, OPS[i].name);
		h = mix(h, OPS[i].prec);
		h = mixs(h, OPS[i].sym);
		h = mixb(h, OPS[i].commutes);
	}
	h = mix(h, Color.count);
	h = mix(h, Bit.count);
	h = mix(h, Op.count);
	h = mix(h, Only.count);
	acci(h);

	if (Color.RED.tag != 0) fail_assert(101);
	if (Color.GREEN.tag != 1) fail_assert(102);
	if (Color.WHITE.tag != 7) fail_assert(103);
	if (Bit.B0.tag != 0) fail_assert(104);
	if (Bit.B15.tag != 15) fail_assert(105);
	if (Only.SOLE.tag != 0) fail_assert(106);
	if (Color.count != 8) fail_assert(107);
	if (Bit.count != 16) fail_assert(108);
	if (Op.count != 6) fail_assert(109);
	if (Only.count != 1) fail_assert(110);
	if (Color.RED.name.length != 3) fail_assert(111);
	if (Color.MAGENTA.name.length != 7) fail_assert(112);
	if (Color.RED.name[0] != 'R') fail_assert(113);
	if (Bit.B15.name.length != 3) fail_assert(114);
	if (Only.SOLE.name.length != 4) fail_assert(115);
	// parameterized cases
	if (Op.ADD.prec != 1) fail_assert(116);
	if (Op.MUL.prec != 2) fail_assert(117);
	if (Op.POW.prec != 3) fail_assert(118);
	if (Op.ADD.sym.length != 1) fail_assert(119);
	if (Op.ADD.sym[0] != '+') fail_assert(120);
	if (Op.DIV.sym[0] != '/') fail_assert(121);
	if (!Op.MUL.commutes) fail_assert(122);
	if (Op.SUB.commutes) fail_assert(123);
	if (Op.POW.tag != 5) fail_assert(124);
	// enum values compare by identity of the case
	if (!(Color.RED == Color.RED)) fail_assert(125);
	if (Color.RED == Color.BLUE) fail_assert(126);
	if (!(Color.RED != Color.BLUE)) fail_assert(127);
	if (COLORS[3] != Color.CYAN) fail_assert(128);
	// the default value of an enum-typed variable is the first case
	var d: Color;
	if (d != Color.RED) fail_assert(129);
	var e: Op;
	if (e != Op.ADD) fail_assert(130);
	if (e.prec != 1) fail_assert(131);
	// two references to the same case name string are the same object
	if (Color.RED.name != Color.RED.name) fail_assert(132);
}

//======================================================================
// Section 2: iteration
//======================================================================
def iterate() {
	var h = 0;
	var n = 0;
	for (c in Color) {
		h = mix(h, c.tag);
		h = mixs(h, c.name);
		n++;
	}
	h = mix(h, n);
	var nb = 0;
	for (b in Bit) {
		h = mix(h, b.tag);
		nb++;
	}
	h = mix(h, nb);
	var no = 0;
	for (o in Op) {
		h = mix(h, o.prec);
		h = mixs(h, o.sym);
		no++;
	}
	h = mix(h, no);
	acci(h);
	if (n != 8) fail_assert(201);
	if (nb != 16) fail_assert(202);
	if (no != 6) fail_assert(203);

	// iteration visits the cases in declaration order
	var order = Array<int>.new(Color.count);
	var k = 0;
	for (c in Color) order[k++] = c.tag;
	var g = 0;
	for (i < order.length) g = mix(g, order[i]);
	acci(g);
	for (i < order.length) if (order[i] != i) fail_assert(204);

	// break out of an enum iteration
	var stopped = 0;
	for (c in Color) {
		if (c.tag == 4) break;
		stopped++;
	}
	if (stopped != 4) fail_assert(205);
	// sum the parameters over the whole enum
	var precSum = 0;
	for (o in Op) precSum += o.prec;
	if (precSum != 11) fail_assert(206);		// 1+1+2+2+2+3
	var comm = 0;
	for (o in Op) if (o.commutes) comm++;
	if (comm != 2) fail_assert(207);
	var symLen = 0;
	for (o in Op) symLen += o.sym.length;
	if (symLen != 6) fail_assert(208);
	// iteration over a set visits only its members, in tag order
	var s: Color.set = Color.BLUE | Color.RED | Color.WHITE;
	var seen = Array<int>.new(3);
	var m = 0;
	for (c in s) seen[m++] = c.tag;
	if (m != 3) fail_assert(209);
	if (seen[0] != 0) fail_assert(210);
	if (seen[1] != 2) fail_assert(211);
	if (seen[2] != 7) fail_assert(212);
	var empty: Color.set;
	var z = 0;
	for (c in empty) z++;
	if (z != 0) fail_assert(213);
	var all = 0;
	for (c in Color.set.all) all++;
	if (all != 8) fail_assert(214);
	var kk = mix(0, m);
	for (i < seen.length) kk = mix(kk, seen[i]);
	acci(kk);
}

//======================================================================
// Section 3: enums as array indices
//======================================================================
def counts(a: Array<int>, cs: Array<Color>) {
	for (i < cs.length) a[cs[i].tag]++;
}
def indexing() {
	var table = Array<int>.new(Color.count);
	// the tag has the enum's narrow tag type; widen before doing arithmetic
	for (c in Color) { var t = int.!(c.tag); table[t] = t * t + 1; }
	var h = 0;
	for (i < table.length) h = mix(h, table[i]);
	acci(h);
	if (table[Color.RED.tag] != 1) fail_assert(301);
	if (table[Color.WHITE.tag] != 50) fail_assert(302);
	if (table[Color.CYAN.tag] != 10) fail_assert(303);

	// a histogram driven by data
	var hist = Array<int>.new(Color.count);
	var draw = Array<Color>.new(240);
	for (i < draw.length) draw[i] = COLORS[i % COLORS.length];
	counts(hist, draw);
	var g = 0;
	for (i < hist.length) g = mix(g, hist[i]);
	acci(g);
	for (i < hist.length) if (hist[i] != 30) fail_assert(304);

	// a table of names and a table of parameters
	var names = Array<string>.new(Color.count);
	for (c in Color) names[c.tag] = c.name;
	var precs = Array<int>.new(Op.count);
	var syms = Array<string>.new(Op.count);
	for (o in Op) {
		precs[o.tag] = o.prec;
		syms[o.tag] = o.sym;
	}
	var k = 0;
	for (i < names.length) k = mixs(k, names[i]);
	for (i < precs.length) {
		k = mix(k, precs[i]);
		k = mixs(k, syms[i]);
	}
	acci(k);
	if (names[Color.BLACK.tag].length != 5) fail_assert(305);
	if (precs[Op.POW.tag] != 3) fail_assert(306);
	if (syms[Op.MOD.tag][0] != '%') fail_assert(307);

	// a two-dimensional table indexed by two enums
	var m = Array<Array<int>>.new(Color.count);
	for (c in Color) {
		m[c.tag] = Array<int>.new(Op.count);
		for (o in Op) m[c.tag][o.tag] = int.!(c.tag) * 10 + o.prec;
	}
	var q = 0;
	for (i < m.length) for (j < Op.count) q = mix(q, m[i][j]);
	acci(q);
	if (m[Color.BLUE.tag][Op.POW.tag] != 23) fail_assert(308);
	if (m[Color.WHITE.tag][Op.ADD.tag] != 71) fail_assert(309);
	// an array of enums, indexed by a computed tag
	var wheel = Array<Color>.new(24);
	for (i < wheel.length) wheel[i] = COLORS[(i * 3) % Color.count];
	var r = 0;
	for (i < wheel.length) r = mix(r, wheel[i].tag);
	acci(r);
	if (wheel[1] != Color.CYAN) fail_assert(310);
	if (wheel[8] != Color.RED) fail_assert(311);
}

//======================================================================
// Section 4: set algebra
//======================================================================
def bitsOf(s: Color.set) -> int {
	var r = 0;
	for (c in s) r |= 1 << byte.view(c.tag);
	return r;
}
def setOf(x: int) -> Color.set {
	var s: Color.set;
	for (c in Color) if ((x & (1 << byte.view(c.tag))) != 0) s |= c;
	return s;
}
// A spread of representative subsets: the empty set, every singleton, every
// adjacent pair, a few dense masks and the full set.
def MASKS: Array<int> = [
	0, 1, 2, 4, 8, 16, 32, 64, 128,
	3, 6, 12, 24, 48, 96, 192, 129,
	5, 10, 85, 170, 15, 240, 51, 204, 63, 252, 127, 254, 255
];
def setops() {
	// over all pairs of representative subsets, the operators must agree with
	// the corresponding bit operations
	var h = 0;
	for (i < MASKS.length) {
		var a = setOf(MASKS[i]);
		for (j < MASKS.length) {
			var b = setOf(MASKS[j]);
			h = mix(h, bitsOf(a | b));
			h = mix(h, bitsOf(a & b));
			h = mix(h, bitsOf(a - b));
			if (bitsOf(a | b) != (MASKS[i] | MASKS[j])) fail_assert(401);
			if (bitsOf(a & b) != (MASKS[i] & MASKS[j])) fail_assert(402);
			if (bitsOf(a - b) != (MASKS[i] & ~MASKS[j])) fail_assert(403);
		}
	}
	acci(h);

	var empty: Color.set;
	var all = Color.set.all;
	var rg: Color.set = Color.RED | Color.GREEN;
	var gb: Color.set = Color.GREEN | Color.BLUE;
	var g = mix(0, bitsOf(empty));
	g = mix(g, bitsOf(all));
	g = mix(g, bitsOf(rg));
	g = mix(g, bitsOf(gb));
	g = mix(g, bitsOf(rg | gb));
	g = mix(g, bitsOf(rg & gb));
	g = mix(g, bitsOf(rg - gb));
	g = mix(g, bitsOf(all - rg));
	acci(g);

	if (bitsOf(empty) != 0) fail_assert(404);
	if (bitsOf(all) != 255) fail_assert(405);
	if (bitsOf(rg) != 3) fail_assert(406);
	if (bitsOf(gb) != 6) fail_assert(407);
	if (bitsOf(rg | gb) != 7) fail_assert(408);
	if (bitsOf(rg & gb) != 2) fail_assert(409);
	if (bitsOf(rg - gb) != 1) fail_assert(410);
	if (bitsOf(gb - rg) != 4) fail_assert(411);
	if (bitsOf(all - rg) != 252) fail_assert(412);
	// identities
	if (!((rg | empty) == rg)) fail_assert(413);
	if (!((rg & empty) == empty)) fail_assert(414);
	if (!((rg & all) == rg)) fail_assert(415);
	if (!((rg | all) == all)) fail_assert(416);
	if (!((rg - rg) == empty)) fail_assert(417);
	if (!((rg - empty) == rg)) fail_assert(418);
	if (!((rg | gb) == (gb | rg))) fail_assert(419);
	if (!((rg & gb) == (gb & rg))) fail_assert(420);
	if ((rg - gb) == (gb - rg)) fail_assert(421);
	// compound assignment
	var acc: Color.set;
	for (c in Color) acc |= c;
	if (!(acc == all)) fail_assert(422);
	acc = acc - Color.RED;
	if (acc.RED) fail_assert(423);
	if (!acc.GREEN) fail_assert(424);
	acc &= rg;
	if (!(acc == Color.set.!<Color>(Color.GREEN))) fail_assert(425);
	// a single case coerces to a singleton set
	var one: Color.set = Color.BLUE;
	if (bitsOf(one) != 4) fail_assert(426);
	if (!one.BLUE) fail_assert(427);
	if (one.RED) fail_assert(428);
	// the wider, 16-case set
	var bs: Bit.set = Bit.B0 | Bit.B15 | Bit.B8;
	var nb = 0;
	for (b in bs) nb++;
	if (nb != 3) fail_assert(429);
	if (!bs.B15) fail_assert(430);
	if (bs.B1) fail_assert(431);
	var allb = 0;
	for (b in Bit.set.all) allb++;
	if (allb != 16) fail_assert(432);
	var k = mix(0, nb);
	for (b in bs) k = mix(k, b.tag);
	acci(k);
}

//======================================================================
// Section 5: subset, superset and membership
//======================================================================
def setrel() {
	var h = 0;
	for (i < MASKS.length) {
		var x = MASKS[i];
		var a = setOf(x);
		for (j < MASKS.length) {
			var y = MASKS[j];
			var b = setOf(y);
			h = mixb(h, a <= b);
			h = mixb(h, a < b);
			h = mixb(h, a >= b);
			h = mixb(h, a > b);
			h = mixb(h, a == b);
			if ((a <= b) != ((x & ~y) == 0)) fail_assert(501);
			if ((a < b) != (((x & ~y) == 0) && x != y)) fail_assert(502);
			if ((a >= b) != ((y & ~x) == 0)) fail_assert(503);
			if ((a > b) != (((y & ~x) == 0) && x != y)) fail_assert(504);
			if ((a == b) != (x == y)) fail_assert(505);
		}
	}
	acci(h);

	var empty: Color.set;
	var all = Color.set.all;
	var rg: Color.set = Color.RED | Color.GREEN;
	var r: Color.set = Color.RED;
	// reflexivity: <= and >= hold, < and > do not
	if (!(rg <= rg)) fail_assert(506);
	if (!(rg >= rg)) fail_assert(507);
	if (rg < rg) fail_assert(508);
	if (rg > rg) fail_assert(509);
	// the empty set is a subset of everything
	if (!(empty <= rg)) fail_assert(510);
	if (!(empty < rg)) fail_assert(511);
	if (!(empty <= empty)) fail_assert(512);
	if (empty < empty) fail_assert(513);
	// the full set is a superset of everything
	if (!(all >= rg)) fail_assert(514);
	if (!(all > rg)) fail_assert(515);
	if (all < rg) fail_assert(516);
	// strict containment
	if (!(r < rg)) fail_assert(517);
	if (!(rg > r)) fail_assert(518);
	if (rg < r) fail_assert(519);
	// incomparable sets
	var b: Color.set = Color.BLUE;
	if (r <= b) fail_assert(520);
	if (r >= b) fail_assert(521);
	if (r < b) fail_assert(522);
	if (r > b) fail_assert(523);
	// membership
	if (!rg.RED) fail_assert(524);
	if (!rg.GREEN) fail_assert(525);
	if (rg.BLUE) fail_assert(526);
	if (empty.RED) fail_assert(527);
	if (!all.WHITE) fail_assert(528);
	// membership as a first-class function
	def isRed = Color.set.RED;
	def isWhite = Color.set.WHITE;
	if (!isRed(rg)) fail_assert(529);
	if (isWhite(rg)) fail_assert(530);
	if (!isWhite(all)) fail_assert(531);
	var g = 0;
	for (i < MASKS.length) {
		var s = setOf(MASKS[i]);
		g = mixb(g, isRed(s));
		g = mixb(g, isWhite(s));
		g = mixb(g, s <= all);
		g = mixb(g, empty <= s);
	}
	acci(g);
}

//======================================================================
// Section 6: enums in match statements
//======================================================================
def describe(c: Color) -> int {
	match (c) {
		RED => return 10;
		GREEN => return 20;
		BLUE => return 30;
		CYAN => return 40;
		MAGENTA => return 50;
		YELLOW => return 60;
		BLACK => return 70;
		WHITE => return 80;
	}
}
def bucket(c: Color) -> int {
	match (c) {
		RED => return 1;
		GREEN => return 1;
		BLUE => return 1;
		_ => return 2;
	}
}
def apply(o: Op, a: int, b: int) -> int {
	match (o) {
		ADD => return a + b;
		SUB => return a - b;
		MUL => return a * b;
		DIV => return if(b == 0, 0, a / b);
		MOD => return if(b == 0, 0, a % b);
		POW => {
			var r = 1;
			for (i < 3) r = r * a;
			return r;
		}
	}
}
def matching() {
	var h = 0;
	for (i < 240) {
		var c = COLORS[i % COLORS.length];
		h = mix(h, describe(c));
		h = mix(h, bucket(c));
		match (c.tag) {
			0 => h = mix(h, 100);
			7 => h = mix(h, 107);
			_ => h = mix(h, c.tag);
		}
	}
	acci(h);
	var g = 0;
	for (i < OPS.length) {
		for (j < NUMS.length) {
			g = mix(g, apply(OPS[i], NUMS[j], NUMS[(j + 3) % NUMS.length]));
		}
	}
	acci(g);

	if (describe(Color.RED) != 10) fail_assert(601);
	if (describe(Color.WHITE) != 80) fail_assert(602);
	if (describe(COLORS[4]) != 50) fail_assert(603);
	if (bucket(Color.BLUE) != 1) fail_assert(604);
	if (bucket(Color.YELLOW) != 2) fail_assert(605);
	if (apply(Op.ADD, 3, 4) != 7) fail_assert(606);
	if (apply(Op.SUB, 3, 4) != -1) fail_assert(607);
	if (apply(Op.MUL, 3, 4) != 12) fail_assert(608);
	if (apply(Op.DIV, 12, 4) != 3) fail_assert(609);
	if (apply(Op.DIV, 12, 0) != 0) fail_assert(610);
	if (apply(Op.MOD, 13, 4) != 1) fail_assert(611);
	if (apply(Op.POW, 3, 0) != 27) fail_assert(612);
	// nested match: an enum inside a match on another enum
	var k = 0;
	for (i < COLORS.length) {
		var c = COLORS[i];
		match (c) {
			RED => {
				match (Op.ADD) {
					ADD => k = mix(k, 1);
					_ => k = mix(k, -1);
				}
			}
			_ => k = mix(k, c.tag);
		}
	}
	acci(k);
}

//======================================================================
// Section 7: enums in classes, variants, tuples and globals
//======================================================================
class Pixel {
	def c: Color;
	var mask: Color.set;
	var op: Op;
	new(c) {
		mask = c;
		op = Op.ADD;
	}
	def weight() -> int { return int.!(c.tag) * 10 + op.prec; }
}
type Node {
	case Leaf(c: Color);
	case Marked(c: Color, s: Color.set);
	case Applied(o: Op, a: int);
	case Blank;
}
var gColor: Color;
var gSet: Color.set;
var gOp: Op;
var gTup: (Color, Color.set, Op, int);
var gArr: Array<Node>;

def nodeVal(n: Node) -> int {
	match (n) {
		Leaf(c) => return int.!(c.tag);
		Marked(c, s) => return int.!(c.tag) + bitsOf(s) * 10;
		Applied(o, a) => return apply(o, a, 3);
		Blank => return -1;
	}
}
def makeNode(i: int) -> Node {
	var c = COLORS[i % COLORS.length];
	match (i % 4) {
		0 => return Node.Leaf(c);
		1 => return Node.Marked(c, c | Color.WHITE);
		2 => return Node.Applied(OPS[i % OPS.length], NUMS[i % NUMS.length]);
		_ => return Node.Blank;
	}
}
def storage() {
	gColor = Color.RED;
	gSet = Color.set.all;
	gOp = Op.ADD;
	gTup = (Color.RED, Color.set.all, Op.ADD, 0);
	gArr = null;
	gSet = setOf(0);

	var h = mix(0, gColor.tag);
	h = mix(h, bitsOf(gSet));
	h = mix(h, gOp.prec);
	h = mixb(h, gArr == null);
	acci(h);
	if (gColor != Color.RED) fail_assert(701);
	if (bitsOf(gSet) != 0) fail_assert(702);
	if (gOp != Op.ADD) fail_assert(703);

	var px = Array<Pixel>.new(64);
	for (i < px.length) {
		var p = Pixel.new(COLORS[i % COLORS.length]);
		p.op = OPS[i % OPS.length];
		p.mask = p.mask | COLORS[(i + 1) % COLORS.length];
		px[i] = p;
	}
	var g = 0;
	for (i < px.length) {
		g = mix(g, px[i].c.tag);
		g = mix(g, bitsOf(px[i].mask));
		g = mix(g, px[i].op.tag);
		g = mix(g, px[i].weight());
	}
	acci(g);
	var p0 = Pixel.new(Color.BLUE);
	if (p0.c != Color.BLUE) fail_assert(704);
	if (bitsOf(p0.mask) != 4) fail_assert(705);
	if (p0.weight() != 21) fail_assert(706);
	p0.op = Op.POW;
	if (p0.weight() != 23) fail_assert(707);
	p0.mask = p0.mask | Color.RED;
	if (bitsOf(p0.mask) != 5) fail_assert(708);

	gArr = Array<Node>.new(96);
	for (i < gArr.length) gArr[i] = makeNode(i);
	var k = 0;
	for (i < gArr.length) {
		gColor = COLORS[i % COLORS.length];
		gSet = gColor | Color.BLACK;
		gOp = OPS[i % OPS.length];
		gTup = (gColor, gSet, gOp, i);
		k = mix(k, nodeVal(gArr[i]));
		k = mix(k, gArr[i].tag);
		k = mix(k, gTup.0.tag);
		k = mix(k, bitsOf(gTup.1));
		k = mix(k, gTup.2.prec);
		k = mix(k, gTup.3);
	}
	acci(k);
	if (gTup.3 != 95) fail_assert(709);
	if (nodeVal(Node.Leaf(Color.CYAN)) != 3) fail_assert(710);
	if (nodeVal(Node.Marked(Color.RED, Color.RED | Color.WHITE)) != 1290) fail_assert(711);
	if (nodeVal(Node.Applied(Op.MUL, 4)) != 12) fail_assert(712);
	if (nodeVal(Node.Blank) != -1) fail_assert(713);
	// variant equality over enum and enum-set payloads
	var n1: Node = Node.Leaf(Color.RED);
	var n2: Node = Node.Leaf(Color.RED);
	var n3: Node = Node.Leaf(Color.BLUE);
	if (!(n1 == n2)) fail_assert(714);
	if (n1 == n3) fail_assert(715);
	var m1: Node = Node.Marked(Color.RED, Color.RED | Color.BLUE);
	var m2: Node = Node.Marked(Color.RED, Color.BLUE | Color.RED);
	var m3: Node = Node.Marked(Color.RED, Color.BLUE);
	if (!(m1 == m2)) fail_assert(716);
	if (m1 == m3) fail_assert(717);
	if (n1 == m1) fail_assert(718);
	// tuples of enums compare componentwise
	var t1 = (Color.RED, Op.MUL);
	var t2 = (Color.RED, Op.MUL);
	if (!(t1 == t2)) fail_assert(719);
	if (t1 == (Color.RED, Op.DIV)) fail_assert(720);

	gColor = Color.RED;
	gSet = setOf(0);
	gOp = Op.ADD;
	gTup = (Color.RED, setOf(0), Op.ADD, 0);
	gArr = null;
}

//======================================================================
// Section 8: enums and sets through functions
//======================================================================
def opOf(c: Color) -> Op { return OPS[c.tag % OPS.length]; }
def merge(a: Color.set, b: Color.set) -> Color.set { return a | b; }
def selectSet(f: (Color.set, Color.set) -> Color.set, xs: Array<Color.set>) -> Color.set {
	var acc: Color.set;
	for (i < xs.length) acc = f(acc, xs[i]);
	return acc;
}
def funcs() {
	def SETOPS: Array<(Color.set, Color.set) -> Color.set> = [
		Color.set.|, Color.set.&, Color.set.-, merge
	];
	var xs = Array<Color.set>.new(16);
	for (i < xs.length) xs[i] = setOf(i * 17);
	var h = 0;
	for (k < SETOPS.length) {
		h = mix(h, bitsOf(selectSet(SETOPS[k], xs)));
		for (i < xs.length) h = mix(h, bitsOf(SETOPS[k](xs[i], xs[(i + 1) % xs.length])));
	}
	acci(h);

	// enum-valued and set-valued function results
	var g = 0;
	for (i < COLORS.length) {
		g = mix(g, opOf(COLORS[i]).tag);
		g = mix(g, opOf(COLORS[i]).prec);
		g = mix(g, bitsOf(merge(COLORS[i], Color.WHITE)));
	}
	acci(g);

	// the enum-to-set cast, taken as a function value
	def toSet = Color.set.!<Color>;
	var k = 0;
	for (i < COLORS.length) k = mix(k, bitsOf(toSet(COLORS[i])));
	acci(k);
	if (bitsOf(toSet(Color.RED)) != 1) fail_assert(801);
	if (bitsOf(toSet(Color.WHITE)) != 128) fail_assert(802);
	if (!toSet(Color.BLUE).BLUE) fail_assert(803);
	if (opOf(Color.RED) != Op.ADD) fail_assert(804);
	if (opOf(Color.YELLOW) != Op.POW) fail_assert(805);	// tag 5
	if (opOf(Color.BLACK) != Op.ADD) fail_assert(806);	// tag 6 % 6
	if (bitsOf(merge(Color.RED, Color.BLUE)) != 5) fail_assert(807);
	if (bitsOf(selectSet(merge, xs)) == 0) fail_assert(808);
	// delegates keyed by enum tag
	var table = Array<(int, int) -> int>.new(Op.count);
	for (o in Op) table[o.tag] = apply(o, _, _);
	var q = 0;
	for (i < table.length) for (j < NUMS.length) q = mix(q, table[i](NUMS[j], 3));
	acci(q);
	if (table[Op.ADD.tag](3, 4) != 7) fail_assert(809);
	if (table[Op.MUL.tag](3, 4) != 12) fail_assert(810);
}

//======================================================================
// Section 9: bulk round trips
//======================================================================
def bulk() {
	srand(0x5EEDE1);
	var h = 0;
	for (i < 1500) {
		var x = randn(256);
		var s = setOf(x);
		h = mix(h, bitsOf(s));
		h = mixb(h, bitsOf(s) == x);
		var y = randn(256);
		var t = setOf(y);
		h = mix(h, bitsOf(s | t));
		h = mix(h, bitsOf(s & t));
		h = mix(h, bitsOf(s - t));
		h = mixb(h, (s & t) <= s);
		h = mixb(h, s <= (s | t));
	}
	acci(h);

	// a long run of enum-driven dispatch
	srand(0x5EEDE2);
	var g = 0;
	var acc = 0;
	for (i < 2000) {
		var o = OPS[randn(OPS.length)];
		var c = COLORS[randn(COLORS.length)];
		acc = apply(o, acc & 0xFFFF, c.tag + 1);
		g = mix(g, acc);
		g = mix(g, describe(c));
	}
	g = mix(g, acc);
	acci(g);

	// arrays of enums and sets kept live across allocation
	var keep = Array<Array<Color>>.new(8);
	var sets = Array<Color.set>.new(64);
	for (i < sets.length) sets[i] = setOf(randn(256));
	for (i < 400) {
		var a = Array<Color>.new(64);
		for (j < a.length) a[j] = COLORS[randn(COLORS.length)];
		if ((i % 53) == 0) keep[(i / 53) % keep.length] = a;
	}
	var k = 0;
	for (i < keep.length) {
		if (keep[i] == null) continue;
		for (j < keep[i].length) k = mix(k, keep[i][j].tag);
	}
	for (i < sets.length) k = mix(k, bitsOf(sets[i]));
	acci(k);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) decls();
	if (a == 0 || a == 2) iterate();
	if (a == 0 || a == 3) indexing();
	if (a == 0 || a == 4) setops();
	if (a == 0 || a == 5) setrel();
	if (a == 0 || a == 6) matching();
	if (a == 0 || a == 7) storage();
	if (a == 0 || a == 8) funcs();
	if (a == 0 || a == 9) bulk();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
