//@execute 0=501121163; 1=539609380; 2=-1539909116; 3=-171240634; 4=-843820425; 5=-597132882; 6=-471753179; 7=-1349247488
//@heap-size=400000
// Smoke test: polymorphic and structural casts.
// Where cast02.v3 walks a plain class hierarchy, this file casts and queries
// the *composed* types: type-parameterized classes and ADTs, arrays and ranges,
// function types, tuples, and type parameters inside generic methods. Most
// queries are routed through a generic helper, because asking a structurally
// impossible question directly is a static error -- inside a generic method the
// same question is legal and answered at runtime.
// Everything observed is folded into a running CRC that main() returns, so
// nothing can be deleted as dead; interleaved assert()s over compile-time
// constants encode what the answers must be. `T.!` is only applied where the
// cast is known to succeed.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Generic cast machinery
//
// `gq` asks "is this F actually a T?" at runtime. Written directly, most of
// these questions are rejected at compile time as statically impossible; behind
// a type parameter they compile and are answered dynamically.
//======================================================================
def gq<F, T>(x: F) -> bool { return T.?(x); }
def gc<F, T>(x: F) -> T { return T.!(x); }

//======================================================================
// Types under test
//======================================================================
class Base {
	def id: int;
	new(id) { }
	def kind() -> int { return 0; }
}
class Derived extends Base {
	new(id: int) super(id) { }
	def kind() -> int { return 1; }
}
class Other extends Base {
	new(id: int) super(id) { }
	def kind() -> int { return 2; }
}
class Box<T> {
	var v: T;
	new(v) { }
	def get() -> T { return v; }
}
class SubBox<T> extends Box<T> {
	def extra: int;
	new(v: T, extra) super(v) { }
}
class Pair<A, B>(a: A, b: B) { }

type Opt<T> {
	case Some(v: T);
	case None;
}
type Lst<T> {
	case Cons(head: T, tail: Lst<T>);
	case Nil;
}

//======================================================================
// Section 1: parameterized classes
//======================================================================
def genericClasses() {
	var bi = Box<int>.new(7);
	var bl = Box<long>.new(7);
	var bb = Box<Base>.new(Base.new(1));
	var bd = Box<Base>.new(Derived.new(2));
	var bdd = Box<Derived>.new(Derived.new(3));
	var sb = SubBox<int>.new(9, 11);

	var h = 0;
	// same type argument: yes; different type argument: no, in either direction
	h = mixb(h, gq<Box<int>, Box<int>>(bi));
	h = mixb(h, gq<Box<int>, Box<long>>(bi));
	h = mixb(h, gq<Box<long>, Box<int>>(bl));
	// type arguments are invariant even when they are related classes
	h = mixb(h, gq<Box<Derived>, Box<Base>>(bdd));
	h = mixb(h, gq<Box<Base>, Box<Derived>>(bd));
	// but the class hierarchy on the container itself still works
	h = mixb(h, gq<Box<int>, SubBox<int>>(bi));
	h = mixb(h, gq<Box<int>, SubBox<int>>(sb));
	h = mixb(h, gq<SubBox<int>, Box<int>>(sb));
	h = mixb(h, gq<Box<int>, SubBox<long>>(sb));
	h = mix(h, bi.get());
	h = mixl(h, bl.get());
	h = mix(h, bb.get().id);
	h = mix(h, bd.get().kind());
	acci(h);

	// a heterogeneous population, each entry queried at every instantiation
	var boxes = Array<Box<int>>.new(40);
	for (i < boxes.length) {
		boxes[i] = if((i % 3) == 0, SubBox<int>.new(i, i * 2), Box<int>.new(i));
	}
	var g = 0;
	var subs = 0;
	for (i < boxes.length) {
		var b = boxes[i];
		g = mix(g, b.get());
		if (SubBox<int>.?(b)) {
			subs++;
			g = mix(g, SubBox<int>.!(b).extra);
		} else {
			g = mix(g, -1);
		}
	}
	acci(mix(g, subs));

	// nesting: the type argument is itself a parameterized class
	var nested = Box<Box<int>>.new(Box<int>.new(5));
	var k = mix(0, nested.get().get());
	k = mixb(k, gq<Box<Box<int>>, Box<Box<long>>>(nested));
	k = mixb(k, gq<Box<Box<int>>, Box<Box<int>>>(nested));
	var p = Pair<int, Base>.new(3, Derived.new(4));
	k = mix(k, p.a);
	k = mix(k, p.b.kind());
	k = mixb(k, gq<Pair<int, Base>, Pair<int, Base>>(p));
	k = mixb(k, gq<Pair<int, Base>, Pair<long, Base>>(p));
	k = mixb(k, Derived.?(p.b));
	acci(k);

	if (!gq<Box<int>, Box<int>>(bi)) fail_assert(101);
	if (gq<Box<int>, Box<long>>(bi)) fail_assert(102);
	if (gq<Box<Derived>, Box<Base>>(bdd)) fail_assert(103);
	if (gq<Box<Base>, Box<Derived>>(bd)) fail_assert(104);
	if (!gq<SubBox<int>, Box<int>>(sb)) fail_assert(105);
	if (gq<Box<int>, SubBox<int>>(bi)) fail_assert(106);
	if (!gq<Box<int>, SubBox<int>>(sb)) fail_assert(107);
	if (gq<Box<int>, SubBox<long>>(sb)) fail_assert(108);
	if (gc<SubBox<int>, Box<int>>(sb).get() != 9) fail_assert(109);
	if (gc<Box<int>, SubBox<int>>(sb).extra != 11) fail_assert(110);
	if (subs != 14) fail_assert(111);		// i = 0,3,...,39
	// null is not an instance of anything, but casting it always succeeds
	if (gq<Box<int>, Box<int>>(null)) fail_assert(112);
	if (gc<Box<int>, SubBox<int>>(null) != null) fail_assert(113);
}

//======================================================================
// Section 2: parameterized ADTs
//======================================================================
def sumOpt(o: Opt<int>) -> int {
	match (o) {
		Some(v) => return v;
		None => return -1;
	}
}
def lenOf<T>(l: Lst<T>) -> int {
	var n = 0;
	var p = l;
	while (Lst<T>.Cons.?(p)) {
		n++;
		p = Lst<T>.Cons.!(p).tail;
	}
	return n;
}
def genericAdts() {
	var oi: Opt<int> = Opt<int>.Some(5);
	var on: Opt<int> = Opt<int>.None;
	var ob: Opt<Base> = Opt<Base>.Some(Derived.new(1));
	var od: Opt<Derived> = Opt<Derived>.Some(Derived.new(2));

	var h = 0;
	h = mixb(h, Opt<int>.Some.?(oi));
	h = mixb(h, Opt<int>.None.?(oi));
	h = mixb(h, Opt<int>.Some.?(on));
	h = mixb(h, Opt<int>.None.?(on));
	// different type arguments never match
	h = mixb(h, gq<Opt<int>, Opt<long>>(oi));
	h = mixb(h, gq<Opt<int>, Opt<int>>(oi));
	h = mixb(h, gq<Opt<Derived>, Opt<Base>>(od));
	h = mixb(h, gq<Opt<Base>, Opt<Derived>>(ob));
	h = mix(h, sumOpt(oi));
	h = mix(h, sumOpt(on));
	h = mix(h, oi.tag);
	h = mix(h, on.tag);
	// the payload's own dynamic type is still queryable
	h = mixb(h, Derived.?(Opt<Base>.Some.!(ob).v));
	h = mixb(h, Other.?(Opt<Base>.Some.!(ob).v));
	acci(h);

	// build lists at two instantiations and query them through a generic method
	var li: Lst<int> = Lst<int>.Nil;
	for (i < 30) li = Lst<int>.Cons(i, li);
	var lb: Lst<Base> = Lst<Base>.Nil;
	for (i < 20) lb = Lst<Base>.Cons(if((i % 2) == 0, Derived.new(i), Other.new(i)), lb);
	var g = mix(0, lenOf(li));
	g = mix(g, lenOf(lb));
	var p = li;
	while (Lst<int>.Cons.?(p)) {
		var c = Lst<int>.Cons.!(p);
		g = mix(g, c.head);
		p = c.tail;
	}
	var q = lb;
	var derived = 0;
	while (Lst<Base>.Cons.?(q)) {
		var c = Lst<Base>.Cons.!(q);
		g = mixb(g, Derived.?(c.head));
		if (Derived.?(c.head)) derived++;
		g = mix(g, c.head.kind());
		q = c.tail;
	}
	acci(mix(g, derived));

	// options stored in an array, queried per element
	var opts = Array<Opt<Base>>.new(24);
	for (i < opts.length) {
		match (i % 3) {
			0 => opts[i] = Opt<Base>.Some(Derived.new(i));
			1 => opts[i] = Opt<Base>.Some(Other.new(i));
			_ => opts[i] = Opt<Base>.None;
		}
	}
	var k = 0;
	for (i < opts.length) {
		var o = opts[i];
		k = mix(k, o.tag);
		if (Opt<Base>.Some.?(o)) {
			var v = Opt<Base>.Some.!(o).v;
			k = mix(k, v.kind());
			k = mixb(k, Derived.?(v));
			k = mixb(k, Other.?(v));
		} else {
			k = mix(k, -1);
		}
	}
	acci(k);

	if (!Opt<int>.Some.?(oi)) fail_assert(201);
	if (Opt<int>.None.?(oi)) fail_assert(202);
	if (gq<Opt<int>, Opt<long>>(oi)) fail_assert(203);
	if (!gq<Opt<int>, Opt<int>>(oi)) fail_assert(204);
	if (gq<Opt<Derived>, Opt<Base>>(od)) fail_assert(205);
	if (gq<Opt<Base>, Opt<Derived>>(ob)) fail_assert(206);
	if (sumOpt(Opt<int>.Some(5)) != 5) fail_assert(207);
	if (sumOpt(Opt<int>.None) != -1) fail_assert(208);
	if (Opt<int>.None.tag != 1) fail_assert(209);
	if (lenOf(Lst<int>.Cons(1, Lst<int>.Cons(2, Lst<int>.Nil))) != 2) fail_assert(210);
	if (lenOf<int>(Lst<int>.Nil) != 0) fail_assert(211);
	if (derived != 10) fail_assert(212);
}

//======================================================================
// Section 3: array and range casts
//======================================================================
def rangesAndArrays() {
	var ai = Array<int>.new(16);
	for (i < ai.length) ai[i] = i * i;
	var ab = Array<Base>.new(12);
	for (i < ab.length) ab[i] = if((i % 2) == 0, Derived.new(i), Other.new(i));
	var ad = Array<Derived>.new(6);
	for (i < ad.length) ad[i] = Derived.new(i);

	var h = 0;
	// arrays are invariant: neither direction is an instance of the other
	h = mixb(h, gq<Array<Derived>, Array<Base>>(ad));
	h = mixb(h, gq<Array<Base>, Array<Derived>>(ab));
	h = mixb(h, gq<Array<int>, Array<long>>(ai));
	h = mixb(h, gq<Array<int>, Array<int>>(ai));
	// and so are ranges
	var ri: Range<int> = ai;
	var rb: Range<Base> = ab;
	var rd: Range<Derived> = ad;
	h = mixb(h, gq<Range<Derived>, Range<Base>>(rd));
	h = mixb(h, gq<Range<Base>, Range<Derived>>(rb));
	h = mixb(h, gq<Range<int>, Range<int>>(ri));
	acci(h);

	// an array converts to a range with a checked cast (this is the direction
	// that test/range/cast00.v3 pins down); the reverse does not
	var g = 0;
	var conv = gc<Array<int>, Range<int>>(ai);
	g = mix(g, conv.length);
	for (i < conv.length) g = mix(g, conv[i]);
	var slice = conv[4 ... 12];
	g = mix(g, slice.length);
	for (i < slice.length) g = mix(g, slice[i]);
	g = mixb(g, gq<Range<int>, Array<int>>(ri));
	acci(g);

	// a string is an Array<byte>, and slices of it are Range<byte>
	var s = "polymorphic";
	var k = mixs(0, s);
	k = mixb(k, gq<string, Array<byte>>(s));
	k = mixb(k, gq<Array<byte>, string>(s));
	var br: Range<byte> = s;
	k = mix(k, br.length);
	var tail = br[4 ...];
	for (i < tail.length) k = mix(k, tail[i]);
	var bytes = gc<string, Array<byte>>(s);
	for (i < bytes.length) k = mix(k, bytes[i]);
	acci(k);

	// element-level casts inside a base-typed array
	var j = 0;
	var derived = 0;
	for (i < ab.length) {
		if (Derived.?(ab[i])) { derived++; j = mix(j, Derived.!(ab[i]).id); }
		else j = mix(j, -ab[i].id);
		j = mix(j, ab[i].kind());
	}
	acci(mix(j, derived));

	if (gq<Array<Derived>, Array<Base>>(ad)) fail_assert(301);
	if (gq<Array<Base>, Array<Derived>>(ab)) fail_assert(302);
	if (gq<Array<int>, Array<long>>(ai)) fail_assert(303);
	if (!gq<Array<int>, Array<int>>(ai)) fail_assert(304);
	if (gq<Range<Derived>, Range<Base>>(rd)) fail_assert(305);
	if (gq<Range<Base>, Range<Derived>>(rb)) fail_assert(306);
	if (!gq<Range<int>, Range<int>>(ri)) fail_assert(307);
	if (conv.length != 16) fail_assert(308);
	if (slice.length != 8) fail_assert(309);
	if (conv[3] != 9) fail_assert(310);
	if (slice[0] != 16) fail_assert(311);
	if (!gq<string, Array<byte>>(s)) fail_assert(312);
	if (br.length != 11) fail_assert(313);
	if (tail.length != 7) fail_assert(314);
	if (bytes[0] != 'p') fail_assert(315);
	if (derived != 6) fail_assert(316);
	// a null array is not an instance of any array type, but casts fine
	if (gq<Array<int>, Array<int>>(null)) fail_assert(317);
	if (gc<Array<int>, Array<int>>(null) != null) fail_assert(318);
}

//======================================================================
// Section 4: function types
//======================================================================
def baseToBase(x: Base) -> Base { return x; }
def baseToDerived(x: Base) -> Derived { return Derived.new(x.id); }
def derivedToBase(x: Derived) -> Base { return x; }
def derivedToDerived(x: Derived) -> Derived { return x; }
def intToBase(x: int) -> Base { return Base.new(x); }
def functions() {
	var bb: Base -> Base = baseToBase;
	var bd: Base -> Derived = baseToDerived;
	var db: Derived -> Base = derivedToBase;
	var dd: Derived -> Derived = derivedToDerived;
	var ib: int -> Base = intToBase;

	var h = 0;
	// parameters are contravariant: a Base->Base can stand in for a Derived->Base
	h = mixb(h, gq<Base -> Base, Derived -> Base>(bb));
	h = mixb(h, gq<Derived -> Base, Base -> Base>(db));
	// results are covariant: a Base->Derived can stand in for a Base->Base
	h = mixb(h, gq<Base -> Derived, Base -> Base>(bd));
	h = mixb(h, gq<Base -> Base, Base -> Derived>(bb));
	// both at once
	h = mixb(h, gq<Base -> Derived, Derived -> Base>(bd));
	h = mixb(h, gq<Derived -> Derived, Base -> Base>(dd));
	// unrelated parameter types never match
	h = mixb(h, gq<int -> Base, Base -> Base>(ib));
	h = mixb(h, gq<Base -> Base, int -> Base>(bb));
	acci(h);

	// subsumption is a static property, so it holds for every value of the type
	var fns = Array<Base -> Base>.new(24);
	for (i < fns.length) {
		fns[i] = if((i % 2) == 0, baseToBase, gc<Base -> Derived, Base -> Base>(baseToDerived));
	}
	var g = 0;
	for (i < fns.length) {
		var r = fns[i](Base.new(i));
		g = mix(g, r.id);
		g = mix(g, r.kind());
		g = mixb(g, Derived.?(r));
		g = mixb(g, gq<Base -> Base, Derived -> Base>(fns[i]));
	}
	acci(g);

	// casts themselves are function values, and can be passed around
	var isD: Base -> bool = Derived.?;
	var toD: Base -> Derived = Derived.!;
	var k = 0;
	var pop = Array<Base>.new(30);
	for (i < pop.length) pop[i] = if((i % 3) == 0, Derived.new(i), Other.new(i));
	var n = 0;
	for (i < pop.length) {
		k = mixb(k, isD(pop[i]));
		if (isD(pop[i])) { n++; k = mix(k, toD(pop[i]).id); }
		else k = mix(k, -1);
	}
	acci(mix(k, n));

	if (!gq<Base -> Base, Derived -> Base>(bb)) fail_assert(401);
	if (gq<Derived -> Base, Base -> Base>(db)) fail_assert(402);
	if (!gq<Base -> Derived, Base -> Base>(bd)) fail_assert(403);
	if (gq<Base -> Base, Base -> Derived>(bb)) fail_assert(404);
	if (!gq<Base -> Derived, Derived -> Base>(bd)) fail_assert(405);
	if (gq<Derived -> Derived, Base -> Base>(dd)) fail_assert(406);
	if (gq<int -> Base, Base -> Base>(ib)) fail_assert(407);
	if (gq<Base -> Base, int -> Base>(bb)) fail_assert(408);
	if (gc<Base -> Derived, Base -> Base>(baseToDerived)(Base.new(3)).id != 3) fail_assert(409);
	if (!isD(Derived.new(1))) fail_assert(410);
	if (isD(Other.new(1))) fail_assert(411);
	if (toD(Derived.new(9)).id != 9) fail_assert(412);
	if (n != 10) fail_assert(413);
}

//======================================================================
// Section 5: tuple types
//======================================================================
def tuples() {
	var tb: (int, Base) = (1, Derived.new(1));
	var to: (int, Base) = (2, Other.new(2));
	var td: (int, Derived) = (3, Derived.new(3));

	var h = 0;
	// a tuple query descends into the components dynamically
	h = mixb(h, gq<(int, Base), (int, Derived)>(tb));
	h = mixb(h, gq<(int, Base), (int, Derived)>(to));
	h = mixb(h, gq<(int, Derived), (int, Base)>(td));
	h = mixb(h, gq<(int, Base), (long, Base)>(tb));
	h = mixb(h, gq<(int, Base), (int, Base)>(tb));
	// numeric components are queried by value, not by type identity
	var tl: (long, Base) = (10000000000L, Derived.new(4));
	var ts2: (long, Base) = (5L, Derived.new(5));
	h = mixb(h, gq<(long, Base), (int, Base)>(tl));
	h = mixb(h, gq<(long, Base), (int, Base)>(ts2));
	h = mixb(h, gq<(long, Base), (int, Derived)>(ts2));
	h = mix(h, tb.0);
	h = mix(h, tb.1.kind());
	h = mix(h, to.1.kind());
	acci(h);

	// a population of tuples, filtered by the component query
	var ts = Array<(int, Base)>.new(36);
	for (i < ts.length) {
		ts[i] = (i, if((i % 3) == 0, Derived.new(i), Other.new(i)));
	}
	var g = 0;
	var hits = 0;
	for (i < ts.length) {
		var t = ts[i];
		var isD = gq<(int, Base), (int, Derived)>(t);
		g = mixb(g, isD);
		if (isD) {
			hits++;
			var nd = gc<(int, Base), (int, Derived)>(t);
			g = mix(g, nd.0);
			g = mix(g, nd.1.id);
		} else {
			g = mix(g, -1);
		}
	}
	acci(mix(g, hits));

	// nested tuples, and tuples of tuples inside an array
	var nested: (int, (Base, Base)) = (7, (Derived.new(8), Other.new(9)));
	var k = mix(0, nested.0);
	k = mix(k, nested.1.0.kind());
	k = mix(k, nested.1.1.kind());
	k = mixb(k, gq<(int, (Base, Base)), (int, (Derived, Base))>(nested));
	k = mixb(k, gq<(int, (Base, Base)), (int, (Derived, Derived))>(nested));
	k = mixb(k, gq<(int, (Base, Base)), (int, (Base, Base))>(nested));
	var arr = Array<(Base, Base)>.new(12);
	for (i < arr.length) arr[i] = (Derived.new(i), if((i % 2) == 0, Derived.new(i), Other.new(i)));
	var both = 0;
	for (i < arr.length) {
		if (gq<(Base, Base), (Derived, Derived)>(arr[i])) both++;
		k = mixb(k, gq<(Base, Base), (Derived, Derived)>(arr[i]));
		k = mix(k, arr[i].0.kind() + arr[i].1.kind());
	}
	acci(mix(k, both));

	if (!gq<(int, Base), (int, Derived)>(tb)) fail_assert(501);
	if (gq<(int, Base), (int, Derived)>(to)) fail_assert(502);
	if (!gq<(int, Derived), (int, Base)>(td)) fail_assert(503);
	// a tuple query descends by value: every int is representable as a long, so
	// this one is true even though the component types differ
	if (!gq<(int, Base), (long, Base)>(tb)) fail_assert(504);
	if (gq<(long, Base), (int, Base)>(tl)) fail_assert(513);	// 10^10 is not an int
	if (!gq<(long, Base), (int, Base)>(ts2)) fail_assert(514);
	if (!gq<(long, Base), (int, Derived)>(ts2)) fail_assert(515);
	if (!gq<(int, Base), (int, Base)>(tb)) fail_assert(505);
	if (gc<(int, Base), (int, Derived)>(tb).1.id != 1) fail_assert(506);
	if (hits != 12) fail_assert(507);
	if (!gq<(int, (Base, Base)), (int, (Derived, Base))>(nested)) fail_assert(508);
	if (gq<(int, (Base, Base)), (int, (Derived, Derived))>(nested)) fail_assert(509);
	if (both != 6) fail_assert(510);
	// a tuple containing null does not satisfy the narrower query
	var tn: (int, Base) = (0, null);
	if (gq<(int, Base), (int, Derived)>(tn)) fail_assert(511);
	// null is not an instance of any class type, so even the identity query on a
	// tuple with a null component is false
	if (gq<(int, Base), (int, Base)>(tn)) fail_assert(512);
}

//======================================================================
// Section 6: queries flowing through generic methods
//======================================================================
// The same generic body is instantiated at many argument types; each
// instantiation must answer for its own type.
def describe<T>(x: T) -> int {
	var n = 0;
	if (int.?(x)) n += 1;
	if (long.?(x)) n += 2;
	if (double.?(x)) n += 4;
	if (Base.?(x)) n += 8;
	if (Derived.?(x)) n += 16;
	return n;
}
def isDerived: Base -> bool = Derived.?;
def isOther: Base -> bool = Other.?;
def firstMatching<T>(a: Array<T>, f: T -> bool) -> int {
	for (i < a.length) if (f(a[i])) return i;
	return -1;
}
def generics() {
	var h = 0;
	h = mix(h, describe(3));
	h = mix(h, describe(3L));
	h = mix(h, describe(3.5d));
	h = mix(h, describe('a'));
	h = mix(h, describe(Base.new(1)));
	h = mix(h, describe(Derived.new(1)));
	h = mix(h, describe<Base>(Derived.new(1)));
	h = mix(h, describe<Base>(null));
	acci(h);

	var g = 0;
	for (i < 40) {
		g = mix(g, describe(i * 7 - 100));
		g = mix(g, describe(long.!(i) * 1000000000L));
		g = mix(g, describe(double.roundi(i) + 0.5d));
	}
	acci(g);

	var pop = Array<Base>.new(20);
	for (i < pop.length) pop[i] = if(i == 13, Derived.new(i), Other.new(i));
	var ints = Array<int>.new(20);
	for (i < ints.length) ints[i] = i * 3;
	var k = mix(0, firstMatching<Base>(pop, isDerived));
	k = mix(k, firstMatching<Base>(pop, isOther));
	k = mix(k, firstMatching<int>(ints, fun (x: int) => x > 30));
	k = mix(k, firstMatching<int>(ints, fun (x: int) => x < 0));
	for (i < pop.length) k = mix(k, describe<Base>(pop[i]));
	acci(k);

	// int is exactly representable in all three numeric targets
	if (describe(3) != 7) fail_assert(601);
	// a long that does not fit in an int
	if (describe(10000000000L) != 6) fail_assert(602);
	// a long that does
	if (describe(3L) != 7) fail_assert(603);
	// a double with a fraction is not an integer, but is trivially a double
	if (describe(3.5d) != 4) fail_assert(604);
	if (describe(4d) != 7) fail_assert(605);
	if (describe(Base.new(1)) != 8) fail_assert(606);
	if (describe(Derived.new(1)) != 24) fail_assert(607);
	if (describe<Base>(Derived.new(1)) != 24) fail_assert(608);
	if (describe<Base>(null) != 0) fail_assert(609);
	if (firstMatching<Base>(pop, isDerived) != 13) fail_assert(610);
	if (firstMatching<Base>(pop, isOther) != 0) fail_assert(611);
	if (firstMatching<int>(ints, fun (x: int) => x < 0) != -1) fail_assert(612);
}

//======================================================================
// Section 7: polymorphic containers under allocation churn
//======================================================================
def churn() {
	var boxes = Array<Box<Base>>.new(24);
	var lists = Array<Lst<Base>>.new(8);
	for (i < lists.length) lists[i] = Lst<Base>.Nil;
	var chain: Lst<Base> = Lst<Base>.Nil;
	for (i < 2500) {
		var e: Base = if((i % 3) == 0, Derived.new(i), Other.new(i));
		chain = Lst<Base>.Cons(e, chain);
		if ((i % 53) == 0) boxes[(i / 53) % boxes.length] = SubBox<Base>.new(e, i);
		if ((i % 211) == 0) lists[(i / 211) % lists.length] = chain;
		if ((i % 17) == 0) chain = Lst<Base>.Nil;
	}
	var h = 0;
	var subs = 0;
	for (i < boxes.length) {
		var b = boxes[i];
		if (b == null) { h = mix(h, -1); continue; }
		h = mix(h, b.get().kind());
		h = mixb(h, Derived.?(b.get()));
		if (SubBox<Base>.?(b)) { subs++; h = mix(h, SubBox<Base>.!(b).extra); }
	}
	acci(mix(h, subs));

	var g = 0;
	var seen = 0, derived = 0;
	for (i < lists.length) {
		var p = lists[i];
		while (Lst<Base>.Cons.?(p)) {
			var c = Lst<Base>.Cons.!(p);
			if (Derived.?(c.head)) { derived++; g = mix(g, Derived.!(c.head).id); }
			else g = mix(g, c.head.kind());
			p = c.tail;
			seen++;
			if (seen > 200000) { acci(g); return; }
		}
	}
	acci(mix(mix(g, seen), derived));
	if (boxes.length != 24) fail_assert(701);
	if (lists.length != 8) fail_assert(702);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) genericClasses();
	if (a == 0 || a == 2) genericAdts();
	if (a == 0 || a == 3) rangesAndArrays();
	if (a == 0 || a == 4) functions();
	if (a == 0 || a == 5) tuples();
	if (a == 0 || a == 6) generics();
	if (a == 0 || a == 7) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
