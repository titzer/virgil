//@execute 0=-1571936138; 1=-970169195; 2=-206730515; 3=2108947240; 4=-1276913471; 5=370359273; 6=-1213665902; 7=-1490977871; 8=-2038968733; 9=-134607721
//@heap-size=1500000
// Smoke test: arrays, part 2 — arrays whose elements are aggregates.
// Arrays of tuples, classes, boxed and unboxed variants, functions, arrays and
// ranges; writing through them, aliasing between them, and passing them to
// polymorphic methods. This one allocates heavily on purpose so that the GC
// has to trace element types of every shape.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def KEYS: Array<int> = [0, 1, -1, 7, 42, -42, 1000, 65535, -65536, 3];
def NAMES: Array<string> = ["", "a", "bc", "def", "wxyz"];

//======================================================================
// Section 1: arrays of tuples
//======================================================================
def tuples() {
	var pairs = Array<(int, int)>.new(KEYS.length);
	for (i < pairs.length) pairs[i] = (KEYS[i], KEYS[i] * 3 - 1);
	var h = 0;
	for (i < pairs.length) {
		var p = pairs[i];
		h = mix(h, p.0);
		h = mix(h, p.1);
	}
	acci(h);

	// heterogeneous and nested tuple elements
	var mixed = Array<(int, string, bool, float)>.new(NAMES.length);
	for (i < mixed.length) mixed[i] = (i * 11, NAMES[i], (i % 2) == 0, float.roundi(i) * 0.5f);
	var g = 0;
	for (i < mixed.length) {
		var t = mixed[i];
		g = mix(g, t.0);
		g = mixs(g, t.1);
		g = mixb(g, t.2);
		g = mixf(g, t.3);
	}
	acci(g);

	var nested = Array<((int, int), (int, long))>.new(8);
	for (i < nested.length) nested[i] = ((i, i * i), (i + 1, long.!(i) * 1000000000L));
	var k = 0;
	for (i < nested.length) {
		var t = nested[i];
		k = mix(k, t.0.0);
		k = mix(k, t.0.1);
		k = mix(k, t.1.0);
		k = mixl(k, t.1.1);
	}
	acci(k);

	// writing whole elements and reading fields back
	for (i < pairs.length) pairs[i] = (pairs[i].1, pairs[i].0);
	var m = 0;
	for (i < pairs.length) m = mix(m, pairs[i].0 - pairs[i].1);
	acci(m);

	// tuple elements are values: reading one out and mutating it does not
	// write back into the array
	var t0 = pairs[0];
	t0 = (999, 999);
	var q = mix(0, pairs[0].0);
	q = mix(q, t0.0);
	acci(q);

	if (pairs.length != 10) fail_assert(101);
	if (pairs[0].0 != -1) fail_assert(102);		// swapped: 0*3-1
	if (pairs[0].1 != 0) fail_assert(103);
	if (t0.0 != 999) fail_assert(104);
	if (nested[3].0.1 != 9) fail_assert(105);
	if (nested[3].1.1 != 3000000000L) fail_assert(106);
	if (!mixed[2].2) fail_assert(107);
	if (mixed[3].2) fail_assert(108);
	if (Array<(int, int)>.new(2)[0].0 != 0) fail_assert(109);	// zero-initialized
	if (Array<(int, string)>.new(2)[1].1 != null) fail_assert(110);
}

//======================================================================
// Section 2: arrays of classes
//======================================================================
class Shape {
	var id: int;
	new(id) { }
	def area() -> int { return 0; }
	def label() -> string { return "shape"; }
}
class Square extends Shape {
	var side: int;
	new(id: int, side) super(id) { }
	def area() -> int { return side * side; }
	def label() -> string { return "square"; }
}
class Rect extends Square {
	var h: int;
	new(id: int, w: int, h) super(id, w) { }
	def area() -> int { return side * h; }
	def label() -> string { return "rect"; }
}
def classes() {
	var shapes = Array<Shape>.new(3 * KEYS.length + 1);
	for (i < KEYS.length) {
		var k = KEYS[i] % 50;
		shapes[3 * i + 0] = Shape.new(i);
		shapes[3 * i + 1] = Square.new(i, k);
		shapes[3 * i + 2] = Rect.new(i, k, k + 2);
	}
	// last slot stays null on purpose
	var h = 0;
	for (i < shapes.length) {
		var s = shapes[i];
		if (s == null) { h = mix(h, -7); continue; }
		h = mix(h, s.area());				// virtual dispatch, 3 impls
		h = mixs(h, s.label());
		h = mix(h, s.id);
		h = mixb(h, Square.?(s));
		h = mixb(h, Rect.?(s));
	}
	acci(h);

	// mutate through the array and re-read
	for (i < shapes.length) {
		var s = shapes[i];
		if (s != null) s.id = s.id + 100;
	}
	var g = 0;
	for (i < shapes.length) g = mix(g, if(shapes[i] == null, 0, shapes[i].id));
	acci(g);

	// aliasing: the same object stored in several slots
	var box = Array<Shape>.new(4);
	var sq = Square.new(5, 6);
	box[0] = sq;
	box[1] = sq;
	box[2] = Square.new(5, 6);
	box[3] = null;
	Square.!(box[0]).side = 9;
	var k = mix(0, box[1].area());
	k = mix(k, box[2].area());
	k = mixb(k, box[0] == box[1]);
	k = mixb(k, box[0] == box[2]);
	acci(k);

	if (Shape.new(1).area() != 0) fail_assert(201);
	if (Square.new(1, 4).area() != 16) fail_assert(202);
	if (Rect.new(1, 4, 5).area() != 20) fail_assert(203);
	if (box[1].area() != 81) fail_assert(204);		// aliased write
	if (box[2].area() != 36) fail_assert(205);
	if (box[0] != box[1]) fail_assert(206);
	if (box[0] == box[2]) fail_assert(207);
	if (!Square.?(Rect.new(0, 1, 1))) fail_assert(208);
	if (Rect.?(Square.new(0, 1))) fail_assert(209);
	if (Square.?(Shape.new(0))) fail_assert(210);
}

//======================================================================
// Section 3: arrays of boxed variants
//======================================================================
type Expr {
	case Lit(v: int);
	case Add(a: Expr, b: Expr);
	case Neg(a: Expr);
	case Named(label: string, v: int);
	case Nil;
}
def eval(e: Expr) -> int {
	match (e) {
		Lit(v) => return v;
		Add(a, b) => return eval(a) + eval(b);
		Neg(a) => return 0 - eval(a);
		Named(label, v) => return v + label.length;
		Nil => return -1;
	}
}
def boxedVariants() {
	var es = Array<Expr>.new(5 * KEYS.length);
	for (i < KEYS.length) {
		var v = KEYS[i] % 1000;
		es[5 * i + 0] = Expr.Lit(v);
		es[5 * i + 1] = Expr.Neg(Expr.Lit(v));
		es[5 * i + 2] = Expr.Add(Expr.Lit(v), Expr.Lit(i));
		es[5 * i + 3] = Expr.Named(NAMES[i % NAMES.length], v);
		es[5 * i + 4] = Expr.Nil;
	}
	var h = 0;
	for (i < es.length) {
		var e = es[i];
		h = mix(h, eval(e));
		h = mix(h, e.tag);
		h = mixb(h, Expr.Lit.?(e));
		h = mixb(h, Expr.Nil.?(e));
	}
	acci(h);

	// build a deep tree out of array elements
	var acc: Expr = Expr.Lit(0);
	for (i < es.length) acc = Expr.Add(acc, es[i]);
	var g = mix(0, eval(acc));
	g = mix(g, acc.tag);
	acci(g);

	// overwrite elements, then re-evaluate
	for (i < es.length) es[i] = Expr.Neg(es[i]);
	var k = 0;
	for (i < es.length) k = mix(k, eval(es[i]));
	acci(k);

	// equality of boxed variants is structural over non-reference payloads
	var m = 0;
	for (i < KEYS.length) {
		var a: Expr = Expr.Lit(KEYS[i]);
		var b: Expr = Expr.Lit(KEYS[i]);
		var c: Expr = Expr.Add(a, b);
		m = mixb(m, a == b);
		m = mixb(m, a == c);
		m = mixb(m, c == Expr.Add(a, b));
	}
	acci(m);

	if (eval(Expr.Lit(5)) != 5) fail_assert(301);
	if (eval(Expr.Neg(Expr.Lit(5))) != -5) fail_assert(302);
	if (eval(Expr.Add(Expr.Lit(2), Expr.Lit(3))) != 5) fail_assert(303);
	if (eval(Expr.Nil) != -1) fail_assert(304);
	if (Expr.Lit(1).tag != 0) fail_assert(305);
	if (Expr.Nil.tag != 4) fail_assert(306);
	if (!(Expr.Lit(3) == Expr.Lit(3))) fail_assert(307);
	if (Expr.Lit(3) == Expr.Lit(4)) fail_assert(308);
	var nilv: Expr = Expr.Nil;
	if (Expr.Lit.?(nilv)) fail_assert(309);
	if (!Expr.Nil.?(nilv)) fail_assert(310);
	// the default element of a variant array is the first case, not null
	if (Array<Expr>.new(2)[0].tag != 0) fail_assert(311);
	if (!(Array<Expr>.new(2)[0] == Expr.Lit(0))) fail_assert(312);
}

//======================================================================
// Section 4: arrays of unboxed variants
//======================================================================
type Pt #unboxed {
	case Zero;
	case One(x: int);
	case Two(x: int, y: int);
	case Three(x: int, y: int, z: long);
}
def norm(p: Pt) -> long {
	match (p) {
		Zero => return 0;
		One(x) => return x;
		Two(x, y) => return long.!(x) + y;
		Three(x, y, z) => return long.!(x) + y + z;
	}
}
def unboxedVariants() {
	var ps = Array<Pt>.new(4 * KEYS.length);
	for (i < KEYS.length) {
		var v = KEYS[i];
		ps[4 * i + 0] = Pt.Zero;
		ps[4 * i + 1] = Pt.One(v);
		ps[4 * i + 2] = Pt.Two(v, i);
		ps[4 * i + 3] = Pt.Three(v, i, long.!(i) * 100000000000L);
	}
	var h = 0;
	for (i < ps.length) {
		var p = ps[i];
		h = mixl(h, norm(p));
		h = mix(h, p.tag);
		h = mixb(h, Pt.Two.?(p));
	}
	acci(h);

	// elements are values: reading one out and rebinding leaves the array alone
	var p0 = ps[1];
	p0 = Pt.Zero;
	var g = mixl(0, norm(ps[1]));
	g = mixl(g, norm(p0));
	acci(g);

	// overwrite in place, then compare pairwise for equality
	for (i < ps.length) ps[i] = Pt.Two(i, i * i);
	var k = 0;
	for (i < 20) for (j < 20) k = mixb(k, ps[i] == ps[j]);
	acci(k);

	// mixed unboxed/boxed nesting: array of tuples of unboxed variants
	var tt = Array<(Pt, Pt)>.new(KEYS.length);
	for (i < tt.length) tt[i] = (Pt.One(KEYS[i]), Pt.Three(i, i, 7));
	var m = 0;
	for (i < tt.length) {
		m = mixl(m, norm(tt[i].0));
		m = mixl(m, norm(tt[i].1));
		m = mixb(m, tt[i].0 == tt[i].1);
	}
	acci(m);

	if (norm(Pt.Zero) != 0) fail_assert(401);
	if (norm(Pt.One(5)) != 5) fail_assert(402);
	if (norm(Pt.Two(5, 6)) != 11) fail_assert(403);
	if (norm(Pt.Three(1, 2, 3)) != 6) fail_assert(404);
	if (Pt.Zero.tag != 0) fail_assert(405);
	if (Pt.Three(0, 0, 0).tag != 3) fail_assert(406);
	if (!(Pt.Two(1, 2) == Pt.Two(1, 2))) fail_assert(407);
	if (Pt.Two(1, 2) == Pt.Two(2, 1)) fail_assert(408);
	var zerov: Pt = Pt.Zero;
	if (Pt.One.?(zerov)) fail_assert(409);
	// the default element of an unboxed variant array is the first case
	if (Array<Pt>.new(2)[0].tag != 0) fail_assert(410);
	if (ps[1].tag != 2) fail_assert(411);		// overwritten with Two above
}

//======================================================================
// Section 5: arrays of functions
//======================================================================
def add3(x: int) -> int { return x + 3; }
def dbl(x: int) -> int { return x * 2; }
def neg(x: int) -> int { return 0 - x; }
def addTo(a: int, b: int) -> int { return a + b; }
def makeAdder(a: int) -> int -> int { return fun (b: int) => a + b; }
def funcs() {
	def FS: Array<int -> int> = [add3, dbl, neg];
	var h = 0;
	for (i < FS.length) for (j < KEYS.length) h = mix(h, FS[i](KEYS[j]));
	acci(h);

	// an array of closures, each capturing a distinct value
	var adders = Array<int -> int>.new(16);
	for (i < adders.length) adders[i] = makeAdder(i * 7);
	var g = 0;
	for (i < adders.length) for (j < KEYS.length) g = mix(g, adders[i](KEYS[j]));
	acci(g);

	// partial applications and operator references
	var ops = Array<(int, int) -> int>.new(4);
	ops[0] = addTo;
	ops[1] = int.+;
	ops[2] = int.*;
	ops[3] = int.^;
	var k = 0;
	for (i < ops.length) for (j < KEYS.length) k = mix(k, ops[i](KEYS[j], 11));
	acci(k);

	var partials = Array<int -> int>.new(KEYS.length);
	for (i < partials.length) partials[i] = addTo(KEYS[i], _);
	var m = 0;
	for (i < partials.length) m = mix(m, partials[i](5));
	acci(m);

	// bound methods of objects stored in an array
	var sqs = Array<Square>.new(6);
	var meths = Array<void -> int>.new(6);
	for (i < sqs.length) {
		sqs[i] = Square.new(i, i + 2);
		meths[i] = sqs[i].area;
	}
	var q = 0;
	for (i < meths.length) q = mix(q, meths[i]());
	for (i < sqs.length) sqs[i].side = sqs[i].side + 1;
	for (i < meths.length) q = mix(q, meths[i]());		// sees the mutation
	acci(q);

	// null function slots
	var maybe = Array<int -> int>.new(3);
	maybe[1] = dbl;
	var n = 0;
	for (i < maybe.length) n = mixb(n, maybe[i] == null);
	n = mix(n, maybe[1](21));
	acci(n);

	if (FS[0](1) != 4) fail_assert(501);
	if (FS[1](1) != 2) fail_assert(502);
	if (FS[2](1) != -1) fail_assert(503);
	if (makeAdder(10)(5) != 15) fail_assert(504);
	if (addTo(3, _)(4) != 7) fail_assert(505);
	if (addTo(_, 4)(3) != 7) fail_assert(506);
	if (Array<int -> int>.new(1)[0] != null) fail_assert(507);
	if (meths[0]() != 9) fail_assert(508);		// side was 2, then bumped to 3
	if (sqs[0].area() != 9) fail_assert(509);
}

//======================================================================
// Section 6: arrays of arrays, with aliasing
//======================================================================
def arraysOfArrays() {
	var grid = Array<Array<int>>.new(12);
	for (i < grid.length) {
		grid[i] = Array<int>.new(6);
		for (j < 6) grid[i][j] = i * 6 + j;
	}
	var h = 0;
	for (i < grid.length) for (j < 6) h = mix(h, grid[i][j]);
	acci(h);

	// alias every odd row onto the row before it
	for (i < grid.length) if ((i % 2) == 1) grid[i] = grid[i - 1];
	for (i < grid.length) grid[i][0] = grid[i][0] + 1000;
	var g = 0;
	for (i < grid.length) {
		g = mix(g, grid[i][0]);
		g = mixb(g, i > 0 && grid[i] == grid[i - 1]);
	}
	acci(g);

	// arrays of arrays of tuples and of strings
	var tabs = Array<Array<(int, string)>>.new(5);
	for (i < tabs.length) {
		tabs[i] = Array<(int, string)>.new(NAMES.length);
		for (j < NAMES.length) tabs[i][j] = (i * 10 + j, NAMES[j]);
	}
	var k = 0;
	for (i < tabs.length) for (j < NAMES.length) {
		k = mix(k, tabs[i][j].0);
		k = mixs(k, tabs[i][j].1);
	}
	acci(k);

	// a ragged array where some rows are null
	var ragged = Array<Array<byte>>.new(9);
	for (i < ragged.length) {
		if ((i % 3) == 0) continue;
		ragged[i] = Array<byte>.new(i);
		for (j < i) ragged[i][j] = byte.view(i * j);
	}
	var m = 0;
	for (i < ragged.length) {
		var r = ragged[i];
		if (r == null) { m = mix(m, -5); continue; }
		for (j < r.length) m = mix(m, r[j]);
	}
	acci(m);

	if (grid[1] != grid[0]) fail_assert(601);
	if (grid[2] == grid[1]) fail_assert(602);
	// row 0 is written twice because rows 0 and 1 alias
	if (grid[0][0] != 2000) fail_assert(603);
	if (grid[2][0] != 12 + 2000) fail_assert(604);
	if (ragged[0] != null) fail_assert(605);
	if (ragged[4].length != 4) fail_assert(606);
	if (ragged[4][3] != 12) fail_assert(607);
	if (tabs[3][2].0 != 32) fail_assert(608);
}

//======================================================================
// Section 7: arrays of ranges
//======================================================================
def rangesInArrays() {
	var backing = Array<int>.new(64);
	for (i < backing.length) backing[i] = i * i - 10;
	var views = Array<Range<int>>.new(8);
	for (i < views.length) views[i] = backing[i * 8 ... i * 8 + 8];
	var h = 0;
	for (i < views.length) {
		var r = views[i];
		h = mix(h, r.length);
		for (j < r.length) h = mix(h, r[j]);
	}
	acci(h);

	// writes through a stored range are visible in the backing array
	for (i < views.length) views[i][0] = -i;
	var g = 0;
	for (i < backing.length) g = mix(g, backing[i]);
	acci(g);

	// ranges over strings stored in an array
	var parts = Array<Range<byte>>.new(NAMES.length);
	for (i < NAMES.length) parts[i] = NAMES[i];
	var k = 0;
	for (i < parts.length) {
		k = mix(k, parts[i].length);
		for (j < parts[i].length) k = mix(k, parts[i][j]);
	}
	acci(k);

	// overlapping ranges over one array
	var overlap = Array<Range<int>>.new(6);
	for (i < overlap.length) overlap[i] = backing[i ... i + 20];
	var m = 0;
	for (i < overlap.length) for (j < overlap[i].length) m = mix(m, overlap[i][j]);
	overlap[0][10] = 12345;
	for (i < overlap.length) m = mix(m, overlap[i][0]);
	acci(m);

	if (views.length != 8) fail_assert(701);
	if (views[0].length != 8) fail_assert(702);
	if (backing[8] != -1) fail_assert(703);		// views[1][0] = -1
	if (backing[16] != -2) fail_assert(704);
	if (parts[3].length != 3) fail_assert(705);
	if (parts[3][0] != 'd') fail_assert(706);
	if (overlap[3].length != 20) fail_assert(707);
	if (backing[10] != 12345) fail_assert(708);
}

//======================================================================
// Section 8: aggregates through polymorphic methods
//======================================================================
def at<T>(a: Array<T>, i: int, dflt: T) -> T {
	if (a == null || i < 0 || i >= a.length) return dflt;
	return a[i];
}
def swapAll<T>(a: Array<T>) -> Array<T> {
	for (i < a.length / 2) {
		var t = a[i];
		a[i] = a[a.length - 1 - i];
		a[a.length - 1 - i] = t;
	}
	return a;
}
def mapTo<A, B>(a: Array<A>, f: A -> B) -> Array<B> {
	var b = Array<B>.new(a.length);
	for (i < a.length) b[i] = f(a[i]);
	return b;
}
def countIf<T>(a: Array<T>, p: T -> bool) -> int {
	var n = 0;
	for (e in a) if (p(e)) n++;
	return n;
}
def polymorphic() {
	var ints = Array<int>.new(10);
	for (i < ints.length) ints[i] = KEYS[i];
	var pts = Array<Pt>.new(10);
	for (i < pts.length) pts[i] = Pt.Two(KEYS[i], i);
	var sqs = Array<Square>.new(10);
	for (i < sqs.length) sqs[i] = Square.new(i, i + 1);
	var tups = Array<(int, int)>.new(10);
	for (i < tups.length) tups[i] = (KEYS[i], i);

	var h = 0;
	for (i < 12) {
		h = mix(h, at<int>(ints, i - 1, -999));
		h = mixl(h, norm(at<Pt>(pts, i - 1, Pt.Zero)));
		var s = at<Square>(sqs, i - 1, null);
		h = mix(h, if(s == null, -1, s.area()));
		h = mix(h, at<(int, int)>(tups, i - 1, (-1, -1)).0);
	}
	acci(h);

	swapAll<int>(ints);
	swapAll<Pt>(pts);
	swapAll<Square>(sqs);
	swapAll<(int, int)>(tups);
	var g = 0;
	for (i < 10) {
		g = mix(g, ints[i]);
		g = mixl(g, norm(pts[i]));
		g = mix(g, sqs[i].area());
		g = mix(g, tups[i].1);
	}
	acci(g);

	var areas = mapTo<Square, int>(sqs, Square.area);
	var norms = mapTo<Pt, long>(pts, norm);
	var firsts = mapTo<(int, int), int>(tups, fun (t: (int, int)) => t.0);
	var k = 0;
	for (i < areas.length) k = mix(k, areas[i]);
	for (i < norms.length) k = mixl(k, norms[i]);
	for (i < firsts.length) k = mix(k, firsts[i]);
	acci(k);

	var m = mix(0, countIf<int>(ints, fun (x: int) => x > 0));
	m = mix(m, countIf<Pt>(pts, Pt.Two.?));
	m = mix(m, countIf<Square>(sqs, fun (s: Square) => s.area() > 25));
	acci(m);

	if (at<int>(null, 0, -999) != -999) fail_assert(801);
	if (at<int>(ints, -1, -999) != -999) fail_assert(802);
	if (at<int>(ints, 10, -999) != -999) fail_assert(803);
	if (swapAll<int>([1, 2, 3])[0] != 3) fail_assert(804);
	if (mapTo<int, int>([1, 2, 3], dbl)[2] != 6) fail_assert(805);
	if (countIf<int>([1, -2, 3], fun (x: int) => x > 0) != 2) fail_assert(806);
	if (areas.length != 10) fail_assert(807);
	// sqs was reversed, so slot 0 now holds the square with side 10
	if (sqs[0].area() != 100) fail_assert(808);
	if (ints[0] != 3) fail_assert(809);
}

//======================================================================
// Section 9: allocation churn over aggregate element types
//======================================================================
class Cell(v: int, tag: string) { }
def churn() {
	var live = Array<Array<Cell>>.new(16);
	var liveE = Array<Expr>.new(16);
	var liveT = Array<(Pt, Square)>.new(16);
	var total = 0;
	for (i < 1200) {
		var n = 1 + (i % 11);
		var cells = Array<Cell>.new(n);
		for (j < n) cells[j] = Cell.new(i * n + j, NAMES[j % NAMES.length]);
		total += cells[n - 1].v;
		var e: Expr = Expr.Add(Expr.Lit(i), Expr.Named(NAMES[i % NAMES.length], n));
		if ((i % 71) == 0) {
			var s = (i / 71) % live.length;
			live[s] = cells;
			liveE[s] = e;
			liveT[s] = (Pt.Three(i, n, long.!(i) * 7), Square.new(i, n));
		}
	}
	var h = mix(0, total);
	for (i < live.length) {
		var a = live[i];
		if (a == null) { h = mix(h, -1); continue; }
		for (j < a.length) {
			h = mix(h, a[j].v);
			h = mixs(h, a[j].tag);
		}
		h = mix(h, eval(liveE[i]));
		h = mixl(h, norm(liveT[i].0));
		h = mix(h, liveT[i].1.area());
	}
	acci(h);

	if (live.length != 16) fail_assert(901);
	if (live[0] == null) fail_assert(902);
	if (liveE[0].tag != 1) fail_assert(903);	// Expr.Add
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) tuples();
	if (a == 0 || a == 2) classes();
	if (a == 0 || a == 3) boxedVariants();
	if (a == 0 || a == 4) unboxedVariants();
	if (a == 0 || a == 5) funcs();
	if (a == 0 || a == 6) arraysOfArrays();
	if (a == 0 || a == 7) rangesInArrays();
	if (a == 0 || a == 8) polymorphic();
	if (a == 0 || a == 9) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
