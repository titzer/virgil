//@execute 0=440759632; 1=-368169901; 2=833846461; 3=981916866; 4=-1446738554; 5=-1813283285; 6=1608799982; 7=-1670779582; 8=-826793720
//@heap-size=1000000
// Smoke test: class fundamentals as an integration test.
// A deep inheritance chain, virtual dispatch across many overrides, the three
// kinds of field (constructor parameter, `var`, `def` with initializer),
// initialization order, `-> this` method chaining, factored base
// implementations, and objects held in arrays, tuples, globals and variant
// payloads. Results are mixed into a running CRC that main() returns, so no
// computation can be deleted as dead. Interleaved are assert()s over
// compile-time constants, which the optimizer is expected to fold away; a
// folding bug sets the failure flag instead. Input selects the section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

// Deterministic pseudo-random source; reset by every section that uses it.
var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

def NAMES: Array<string> = ["shape", "rect", "square", "cube", "tinted", "solid"];
def DIMS: Array<int> = [1, 2, 3, 5, 7, 11, 13, 0, 4, 6];

//======================================================================
// The hierarchy: six levels deep, with overrides at every level.
//
// Virgil has no `super.m()` call form -- `Base.m(obj)` is an ordinary virtual
// call, so it re-dispatches to the override. Where a subclass wants the parent
// behavior it calls a separate, never-overridden helper (rectArea, boxVol, ...)
// that holds the parent implementation.
//======================================================================
class Shape {
	def id: int;			// constructor parameter field: immutable
	var scale: int = 1;		// mutable field with an initializer
	def kind: int = 0;		// def field with an initializer
	new(id) { }

	def area() -> int { return 0; }
	def rank() -> int { return 0; }
	def label() -> string { return NAMES[0]; }
	// A non-virtual-looking composite: calls two virtual methods on `this`.
	def describe() -> int { return area() * 100 + rank() * 10 + scale; }
	def bump(n: int) -> this { scale = scale + n; }
}
class Rect extends Shape {
	def w: int;
	def h: int;
	new(id: int, w, h) super(id) { }
	def rectArea() -> int { return w * h; }		// the "parent implementation"
	def area() -> int { return rectArea(); }
	def rank() -> int { return 1; }
	def label() -> string { return NAMES[1]; }
}
class Square extends Rect {
	new(id: int, s: int) super(id, s, s) { }
	def rank() -> int { return 2; }
	def label() -> string { return NAMES[2]; }
}
class Box extends Square {
	def d: int;
	new(id: int, s: int, d) super(id, s) { }
	def boxVol() -> int { return rectArea() * d; }	// the "parent implementation"
	def area() -> int { return boxVol(); }
	def rank() -> int { return 3; }
	def label() -> string { return NAMES[3]; }
}
class Tinted extends Box {
	var tint: int;
	new(id: int, s: int, d: int, tint) super(id, s, d) { }
	def area() -> int { return boxVol() + tint; }	// base impl + extra
	def rank() -> int { return 4; }
	def label() -> string { return NAMES[4]; }
}
class Solid extends Tinted {
	def dens: int;
	new(id: int, s: int, d: int, tint: int, dens) super(id, s, d, tint) { }
	def area() -> int { return boxVol() * dens; }
	def rank() -> int { return 5; }
	def label() -> string { return NAMES[5]; }
}

def makeShape(i: int) -> Shape {
	var a = DIMS[i % DIMS.length];
	var b = DIMS[(i + 3) % DIMS.length];
	var c = DIMS[(i + 5) % DIMS.length];
	match (i % 6) {
		0 => return Shape.new(i);
		1 => return Rect.new(i, a, b);
		2 => return Square.new(i, a);
		3 => return Box.new(i, a, b);
		4 => return Tinted.new(i, a, b, c);
		_ => return Solid.new(i, a, b, c, 2);
	}
}

//======================================================================
// Section 1: the inheritance chain and virtual dispatch
//======================================================================
def chain() {
	var objs = Array<Shape>.new(240);
	for (i < objs.length) objs[i] = makeShape(i);
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mix(h, o.id);
		h = mix(h, o.area());		// dispatched over 4 implementations
		h = mix(h, o.rank());		// dispatched over 6 implementations
		h = mix(h, o.describe());	// virtual calls made from the base class
		h = mixs(h, o.label());
	}
	acci(h);

	// same objects, now viewed at intermediate static types
	var g = 0;
	for (i < objs.length) {
		var o = objs[i];
		if (Rect.?(o)) {
			var r = Rect.!(o);
			g = mix(g, r.w * r.h);
			g = mix(g, r.rectArea());
			g = mix(g, r.area());	// still virtual
		}
		if (Box.?(o)) g = mix(g, Box.!(o).boxVol());
		if (Solid.?(o)) g = mix(g, Solid.!(o).dens);
		g = mixb(g, Shape.?(o));
		g = mixb(g, Rect.?(o));
		g = mixb(g, Square.?(o));
		g = mixb(g, Box.?(o));
		g = mixb(g, Tinted.?(o));
		g = mixb(g, Solid.?(o));
	}
	acci(g);

	// hand-checked values
	var sh = Shape.new(9);
	var re = Rect.new(9, 3, 4);
	var sq = Square.new(9, 5);
	var bx = Box.new(9, 3, 4);		// 3x3 base, depth 4
	var ti = Tinted.new(9, 3, 4, 7);
	var so = Solid.new(9, 3, 4, 7, 2);
	if (sh.area() != 0) fail_assert(101);
	if (re.area() != 12) fail_assert(102);
	if (sq.area() != 25) fail_assert(103);
	if (bx.area() != 36) fail_assert(104);		// 3*3*4
	if (ti.area() != 43) fail_assert(105);		// 36 + 7
	if (so.area() != 72) fail_assert(106);		// 36 * 2
	if (sh.rank() != 0) fail_assert(107);
	if (re.rank() != 1) fail_assert(108);
	if (sq.rank() != 2) fail_assert(109);
	if (bx.rank() != 3) fail_assert(110);
	if (ti.rank() != 4) fail_assert(111);
	if (so.rank() != 5) fail_assert(112);
	// describe() lives on Shape but sees the overrides
	if (sh.describe() != 1) fail_assert(113);	// 0*100 + 0*10 + 1
	if (re.describe() != 1211) fail_assert(114);	// 12*100 + 1*10 + 1
	if (so.describe() != 7251) fail_assert(115);	// 72*100 + 5*10 + 1
	// the factored parent implementation is reachable and is not overridden
	if (bx.rectArea() != 9) fail_assert(116);
	if (ti.boxVol() != 36) fail_assert(117);
	if (so.boxVol() != 36) fail_assert(118);
	// static-type views do not change dispatch
	var asRect: Rect = so;
	if (asRect.area() != 72) fail_assert(119);
	var asShape: Shape = so;
	if (asShape.rank() != 5) fail_assert(120);
	// queries respect the whole chain
	if (!Rect.?(so)) fail_assert(121);
	if (!Square.?(so)) fail_assert(122);
	if (Box.?(re)) fail_assert(123);
	if (Solid.?(ti)) fail_assert(124);
	if (Rect.?(sh)) fail_assert(125);
	if (!Shape.?(so)) fail_assert(126);
	var nul: Shape;
	if (Shape.?(nul)) fail_assert(127);		// null is not an instance
}

//======================================================================
// Section 2: field kinds and initialization order
//
// Field initializers of the MOST DERIVED class run first, then those of each
// parent in turn, then the parent constructor bodies outward-in. The order
// observed here is recorded in `iord`; the assertions below only pin the
// relations that are stable.
//======================================================================
var tick: int;
def note() -> int { return tick++; }

class Base2 {
	var bp: int = note();		// var field with initializer
	def bq: int = note();		// def field with initializer
	var br: int;			// zero-initialized, set by the body
	def param: int;			// constructor parameter field
	new(param) { br = note(); }
}
class Mid2 extends Base2 {
	var mp: int = note();
	var mq: int;
	new(p: int) super(p) { mq = note(); }
}
class Leaf2 extends Mid2 {
	var lp: int = note();
	var lq: int;
	new(p: int) super(p) { lq = note(); }
}
def fieldkinds() {
	tick = 0;
	var o = Leaf2.new(42);
	var h = mix(0, o.bp);
	h = mix(h, o.bq);
	h = mix(h, o.br);
	h = mix(h, o.mp);
	h = mix(h, o.mq);
	h = mix(h, o.lp);
	h = mix(h, o.lq);
	h = mix(h, o.param);
	h = mix(h, tick);
	acci(h);

	// initializers of a class run adjacent to each other and in declaration order
	if (o.bq != o.bp + 1) fail_assert(201);
	// constructor bodies run outermost-first, after every initializer
	if (!(o.br < o.mq)) fail_assert(202);
	if (!(o.mq < o.lq)) fail_assert(203);
	if (!(o.bp < o.br)) fail_assert(204);
	if (!(o.mp < o.br)) fail_assert(205);
	if (!(o.lp < o.br)) fail_assert(206);
	if (tick != 7) fail_assert(207);
	if (o.param != 42) fail_assert(208);

	// each allocation gets a fresh set of fields
	tick = 0;
	var many = Array<Base2>.new(200);
	for (i < many.length) {
		match (i % 3) {
			0 => many[i] = Base2.new(i);
			1 => many[i] = Mid2.new(i);
			_ => many[i] = Leaf2.new(i);
		}
	}
	var g = 0;
	for (i < many.length) {
		var b = many[i];
		g = mix(g, b.bp);
		g = mix(g, b.bq);
		g = mix(g, b.br);
		g = mix(g, b.param);
	}
	g = mix(g, tick);
	acci(g);
	if (many[0].param != 0) fail_assert(209);
	if (many[199].param != 199) fail_assert(210);

	// mutable vs immutable: `var` fields can be written through an alias, and
	// the write is visible through every reference to the same object.
	var a = Shape.new(3);
	var b: Shape = a;
	a.scale = 9;
	if (b.scale != 9) fail_assert(211);
	b.scale = b.scale + 1;
	if (a.scale != 10) fail_assert(212);
	if (a.kind != 0) fail_assert(213);
	if (Shape.new(5).scale != 1) fail_assert(214);	// initializer, not stale state
	var k = 0;
	for (i < 100) {
		var s = Shape.new(i);
		s.scale = i * 2;
		k = mix(k, s.scale + s.id + s.kind);
	}
	acci(k);
}

//======================================================================
// Section 3: `this` and method chaining
//======================================================================
class Buf {
	def data = Array<int>.new(64);
	var n: int;
	var marks: int;
	def put(x: int) -> this { data[n++ % data.length] = x; }
	def putAll(a: Array<int>) -> this { for (i < a.length) put(a[i]); }
	def mark() -> this { marks++; }
	def rewind() -> this { n = 0; }
	def total() -> int {
		var s = 0;
		for (i < n) s += data[i % data.length];
		return s;
	}
	def me() -> Buf { return this; }		// `this` as an ordinary value
}
def chaining() {
	var b = Buf.new();
	b.put(1).put(2).put(3).mark().put(4).putAll(DIMS).mark();
	var h = mix(0, b.n);
	h = mix(h, b.marks);
	h = mix(h, b.total());
	for (i < b.n) h = mix(h, b.data[i]);
	acci(h);

	if (b.n != 4 + DIMS.length) fail_assert(301);
	if (b.marks != 2) fail_assert(302);
	if (b.total() != 1 + 2 + 3 + 4 + 52) fail_assert(303);	// DIMS sums to 52
	// the chain returns the same object every time
	if (b.put(0) != b) fail_assert(304);
	if (b.me() != b) fail_assert(305);
	if (b.mark().rewind().me() != b) fail_assert(306);
	if (b.n != 0) fail_assert(307);
	if (b.marks != 3) fail_assert(308);

	// long chains over many objects, driven by data
	var bufs = Array<Buf>.new(32);
	for (i < bufs.length) bufs[i] = Buf.new();
	for (i < bufs.length) {
		var x = bufs[i];
		for (j < DIMS.length) x = x.put(DIMS[j] + i).mark();
		x.put(i).rewind().put(i * 2).mark();
	}
	var g = 0;
	for (i < bufs.length) {
		g = mix(g, bufs[i].n);
		g = mix(g, bufs[i].marks);
		g = mix(g, bufs[i].total());
	}
	acci(g);
	if (bufs[0].n != 1) fail_assert(309);			// rewind then one put
	if (bufs[0].marks != DIMS.length + 1) fail_assert(310);
	if (bufs[5].total() != 10) fail_assert(311);		// put(5*2) only

	// `-> this` on the shape hierarchy: bump returns the static receiver type
	var s = Solid.new(1, 2, 3, 4, 5);
	if (s.bump(3).bump(4).scale != 8) fail_assert(312);	// 1 + 3 + 4
	if (s.bump(0) != s) fail_assert(313);
}

//======================================================================
// Section 4: factored base implementations and abstract-style bases
//======================================================================
class Visitor {
	var count: int;
	var sum: int;
	def visit(s: Shape) -> int { count++; return 0; }
	def visitAll(a: Array<Shape>) -> int {
		var t = 0;
		for (i < a.length) t += visit(a[i]);
		sum = t;
		return t;
	}
}
class AreaVisitor extends Visitor {
	def visit(s: Shape) -> int { count++; return s.area(); }
}
class RankVisitor extends AreaVisitor {
	def areaOf(s: Shape) -> int { return s.area(); }	// parent behavior, factored
	def visit(s: Shape) -> int { count++; return areaOf(s) + s.rank(); }
}
class WeightedVisitor extends RankVisitor {
	def weight: int;
	new(weight) { }
	def visit(s: Shape) -> int { count++; return (areaOf(s) + s.rank()) * weight; }
}
def basecalls() {
	var shapes = Array<Shape>.new(60);
	for (i < shapes.length) shapes[i] = makeShape(i);
	def vs: Array<Visitor> = [
		Visitor.new(), AreaVisitor.new(), RankVisitor.new(), WeightedVisitor.new(3)
	];
	var h = 0;
	for (i < vs.length) {
		var v = vs[i];
		h = mix(h, v.visitAll(shapes));
		h = mix(h, v.count);
		h = mix(h, v.sum);
		h = mixb(h, RankVisitor.?(v));
		h = mixb(h, WeightedVisitor.?(v));
	}
	acci(h);

	var one: Array<Shape> = [Solid.new(0, 3, 4, 7, 2)];	// area 72, rank 5
	var v0 = Visitor.new(), v1 = AreaVisitor.new();
	var v2 = RankVisitor.new(), v3 = WeightedVisitor.new(3);
	if (v0.visitAll(one) != 0) fail_assert(401);
	if (v1.visitAll(one) != 72) fail_assert(402);
	if (v2.visitAll(one) != 77) fail_assert(403);
	if (v3.visitAll(one) != 231) fail_assert(404);		// (72 + 5) * 3
	if (v0.count != 1) fail_assert(405);
	if (v3.sum != 231) fail_assert(406);
	// visitAll lives on Visitor and dispatches through the override each call
	if (v3.visitAll(one) != 231) fail_assert(407);
	if (v3.count != 2) fail_assert(408);
	// the factored parent behavior is unaffected by the override
	if (v3.areaOf(one[0]) != 72) fail_assert(409);
	if (v2.areaOf(one[0]) != 72) fail_assert(410);
	if (v3.weight != 3) fail_assert(411);
}

//======================================================================
// Section 5: objects in arrays, tuples, globals and variant payloads
//======================================================================
type Slot {
	case Empty;
	case One(s: Shape);
	case Pair(a: Shape, b: Shape);
	case Tagged(s: Shape, t: (int, int));
}
var gShape: Shape;
var gPair: (Shape, Shape);
var gArr: Array<Shape>;
var gSlots: Array<Slot>;

def slotArea(s: Slot) -> int {
	match (s) {
		Empty => return -1;
		One(x) => return if(x == null, -2, x.area());
		Pair(a, b) => return (if(a == null, 0, a.area())) + (if(b == null, 0, b.area()));
		Tagged(x, t) => return (if(x == null, 0, x.area())) + t.0 * t.1;
	}
}
def containers() {
	gShape = null;
	gPair = (null, null);
	gArr = Array<Shape>.new(48);
	gSlots = Array<Slot>.new(48);

	for (i < gArr.length) gArr[i] = makeShape(i);
	for (i < gSlots.length) {
		var s = gArr[i];
		match (i % 4) {
			0 => gSlots[i] = Slot.Empty;
			1 => gSlots[i] = Slot.One(s);
			2 => gSlots[i] = Slot.Pair(s, gArr[(i + 1) % gArr.length]);
			_ => gSlots[i] = Slot.Tagged(s, (i, i + 1));
		}
	}
	var h = 0;
	for (i < gSlots.length) {
		h = mix(h, slotArea(gSlots[i]));
		h = mix(h, gSlots[i].tag);
		h = mixb(h, Slot.Pair.?(gSlots[i]));
	}
	acci(h);

	// tuples of objects, arrays of tuples of objects
	var pairs = Array<(Shape, Shape, int)>.new(32);
	for (i < pairs.length) pairs[i] = (gArr[i], gArr[(i + 7) % gArr.length], i);
	var g = 0;
	for (i < pairs.length) {
		var p = pairs[i];
		g = mix(g, p.0.area());
		g = mix(g, p.1.rank());
		g = mix(g, p.2);
		g = mixb(g, p.0 == p.1);
	}
	acci(g);

	// globals of object type
	var k = 0;
	for (i < gArr.length) {
		gShape = gArr[i];
		gPair = (gShape, gArr[(i + 2) % gArr.length]);
		k = mix(k, gShape.area());
		k = mix(k, gPair.1.rank());
		k = mixb(k, gPair.0 == gShape);
	}
	acci(k);

	var s1 = Rect.new(1, 3, 4);
	var s2 = Square.new(2, 5);
	var e: Slot = Slot.Empty;
	var o: Slot = Slot.One(s1);
	var p: Slot = Slot.Pair(s1, s2);
	var t: Slot = Slot.Tagged(s1, (3, 5));
	if (slotArea(e) != -1) fail_assert(501);
	if (slotArea(o) != 12) fail_assert(502);
	if (slotArea(p) != 37) fail_assert(503);		// 12 + 25
	if (slotArea(t) != 27) fail_assert(504);		// 12 + 15
	if (slotArea(Slot.One(null)) != -2) fail_assert(505);
	if (e.tag != 0) fail_assert(506);
	if (t.tag != 3) fail_assert(507);
	// variant payloads compare by object identity, not by object contents
	if (!(o == Slot.One(s1))) fail_assert(508);
	if (o == Slot.One(Rect.new(1, 3, 4))) fail_assert(509);
	if (o == p) fail_assert(510);
	if (!(e == Slot.Empty)) fail_assert(511);
	if (!(Slot.Tagged(s1, (3, 5)) == t)) fail_assert(512);
	if (Slot.Tagged(s1, (3, 6)) == t) fail_assert(513);
}

//======================================================================
// Section 6: methods as values
//======================================================================
def applyShape(f: Shape -> int, s: Shape) -> int { return f(s); }
def sumOver(f: Shape -> int, a: Array<Shape>) -> int {
	var t = 0;
	for (i < a.length) t += f(a[i]);
	return t;
}
def methodvals() {
	var shapes = Array<Shape>.new(60);
	for (i < shapes.length) shapes[i] = makeShape(i);

	// unbound method references dispatch virtually on their receiver
	def UNBOUND: Array<Shape -> int> = [Shape.area, Shape.rank, Shape.describe];
	var h = 0;
	for (k < UNBOUND.length) {
		h = mix(h, sumOver(UNBOUND[k], shapes));
		for (i < 12) h = mix(h, applyShape(UNBOUND[k], shapes[i]));
	}
	acci(h);

	// bound delegates: one per object, all of them live at once
	var bound = Array<void -> int>.new(shapes.length);
	for (i < shapes.length) bound[i] = shapes[i].area;
	var g = 0;
	for (i < bound.length) g = mix(g, bound[i]());
	acci(g);

	// delegates captured in a closure over a heap object
	var acc = Buf.new();
	var add = acc.put;
	for (i < shapes.length) add(shapes[i].rank());
	var k = mix(0, acc.n);
	k = mix(k, acc.total());
	acci(k);

	var so = Solid.new(0, 3, 4, 7, 2);
	var re = Rect.new(0, 3, 4);
	if (applyShape(Shape.area, so) != 72) fail_assert(601);
	if (applyShape(Shape.rank, so) != 5) fail_assert(602);
	if (applyShape(Shape.area, re) != 12) fail_assert(603);
	var bd = so.area;
	if (bd() != 72) fail_assert(604);
	var bd2: void -> int = re.rank;
	if (bd2() != 1) fail_assert(605);
	// a delegate keeps its receiver even after the variable is reassigned
	var cur: Shape = so;
	var frozen = cur.area;
	cur = re;
	if (frozen() != 72) fail_assert(606);
	if (cur.area() != 12) fail_assert(607);
	// partial application over a class method
	var vis = WeightedVisitor.new(2);
	var vf = vis.visit;
	if (vf(so) != 154) fail_assert(608);			// (72 + 5) * 2
	if (vis.count != 1) fail_assert(609);
	var two: Array<Shape> = [so, re];
	if (sumOver(Shape.rank, two) != 6) fail_assert(610);
	if (sumOver(Shape.area, two) != 84) fail_assert(611);
}

//======================================================================
// Section 7: identity, null and cast behavior
//======================================================================
def identity() {
	var a = Rect.new(1, 2, 3);
	var b = Rect.new(1, 2, 3);
	var c: Shape = a;
	var h = mixb(0, a == b);
	h = mixb(h, a == c);
	h = mixb(h, a != b);
	h = mixb(h, c == null);
	acci(h);

	if (a == b) fail_assert(701);			// structurally equal, distinct
	if (!(a == c)) fail_assert(702);
	if (!(a != b)) fail_assert(703);
	var n: Shape;
	if (n != null) fail_assert(704);
	if (a == null) fail_assert(705);
	// casting null succeeds; querying null does not
	var cn = Rect.!(n);
	if (cn != null) fail_assert(706);
	if (Rect.?(n)) fail_assert(707);
	// upcast is implicit, downcast is checked
	var up: Shape = Solid.new(2, 1, 1, 0, 1);
	if (!Solid.?(up)) fail_assert(708);
	if (Solid.!(up).dens != 1) fail_assert(709);
	if (Rect.!(up).w != 1) fail_assert(710);

	// object identity through arrays, tuples and variants
	var arr = Array<Shape>.new(64);
	for (i < arr.length) arr[i] = if((i % 3) == 0, a, makeShape(i));
	var same = 0, g = 0;
	for (i < arr.length) {
		if (arr[i] == a) same++;
		g = mixb(g, arr[i] == a);
		g = mixb(g, arr[i] == arr[i]);
	}
	g = mix(g, same);
	acci(g);
	if (same != 22) fail_assert(711);		// i = 0,3,...,63
	var t = (a, b);
	if (t.0 == t.1) fail_assert(712);
	if (!(t.0 == a)) fail_assert(713);
	var s1: Slot = Slot.One(a);
	var s2: Slot = Slot.One(b);
	if (s1 == s2) fail_assert(714);
	if (!(s1 == Slot.One(a))) fail_assert(715);
}

//======================================================================
// Section 8: allocation churn with a live object graph
//======================================================================
class Node {
	def val: int;
	var next: Node;
	var owner: Shape;
	new(val, next) { }
}
def churn() {
	srand(0x5EED81);
	var roots = Array<Node>.new(24);
	var head: Node;
	for (i < 6000) {
		var s = makeShape(randn(60));
		head = Node.new(randn(1000), head);
		head.owner = s;
		if ((i % 211) == 0) roots[(i / 211) % roots.length] = head;
		if ((i % 17) == 0) head = null;		// most of the chain becomes garbage
	}
	var h = 0;
	var n = 0;
	for (i < roots.length) {
		var p = roots[i];
		while (p != null) {
			h = mix(h, p.val);
			if (p.owner != null) h = mix(h, p.owner.area());
			p = p.next;
			n++;
			if (n > 200000) { acci(h); return; }
		}
	}
	h = mix(h, n);
	acci(h);
	var p = head;
	var g = 0;
	while (p != null) {
		g = mix(g, p.val);
		g = mix(g, p.owner.rank());
		p = p.next;
	}
	acci(g);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) chain();
	if (a == 0 || a == 2) fieldkinds();
	if (a == 0 || a == 3) chaining();
	if (a == 0 || a == 4) basecalls();
	if (a == 0 || a == 5) containers();
	if (a == 0 || a == 6) methodvals();
	if (a == 0 || a == 7) identity();
	if (a == 0 || a == 8) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
