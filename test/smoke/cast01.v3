//@execute 0=-1646755942; 1=1623249596; 2=557736556; 3=-1354530523; 4=-352893569; 5=2084053032; 6=525935085; 7=-531137112; 8=-1863384635; 9=520664123; 10=-2133070745; 11=-1359619708
//@heap-size=200000
// Smoke test: casts and queries over the primitive types, used together.
// Integers, longs, bytes, bools, floats, doubles, tuples and void all flow
// through `T.!` (checked cast), `T.?` (query) and `T.view` (reinterpret), as
// direct expressions, as first-class function values, through generic helpers,
// and stored into arrays, tuples, class fields and variant payloads.
//
// No cast here is allowed to trap: an out-of-range case is always established
// through the query, and the checked cast is only applied where the query has
// already said yes.
//
// Values flow into a CRC that main() returns so nothing is dead; interleaved
// assert()s over compile-time constants are expected to fold away entirely.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
// NaN bit patterns are not portable across backends, so all NaNs mix one
// canonical marker; every other float mixes its exact bits.
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Generic cast and query helpers. Casting a tuple type is only expressible
// through a type parameter, so these carry the whole file's tuple work.
//======================================================================
def gcast<X, Y>(x: X, v: void) -> Y { return Y.!(x); }
def gquery<X, Y>(x: X, v: void) -> bool { return Y.?(x); }

//======================================================================
// Shared data
//======================================================================
def INTS: Array<int> = [
	0, 1, -1, 2, 127, -128, 128, 255, -256, 256, 32767, -32768, 65535,
	16777216, 16777217, 1000000, -1000000, 2147483647, -2147483648
];
def LONGS: Array<long> = [
	0, 1, -1, 255, -256, 2147483647, -2147483648, 2147483648L,
	4294967295L, -4294967296L, 9007199254740993L, 9223372036854775807L,
	-9223372036854775808L
];
def BYTES: Array<byte> = [0, 1, 65, 127, 128, 254, 255];
def BOOLS: Array<bool> = [true, false, true, false];
def FLOATS: Array<float> = [
	0f, -0.0f, 1f, -1f, 0.5f, 3.9f, -3.9f, 127f, 16777216f, 1e10f, -1e10f,
	float.infinity, -float.infinity, float.nan
];
def DOUBLES: Array<double> = [
	0d, -0.0d, 1.5d, 0.1d, 1e300d, -1e300d, 1e-300d, 3.9d, 16777217d,
	double.infinity, double.nan
];
def PAIRS: Array<(int, int)> = [(0, 0), (1, 2), (255, -1), (300, 3), (-1, 256), (127, 128)];

//======================================================================
// Section 1: int against the narrower integer types
//======================================================================
def narrowInts() {
	var h = 0;
	for (i < INTS.length) {
		var v = INTS[i];
		h = mixb(h, byte.?(v));
		h = mixb(h, i8.?(v));
		h = mixb(h, i16.?(v));
		h = mixb(h, u16.?(v));
		h = mix(h, byte.view(v));
		h = mix(h, i8.view(v));
		h = mix(h, i16.view(v));
		h = mix(h, u16.view(v));
		if (byte.?(v)) h = mix(h, byte.!(v));
		if (i16.?(v)) h = mix(h, i16.!(v));
	}
	for (i < BYTES.length) {
		var b = BYTES[i];
		h = mix(h, int.!(b));		// a byte always fits in an int
		h = mix(h, i8.view(b));
		h = mixb(h, i8.?(b));
	}
	acci(h);

	if (byte.!(255) != 255) fail_assert(101);
	if (byte.!(0) != 0) fail_assert(102);
	if (byte.?(256)) fail_assert(103);
	if (byte.?(-1)) fail_assert(104);
	if (!byte.?(255)) fail_assert(105);
	if (byte.view(300) != 44) fail_assert(106);
	if (byte.view(-1) != 255) fail_assert(107);
	if (i8.view(255) != -1) fail_assert(108);
	if (i8.?(255)) fail_assert(109);
	if (!i8.?(-128)) fail_assert(110);
	if (int.!(BYTES[6]) != 255) fail_assert(111);	// zero-extends
	if (i16.?(32768)) fail_assert(112);
	if (!u16.?(65535)) fail_assert(113);
	if (u16.?(-1)) fail_assert(114);
	if (u16.view(-1) != 65535) fail_assert(115);
}

//======================================================================
// Section 2: int against long and u32
//======================================================================
def longs() {
	var h = 0;
	for (i < LONGS.length) {
		var v = LONGS[i];
		h = mixb(h, int.?(v));
		h = mixb(h, u32.?(v));
		h = mixb(h, byte.?(v));
		h = mix(h, int.view(v));
		h = mix(h, int.view(u32.view(v)));
		if (int.?(v)) h = mix(h, int.!(v));
		if (u32.?(v)) h = mixl(h, u32.!(v));
	}
	for (i < INTS.length) {
		var v = INTS[i];
		h = mixl(h, long.!(v));		// an int always fits in a long
		h = mixl(h, long.view(v));
		h = mixl(h, long.view(u32.view(v)));
		h = mixb(h, u32.?(v));
	}
	acci(h);

	if (long.!(-1) != -1) fail_assert(201);
	if (long.view(-1) != -1) fail_assert(202);
	if (long.view(u32.view(-1)) != 4294967295L) fail_assert(203);
	if (int.?(2147483648L)) fail_assert(204);
	if (!int.?(2147483647L)) fail_assert(205);
	if (int.?(-2147483649L)) fail_assert(206);
	if (int.!(2147483647L) != 2147483647) fail_assert(207);
	if (int.view(4294967296L) != 0) fail_assert(208);
	if (int.view(4294967297L) != 1) fail_assert(209);
	if (u32.?(-1)) fail_assert(210);
	if (!u32.?(4294967295L)) fail_assert(211);
	if (u32.?(4294967296L)) fail_assert(212);
	if (u32.view(-1) != 4294967295L) fail_assert(213);
	if (long.?(u64.view(-1L))) fail_assert(214);
}

//======================================================================
// Section 3: bools, alone and inside aggregates
//======================================================================
def boolTable(b: bool) -> int {
	return if(b, 1, 0);
}
def bools() {
	var v: void;
	var h = 0;
	for (i < BOOLS.length) {
		var b = BOOLS[i];
		h = mixb(h, b);
		h = mixb(h, gcast<bool, bool>(b, v));	// identity cast through a type param
		h = mix(h, boolTable(b));
		h = mix(h, u1.view(b));			// a bool views as a one-bit integer
		h = mix(h, byte.view(b));
		h = mix(h, int.view(b));
		h = mixb(h, gquery<int, byte>(int.view(b), v));
	}
	acci(h);

	var pairs = Array<(bool, int)>.new(16);
	for (i < pairs.length) pairs[i] = (BOOLS[i % BOOLS.length], INTS[i % INTS.length]);
	var g = 0;
	for (i < pairs.length) {
		var t = pairs[i];
		g = mixb(g, t.0);
		g = mix(g, t.1);
		g = mixb(g, gcast<(bool, int), (bool, long)>(t, v).0);
		g = mixl(g, gcast<(bool, int), (bool, long)>(t, v).1);
	}
	acci(g);

	if (u1.view(true) != 1) fail_assert(301);
	if (u1.view(false) != 0) fail_assert(302);
	if (int.view(true) != 1) fail_assert(303);
	if (byte.view(false) != 0) fail_assert(304);
	if (!gcast<bool, bool>(true, v)) fail_assert(305);
	if (gcast<bool, bool>(false, v)) fail_assert(306);
	if (gcast<(bool, int), (bool, long)>((true, -1), v).1 != -1) fail_assert(307);
}

//======================================================================
// Section 4: floats and doubles against the integer types
//======================================================================
def floats() {
	var h = 0;
	for (i < FLOATS.length) {
		var f = FLOATS[i];
		h = mixb(h, int.?(f));
		h = mixb(h, long.?(f));
		h = mixb(h, byte.?(f));
		h = mix(h, int.truncf(f));	// truncation saturates, it does not trap
		h = mixl(h, long.truncf(f));
		if (int.?(f)) h = mix(h, int.!(f));
		if (long.?(f)) h = mixl(h, long.!(f));
		var d: double = f;		// float promotes to double exactly
		h = mixd(h, d);
	}
	for (i < INTS.length) {
		var v = INTS[i];
		h = mixb(h, float.?(v));
		h = mixf(h, float.roundi(v));
		h = mixd(h, double.roundi(v));
		if (float.?(v)) h = mixf(h, float.!(v));
	}
	acci(h);

	var g = 0;
	for (i < DOUBLES.length) {
		var d = DOUBLES[i];
		g = mixb(g, float.?(d));
		g = mixf(g, float.roundd(d));
		g = mixb(g, int.?(d));
		g = mix(g, int.truncd(d));
		if (float.?(d)) g = mixf(g, float.!(d));
		if (int.?(d)) g = mix(g, int.!(d));
	}
	acci(g);

	// exact-representability queries into float
	if (!float.?(16777216)) fail_assert(401);
	if (float.?(16777217)) fail_assert(402);
	if (!float.?(-2147483648)) fail_assert(403);
	// queries out of float
	if (!int.?(3f)) fail_assert(404);
	if (int.?(3.9f)) fail_assert(405);
	if (int.?(float.nan)) fail_assert(406);
	if (int.?(1e10f)) fail_assert(407);		// out of int range
	if (!long.?(1e10f)) fail_assert(408);
	if (int.?(float.infinity)) fail_assert(409);
	// checked casts that are in range
	if (int.!(3f) != 3) fail_assert(410);
	if (int.!(-4f) != -4) fail_assert(411);
	if (long.!(1e10f) != 10000000000L) fail_assert(412);
	if (float.!(16777216) != 16777216f) fail_assert(413);
	// truncation is toward zero, and saturates at the ends of the range
	if (int.truncf(3.9f) != 3) fail_assert(414);
	if (int.truncf(-3.9f) != -3) fail_assert(415);
	if (int.truncf(1e10f) != 2147483647) fail_assert(416);
	if (int.truncf(-1e10f) != -2147483648) fail_assert(417);
	// float against double
	if (float.?(1e300d)) fail_assert(418);
	if (!float.?(1.5d)) fail_assert(419);
	if (float.?(0.1d)) fail_assert(420);		// 0.1 is not exact in binary32
	if (float.!(1.5d) != 1.5f) fail_assert(421);
	if (float.roundd(1e300d) != double.infinity) fail_assert(422);
	// a float promotes to double with no loss
	var p: double = 3.5f;
	if (p != 3.5d) fail_assert(423);
}

//======================================================================
// Section 5: tuple casts
//======================================================================
def tuples() {
	var v: void;
	var h = 0;
	for (i < PAIRS.length) {
		var t = PAIRS[i];
		h = mix(h, t.0);
		h = mix(h, t.1);
		h = mixb(h, gquery<(int, int), (byte, byte)>(t, v));
		h = mixb(h, gquery<(int, int), (i16, i16)>(t, v));
		h = mixb(h, gquery<(int, int), (long, long)>(t, v));
		var w = gcast<(int, int), (long, long)>(t, v);	// widening never traps
		h = mixl(h, w.0);
		h = mixl(h, w.1);
		if (gquery<(int, int), (byte, byte)>(t, v)) {
			var b = gcast<(int, int), (byte, byte)>(t, v);
			h = mix(h, b.0);
			h = mix(h, b.1);
		}
	}
	acci(h);

	// nested tuples, and a tuple carrying a bool and a void
	var g = 0;
	for (i < PAIRS.length) {
		var n = ((PAIRS[i].0, PAIRS[i].1), (BOOLS[i % BOOLS.length], v));
		var m = gcast<((int, int), (bool, void)), ((long, long), (bool, void))>(n, v);
		g = mixl(g, m.0.0);
		g = mixl(g, m.0.1);
		g = mixb(g, m.1.0);
		var three = gcast<(int, int, int), (long, byte, i16)>((PAIRS[i].0, 200, -300), v);
		g = mixl(g, three.0);
		g = mix(g, three.1);
		g = mix(g, three.2);
	}
	acci(g);

	// a tuple query is the conjunction of its component queries
	if (!gquery<(int, int), (byte, byte)>((1, 2), v)) fail_assert(501);
	if (gquery<(int, int), (byte, byte)>((1, 300), v)) fail_assert(502);
	if (gquery<(int, int), (byte, byte)>((-1, 2), v)) fail_assert(503);
	if (!gquery<(int, int), (long, long)>((-1, 2), v)) fail_assert(504);
	if (gquery<(int, int, int), (byte, byte, byte)>((1, 2, 300), v)) fail_assert(505);
	if (!gquery<(int, int, int), (byte, byte, byte)>((1, 2, 3), v)) fail_assert(506);
	// a tuple cast is component-wise
	if (gcast<(int, int), (byte, byte)>((1, 255), v).1 != 255) fail_assert(507);
	if (gcast<(int, int), (long, long)>((-1, 2), v).0 != -1) fail_assert(508);
	if (gcast<(int, int, int), (long, byte, i16)>((5, 200, -300), v).2 != -300) fail_assert(509);
	if (gcast<((int, int), (bool, void)), ((long, long), (bool, void))>(((7, 8), (true, v)), v).0.1 != 8) fail_assert(510);
}

//======================================================================
// Section 6: casts and queries as first-class function values
//======================================================================
def applyIQ(f: int -> bool, v: int) -> bool { return f(v); }
def applyIC(f: int -> byte, v: int) -> byte { return f(v); }
def firstClass() {
	def QUERIES: Array<int -> bool> = [byte.?<int>, i8.?<int>, i16.?<int>, u16.?<int>, float.?<int>];
	def VIEWS: Array<int -> byte> = [byte.view<int>, byte.view<int>];
	var h = 0;
	for (i < INTS.length) {
		for (k < QUERIES.length) h = mixb(h, applyIQ(QUERIES[k], INTS[i]));
		h = mix(h, applyIC(VIEWS[i % VIEWS.length], INTS[i]));
	}
	acci(h);

	var widen: int -> long = long.!<int>;
	var reint: int -> u32 = u32.view<int>;
	var fromf: float -> int = int.truncf;
	var tof: int -> float = float.roundi;
	var g = 0;
	for (i < INTS.length) {
		g = mixl(g, widen(INTS[i]));
		g = mixl(g, reint(INTS[i]));
		g = mixf(g, tof(INTS[i]));
	}
	for (i < FLOATS.length) g = mix(g, fromf(FLOATS[i]));
	acci(g);

	// a partially applied generic cast is itself a value
	var toLong = gcast<int, long>(_, ());
	var k = 0;
	for (i < INTS.length) k = mixl(k, toLong(INTS[i]));
	acci(k);

	if (applyIQ(byte.?<int>, 256)) fail_assert(601);
	if (!applyIQ(byte.?<int>, 255)) fail_assert(602);
	if (applyIC(byte.view<int>, 300) != 44) fail_assert(603);
	if (long.!<int>(-1) != -1) fail_assert(604);
	if (u32.view<int>(-1) != 4294967295L) fail_assert(605);
	if (toLong(-5) != -5) fail_assert(606);
	if (int.truncf(3.9f) != 3) fail_assert(607);
}

//======================================================================
// Section 7: casts flowing through arrays and ranges
//======================================================================
def widenAll(src: Range<int>, dst: Range<long>) {
	for (i < src.length) dst[i] = src[i];		// implicit promotion
}
def narrowAll(src: Range<int>, dst: Range<byte>) -> int {
	var n = 0;
	for (i < src.length) {
		if (byte.?(src[i])) { dst[i] = byte.!(src[i]); n++; }
		else dst[i] = byte.view(src[i]);
	}
	return n;
}
def arrays() {
	var src = Array<int>.new(64);
	for (i < src.length) src[i] = i * 37 - 600;
	var wide = Array<long>.new(64);
	var narrow = Array<byte>.new(64);
	widenAll(src, wide);
	var exact = narrowAll(src, narrow);
	var h = mix(0, exact);
	for (i < src.length) {
		h = mix(h, src[i]);
		h = mixl(h, wide[i]);
		h = mix(h, narrow[i]);
		if (wide[i] != src[i]) fail_assert(701);
		if (narrow[i] != byte.view(src[i])) fail_assert(702);
	}
	acci(h);

	// a range view over part of the same backing array
	var r: Range<int> = src;
	var mid = r[16 ... 48];
	var g = mix(0, mid.length);
	for (i < mid.length) {
		g = mix(g, mid[i]);
		g = mixb(g, byte.?(mid[i]));
		g = mixf(g, float.roundi(mid[i]));
	}
	acci(g);

	// a string is an Array<byte>, so the cast between them is the identity
	var v: void;
	var s = "cast01 smoke";
	var b: Array<byte> = s;
	var back = gcast<Array<byte>, string>(b, v);
	var k = mix(0, back.length);
	for (i < back.length) k = mix(k, back[i]);
	acci(k);

	if (mid.length != 32) fail_assert(703);
	if (back.length != 12) fail_assert(704);
	if (back[0] != 'c') fail_assert(705);
	if (exact < 0) fail_assert(706);
}

//======================================================================
// Section 8: casts in class fields and through virtual dispatch
//======================================================================
class Holder {
	var i: int;
	var l: long;
	var b: byte;
	var f: float;
	new(v: int) {
		i = v;
		l = v;			// promotion on store
		b = byte.view(v);
		f = float.roundi(v);
	}
	def kind() -> int { return 0; }
	def value() -> long { return l; }
}
class ByteHolder extends Holder {
	new(v: int) super(v) { }
	def kind() -> int { return 1; }
	def value() -> long { return b; }
}
class FloatHolder extends Holder {
	new(v: int) super(v) { }
	def kind() -> int { return 2; }
	def value() -> long { return long.truncf(f); }
}
def classes() {
	var objs = Array<Holder>.new(3 * INTS.length);
	for (i < INTS.length) {
		objs[3 * i + 0] = Holder.new(INTS[i]);
		objs[3 * i + 1] = ByteHolder.new(INTS[i]);
		objs[3 * i + 2] = FloatHolder.new(INTS[i]);
	}
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mix(h, o.kind());
		h = mixl(h, o.value());		// virtual dispatch over 3 implementations
		h = mix(h, o.i);
		h = mixl(h, o.l);
		h = mix(h, o.b);
		h = mixf(h, o.f);
		h = mixb(h, ByteHolder.?(o));
		h = mixb(h, FloatHolder.?(o));
		if (o.l != o.i) fail_assert(801);
		if (o.b != byte.view(o.i)) fail_assert(802);
	}
	acci(h);

	// downcast, then read a field through the narrower static type
	var g = 0;
	for (i < objs.length) {
		var o = objs[i];
		if (ByteHolder.?(o)) g = mixl(g, ByteHolder.!(o).value());
		if (FloatHolder.?(o)) g = mixl(g, FloatHolder.!(o).value());
	}
	acci(g);

	var c = Holder.new(300);
	if (c.b != 44) fail_assert(803);
	if (c.l != 300) fail_assert(804);
	if (ByteHolder.new(300).value() != 44) fail_assert(805);
	if (FloatHolder.new(300).value() != 300) fail_assert(806);
	if (FloatHolder.?(c)) fail_assert(807);
	if (!Holder.?(ByteHolder.new(1))) fail_assert(808);
}

//======================================================================
// Section 9: casts in variant payloads
//======================================================================
type Prim {
	case I(v: int);
	case L(v: long);
	case B(v: byte);
	case F(v: float);
	case Z(v: bool);
	case Nothing;
}
def asLong(p: Prim) -> long {
	match (p) {
		I(v) => return v;
		L(v) => return v;
		B(v) => return v;
		F(v) => return long.truncf(v);
		Z(v) => return if(v, 1, 0);
		Nothing => return -1;
	}
}
def variants() {
	var ps = Array<Prim>.new(5 * INTS.length);
	for (i < INTS.length) {
		var v = INTS[i];
		ps[5 * i + 0] = Prim.I(v);
		ps[5 * i + 1] = Prim.L(v);
		ps[5 * i + 2] = Prim.B(byte.view(v));
		ps[5 * i + 3] = Prim.F(float.roundi(v));
		ps[5 * i + 4] = Prim.Z(v != 0);
	}
	var h = 0;
	for (i < ps.length) {
		h = mixl(h, asLong(ps[i]));
		h = mix(h, ps[i].tag);
		h = mixb(h, Prim.B.?(ps[i]));
		if (Prim.B.?(ps[i])) h = mix(h, Prim.B.!(ps[i]).v);
	}
	acci(h);

	if (asLong(Prim.I(-1)) != -1) fail_assert(901);
	if (asLong(Prim.B(byte.view(300))) != 44) fail_assert(902);
	if (asLong(Prim.F(3.9f)) != 3) fail_assert(903);
	if (asLong(Prim.Z(true)) != 1) fail_assert(904);
	if (asLong(Prim.Nothing) != -1) fail_assert(905);
	if (Prim.Nothing.tag != 5) fail_assert(906);
	// a case query needs a parent-typed operand
	var pi: Prim = Prim.I(0);
	var pb: Prim = Prim.B(byte.view(7));
	if (Prim.B.?(pi)) fail_assert(907);
	if (!Prim.B.?(pb)) fail_assert(908);
	if (Prim.B.!(pb).v != 7) fail_assert(909);
}

//======================================================================
// Section 10: void, and the identity cases
//======================================================================
var sideEffect: int;
def unit() {
	sideEffect = 0;
	var v: void;
	var h = 0;
	for (i < INTS.length) {
		void(bump(INTS[i]));			// discard the result, keep the effect
		h = mix(h, sideEffect);
		var t = gcast<(int, void), (long, void)>((INTS[i], v), v);
		h = mixl(h, t.0);
		h = mixl(h, gcast<int, long>(INTS[i], v));
		h = mix(h, gcast<int, int>(INTS[i], v));	// identity cast
		h = mixb(h, gquery<int, int>(INTS[i], v));	// identity query
	}
	acci(h);

	if (sideEffect != INTS.length) fail_assert(1001);
	if (gcast<int, int>(-7, v) != -7) fail_assert(1002);
	if (!gquery<int, int>(-7, v)) fail_assert(1003);
	if (gcast<(int, void), (long, void)>((-7, v), v).0 != -7) fail_assert(1004);
	sideEffect = 0;
}
def bump(x: int) -> int {
	sideEffect++;
	return x;
}

//======================================================================
// Section 11: allocation churn with casts on every node
//======================================================================
class Node(i: int, l: long, b: byte, f: float, next: Node) { }
def churn() {
	var head: Node;
	var live = Array<Node>.new(16);
	for (i < 2000) {
		var v = i * 7919 - 4000000;
		head = Node.new(v, v, byte.view(v), float.roundi(v), head);
		if ((i % 97) == 0) live[(i / 97) % live.length] = head;
		if ((i % 13) == 0) head = null;		// drop most of the chain
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mix(h, p.i);
			h = mixl(h, p.l);
			h = mix(h, p.b);
			h = mixf(h, p.f);
			if (p.b != byte.view(p.i)) fail_assert(1101);
			if (p.l != p.i) fail_assert(1102);
			p = p.next;
			n++;
			if (n > 100000) { acci(h); return; }
		}
	}
	h = mix(h, n);
	acci(h);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) narrowInts();
	if (a == 0 || a == 2) longs();
	if (a == 0 || a == 3) bools();
	if (a == 0 || a == 4) floats();
	if (a == 0 || a == 5) tuples();
	if (a == 0 || a == 6) firstClass();
	if (a == 0 || a == 7) arrays();
	if (a == 0 || a == 8) classes();
	if (a == 0 || a == 9) variants();
	if (a == 0 || a == 10) unit();
	if (a == 0 || a == 11) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
