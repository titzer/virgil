//@execute 0=-1031206522; 1=758919186; 2=-795138083; 3=-1761942656; 4=-257071500; 5=-813004281; 6=2076087307; 7=780128010; 8=-1552470261; 9=91695367; 10=-451555653
//@heap-size=400000
// Smoke test: arrays, part 1 — the core array feature space.
// Construction, element access, length, every element type, multi-dimensional
// arrays, identity vs. content equality, every iteration form, and copying.
// Bulk work is recorded in a running CRC that main() returns so nothing can be
// deleted as dead code; interleaved assertions have compile-time constant
// operands, so a folding bug shows up as an assertion id instead of a hash.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data — values arrive from globals so no section folds away wholly.
//======================================================================
def SIZES: Array<int> = [0, 1, 2, 3, 7, 8, 15, 16, 31, 64];
def LIT_I: Array<int> = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5];
def LIT_B: Array<byte> = [0, 1, 65, 127, 128, 200, 255];

//======================================================================
// Section 1: construction, literals, length
//======================================================================
def construct() {
	var h = 0;
	for (i < SIZES.length) {
		var n = SIZES[i];
		var a = Array<int>.new(n);
		h = mix(h, a.length);
		for (j < a.length) h = mix(h, a[j]);		// zero-initialized
		for (j < a.length) a[j] = j * 3 - 1;
		for (j < a.length) h = mix(h, a[j]);
	}
	acci(h);

	var g = mix(0, LIT_I.length);
	for (i < LIT_I.length) g = mix(g, LIT_I[i]);
	g = mix(g, LIT_B.length);
	for (i < LIT_B.length) g = mix(g, LIT_B[i]);
	acci(g);

	// default values of reference element types
	var k = 0;
	var refs = Array<Array<int>>.new(4);
	for (i < refs.length) k = mixb(k, refs[i] == null);
	var strs = Array<string>.new(4);
	for (i < strs.length) k = mixs(k, strs[i]);
	var bools = Array<bool>.new(4);
	for (i < bools.length) k = mixb(k, bools[i]);
	acci(k);

	if (Array<int>.new(0).length != 0) fail_assert(101);
	if (Array<int>.new(5).length != 5) fail_assert(102);
	if (Array<int>.new(5)[0] != 0) fail_assert(103);
	if (Array<int>.new(5)[4] != 0) fail_assert(104);
	if ([3, 1, 4].length != 3) fail_assert(105);
	if ([3, 1, 4][0] != 3) fail_assert(106);
	if ([3, 1, 4][2] != 4) fail_assert(107);
	if (Array<bool>.new(3)[1]) fail_assert(108);
	if (Array<string>.new(3)[1] != null) fail_assert(109);
	if (Array<Array<int>>.new(2)[0] != null) fail_assert(110);
	if (Array<byte>.new(3)[2] != 0) fail_assert(111);
	if (Array<double>.new(3)[0] != 0d) fail_assert(112);
}

//======================================================================
// Section 2: element read/write, including both edges of the bounds check
//======================================================================
def readwrite() {
	var n = 64;
	var a = Array<int>.new(n);
	for (i < n) a[i] = i * i - 7;
	// deliberate in-bounds accesses at both edges; never out of bounds
	a[0] = a[0] + 1;
	a[a.length - 1] = a[a.length - 1] - 1;
	var h = mix(0, a[0]);
	h = mix(h, a[a.length - 1]);
	for (i < n) h = mix(h, a[i]);
	acci(h);

	// compound assignment and increment through an element
	var b = Array<int>.new(8);
	for (i < b.length) b[i] = 1;
	for (i < b.length) b[i] += i;
	for (i < b.length) b[i] *= 3;
	for (i < b.length) b[i] -= 2;
	for (i < b.length) b[i] |= 0x40;
	for (i < b.length) b[i] ^= i;
	var g = 0;
	for (i < b.length) g = mix(g, b[i]);
	acci(g);

	var c = Array<int>.new(4);
	c[0]++;
	c[0]++;
	c[3]--;
	var d = c[0]++;			// post-increment yields the old value
	var e = ++c[1];			// pre-increment yields the new value
	var k = mix(0, c[0]);
	k = mix(k, c[1]);
	k = mix(k, c[3]);
	k = mix(k, d);
	k = mix(k, e);
	acci(k);

	// writing through an index computed from data
	var idx = Array<int>.new(LIT_I.length);
	var dst = Array<int>.new(16);
	for (i < LIT_I.length) idx[i] = LIT_I[i];
	for (i < idx.length) dst[idx[i]] = dst[idx[i]] + 1;
	var m = 0;
	for (i < dst.length) m = mix(m, dst[i]);
	acci(m);

	if (d != 2) fail_assert(201);
	if (e != 1) fail_assert(202);
	if (c[0] != 3) fail_assert(203);
	if (c[1] != 1) fail_assert(204);
	if (c[2] != 0) fail_assert(205);
	if (c[3] != -1) fail_assert(206);
	// a[i] = i*i - 7, then both edges adjusted by one
	if (a[0] != -6) fail_assert(207);
	if (a[63] != 63 * 63 - 8) fail_assert(208);
	if (a[1] != -6) fail_assert(209);
	if (a.length != 64) fail_assert(210);
}

//======================================================================
// Section 3: arrays of every primitive element type
//======================================================================
def prims() {
	var ab: Array<bool> = [true, false, true, true];
	var au8: Array<byte> = [0, 1, 65, 200, 255];
	var ai8: Array<i8> = [0, 1, -1, 127, -128];
	var au16: Array<u16> = [0, 1, 32768, 65535];
	var ai16: Array<i16> = [0, -1, 32767, -32768];
	var ai: Array<int> = [0, -1, 2147483647, -2147483648];
	var au: Array<u32> = [0u, 1u, 2147483648u, 4294967295u];
	var al: Array<long> = [0, -1, 1099511627776L, long.max, long.min];
	var aul: Array<u64> = [0uL, 1uL, 18446744073709551615uL];
	var af: Array<float> = [0f, -0.0f, 1.5f, float.infinity, float.nan];
	var ad: Array<double> = [0d, -0.0d, 1.5d, double.infinity, double.nan];

	var h = 0;
	for (i < ab.length) h = mixb(h, ab[i]);
	for (i < au8.length) h = mix(h, au8[i]);
	for (i < ai8.length) h = mix(h, ai8[i]);
	for (i < au16.length) h = mix(h, au16[i]);
	for (i < ai16.length) h = mix(h, ai16[i]);
	for (i < ai.length) h = mix(h, ai[i]);
	acci(h);
	var g = 0;
	for (i < au.length) g = mix(g, int.view(au[i]));
	for (i < al.length) g = mixl(g, al[i]);
	for (i < aul.length) g = mixl(g, long.view(aul[i]));
	for (i < af.length) g = mixf(g, af[i]);
	for (i < ad.length) g = mixd(g, ad[i]);
	acci(g);

	// round-trip every primitive width through a freshly allocated array
	var k = 0;
	var b8 = Array<byte>.new(256);
	for (i < b8.length) b8[i] = byte.view(i);
	for (i < b8.length) k = mix(k, b8[i]);
	var s8 = Array<i8>.new(256);
	for (i < s8.length) s8[i] = i8.view(i);
	for (i < s8.length) k = mix(k, s8[i]);
	acci(k);

	if (au8[4] != 255) fail_assert(301);
	if (ai8[4] != -128) fail_assert(302);
	if (ai16[3] != -32768) fail_assert(303);
	if (au16[3] != 65535) fail_assert(304);
	if (ai[3] != -2147483648) fail_assert(305);
	if (au[3] != 4294967295u) fail_assert(306);
	if (al[3] != 9223372036854775807L) fail_assert(307);
	if (aul[2] != 18446744073709551615uL) fail_assert(308);
	if (af[2] != 1.5f) fail_assert(309);
	if (ad[4] == ad[4]) fail_assert(310);				// NaN survived
	if (int.view(af[1]) != int.view(-0.0f)) fail_assert(311);	// -0.0 survived
	if (!ab[0]) fail_assert(312);
	if (ab[1]) fail_assert(313);
	// byte and i8 store the same bits, interpreted differently
	if (byte.view(200) != 200) fail_assert(314);
	if (i8.view(200) != -56) fail_assert(315);
}

//======================================================================
// Section 4: multi-dimensional and jagged arrays
//======================================================================
def multi() {
	var m = Array<Array<int>>.new(8);
	for (i < m.length) {
		m[i] = Array<int>.new(8);
		for (j < 8) m[i][j] = i * 8 + j;
	}
	var h = 0;
	for (i < m.length) for (j < 8) h = mix(h, m[i][j]);
	acci(h);

	// transpose in place through the row references
	for (i < m.length) {
		for (j < i) {
			var t = m[i][j];
			m[i][j] = m[j][i];
			m[j][i] = t;
		}
	}
	var g = 0;
	for (i < m.length) for (j < 8) g = mix(g, m[i][j]);
	acci(g);

	// jagged: row i has i elements
	var jag = Array<Array<int>>.new(10);
	for (i < jag.length) {
		jag[i] = Array<int>.new(i);
		for (j < i) jag[i][j] = i * 100 + j;
	}
	var k = 0;
	for (i < jag.length) {
		k = mix(k, jag[i].length);
		for (j < jag[i].length) k = mix(k, jag[i][j]);
	}
	acci(k);

	// three deep
	var cube = Array<Array<Array<int>>>.new(4);
	for (i < cube.length) {
		cube[i] = Array<Array<int>>.new(4);
		for (j < 4) {
			cube[i][j] = Array<int>.new(4);
			for (l < 4) cube[i][j][l] = i * 16 + j * 4 + l;
		}
	}
	var q = 0;
	for (i < 4) for (j < 4) for (l < 4) q = mix(q, cube[i][j][l]);
	acci(q);

	// aliasing rows: two slots holding the same row observe the same writes
	var alias = Array<Array<int>>.new(3);
	alias[0] = Array<int>.new(4);
	alias[1] = alias[0];
	alias[2] = Array<int>.new(4);
	alias[0][2] = 77;
	var p = mix(0, alias[1][2]);
	alias[1][3] = 88;
	p = mix(p, alias[0][3]);
	p = mix(p, alias[2][2]);
	acci(p);

	if (m.length != 8) fail_assert(401);
	if (m[0].length != 8) fail_assert(402);
	if (m[3][5] != 5 * 8 + 3) fail_assert(403);		// after transpose
	if (m[0][0] != 0) fail_assert(404);
	if (jag[0].length != 0) fail_assert(405);
	if (jag[9].length != 9) fail_assert(406);
	if (jag[9][8] != 908) fail_assert(407);
	if (cube[3][2][1] != 3 * 16 + 2 * 4 + 1) fail_assert(408);
	if (alias[1][2] != 77) fail_assert(409);
	if (alias[0][3] != 88) fail_assert(410);
	if (alias[2][2] != 0) fail_assert(411);
	if (alias[0] != alias[1]) fail_assert(412);
	if (alias[0] == alias[2]) fail_assert(413);
}

//======================================================================
// Section 5: identity vs. content equality
//======================================================================
def contentEq(a: Array<int>, b: Array<int>) -> bool {
	if (a == b) return true;
	if (a == null || b == null) return false;
	if (a.length != b.length) return false;
	for (i < a.length) if (a[i] != b[i]) return false;
	return true;
}
def identity() {
	var a = Array<int>.new(4);
	var b = Array<int>.new(4);
	for (i < 4) { a[i] = i; b[i] = i; }
	var c = a;
	var nul: Array<int>;

	var h = mixb(0, a == b);		// distinct objects: reference-unequal
	h = mixb(h, a == c);
	h = mixb(h, contentEq(a, b));
	h = mixb(h, contentEq(a, c));
	h = mixb(h, a == nul);
	h = mixb(h, contentEq(nul, nul));
	h = mixb(h, contentEq(a, nul));
	acci(h);

	// mutation through one name is visible through the other
	c[1] = 99;
	var g = mix(0, a[1]);
	g = mixb(g, contentEq(a, b));
	b[1] = 99;
	g = mixb(g, contentEq(a, b));
	g = mixb(g, a == b);
	acci(g);

	// arrays of arrays: element equality is reference equality
	var rows = Array<Array<int>>.new(4);
	rows[0] = a;
	rows[1] = b;
	rows[2] = a;
	rows[3] = null;
	var k = 0;
	for (i < rows.length) for (j < rows.length) k = mixb(k, rows[i] == rows[j]);
	acci(k);

	if (a == b) fail_assert(501);
	if (!(a == c)) fail_assert(502);
	if (!contentEq(a, b)) fail_assert(503);		// contents were made equal above
	if (a[1] != 99) fail_assert(504);
	if (contentEq(a, null)) fail_assert(505);
	if (!contentEq(null, null)) fail_assert(506);
	if (rows[0] != rows[2]) fail_assert(507);
	if (rows[0] == rows[1]) fail_assert(508);
	if (rows[3] != null) fail_assert(509);
}

//======================================================================
// Section 6: iteration forms
//======================================================================
def iterate() {
	var a = Array<int>.new(LIT_I.length);
	for (i < a.length) a[i] = LIT_I[i] * 7 - 3;

	var h1 = 0;
	for (i < a.length) h1 = mix(h1, a[i]);			// counting form
	var h2 = 0;
	for (e in a) h2 = mix(h2, e);				// foreach form
	var h3 = 0;
	for (i = 0; i < a.length; i++) h3 = mix(h3, a[i]);	// C-style form
	var h4 = 0;
	var i4 = 0;
	while (i4 < a.length) { h4 = mix(h4, a[i4]); i4++; }	// while form
	acci(h1);
	acci(h2);
	acci(h3);
	acci(h4);

	// reverse iteration
	var r = 0;
	for (i = a.length - 1; i >= 0; i--) r = mix(r, a[i]);
	acci(r);

	// strided iteration, and early exit
	var s = 0;
	for (i = 0; i < a.length; i = i + 2) s = mix(s, a[i]);
	for (e in a) {
		if (e > 40) break;
		s = mix(s, e);
	}
	for (e in a) {
		if ((e % 2) == 0) continue;
		s = mix(s, e);
	}
	acci(s);

	// nested foreach over an array of arrays
	var rows = Array<Array<int>>.new(4);
	for (i < rows.length) {
		rows[i] = Array<int>.new(4);
		for (j < 4) rows[i][j] = i * 4 + j;
	}
	var n = 0;
	for (row in rows) for (e in row) n = mix(n, e);
	acci(n);

	// all four forms must agree
	if (h1 != h2) fail_assert(601);
	if (h1 != h3) fail_assert(602);
	if (h1 != h4) fail_assert(603);
	// foreach over a zero-length array runs zero times
	var z = 0;
	for (e in Array<int>.new(0)) z++;
	if (z != 0) fail_assert(604);
	var one = 0;
	for (e in [5]) one += e;
	if (one != 5) fail_assert(605);
	if (a[0] != 3 * 7 - 3) fail_assert(606);
	if (a.length != 11) fail_assert(607);
}

//======================================================================
// Section 7: copying
//======================================================================
def copyOf(a: Array<int>) -> Array<int> {
	var b = Array<int>.new(a.length);
	for (i < a.length) b[i] = a[i];
	return b;
}
def copying() {
	var src = Array<int>.new(32);
	for (i < src.length) src[i] = i * 5 + 1;
	var dup = copyOf(src);
	var h = 0;
	for (i < dup.length) h = mix(h, dup[i]);
	h = mixb(h, src == dup);
	h = mixb(h, contentEq(src, dup));
	acci(h);

	// writing the copy leaves the original alone
	for (i < dup.length) dup[i] = -dup[i];
	var g = 0;
	for (i < src.length) g = mix(g, src[i]);
	for (i < dup.length) g = mix(g, dup[i]);
	acci(g);

	// overlapping self-copy, forward (shift left by 3)
	var f = Array<int>.new(16);
	for (i < f.length) f[i] = i;
	for (i < f.length - 3) f[i] = f[i + 3];
	var k = 0;
	for (i < f.length) k = mix(k, f[i]);
	acci(k);

	// overlapping self-copy, backward (shift right by 3)
	var b = Array<int>.new(16);
	for (i < b.length) b[i] = i;
	for (i = b.length - 1; i >= 3; i--) b[i] = b[i - 3];
	var m = 0;
	for (i < b.length) m = mix(m, b[i]);
	acci(m);

	// grow-by-copy, repeatedly
	var grow = Array<int>.new(1);
	grow[0] = 1;
	for (n < 8) {
		var bigger = Array<int>.new(grow.length * 2);
		for (i < grow.length) bigger[i] = grow[i];
		for (i = grow.length; i < bigger.length; i++) bigger[i] = i * i;
		grow = bigger;
	}
	var q = mix(0, grow.length);
	for (i < grow.length) q = mix(q, grow[i]);
	acci(q);

	if (dup.length != 32) fail_assert(701);
	if (src[0] != 1) fail_assert(702);
	if (dup[0] != -1) fail_assert(703);
	if (f[0] != 3) fail_assert(704);
	if (f[12] != 15) fail_assert(705);
	if (f[13] != 13) fail_assert(706);	// tail untouched
	if (f[15] != 15) fail_assert(707);
	if (b[15] != 12) fail_assert(708);
	if (b[3] != 0) fail_assert(709);
	if (b[2] != 2) fail_assert(710);	// head untouched
	if (grow.length != 256) fail_assert(711);
	if (grow[0] != 1) fail_assert(712);
}

//======================================================================
// Section 8: arrays through methods, including polymorphic ones
//======================================================================
def firstOf<T>(a: Array<T>, dflt: T) -> T {
	if (a == null || a.length == 0) return dflt;
	return a[0];
}
def lengthOf<T>(a: Array<T>) -> int {
	return if(a == null, -1, a.length);
}
def fillWith<T>(a: Array<T>, v: T) -> Array<T> {
	for (i < a.length) a[i] = v;
	return a;
}
def reverseOf<T>(a: Array<T>) -> Array<T> {
	var b = Array<T>.new(a.length);
	for (i < a.length) b[i] = a[a.length - 1 - i];
	return b;
}
def sumInto(a: Array<int>, start: int) -> int {
	var s = start;
	for (e in a) s += e;
	return s;
}
def methods() {
	var a = Array<int>.new(12);
	for (i < a.length) a[i] = i * i - 3;
	var h = mix(0, firstOf<int>(a, -1));
	h = mix(h, lengthOf<int>(a));
	h = mix(h, sumInto(a, 1000));
	var rv = reverseOf<int>(a);
	for (i < rv.length) h = mix(h, rv[i]);
	acci(h);

	var g = 0;
	var bs = fillWith<byte>(Array<byte>.new(8), 0xAB);
	for (i < bs.length) g = mix(g, bs[i]);
	var ss = fillWith<string>(Array<string>.new(4), "ab");
	for (i < ss.length) g = mixs(g, ss[i]);
	var ds = fillWith<double>(Array<double>.new(4), 2.5d);
	for (i < ds.length) g = mixd(g, ds[i]);
	var aa = fillWith<Array<int>>(Array<Array<int>>.new(3), a);
	for (i < aa.length) g = mix(g, lengthOf<int>(aa[i]));
	acci(g);

	// first-class array operators
	def len: Array<int> -> int = Array<int>.length;
	var k = mix(0, len(a));
	var mk: int -> Array<int> = Array<int>.new;
	k = mix(k, len(mk(9)));
	acci(k);

	if (firstOf<int>(a, -1) != -3) fail_assert(801);
	if (firstOf<int>(null, -1) != -1) fail_assert(802);
	if (firstOf<int>(Array<int>.new(0), -7) != -7) fail_assert(803);
	if (lengthOf<int>(null) != -1) fail_assert(804);
	if (lengthOf<byte>("abcd") != 4) fail_assert(805);
	if (reverseOf<int>([1, 2, 3])[0] != 3) fail_assert(806);
	if (sumInto([1, 2, 3], 10) != 16) fail_assert(807);
	if (fillWith<int>(Array<int>.new(3), 8)[2] != 8) fail_assert(808);
	if (len([1, 2, 3, 4, 5]) != 5) fail_assert(809);
}

//======================================================================
// Section 9: arrays in globals, components, and class fields
//======================================================================
var gArr: Array<int>;
var gRows: Array<Array<int>>;

component Table {
	var data: Array<int> = Array<int>.new(16);
	var used: int;
	def cap: int = 16;
	def add(v: int) -> int {
		data[used % cap] = v;
		used++;
		return used;
	}
}
class Buf {
	var bytes: Array<byte>;
	var n: int;
	new(cap: int) { bytes = Array<byte>.new(cap); }
	def put(b: byte) -> this {
		if (n < bytes.length) bytes[n++] = b;
	}
	def hash() -> int {
		var h = 0;
		for (i < n) h = mix(h, bytes[i]);
		return h;
	}
}
def stored() {
	// reset all mutable global state: sections must not depend on each other
	gArr = Array<int>.new(24);
	gRows = Array<Array<int>>.new(4);
	Table.data = Array<int>.new(16);
	Table.used = 0;

	for (i < gArr.length) gArr[i] = i * 11 - 5;
	var h = mix(0, gArr.length);
	for (i < gArr.length) h = mix(h, gArr[i]);
	acci(h);

	for (i < gRows.length) {
		gRows[i] = Array<int>.new(5);
		for (j < 5) gRows[i][j] = gArr[i * 5 + j];
	}
	var g = 0;
	for (i < gRows.length) for (j < 5) g = mix(g, gRows[i][j]);
	acci(g);

	for (i < 40) Table.add(i * 3);
	var k = mix(0, Table.used);
	for (i < Table.data.length) k = mix(k, Table.data[i]);
	acci(k);

	var bufs = Array<Buf>.new(8);
	for (i < bufs.length) {
		bufs[i] = Buf.new(8);
		for (j < 12) bufs[i].put(byte.view(i * 12 + j));
	}
	var m = 0;
	for (i < bufs.length) {
		m = mix(m, bufs[i].hash());
		m = mix(m, bufs[i].n);
		m = mix(m, bufs[i].bytes.length);
	}
	acci(m);

	if (gArr.length != 24) fail_assert(901);
	if (gArr[0] != -5) fail_assert(902);
	if (Table.used != 40) fail_assert(903);
	if (Table.cap != 16) fail_assert(904);
	if (Table.data.length != 16) fail_assert(905);
	// slot i%16 is written for i = 0..39, so slot 0 last takes i = 32
	if (Table.data[0] != 96) fail_assert(906);
	if (Table.data[7] != 39 * 3) fail_assert(910);	// slot 7 last takes i = 39
	if (bufs[0].n != 8) fail_assert(907);		// put() stops at capacity
	if (bufs[0].bytes[0] != 0) fail_assert(908);
	if (bufs[1].bytes[0] != 12) fail_assert(909);
}

//======================================================================
// Section 10: allocation churn with live array data
//======================================================================
def churn() {
	var live = Array<Array<int>>.new(24);
	var total = 0;
	for (i < 1500) {
		var n = 1 + (i % 17);
		var a = Array<int>.new(n);
		for (j < n) a[j] = i * n + j;
		total += a[n - 1];
		if ((i % 61) == 0) live[(i / 61) % live.length] = a;
	}
	var h = mix(0, total);
	for (i < live.length) {
		var a = live[i];
		if (a == null) { h = mix(h, -1); continue; }
		h = mix(h, a.length);
		for (j < a.length) h = mix(h, a[j]);
	}
	acci(h);

	// a chain of arrays that keeps its predecessor alive
	var chain: Array<Array<int>>;
	for (i < 400) {
		var next = Array<Array<int>>.new(2);
		next[0] = Array<int>.new(4);
		for (j < 4) next[0][j] = i * 4 + j;
		next[1] = if(chain == null, null, chain[0]);
		chain = next;
	}
	var g = 0;
	for (j < 4) g = mix(g, chain[0][j]);
	if (chain[1] != null) for (j < 4) g = mix(g, chain[1][j]);
	acci(g);

	if (chain[0][0] != 399 * 4) fail_assert(1001);
	if (chain[1][0] != 398 * 4) fail_assert(1002);
	if (live.length != 24) fail_assert(1003);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) construct();
	if (a == 0 || a == 2) readwrite();
	if (a == 0 || a == 3) prims();
	if (a == 0 || a == 4) multi();
	if (a == 0 || a == 5) identity();
	if (a == 0 || a == 6) iterate();
	if (a == 0 || a == 7) copying();
	if (a == 0 || a == 8) methods();
	if (a == 0 || a == 9) stored();
	if (a == 0 || a == 10) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
