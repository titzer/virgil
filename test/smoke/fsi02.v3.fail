//@execute 0=709089980; 1=-1247840594; 2=-524506; 3=-1112433722; 4=1651791463; 5=-18198804; 6=-790510132; 7=1578041495; 8=-1261027187; 9=-1589946004; 10=-1278181992; 11=-270029434; 12=-1049186401
//@heap-size=200000
// Smoke test: wide fixed-size integers, i17..i64 and u17..u64, concentrating on
// the non-power-of-two widths i23, u31, i33, u47 and i63 where the value must be
// carried inside a wider machine register and re-normalized after every
// operation. Every observed value is mixed into a running CRC that main()
// returns, so nothing can be deleted as dead code; interleaved are assert()s
// whose operands are compile-time constants, which the optimizer is expected to
// fold away entirely, so a folding bug shows up as a set failure flag.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
// u64 is the one width that does not promote to long, so it mixes its bits.
def mixu(h: int, x: u64) -> int {
	return mixl(h, long.view(x));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data. Sections read their operands out of these arrays rather than
// out of literals, so no section can be constant-folded away wholesale.
//======================================================================
def I17: Array<i17> = [-65536, -65535, -1, 0, 1, 65534, 65535];
def U17: Array<u17> = [0, 1, 65535, 65536, 131070, 131071];
def I23: Array<i23> = [-4194304, -4194303, -1, 0, 1, 1000, 4194302, 4194303];
def U31: Array<u31> = [0, 1, 1073741823, 1073741824, 2147483646, 2147483647];
def I33: Array<i33> = [-4294967296, -4294967295, -1, 0, 1, 65536, 4294967294, 4294967295];
def U47: Array<u47> = [0, 1, 70368744177663, 70368744177664, 140737488355327];
def I63: Array<i63> = [-4611686018427387904, -1, 0, 1, 4611686018427387903];
def I64: Array<long> = [-9223372036854775808L, -1, 0, 1, 4294967296L, 9223372036854775807L];
def U64: Array<u64> = [0, 1, 4294967296uL, 9223372036854775808uL, 18446744073709551615uL];
def SHIFTS: Array<byte> = [0, 1, 16, 22, 23, 30, 31, 32, 33, 46, 47, 62, 63, 64];
def SEEDS: Array<long> = [
	0, 1, -1, 65535, -65536, 4194303, -4194304, 2147483647, -2147483648,
	4294967295L, -4294967296L, 140737488355327L, 9223372036854775807L,
	-9223372036854775808L, 1234567890123456789L
];

//======================================================================
// Section 1: limits of the wide widths
//======================================================================
def limits() {
	def SMIN: Array<long> = [i17.min, i23.min, i31.min, i32.min, i33.min, i47.min, i63.min, i64.min];
	def SMAX: Array<long> = [i17.max, i23.max, i31.max, i32.max, i33.max, i47.max, i63.max, i64.max];
	def UMAX: Array<u64> = [u17.max, u23.max, u31.max, u32.max, u33.max, u47.max, u63.max, u64.max];
	var h = 0;
	for (i < SMIN.length) {
		h = mixl(h, SMIN[i]);
		h = mixl(h, SMAX[i]);
		h = mixu(h, UMAX[i]);
		h = mixb(h, SMAX[i] == -1 - SMIN[i]);	// two's complement identity
	}
	acci(h);

	if (i17.min != -65536) fail_assert(101);
	if (u17.max != 131071) fail_assert(102);
	if (i23.min != -4194304) fail_assert(103);
	if (i23.max != 4194303) fail_assert(104);
	if (u23.max != 8388607) fail_assert(105);
	if (u31.max != 2147483647) fail_assert(106);
	if (i31.min != -1073741824) fail_assert(107);
	if (u32.max != 4294967295L) fail_assert(108);
	if (i33.min != -4294967296L) fail_assert(109);
	if (i33.max != 4294967295L) fail_assert(110);
	if (u33.max != 8589934591L) fail_assert(111);
	if (i47.max != 70368744177663L) fail_assert(112);
	if (u47.max != 140737488355327L) fail_assert(113);
	if (i63.min != -4611686018427387904L) fail_assert(114);
	if (u63.max != 9223372036854775807L) fail_assert(115);
	if (i64.min != -9223372036854775808L) fail_assert(116);
	if (long.view(u64.max) != -1) fail_assert(117);
}

//======================================================================
// Section 2: arithmetic wraps at the declared width
//======================================================================
def arith() {
	var h = 0;
	for (i < I23.length) for (j < I23.length) {
		var a = I23[i], b = I23[j];
		h = mixl(h, a + b);
		h = mixl(h, a - b);
		h = mixl(h, a * b);
		h = mixl(h, -a);
		// min / -1 is skipped throughout: division overflow at a fixed width
		// is a separate question from the one int.min / -1 asks.
		if (b != 0 && !(a == i23.min && b == -1)) { h = mixl(h, a / b); h = mixl(h, a % b); }
	}
	for (i < I33.length) for (j < I33.length) {
		var a = I33[i], b = I33[j];
		h = mixl(h, a + b);
		h = mixl(h, a - b);
		h = mixl(h, a * b);
		if (b != 0 && !(a == i33.min && b == -1)) { h = mixl(h, a / b); h = mixl(h, a % b); }
	}
	for (i < I63.length) for (j < I63.length) {
		var a = I63[i], b = I63[j];
		h = mixl(h, a + b);
		h = mixl(h, a - b);
		h = mixl(h, a * b);
	}
	acci(h);

	var g = 0;
	for (i < U31.length) for (j < U31.length) {
		var a = U31[i], b = U31[j];
		g = mixl(g, a + b);
		g = mixl(g, a - b);
		g = mixl(g, a * b);
		if (b != 0) { g = mixl(g, a / b); g = mixl(g, a % b); }
	}
	for (i < U47.length) for (j < U47.length) {
		var a = U47[i], b = U47[j];
		g = mixl(g, a + b);
		g = mixl(g, a - b);
		g = mixl(g, a * b);
		if (b != 0) { g = mixl(g, a / b); g = mixl(g, a % b); }
	}
	for (i < U64.length) for (j < U64.length) {
		var a = U64[i], b = U64[j];
		g = mixu(g, a + b);
		g = mixu(g, a - b);
		g = mixu(g, a * b);
		if (b != 0) { g = mixu(g, a / b); g = mixu(g, a % b); }
	}
	acci(g);

	// compound assignment applies the operator at the declared width
	var k = 0;
	var x: i23 = I23[7];		// i23.max
	x++;
	k = mixl(k, x);
	var y: u47 = U47[4];		// u47.max
	y += U47[1];
	k = mixl(k, y);
	var z: i63 = I63[0];		// i63.min
	z -= I63[3];
	k = mixl(k, z);
	var w: u64 = U64[4];		// u64.max
	w += U64[1];
	k = mixu(k, w);
	acci(k);

	if (i23.view(4194303) + i23.view(1) != -4194304) fail_assert(201);
	if (i23.view(-4194304) - i23.view(1) != 4194303) fail_assert(202);
	if (i23.view(-4194304) * i23.view(-1) != -4194304) fail_assert(203);
	if (u31.view(2147483647) + u31.view(1) != 0) fail_assert(204);
	if (u17.view(131071) * u17.view(131071) != 1) fail_assert(205);
	if (i33.view(4294967295L) + i33.view(1) != -4294967296L) fail_assert(206);
	if (i33.view(65536) * i33.view(65536) != -4294967296L) fail_assert(207);	// 2^32 mod 2^33
	if (u47.view(140737488355327L) * u47.view(140737488355327L) != 1) fail_assert(208);
	if (i63.view(4611686018427387903L) + i63.view(1) != -4611686018427387904L) fail_assert(209);
	if (-i63.view(-4611686018427387904L) != -4611686018427387904L) fail_assert(210);
	if (long.view(u64.max + u64.view(1)) != 0) fail_assert(211);
	if (long.view(u64.max * u64.max) != 1) fail_assert(212);
	if (u64.max / u64.view(9223372036854775808uL) != 1) fail_assert(213);
	if (long.view(u64.max % u64.view(9223372036854775808uL)) != 9223372036854775807L) fail_assert(214);
	if (-i64.min != i64.min) fail_assert(215);
	// mixing a wide value with an int literal promotes, so nothing wraps
	if (i23.view(4194303) + 1 != 4194304) fail_assert(216);
	// u31 promotes to i32, not to long, so this wraps at 32 bits, not at 31
	if (u31.view(2147483647) + 1 != -2147483648) fail_assert(217);
	if (u31.view(2147483647) + 1L != 2147483648L) fail_assert(218);
}

//======================================================================
// Section 3: comparisons and ordering
//======================================================================
def compare() {
	var h = 0;
	for (i < I33.length) for (j < I33.length) {
		var a = I33[i], b = I33[j];
		h = mixb(h, a == b);
		h = mixb(h, a != b);
		h = mixb(h, a < b);
		h = mixb(h, a <= b);
		h = mixb(h, a > b);
		h = mixb(h, a >= b);
	}
	for (i < U47.length) for (j < U47.length) {
		var a = U47[i], b = U47[j];
		h = mixb(h, a == b);
		h = mixb(h, a < b);
		h = mixb(h, a >= b);
	}
	for (i < U64.length) for (j < U64.length) {
		var a = U64[i], b = U64[j];
		h = mixb(h, a == b);
		h = mixb(h, a < b);
		h = mixb(h, a > b);
	}
	acci(h);

	// A signed and an unsigned width compare on their mathematical values;
	// both sides widen first, so the sign bit is not misread as magnitude.
	var g = 0;
	for (i < I33.length) for (j < U31.length) {
		g = mixb(g, I33[i] < U31[j]);
		g = mixb(g, I33[i] == U31[j]);
	}
	for (i < I23.length) for (j < U17.length) {
		g = mixb(g, I23[i] < U17[j]);
		g = mixb(g, I23[i] >= U17[j]);
	}
	acci(g);

	if (!(i23.view(-1) < u17.view(1))) fail_assert(301);
	if (i33.view(-1) == u31.view(2147483647)) fail_assert(302);
	if (!(u47.view(140737488355327L) > i33.view(4294967295L))) fail_assert(303);
	if (!(u64.view(9223372036854775808uL) > u64.view(9223372036854775807uL))) fail_assert(304);
	if (!(i63.view(-4611686018427387904L) < i63.view(4611686018427387903L))) fail_assert(305);
	if (i33.view(-4294967296L) >= i33.view(0)) fail_assert(306);
}

//======================================================================
// Section 4: shifts and sign extension at odd widths
//======================================================================
def shifts() {
	var h = 0;
	for (i < I23.length) for (s < SHIFTS.length) {
		var a = I23[i], k = SHIFTS[s];
		h = mixl(h, a << k);
		h = mixl(h, a >> k);
		h = mixl(h, a >>> k);
	}
	for (i < U31.length) for (s < SHIFTS.length) {
		var a = U31[i], k = SHIFTS[s];
		h = mixl(h, a << k);
		h = mixl(h, a >>> k);
	}
	acci(h);

	var g = 0;
	for (i < I33.length) for (s < SHIFTS.length) {
		var a = I33[i], k = SHIFTS[s];
		g = mixl(g, a << k);
		g = mixl(g, a >> k);
		g = mixl(g, a >>> k);
	}
	for (i < U47.length) for (s < SHIFTS.length) {
		g = mixl(g, U47[i] << SHIFTS[s]);
		g = mixl(g, U47[i] >>> SHIFTS[s]);
	}
	for (i < I63.length) for (s < SHIFTS.length) {
		var a = I63[i], k = SHIFTS[s];
		g = mixl(g, a << k);
		g = mixl(g, a >> k);
		g = mixl(g, a >>> k);
	}
	for (i < U64.length) for (s < SHIFTS.length) {
		var a = U64[i], k = SHIFTS[s];
		g = mixu(g, a << k);
		g = mixu(g, a >> k);
	}
	acci(g);

	// left shift drops bits off the top of the declared width
	if (i23.view(1) << 22 != -4194304) fail_assert(401);
	if (i23.view(1) << 23 != 0) fail_assert(402);
	if (i33.view(1) << 32 != -4294967296L) fail_assert(403);
	if (i63.view(1) << 62 != -4611686018427387904L) fail_assert(404);
	if (u31.view(1) << 30 != 1073741824) fail_assert(405);
	if (u47.view(1) << 46 != 70368744177664L) fail_assert(406);
	// arithmetic shift right replicates the sign bit of the width, not bit 63
	if (i23.view(-1) >> 1 != -1) fail_assert(407);
	if (i23.view(-4194304) >> 22 != -1) fail_assert(408);
	if (i33.view(-4294967296L) >> 32 != -1) fail_assert(409);
	if (i63.view(-4611686018427387904L) >> 62 != -1) fail_assert(410);
	// logical shift right fills with zeros from the top of the width
	if (i23.view(-1) >>> 1 != 4194303) fail_assert(411);
	if (i23.view(-1) >>> 22 != 1) fail_assert(412);
	if (i33.view(-1) >>> 1 != 4294967295L) fail_assert(413);
	if (u47.view(-1) >>> 46 != 1) fail_assert(414);
	if (i63.view(-1) >>> 1 != 4611686018427387903L) fail_assert(415);
	if (u31.view(-1) >>> 30 != 1) fail_assert(416);
	if (i17.view(-1) >>> 16 != 1) fail_assert(417);
	// shifting by at least the width yields zero, or the sign for >>
	if (i23.view(-1) >>> 23 != 0) fail_assert(418);
	if (i23.view(-1) >> 23 != -1) fail_assert(419);
	if (i33.view(-1) >>> 33 != 0) fail_assert(420);
	// a wide value keeps its sign when it is widened by promotion
	if (long.view(i23.view(-1)) != -1) fail_assert(421);
	if (int.view(i33.view(-1)) != -1) fail_assert(422);
	if (long.view(u47.view(-1)) != 140737488355327L) fail_assert(423);
}

//======================================================================
// Section 5: .view between wide widths
//======================================================================
def views() {
	var h = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		h = mixl(h, i17.view(v));
		h = mixl(h, u17.view(v));
		h = mixl(h, i23.view(v));
		h = mixl(h, u31.view(v));
		h = mixl(h, i33.view(v));
		h = mixl(h, u47.view(v));
		h = mixl(h, i63.view(v));
		h = mixu(h, u64.view(v));
	}
	acci(h);

	var g = 0;
	for (i < I23.length) {
		var a = I23[i];
		g = mixl(g, i33.view(a));	// widening a signed value sign-extends
		g = mixl(g, u33.view(a));	// into wider unsigned: wraps mod 2^33
		g = mixl(g, u23.view(a));	// same width, sign reinterpreted
		g = mixl(g, i17.view(a));	// narrowing keeps the low bits
		g = mixl(g, long.view(a));
		g = mixu(g, u64.view(a));
	}
	for (i < U47.length) {
		var a = U47[i];
		g = mixl(g, i63.view(a));	// unsigned widening zero-extends
		g = mixl(g, i47.view(a));
		g = mixl(g, i31.view(a));
		g = mixl(g, i23.view(a));
		g = mixu(g, u64.view(a));
	}
	for (i < U64.length) {
		var a = U64[i];
		g = mixl(g, long.view(a));
		g = mixl(g, i63.view(a));
		g = mixl(g, u47.view(a));
		g = mixl(g, i33.view(a));
	}
	acci(g);

	if (i33.view(i23.view(-1)) != -1) fail_assert(501);
	if (u33.view(i23.view(-1)) != 8589934591L) fail_assert(502);
	if (u23.view(i23.view(-1)) != 8388607) fail_assert(503);
	if (i23.view(i33.view(-1)) != -1) fail_assert(504);
	if (u23.view(i33.view(-1)) != 8388607) fail_assert(505);
	if (i31.view(u47.max) != -1) fail_assert(506);
	if (i33.view(u47.max) != -1) fail_assert(507);
	if (i47.view(u31.max) != 2147483647) fail_assert(508);
	if (u31.view(i33.min) != 0) fail_assert(509);		// -2^32 mod 2^31
	if (u63.view(-1L) != 9223372036854775807L) fail_assert(510);
	if (long.view(u64.view(i33.view(-1))) != -1) fail_assert(511);
	if (i63.view(u64.max) != -1) fail_assert(512);
	if (u47.view(u64.max) != 140737488355327L) fail_assert(513);
	if (i17.view(i23.view(-4194304)) != 0) fail_assert(514);
	// a round trip through a wider type is the identity
	if (i23.view(i33.view(i23.view(-4194304))) != -4194304) fail_assert(515);
	if (u31.view(long.view(u31.view(2147483647))) != 2147483647) fail_assert(516);
}

//======================================================================
// Section 6: .! checked casts and .? queries
//======================================================================
def casts() {
	var h = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		h = mixb(h, i17.?(v));
		h = mixb(h, u17.?(v));
		h = mixb(h, i23.?(v));
		h = mixb(h, u31.?(v));
		h = mixb(h, i33.?(v));
		h = mixb(h, u47.?(v));
		h = mixb(h, i63.?(v));
		h = mixb(h, u63.?(v));
		h = mixb(h, u64.?(v));
		// only perform the checked cast where the query says it is safe
		if (i23.?(v)) h = mixl(h, i23.!(v));
		if (u31.?(v)) h = mixl(h, u31.!(v));
		if (i33.?(v)) h = mixl(h, i33.!(v));
		if (u47.?(v)) h = mixl(h, u47.!(v));
		if (i63.?(v)) h = mixl(h, i63.!(v));
		if (u64.?(v)) h = mixu(h, u64.!(v));
	}
	acci(h);

	var g = 0;
	for (i < U64.length) {
		var a = U64[i];
		g = mixb(g, long.?(a));
		g = mixb(g, i63.?(a));
		g = mixb(g, u47.?(a));
		g = mixb(g, i33.?(a));
		if (long.?(a)) g = mixl(g, long.!(a));
	}
	for (i < I33.length) {
		var a = I33[i];
		g = mixb(g, i23.?(a));
		g = mixb(g, u31.?(a));
		g = mixb(g, u33.?(a));
		g = mixl(g, long.!(a));		// widening a signed value always fits
		g = mixl(g, i63.!(a));
	}
	acci(g);

	if (!i23.?(4194303)) fail_assert(601);
	if (i23.?(4194304)) fail_assert(602);
	if (i23.?(-4194305)) fail_assert(603);
	if (!u31.?(2147483647)) fail_assert(604);
	if (u31.?(2147483648L)) fail_assert(605);
	if (u31.?(-1)) fail_assert(606);
	if (!i33.?(4294967295L)) fail_assert(607);
	if (i33.?(4294967296L)) fail_assert(608);
	if (i33.?(u47.max)) fail_assert(609);
	if (!u47.?(140737488355327L)) fail_assert(610);
	if (u47.?(140737488355328L)) fail_assert(611);
	if (i63.?(-9223372036854775808L)) fail_assert(612);
	if (!i63.?(4611686018427387903L)) fail_assert(613);
	if (u63.?(-1L)) fail_assert(614);
	if (u64.?(-1L)) fail_assert(615);
	if (long.?(u64.max)) fail_assert(616);
	if (!long.?(u64.view(9223372036854775807uL))) fail_assert(617);
	if (i23.!(4194303) != 4194303) fail_assert(618);
	if (i33.!(4294967295L) != 4294967295L) fail_assert(619);
	if (long.!(i33.view(-1)) != -1) fail_assert(620);
	// a query is exactly "the value survives a round trip through .view"
	if (i23.?(5000000L) != (i23.view(5000000L) == 5000000L)) fail_assert(621);
	if (u47.?(-5L) != (u47.view(-5L) == -5L)) fail_assert(622);
}

//======================================================================
// Section 7: wide ints in arrays and ranges
//======================================================================
def arrays() {
	var a = Array<i23>.new(64);
	for (i < a.length) a[i] = i23.view(i * 131071 - 4194304);
	var h = 0;
	for (i < a.length) h = mixl(h, a[i]);
	acci(h);

	var r: Range<i23> = a;
	var mid = r[16 ... 48];
	var tail = r[48 ...];
	var g = mix(0, mid.length);
	for (i < mid.length) g = mixl(g, mid[i]);
	for (i < tail.length) g = mixl(g, tail[i]);
	acci(g);

	// range writes alias the backing array, and each store re-normalizes
	for (i < mid.length) mid[i] = i23.view(mid[i] * 3);
	var k = 0;
	for (i < a.length) k = mixl(k, a[i]);
	acci(k);
	if (mid.length != 32) fail_assert(701);
	if (tail.length != 16) fail_assert(702);
	if (a[20] != i23.view(i23.view(20 * 131071 - 4194304) * 3)) fail_assert(703);

	// each array stores its elements at its own declared width
	var p = Array<u47>.new(32);
	var q = Array<i63>.new(32);
	var s = Array<u64>.new(32);
	for (i < 32) {
		p[i] = u47.view(-1L - i);
		q[i] = i63.view(i63.min + i);
		s[i] = u64.view(-1L - i);
	}
	var m = 0;
	for (i < 32) {
		m = mixl(m, p[i]);
		m = mixl(m, q[i]);
		m = mixu(m, s[i]);
	}
	acci(m);
	if (p[0] != 140737488355327L) fail_assert(704);
	if (q[0] != -4611686018427387904L) fail_assert(705);
	if (long.view(s[0]) != -1) fail_assert(706);
}

//======================================================================
// Section 8: wide ints in tuples
//======================================================================
def swapw(t: (i23, u47)) -> (u47, i23) {
	return (u47.view(t.0), i23.view(t.1));
}
def bump3(a: i23, b: u31, c: i63) -> (i23, u31, i63) {
	return (i23.view(a + 1), u31.view(b + 1), i63.view(c + 1));
}
def tuples() {
	var h = 0;
	for (i < I23.length) {
		var t = (I23[i], U47[i % U47.length]);
		var s = swapw(t);
		h = mixl(h, t.0);
		h = mixl(h, t.1);
		h = mixl(h, s.0);
		h = mixl(h, s.1);
		h = mixb(h, t.0 == s.1);
	}
	acci(h);

	var ts = Array<(i23, u31, i63)>.new(24);
	for (i < ts.length) ts[i] = (i23.view(i * 1000000), u31.view(i * 300000000), i63.view(i * 1000000000000000L));
	var g = 0;
	for (i < ts.length) {
		var t = ts[i];
		g = mixl(g, t.0);
		g = mixl(g, t.1);
		g = mixl(g, t.2);
		var u = bump3(t.0, t.1, t.2);
		g = mixl(g, u.0);
		g = mixl(g, u.1);
		g = mixl(g, u.2);
		g = mixb(g, t == u);
	}
	acci(g);

	var n = ((i23.view(-1), u47.view(-1L)), (i33.view(-1), (u64.view(-1L), i63.view(-1L))));
	acci(mixl(mixu(mixl(mixl(mixl(0, n.0.0), n.0.1), n.1.0), n.1.1.0), n.1.1.1));

	if (n.0.1 != 140737488355327L) fail_assert(801);
	if (bump3(i23.view(4194303), u31.view(2147483647), i63.view(4611686018427387903L)).0 != -4194304) fail_assert(802);
	if (bump3(i23.view(4194303), u31.view(2147483647), i63.view(4611686018427387903L)).1 != 0) fail_assert(803);
	if (bump3(i23.view(4194303), u31.view(2147483647), i63.view(4611686018427387903L)).2 != -4611686018427387904L) fail_assert(804);
	if (swapw((i23.view(-1), u47.view(-1L))).0 != 140737488355327L) fail_assert(805);
	if (swapw((i23.view(-1), u47.view(-1L))).1 != -1) fail_assert(807);
	if (!((i23.view(1), u47.view(2)) == (i23.view(1), u47.view(2)))) fail_assert(806);
}

//======================================================================
// Section 9: wide ints in globals, components and class fields
//======================================================================
var g23: i23;
var g47: u47;
var g64: u64;

component Acc {
	var v: i33 = 1;
	def seed: u31 = 2147483647;
	var hist: Array<i63> = Array<i63>.new(8);
	var n: int;

	def push(x: i33) -> i33 {
		v = i33.view(v * 31 + x);
		hist[n % hist.length] = i63.view(v);
		n++;
		return v;
	}
}
class Wide {
	var a: i23;
	var b: u47;
	def tag: i17;
	new(a, b, tag) { }
	def total() -> long { return long.view(a) + b; }
	def bump() -> long { a = i23.view(a + 1); b = u47.view(b + 1); return total(); }
}
class Wider extends Wide {
	var c: i63;
	new(a: i23, b: u47, tag: i17, c) super(a, b, tag) { }
	def total() -> long { return long.view(a) + b + c; }
}
def globals() {
	// Reset every mutable global; the harness may run several inputs in one
	// process, so a section must never depend on what ran before it.
	g23 = 0;
	g47 = 0;
	g64 = 0;
	Acc.v = 1;
	Acc.n = 0;
	Acc.hist = Array<i63>.new(8);

	var h = 0;
	for (i < SEEDS.length) {
		g23 = i23.view(SEEDS[i]);
		g47 = u47.view(SEEDS[i]);
		g64 = u64.view(SEEDS[i]);
		h = mixl(h, g23);
		h = mixl(h, g47);
		h = mixu(h, g64);
	}
	acci(h);

	var g = mixl(0, Acc.seed);
	for (i < 40) g = mixl(g, Acc.push(i33.view(i * 987654321L)));
	for (i < Acc.hist.length) g = mixl(g, Acc.hist[i]);
	g = mix(g, Acc.n);
	acci(g);

	var objs = Array<Wide>.new(2 * I23.length);
	for (i < I23.length) {
		objs[2 * i + 0] = Wide.new(I23[i], U47[i % U47.length], i17.view(i));
		objs[2 * i + 1] = Wider.new(I23[i], U47[i % U47.length], i17.view(i), i63.view(i * 1000000000000L));
	}
	var k = 0;
	for (i < objs.length) {
		var o = objs[i];
		k = mixl(k, o.total());		// virtual dispatch over 2 implementations
		k = mixl(k, o.a);
		k = mixl(k, o.b);
		k = mixl(k, o.tag);
		k = mixb(k, Wider.?(o));
	}
	for (i < objs.length) objs[i].bump();
	for (i < objs.length) k = mixl(k, objs[i].total());
	acci(k);

	if (Acc.seed != 2147483647) fail_assert(901);
	if (Acc.n != 40) fail_assert(902);
	g23 = i23.view(4194304);
	if (g23 != -4194304) fail_assert(903);
	g47 = u47.view(-1L);
	if (g47 != 140737488355327L) fail_assert(904);
	var c = Wide.new(i23.view(4194303), u47.view(140737488355327L), i17.view(-65536));
	if (c.total() != 140737492549630L) fail_assert(905);	// 4194303 + 140737488355327
	if (c.bump() != -4194304) fail_assert(906);		// -4194304 + 0
	if (c.tag != -65536) fail_assert(907);
	var d = Wider.new(i23.view(-1), u47.view(1), i17.view(0), i63.view(-4611686018427387904L));
	if (d.total() != -4611686018427387904L) fail_assert(908);
	if (!Wide.?(d)) fail_assert(909);
	g23 = 0;
	g47 = 0;
	g64 = 0;
}

//======================================================================
// Section 10: wide ints in variants
//======================================================================
type WVal {
	case Small(v: i23);
	case Med(v: u47);
	case Pair(a: i33, b: u31);
	case None;
}
type WPacked #unboxed {
	case One(v: i63);
	case Two(a: u64, b: i17);
	case Zero;
}
def evalW(w: WVal) -> long {
	match (w) {
		Small(v) => return v;
		Med(v) => return v;
		Pair(a, b) => return a * 3 + b;
		None => return -1;
	}
}
def evalP(p: WPacked) -> long {
	match (p) {
		One(v) => return v;
		Two(a, b) => return long.view(a) - b;
		Zero => return 0;
	}
}
def variants() {
	var h = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		var s: WVal = WVal.Small(i23.view(v));
		var m: WVal = WVal.Med(u47.view(v));
		var p: WVal = WVal.Pair(i33.view(v), u31.view(v));
		var n: WVal = WVal.None;
		h = mixl(h, evalW(s));
		h = mixl(h, evalW(m));
		h = mixl(h, evalW(p));
		h = mixl(h, evalW(n));
		h = mix(h, s.tag);
		h = mix(h, p.tag);
		h = mixb(h, s == m);
		h = mixb(h, WVal.Pair.?(p));
		h = mixb(h, WVal.Pair.?(s));

		var q1: WPacked = WPacked.One(i63.view(v));
		var q2: WPacked = WPacked.Two(u64.view(v), i17.view(v));
		var q3: WPacked = WPacked.Zero;
		h = mixl(h, evalP(q1));
		h = mixl(h, evalP(q2));
		h = mixl(h, evalP(q3));
		h = mixb(h, q1 == q2);
		h = mixb(h, q1 == WPacked.One(i63.view(v)));
		h = mix(h, q2.tag);
	}
	acci(h);

	var arr = Array<WPacked>.new(24);
	var barr = Array<WVal>.new(24);
	for (i < arr.length) {
		arr[i] = WPacked.Two(u64.view(-1L - i), i17.view(i * 20000));
		barr[i] = WVal.Pair(i33.view(i * 1000000000L), u31.view(i * 200000000));
	}
	var g = 0;
	for (i < arr.length) {
		g = mixl(g, evalP(arr[i]));
		g = mixl(g, evalW(barr[i]));
	}
	acci(g);

	if (evalW(WVal.Small(i23.view(4194304))) != -4194304) fail_assert(1001);
	if (evalW(WVal.Med(u47.view(-1L))) != 140737488355327L) fail_assert(1002);
	if (evalW(WVal.None) != -1) fail_assert(1003);
	if (evalP(WPacked.One(i63.view(-1L))) != -1) fail_assert(1004);
	if (evalP(WPacked.Two(u64.view(-1L), i17.view(-1))) != 0) fail_assert(1005);
	if (WVal.None.tag != 3) fail_assert(1006);
	if (WPacked.One(i63.view(5)) == WPacked.One(i63.view(6))) fail_assert(1007);
	// a payload is stored at its declared width, so construction truncates
	if (WVal.Small(i23.view(4194304)) != WVal.Small(i23.view(-4194304))) fail_assert(1008);
}

//======================================================================
// Section 11: wide ints through functions and operator references
//======================================================================
def add23(a: i23, b: i23) -> i23 { return a + b; }
def apply23(f: (i23, i23) -> i23, a: i23, b: i23) -> i23 { return f(a, b); }
def fold23(f: (i23, i23) -> i23, init: i23, a: Array<i23>) -> i23 {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def makeAdder(a: i33) -> i33 -> i33 {
	return fun (b: i33) => i33.view(a + b);
}
def funcs() {
	def OPS: Array<(i23, i23) -> i23> = [i23.+, i23.-, i23.*, i23.&, i23.^, add23];
	for (k < OPS.length) {
		var h = 0;
		for (i < I23.length) h = mixl(h, apply23(OPS[k], I23[i], i23.view(1234567)));
		h = mixl(h, fold23(OPS[k], i23.view(1), I23));
		acci(h);
	}
	var inc = add23(i23.view(1), _);	// partial application
	var dec = add23(_, i23.view(-1));
	var g = 0;
	for (i < I23.length) {
		g = mixl(g, inc(I23[i]));
		g = mixl(g, dec(I23[i]));
	}
	var adders = Array<i33 -> i33>.new(8);
	for (i < adders.length) adders[i] = makeAdder(i33.view(i * 1000000000L));
	for (i < adders.length) for (j < I33.length) g = mixl(g, adders[i](I33[j]));
	acci(g);

	// views, queries and casts are first-class function values
	var to23: long -> i23 = i23.view<long>;
	var q47: long -> bool = u47.?<long>;
	var wide: i23 -> i63 = i63.!<i23>;
	var k = 0;
	for (i < SEEDS.length) {
		k = mixl(k, to23(SEEDS[i]));
		k = mixb(k, q47(SEEDS[i]));
	}
	for (i < I23.length) k = mixl(k, wide(I23[i]));
	acci(k);

	if (apply23(i23.+, i23.view(4194303), i23.view(1)) != -4194304) fail_assert(1101);
	if (apply23(i23.*, i23.view(2048), i23.view(2048)) != -4194304) fail_assert(1102);
	if (add23(i23.view(1), _)(i23.view(4194303)) != -4194304) fail_assert(1103);
	if (makeAdder(i33.view(4294967295L))(i33.view(1)) != -4294967296L) fail_assert(1104);
	if (i23.view<long>(4194304L) != -4194304) fail_assert(1105);
	if (i63.!<i23>(i23.view(-1)) != -1) fail_assert(1106);
}

//======================================================================
// Section 12: allocation churn with live wide-int data
//======================================================================
class WLink(v: i23, w: u47, x: u64, next: WLink) { }
def churn() {
	var head: WLink;
	var live = Array<WLink>.new(16);
	for (i < 2000) {
		head = WLink.new(i23.view(i * 65537), u47.view(i * 1000000007L), u64.view(-1L - i), head);
		if ((i % 97) == 0) live[(i / 97) % live.length] = head;
		if ((i % 13) == 0) head = null;		// drop most of the chain
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mixl(h, p.v);
			h = mixl(h, p.w);
			h = mixu(h, p.x);
			p = p.next;
			n++;
			if (n > 100000) { acci(h); return; }
		}
	}
	h = mix(h, n);
	var p = head;
	while (p != null) { h = mixl(h, p.v); p = p.next; }
	acci(h);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) limits();
	if (a == 0 || a == 2) arith();
	if (a == 0 || a == 3) compare();
	if (a == 0 || a == 4) shifts();
	if (a == 0 || a == 5) views();
	if (a == 0 || a == 6) casts();
	if (a == 0 || a == 7) arrays();
	if (a == 0 || a == 8) tuples();
	if (a == 0 || a == 9) globals();
	if (a == 0 || a == 10) variants();
	if (a == 0 || a == 11) funcs();
	if (a == 0 || a == 12) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
