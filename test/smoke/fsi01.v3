//@execute 0=-2142754901; 1=-2093223544; 2=1027597175; 3=1960344600; 4=2025711941; 5=-1496309575; 6=-731003482; 7=-134045037; 8=980206005; 9=583347911; 10=1331342810; 11=2123202976; 12=-1089069200; 13=911317596
//@heap-size=200000
// Smoke test: narrow fixed-size integers, i1..i16 and u1..u16.
// Each section exercises a group of operations at the narrow widths and mixes
// every observed value into a running CRC that main() returns, so nothing can
// be deleted as dead code. Interleaved are assert()s whose operands are
// compile-time constants: the optimizer is expected to fold them away entirely,
// so a folding bug shows up as a set failure flag rather than a wrong CRC.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data. Sections read their operands out of these arrays rather than
// out of literals, so no section can be constant-folded away wholesale.
//======================================================================
def I3: Array<i3>	= [-4, -3, -1, 0, 1, 3];
def I4: Array<i4>	= [-8, -5, -1, 0, 1, 5, 7];
def I8: Array<i8>	= [-128, -127, -100, -1, 0, 1, 100, 126, 127];
def I12: Array<i12>	= [-2048, -2047, -1, 0, 1, 1000, 2046, 2047];
def I16: Array<i16>	= [-32768, -32767, -1, 0, 1, 255, 32766, 32767];
def U3: Array<u3>	= [0, 1, 3, 6, 7];
def U4: Array<u4>	= [0, 1, 7, 8, 15];
def U8: Array<u8>	= [0, 1, 127, 128, 200, 254, 255];
def U12: Array<u12>	= [0, 1, 2047, 2048, 4094, 4095];
def U16: Array<u16>	= [0, 1, 255, 32767, 32768, 65534, 65535];
def SHIFTS: Array<byte>	= [0, 1, 2, 3, 4, 7, 8, 15, 16, 17, 31];
def SEEDS: Array<int>	= [0, 1, -1, 7, -8, 127, -128, 255, -256, 32767, -32768, 65535, 123456, -123456];

//======================================================================
// Section 1: limits of every narrow width
//======================================================================
def limits() {
	def SMIN: Array<int> = [
		i1.min, i2.min, i3.min, i4.min, i5.min, i6.min, i7.min, i8.min,
		i9.min, i10.min, i11.min, i12.min, i13.min, i14.min, i15.min, i16.min
	];
	def SMAX: Array<int> = [
		i1.max, i2.max, i3.max, i4.max, i5.max, i6.max, i7.max, i8.max,
		i9.max, i10.max, i11.max, i12.max, i13.max, i14.max, i15.max, i16.max
	];
	def UMAX: Array<int> = [
		u1.max, u2.max, u3.max, u4.max, u5.max, u6.max, u7.max, u8.max,
		u9.max, u10.max, u11.max, u12.max, u13.max, u14.max, u15.max, u16.max
	];
	var h = 0;
	for (i < SMIN.length) {
		h = mix(h, SMIN[i]);
		h = mix(h, SMAX[i]);
		h = mix(h, UMAX[i]);
		h = mix(h, SMAX[i] - SMIN[i]);
		h = mixb(h, SMAX[i] == -1 - SMIN[i]);		// two's complement identity
		h = mixb(h, UMAX[i] == 2 * SMAX[i] + 1);
	}
	acci(h);

	if (i1.min != -1) fail_assert(101);
	if (i1.max != 0) fail_assert(102);		// i1 holds only -1 and 0
	if (u1.max != 1) fail_assert(103);
	if (i3.max != 3) fail_assert(104);
	if (i8.min != -128) fail_assert(105);
	if (u8.max != 255) fail_assert(106);
	if (i9.min != -256) fail_assert(107);
	if (u9.max != 511) fail_assert(108);
	if (i12.min != -2048) fail_assert(109);
	if (i16.max != 32767) fail_assert(110);
	if (u16.max != 65535) fail_assert(111);
	if (u16.min != 0) fail_assert(112);
}

//======================================================================
// Section 2: arithmetic wraps at the declared width
//======================================================================
def arith() {
	var h = 0;
	for (i < I3.length) for (j < I3.length) {
		var a = I3[i], b = I3[j];
		h = mix(h, a + b);
		h = mix(h, a * b);
		h = mix(h, -a);
		if (b != 0) h = mix(h, a / b);
	}
	for (i < I8.length) for (j < I8.length) {
		var a = I8[i], b = I8[j];
		h = mix(h, a + b);
		h = mix(h, a - b);
		h = mix(h, a * b);
		// i8.min / i8(-1) is deliberately skipped: division overflow at a
		// fixed-size width is a separate question from int.min / -1.
		if (b != 0 && !(a == -128 && b == -1)) { h = mix(h, a / b); h = mix(h, a % b); }
	}
	for (i < I16.length) for (j < I16.length) {
		var a = I16[i], b = I16[j];
		h = mix(h, a + b);
		h = mix(h, a - b);
		h = mix(h, a * b);
	}
	acci(h);

	var g = 0;
	for (i < U3.length) for (j < U3.length) {
		var a = U3[i], b = U3[j];
		g = mix(g, a + b);
		g = mix(g, a - b);
		g = mix(g, a * b);
		if (b != 0) { g = mix(g, a / b); g = mix(g, a % b); }
	}
	for (i < U8.length) for (j < U8.length) {
		var a = U8[i], b = U8[j];
		g = mix(g, a + b);
		g = mix(g, a - b);
		g = mix(g, a * b);
		if (b != 0) { g = mix(g, a / b); g = mix(g, a % b); }
	}
	for (i < U16.length) for (j < U16.length) {
		var a = U16[i], b = U16[j];
		g = mix(g, a + b);
		g = mix(g, a - b);
		g = mix(g, a * b);
	}
	acci(g);

	// compound assignment applies the operator at the declared width
	var k = 0;
	var x: i8 = I8[8];		// 127
	x++;
	k = mix(k, x);
	x--;
	k = mix(k, x);
	var y: u4 = U4[4];		// 15
	y += U4[1];
	k = mix(k, y);
	y -= U4[1];
	k = mix(k, y);
	var z: i12 = I12[0];		// -2048
	z *= I12[2];			// times -1
	k = mix(k, z);
	acci(k);

	if (i8.view(127) + i8.view(1) != -128) fail_assert(201);
	if (i8.view(-128) - i8.view(1) != 127) fail_assert(202);
	if (i8.view(-128) * i8.view(-1) != -128) fail_assert(203);
	if (u8.view(255) + u8.view(1) != 0) fail_assert(204);
	if (u8.view(0) - u8.view(1) != 255) fail_assert(205);
	if (i3.view(3) + i3.view(1) != -4) fail_assert(206);
	if (i16.view(32767) + i16.view(1) != -32768) fail_assert(207);
	if (u4.view(15) * u4.view(15) != 1) fail_assert(208);		// 225 mod 16
	if (i5.view(-16) * i5.view(2) != 0) fail_assert(209);		// -32 mod 32
	if (u12.view(4095) + u12.view(4095) != 4094) fail_assert(210);
	if (i1.view(-1) + i1.view(-1) != 0) fail_assert(211);		// -2 mod 2
	if (i2.view(-2) * i2.view(-1) != -2) fail_assert(212);		// 2 mod 4
	if (-i8.view(-128) != -128) fail_assert(213);			// negation wraps
	if (i8.view(-7) / i8.view(2) != -3) fail_assert(214);		// truncates to zero
	if (i8.view(-7) % i8.view(2) != -1) fail_assert(215);
	if (u8.view(200) / u8.view(3) != 66) fail_assert(216);
	// mixing a narrow value with an int literal promotes, so nothing wraps
	if (i8.view(127) + 1 != 128) fail_assert(217);
	if (u8.view(255) * 2 != 510) fail_assert(218);
}

//======================================================================
// Section 3: comparisons and ordering
//======================================================================
def compare() {
	var h = 0;
	for (i < I8.length) for (j < I8.length) {
		var a = I8[i], b = I8[j];
		h = mixb(h, a == b);
		h = mixb(h, a != b);
		h = mixb(h, a < b);
		h = mixb(h, a <= b);
		h = mixb(h, a > b);
		h = mixb(h, a >= b);
	}
	for (i < U8.length) for (j < U8.length) {
		var a = U8[i], b = U8[j];
		h = mixb(h, a == b);
		h = mixb(h, a < b);
		h = mixb(h, a >= b);
	}
	acci(h);

	// A signed and an unsigned narrow type compare on their mathematical
	// values, not on their bits: both sides widen first.
	var g = 0;
	for (i < I16.length) for (j < U16.length) {
		g = mixb(g, I16[i] < U16[j]);
		g = mixb(g, I16[i] == U16[j]);
	}
	for (i < I4.length) for (j < U4.length) {
		g = mixb(g, I4[i] < U4[j]);
		g = mixb(g, I4[i] > U4[j]);
	}
	acci(g);

	if (!(i8.view(-1) < u8.view(1))) fail_assert(301);	// -1 < 1, not 255 < 1
	if (i8.view(-1) == u8.view(255)) fail_assert(302);	// different values
	if (!(u8.view(255) > u8.view(128))) fail_assert(303);
	if (!(u16.view(65535) > i16.view(32767))) fail_assert(304);
	if (!(i1.view(-1) < i1.view(0))) fail_assert(305);
	if (i4.view(-8) >= i4.view(7)) fail_assert(306);
}

//======================================================================
// Section 4: bitwise operations and shifts
//======================================================================
def bits() {
	var h = 0;
	for (i < I8.length) for (j < I8.length) {
		var a = I8[i], b = I8[j];
		h = mix(h, a & b);
		h = mix(h, a | b);
		h = mix(h, a ^ b);
	}
	for (i < U16.length) for (j < U16.length) {
		var a = U16[i], b = U16[j];
		h = mix(h, a & b);
		h = mix(h, a | b);
		h = mix(h, a ^ b);
	}
	acci(h);

	var g = 0;
	for (i < I8.length) for (s < SHIFTS.length) {
		var a = I8[i], k = SHIFTS[s];
		g = mix(g, a << k);
		g = mix(g, a >> k);
		g = mix(g, a >>> k);
	}
	for (i < U8.length) for (s < SHIFTS.length) {
		var a = U8[i], k = SHIFTS[s];
		g = mix(g, a << k);
		g = mix(g, a >>> k);
	}
	for (i < I16.length) for (s < SHIFTS.length) {
		g = mix(g, I16[i] << SHIFTS[s]);
		g = mix(g, I16[i] >>> SHIFTS[s]);
	}
	for (i < I4.length) for (s < SHIFTS.length) g = mix(g, I4[i] >> SHIFTS[s]);
	acci(g);

	if ((i8.view(-1) & i8.view(15)) != 15) fail_assert(401);
	if ((i8.view(-16) | i8.view(15)) != -1) fail_assert(402);
	if ((u8.view(255) ^ u8.view(15)) != 240) fail_assert(403);
	// shift left drops bits off the top of the width
	if (i8.view(1) << 7 != -128) fail_assert(404);
	if (i8.view(1) << 8 != 0) fail_assert(405);
	if (u16.view(65535) << 8 != 65280) fail_assert(406);
	if (i4.view(1) << 3 != -8) fail_assert(407);
	// arithmetic shift right replicates the sign bit of the width
	if (i4.view(-8) >> 2 != -2) fail_assert(408);
	if (i16.view(-32768) >> 15 != -1) fail_assert(409);
	if (i8.view(-1) >> 8 != -1) fail_assert(410);
	// logical shift right fills with zeros from the top of the width
	if (i8.view(-1) >>> 1 != 127) fail_assert(411);
	if (i4.view(-8) >>> 2 != 2) fail_assert(412);
	if (i16.view(-1) >>> 8 != 255) fail_assert(413);
	if (i5.view(-16) >>> 1 != 8) fail_assert(414);
	if (i8.view(-1) >>> 8 != 0) fail_assert(415);
	if (u16.view(65535) >>> 16 != 0) fail_assert(416);
}

//======================================================================
// Section 5: .view between narrow widths
//======================================================================
def views() {
	var h = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		h = mix(h, i1.view(v));
		h = mix(h, u1.view(v));
		h = mix(h, i3.view(v));
		h = mix(h, u3.view(v));
		h = mix(h, i8.view(v));
		h = mix(h, u8.view(v));
		h = mix(h, i12.view(v));
		h = mix(h, u12.view(v));
		h = mix(h, i16.view(v));
		h = mix(h, u16.view(v));
	}
	acci(h);

	var g = 0;
	for (i < I8.length) {
		var a = I8[i];
		g = mix(g, u8.view(a));		// same width, sign reinterpreted
		g = mix(g, i16.view(a));	// widening a signed value sign-extends
		g = mix(g, u16.view(a));	// into wider unsigned: wraps mod 2^16
		g = mix(g, i4.view(a));
		g = mix(g, u4.view(a));
		g = mix(g, int.view(a));
		g = mixl(g, long.view(a));
	}
	for (i < U8.length) {
		var a = U8[i];
		g = mix(g, i8.view(a));
		g = mix(g, i16.view(a));	// widening an unsigned value zero-extends
		g = mix(g, u16.view(a));
		g = mix(g, u1.view(a));
	}
	acci(g);

	if (u8.view(i8.view(-1)) != 255) fail_assert(501);
	if (i8.view(u8.view(255)) != -1) fail_assert(502);
	if (i8.view(u8.view(128)) != -128) fail_assert(503);
	if (i16.view(i8.view(-128)) != -128) fail_assert(504);
	if (u16.view(i8.view(-1)) != 65535) fail_assert(505);
	if (u16.view(i8.view(-128)) != 65408) fail_assert(506);
	if (i16.view(u8.view(255)) != 255) fail_assert(507);
	if (i4.view(i8.view(8)) != -8) fail_assert(508);
	if (u4.view(i8.view(-1)) != 15) fail_assert(509);
	if (i8.view(i16.view(-32768)) != 0) fail_assert(510);
	if (i1.view(u8.view(1)) != -1) fail_assert(511);
	if (u1.view(i8.view(-1)) != 1) fail_assert(512);
	if (u3.view(255) != 7) fail_assert(513);
	// a bool can be viewed as an integer of any width but i1
	if (u1.view(true) != 1) fail_assert(514);
	if (i8.view(true) != 1) fail_assert(515);
	// a round trip through a wider type is the identity
	if (i8.view(i16.view(i8.view(-100))) != -100) fail_assert(516);
	if (u8.view(int.view(u8.view(200))) != 200) fail_assert(517);
}

//======================================================================
// Section 6: .! checked casts and .? queries
//======================================================================
def casts() {
	var h = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		h = mixb(h, i1.?(v));
		h = mixb(h, u1.?(v));
		h = mixb(h, i4.?(v));
		h = mixb(h, u4.?(v));
		h = mixb(h, i8.?(v));
		h = mixb(h, u8.?(v));
		h = mixb(h, i12.?(v));
		h = mixb(h, u12.?(v));
		h = mixb(h, i16.?(v));
		h = mixb(h, u16.?(v));
		// only perform the checked cast where the query says it is safe
		if (i8.?(v)) h = mix(h, i8.!(v));
		if (u8.?(v)) h = mix(h, u8.!(v));
		if (i16.?(v)) h = mix(h, i16.!(v));
		if (u16.?(v)) h = mix(h, u16.!(v));
	}
	acci(h);

	var g = 0;
	for (i < I8.length) {
		var a = I8[i];
		g = mixb(g, u8.?(a));
		g = mixb(g, i4.?(a));
		g = mix(g, i16.!(a));		// widening a signed value always fits
		g = mixl(g, long.!(a));
	}
	for (i < U8.length) {
		var a = U8[i];
		g = mixb(g, i8.?(a));
		g = mixb(g, u4.?(a));
		g = mix(g, i16.!(a));		// u8 always fits in i16
		g = mix(g, u16.!(a));
	}
	acci(g);

	if (!i8.?(127)) fail_assert(601);
	if (!i8.?(-128)) fail_assert(602);
	if (!i9.?(255)) fail_assert(603);		// 255 fits in -256..255
	if (i9.?(256)) fail_assert(620);
	if (i8.?(128)) fail_assert(604);
	if (i8.?(-129)) fail_assert(605);
	if (u8.?(-1)) fail_assert(606);
	if (u8.?(i8.view(-1))) fail_assert(607);
	if (i8.?(u8.view(128))) fail_assert(608);
	if (u4.?(i8.view(-1))) fail_assert(609);
	if (i1.?(1)) fail_assert(610);			// i1 holds only -1 and 0
	if (!i1.?(-1)) fail_assert(611);
	if (u1.?(2)) fail_assert(612);
	if (i16.?(32768)) fail_assert(613);
	if (u16.?(65536)) fail_assert(614);
	if (i8.!(-128) != -128) fail_assert(615);
	if (u8.!(255) != 255) fail_assert(616);
	if (i4.!(i8.view(-8)) != -8) fail_assert(617);
	// a query is exactly "the value survives a round trip through .view"
	if (i8.?(300) != (i8.view(300) == 300)) fail_assert(618);
	if (u8.?(-5) != (u8.view(-5) == -5)) fail_assert(619);
}

//======================================================================
// Section 7: narrow ints in arrays and ranges
//======================================================================
def arrays() {
	var a = Array<i8>.new(80);
	for (i < a.length) a[i] = i8.view(i * 7 - 100);
	var h = 0;
	for (i < a.length) h = mix(h, a[i]);
	acci(h);

	var r: Range<i8> = a;
	var mid = r[16 ... 48];
	var tail = r[48 ...];
	var g = mix(0, mid.length);
	for (i < mid.length) g = mix(g, mid[i]);
	for (i < tail.length) g = mix(g, tail[i]);
	acci(g);

	// range writes alias the backing array, and each store truncates to i8
	for (i < mid.length) mid[i] = i8.view(mid[i] * 3);
	var k = 0;
	for (i < a.length) k = mix(k, a[i]);
	acci(k);
	if (mid.length != 32) fail_assert(701);
	if (tail.length != 32) fail_assert(702);
	if (a[20] != i8.view(i8.view(20 * 7 - 100) * 3)) fail_assert(703);

	// each array stores elements at its own declared width
	var u = Array<u4>.new(32);
	var s = Array<i12>.new(32);
	var t = Array<u1>.new(32);
	for (i < 32) {
		u[i] = u4.view(i);
		s[i] = i12.view(i * 137 - 2048);
		t[i] = u1.view(i);
	}
	var m = 0;
	for (i < 32) {
		m = mix(m, u[i]);
		m = mix(m, s[i]);
		m = mix(m, t[i]);
	}
	acci(m);
	if (u[17] != 1) fail_assert(704);		// 17 mod 16
	if (t[3] != 1) fail_assert(705);
	if (t[4] != 0) fail_assert(706);

	// two dimensional, with a narrow element type
	var mm = Array<Array<i16>>.new(8);
	for (i < mm.length) {
		mm[i] = Array<i16>.new(8);
		for (j < 8) mm[i][j] = i16.view((i + 1) * (j + 1) * 1000);
	}
	var q = 0;
	for (i < mm.length) for (j < 8) q = mix(q, mm[i][j]);
	acci(q);
	if (mm[7][7] != -1536) fail_assert(707);	// 64000 mod 65536 - 65536
}

//======================================================================
// Section 8: narrow ints in tuples
//======================================================================
def swap8(t: (i8, u8)) -> (u8, i8) {
	return (u8.view(t.0), i8.view(t.1));
}
def spread(a: i4, b: u4, c: i16) -> (i4, u4, i16) {
	return (i4.view(a + 1), u4.view(b + 1), i16.view(c + 1));
}
def tuples() {
	var h = 0;
	for (i < I8.length) {
		var t = (I8[i], U8[i % U8.length]);
		var s = swap8(t);
		h = mix(h, t.0);
		h = mix(h, t.1);
		h = mix(h, s.0);
		h = mix(h, s.1);
		h = mixb(h, t.0 == s.1);
		h = mixb(h, t.1 == s.0);
	}
	acci(h);

	var ts = Array<(i4, u4, i16)>.new(24);
	for (i < ts.length) ts[i] = (i4.view(i - 8), u4.view(i), i16.view(i * 3000));
	var g = 0;
	for (i < ts.length) {
		var t = ts[i];
		g = mix(g, t.0);
		g = mix(g, t.1);
		g = mix(g, t.2);
		var u = spread(t.0, t.1, t.2);
		g = mix(g, u.0);
		g = mix(g, u.1);
		g = mix(g, u.2);
		g = mixb(g, t == u);
	}
	acci(g);

	var n = ((i8.view(-1), u8.view(255)), (i4.view(-8), (u1.view(1), i16.view(-32768))));
	acci(mix(mix(mix(mix(mix(0, n.0.0), n.0.1), n.1.0), n.1.1.0), n.1.1.1));

	if (n.0.1 != 255) fail_assert(801);
	if (n.1.1.1 != -32768) fail_assert(802);
	if (spread(i4.view(7), u4.view(15), i16.view(32767)).0 != -8) fail_assert(803);
	if (spread(i4.view(7), u4.view(15), i16.view(32767)).1 != 0) fail_assert(804);
	if (spread(i4.view(7), u4.view(15), i16.view(32767)).2 != -32768) fail_assert(805);
	if (swap8((i8.view(-1), u8.view(255))).0 != 255) fail_assert(806);
	if (!((i8.view(1), u8.view(2)) == (i8.view(1), u8.view(2)))) fail_assert(807);
}

//======================================================================
// Section 9: narrow ints in globals and components
//======================================================================
var g8: i8;
var gu: u12;
var gt: (i4, u16);

component Bank {
	var acc: i16 = 1;
	def seed: u8 = 200;
	var hist: Array<i8> = Array<i8>.new(8);
	var n: int;

	def push(v: i8) -> i16 {
		acc = i16.view(acc * 3 + v);
		hist[n % hist.length] = v;
		n++;
		return acc;
	}
}
def globals() {
	// Reset every mutable global; the harness may run several inputs in one
	// process, so a section must never depend on what ran before it.
	g8 = 0;
	gu = 0;
	gt = (0, 0);
	Bank.acc = 1;
	Bank.n = 0;
	Bank.hist = Array<i8>.new(8);

	var h = 0;
	for (i < SEEDS.length) {
		g8 = i8.view(SEEDS[i]);
		gu = u12.view(SEEDS[i]);
		gt = (i4.view(SEEDS[i]), u16.view(SEEDS[i]));
		h = mix(h, g8);
		h = mix(h, gu);
		h = mix(h, gt.0);
		h = mix(h, gt.1);
	}
	acci(h);

	var g = mix(0, Bank.seed);
	for (i < 40) g = mix(g, Bank.push(i8.view(i * 13 - 200)));
	for (i < Bank.hist.length) g = mix(g, Bank.hist[i]);
	g = mix(g, Bank.n);
	g = mix(g, Bank.acc);
	acci(g);

	if (Bank.seed != 200) fail_assert(901);
	if (Bank.n != 40) fail_assert(902);
	// a global keeps its declared width across a store/load round trip
	g8 = i8.view(300);
	if (g8 != 44) fail_assert(903);
	gu = u12.view(-1);
	if (gu != 4095) fail_assert(904);
	g8 = 0;
	gu = 0;
}

//======================================================================
// Section 10: narrow ints in class fields
//======================================================================
class Cell {
	var s: i8;
	var u: u8;
	def tag: i4;
	new(s, u, tag) { }
	def sum() -> int { return int.view(s) + u; }
	def bump() -> int { s = i8.view(s + 1); u = u8.view(u + 1); return sum(); }
}
class WideCell extends Cell {
	var w: i16;
	new(s: i8, u: u8, tag: i4, w) super(s, u, tag) { }
	def sum() -> int { return int.view(s) + u + w; }
}
class NarrowCell extends WideCell {
	var b: u1;
	new(s: i8, u: u8, tag: i4, w: i16, b) super(s, u, tag, w) { }
	def sum() -> int { return int.view(s) + u + w + b; }
}
def classes() {
	var objs = Array<Cell>.new(3 * I8.length);
	for (i < I8.length) {
		var s = I8[i], u = U8[i % U8.length];
		objs[3 * i + 0] = Cell.new(s, u, i4.view(i));
		objs[3 * i + 1] = WideCell.new(s, u, i4.view(i), i16.view(i * 5000));
		objs[3 * i + 2] = NarrowCell.new(s, u, i4.view(i), i16.view(-i * 5000), u1.view(i));
	}
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mix(h, o.sum());		// virtual dispatch over 3 implementations
		h = mix(h, o.s);
		h = mix(h, o.u);
		h = mix(h, o.tag);
		h = mixb(h, WideCell.?(o));
		h = mixb(h, NarrowCell.?(o));
	}
	acci(h);

	// mutate through the array; each store truncates to the field's width
	for (i < objs.length) for (j < 3) objs[i].bump();
	var g = 0;
	for (i < objs.length) {
		g = mix(g, objs[i].s);
		g = mix(g, objs[i].u);
		g = mix(g, objs[i].sum());
	}
	acci(g);

	var c = Cell.new(i8.view(127), u8.view(255), i4.view(-8));
	if (c.sum() != 382) fail_assert(1001);
	if (c.bump() != -128) fail_assert(1002);	// -128 + 0, both wrapped
	if (c.u != 0) fail_assert(1003);
	if (c.tag != -8) fail_assert(1004);
	var w = WideCell.new(i8.view(-1), u8.view(1), i4.view(0), i16.view(-32768));
	if (w.sum() != -32768) fail_assert(1005);
	var n = NarrowCell.new(i8.view(-1), u8.view(1), i4.view(0), i16.view(0), u1.view(1));
	if (n.sum() != 1) fail_assert(1006);
	if (!WideCell.?(n)) fail_assert(1007);
	if (NarrowCell.?(w)) fail_assert(1008);
}

//======================================================================
// Section 11: narrow ints in variants
//======================================================================
type Narrow {
	case Signed(v: i8);
	case Unsigned(v: u12);
	case Both(a: i4, b: u4);
	case Empty;
}
type Packed #unboxed {
	case One(v: i16);
	case Two(a: u8, b: i8);
	case Zero;
}
def evalN(n: Narrow) -> int {
	match (n) {
		Signed(v) => return v;
		Unsigned(v) => return v;
		Both(a, b) => return a * 16 + b;
		Empty => return -1;
	}
}
def evalP(p: Packed) -> int {
	match (p) {
		One(v) => return v;
		Two(a, b) => return int.view(a) - b;
		Zero => return 0;
	}
}
def variants() {
	var h = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		var s: Narrow = Narrow.Signed(i8.view(v));
		var u: Narrow = Narrow.Unsigned(u12.view(v));
		var b: Narrow = Narrow.Both(i4.view(v), u4.view(v));
		var e: Narrow = Narrow.Empty;
		h = mix(h, evalN(s));
		h = mix(h, evalN(u));
		h = mix(h, evalN(b));
		h = mix(h, evalN(e));
		h = mix(h, s.tag);
		h = mix(h, b.tag);
		h = mixb(h, s == u);
		h = mixb(h, Narrow.Both.?(b));
		h = mixb(h, Narrow.Both.?(s));

		var p1: Packed = Packed.One(i16.view(v));
		var p2: Packed = Packed.Two(u8.view(v), i8.view(v));
		var p3: Packed = Packed.Zero;
		h = mix(h, evalP(p1));
		h = mix(h, evalP(p2));
		h = mix(h, evalP(p3));
		h = mixb(h, p1 == p2);
		h = mixb(h, p1 == Packed.One(i16.view(v)));
		h = mix(h, p2.tag);
	}
	acci(h);

	var arr = Array<Packed>.new(24);
	var barr = Array<Narrow>.new(24);
	for (i < arr.length) {
		arr[i] = Packed.Two(u8.view(i * 11), i8.view(-i * 11));
		barr[i] = Narrow.Both(i4.view(i), u4.view(i * 3));
	}
	var g = 0;
	for (i < arr.length) {
		g = mix(g, evalP(arr[i]));
		g = mix(g, evalN(barr[i]));
	}
	acci(g);

	if (evalN(Narrow.Signed(i8.view(-128))) != -128) fail_assert(1101);
	if (evalN(Narrow.Unsigned(u12.view(-1))) != 4095) fail_assert(1102);
	if (evalN(Narrow.Both(i4.view(-8), u4.view(15))) != -113) fail_assert(1103);
	if (evalP(Packed.One(i16.view(65535))) != -1) fail_assert(1104);
	if (evalP(Packed.Two(u8.view(255), i8.view(-1))) != 256) fail_assert(1105);
	if (Narrow.Empty.tag != 3) fail_assert(1106);
	if (Packed.One(i16.view(5)) == Packed.One(i16.view(6))) fail_assert(1107);
	// a payload is stored at its declared width, so construction truncates
	if (Narrow.Signed(i8.view(300)) != Narrow.Signed(i8.view(44))) fail_assert(1108);
}

//======================================================================
// Section 12: narrow ints through functions and operator references
//======================================================================
def add8(a: i8, b: i8) -> i8 { return a + b; }
def apply8(f: (i8, i8) -> i8, a: i8, b: i8) -> i8 { return f(a, b); }
def fold8(f: (i8, i8) -> i8, init: i8, a: Array<i8>) -> i8 {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def makeAdder(a: i8) -> i8 -> i8 {
	return fun (b: i8) => i8.view(a + b);
}
def funcs() {
	def OPS: Array<(i8, i8) -> i8> = [i8.+, i8.-, i8.*, i8.&, i8.|, i8.^, add8];
	for (k < OPS.length) {
		var h = 0;
		for (i < I8.length) h = mix(h, apply8(OPS[k], I8[i], i8.view(37)));
		h = mix(h, fold8(OPS[k], i8.view(1), I8));
		acci(h);
	}
	var inc = add8(i8.view(1), _);		// partial application
	var dec = add8(_, i8.view(-1));
	var g = 0;
	for (i < I8.length) {
		g = mix(g, inc(I8[i]));
		g = mix(g, dec(I8[i]));
	}
	acci(g);

	var adders = Array<i8 -> i8>.new(8);
	for (i < adders.length) adders[i] = makeAdder(i8.view(i * 30));
	var k = 0;
	for (i < adders.length) for (j < I8.length) k = mix(k, adders[i](I8[j]));
	// views, queries and casts are first-class function values
	var toI8: int -> i8 = i8.view<int>;
	var qI8: int -> bool = i8.?<int>;
	var wide: i8 -> i16 = i16.!<i8>;
	for (i < SEEDS.length) {
		k = mix(k, toI8(SEEDS[i]));
		k = mixb(k, qI8(SEEDS[i]));
	}
	for (i < I8.length) k = mix(k, wide(I8[i]));
	acci(k);

	if (apply8(i8.+, i8.view(127), i8.view(1)) != -128) fail_assert(1201);
	if (apply8(i8.*, i8.view(16), i8.view(16)) != 0) fail_assert(1202);
	if (add8(i8.view(1), _)(i8.view(127)) != -128) fail_assert(1203);
	if (makeAdder(i8.view(100))(i8.view(100)) != -56) fail_assert(1204);
	if (i8.view<int>(300) != 44) fail_assert(1205);
	if (i16.!<i8>(i8.view(-1)) != -1) fail_assert(1206);
}

//======================================================================
// Section 13: allocation churn with live narrow-int data
//======================================================================
class Link(v: i8, w: u12, next: Link) { }
def churn() {
	var head: Link;
	var live = Array<Link>.new(16);
	for (i < 2000) {
		head = Link.new(i8.view(i * 3), u12.view(i * 7), head);
		if ((i % 97) == 0) live[(i / 97) % live.length] = head;
		if ((i % 13) == 0) head = null;		// drop most of the chain
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mix(h, p.v);
			h = mix(h, p.w);
			p = p.next;
			n++;
			if (n > 100000) { acci(h); return; }
		}
	}
	h = mix(h, n);
	var p = head;
	while (p != null) { h = mix(h, p.v); p = p.next; }
	acci(h);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) limits();
	if (a == 0 || a == 2) arith();
	if (a == 0 || a == 3) compare();
	if (a == 0 || a == 4) bits();
	if (a == 0 || a == 5) views();
	if (a == 0 || a == 6) casts();
	if (a == 0 || a == 7) arrays();
	if (a == 0 || a == 8) tuples();
	if (a == 0 || a == 9) globals();
	if (a == 0 || a == 10) classes();
	if (a == 0 || a == 11) variants();
	if (a == 0 || a == 12) funcs();
	if (a == 0 || a == 13) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
