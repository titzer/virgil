//@execute 0=0
//@heap-size=4000000
// Smoke test: mixed reference and value data.
// The point of this file is the GC's field maps and element maps: which slots of
// an object or array hold references and which hold raw bits. Every shape here
// interleaves the two -- reference-first and primitive-first classes, alternating
// layouts, tuples mixing both, variants with reference payloads, arrays of
// references sitting next to arrays of primitives, and nested containers. Every
// primitive field is filled with a "poison" value that looks like a plausible
// heap address, so a slot that is scanned when it should not be (or skipped when
// it should not be) shows up as a wrong fingerprint rather than as nothing.
// Interleaved are assert()s over compile-time constants, which the optimizer is
// expected to fold away; a folding bug sets the failure flag instead.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

// Primitive fillers that look like heap addresses on a 32-bit or 64-bit target.
def poison(id: int) -> int { return 0x4000_0000 + id * 8; }
def poisonl(id: int) -> long { return 0x0000_7F00_0000_0000L + long.!(id) * 16L; }

//======================================================================
// Shapes
//======================================================================
class Cell {
	def id: int;
	var v: int;
	new(id) { v = id * 11 + 5; }
	def fp() -> int { return id ^ (v * 3); }
}
// references first, then primitives
class RefFirst {
	def id: int;
	var r0: Cell; var r1: Cell; var r2: Cell;
	var p0: int; var p1: long; var p2: byte;
	new(id) {
		r0 = Cell.new(id); r1 = Cell.new(id + 1); r2 = Cell.new(id + 2);
		p0 = poison(id); p1 = poisonl(id); p2 = byte.view(id);
	}
	def fp() -> int {
		return r0.fp() ^ r1.fp() ^ r2.fp() ^ p0 ^
			int.view(u32.view(p1)) ^ int.view(u32.view(p1 >> 32)) ^ int.!(p2);
	}
}
// primitives first, then references
class PrimFirst {
	def id: int;
	var p0: int; var p1: long; var p2: bool; var p3: int;
	var r0: Cell; var r1: Cell;
	new(id) {
		p0 = poison(id); p1 = poisonl(id + 3); p2 = (id & 1) == 1; p3 = poison(id + 7);
		r0 = Cell.new(id + 4); r1 = Cell.new(id + 5);
	}
	def fp() -> int {
		return p0 ^ p3 ^ int.view(u32.view(p1)) ^ int.view(u32.view(p1 >> 32)) ^
			(if(p2, 0x33, 0x55)) ^ r0.fp() ^ r1.fp();
	}
}
// strictly alternating
class Alt {
	def id: int;
	var a: int; var r0: Cell;
	var b: long; var r1: Cell;
	var c: byte; var r2: Cell;
	var d: bool; var r3: Array<int>;
	var e: int; var r4: Array<Cell>;
	new(id) {
		a = poison(id); r0 = Cell.new(id);
		b = poisonl(id); r1 = Cell.new(id + 1);
		c = byte.view(id + 2); r2 = Cell.new(id + 2);
		d = (id % 3) == 0; r3 = Array<int>.new(4);
		for (i < r3.length) r3[i] = poison(id + i);
		e = poison(id + 9); r4 = Array<Cell>.new(3);
		for (i < r4.length) r4[i] = Cell.new(id * 4 + i);
	}
	def fp() -> int {
		var s = a ^ int.view(u32.view(b)) ^ int.view(u32.view(b >> 32));
		s = s ^ int.!(c) ^ (if(d, 0x77, 0x11)) ^ e;
		s = s ^ r0.fp() ^ r1.fp() ^ r2.fp();
		for (i < r3.length) s = s ^ (r3[i] * (i + 1));
		for (i < r4.length) s = s ^ r4[i].fp();
		return s;
	}
}
class AllRef {
	def id: int;
	var r0: Cell; var r1: Cell; var r2: Cell; var r3: Cell; var r4: Cell; var r5: Cell;
	new(id) {
		r0 = Cell.new(id); r1 = Cell.new(id + 1); r2 = Cell.new(id + 2);
		r3 = Cell.new(id + 3); r4 = Cell.new(id + 4); r5 = Cell.new(id + 5);
	}
	def fp() -> int { return r0.fp() ^ r1.fp() ^ r2.fp() ^ r3.fp() ^ r4.fp() ^ r5.fp(); }
}
class AllPrim {
	def id: int;
	var p0: int; var p1: int; var p2: long; var p3: long; var p4: byte; var p5: bool;
	new(id) {
		p0 = poison(id); p1 = poison(id + 1);
		p2 = poisonl(id); p3 = poisonl(id + 1);
		p4 = byte.view(id); p5 = (id & 2) == 2;
	}
	def fp() -> int {
		var s = p0 ^ p1 ^ int.!(p4) ^ (if(p5, 0x99, 0x22));
		s = s ^ int.view(u32.view(p2)) ^ int.view(u32.view(p2 >> 32));
		s = s ^ int.view(u32.view(p3)) ^ int.view(u32.view(p3 >> 32));
		return s;
	}
}

//======================================================================
// A tuple type used in fields, arrays and globals.
//======================================================================
type Mixed {
	case Prim(a: int, b: long);
	case One(c: Cell);
	case Two(c: Cell, d: Cell);
	case WithPrim(c: Cell, k: int, l: long);
	case Arr(a: Array<Cell>);
	case Nest(m: Array<Mixed>);
	case Empty;
}

def churn(n: int) -> int {
	var s = 0;
	for (i < n) {
		var a = Alt.new(i);
		var b = RefFirst.new(i);
		var c = PrimFirst.new(i);
		s = s ^ a.r0.fp() ^ b.p0 ^ c.r1.fp();
		if ((i & 3) == 0) {
			var junk = Array<Cell>.new(8);
			for (j < junk.length) junk[j] = Cell.new(i + j);
			s = s ^ junk[i & 7].fp();
		}
	}
	return s;
}

//======================================================================
// Section 1: field layouts, verified across collections
//======================================================================
def layouts() {
	var n = 200;
	var rf = Array<RefFirst>.new(n);
	var pf = Array<PrimFirst>.new(n);
	var al = Array<Alt>.new(n);
	var ar = Array<AllRef>.new(n);
	var ap = Array<AllPrim>.new(n);
	for (i < n) {
		rf[i] = RefFirst.new(i);
		pf[i] = PrimFirst.new(i);
		al[i] = Alt.new(i);
		ar[i] = AllRef.new(i);
		ap[i] = AllPrim.new(i);
	}
	var prints = Array<int>.new(n);
	for (i < n) prints[i] = rf[i].fp() ^ pf[i].fp() ^ al[i].fp() ^ ar[i].fp() ^ ap[i].fp();

	acci(mix(0, churn(600)));

	var h = 0;
	for (i < n) {
		var now = rf[i].fp() ^ pf[i].fp() ^ al[i].fp() ^ ar[i].fp() ^ ap[i].fp();
		if (now != prints[i]) fail_assert(101);
		h = mix(h, now);
	}
	acci(h);
	// exact contents of a freshly built object of each shape
	if (Cell.new(3).v != 38) fail_assert(102);
	if (Cell.new(3).fp() != 113) fail_assert(103);		// 3 ^ 114 = 113
	if (RefFirst.new(10).p0 != 0x4000_0050) fail_assert(104);
	if (RefFirst.new(10).r2.id != 12) fail_assert(105);
	if (RefFirst.new(10).p2 != 10) fail_assert(106);
	if (PrimFirst.new(10).p2 != false) fail_assert(107);
	if (PrimFirst.new(11).p2 != true) fail_assert(108);
	if (PrimFirst.new(10).r1.id != 15) fail_assert(109);
	if (PrimFirst.new(10).p1 != 0x0000_7F00_0000_00D0L) fail_assert(110);
	if (Alt.new(6).d != true) fail_assert(111);
	if (Alt.new(7).d != false) fail_assert(112);
	if (Alt.new(6).r4[2].id != 26) fail_assert(113);
	if (Alt.new(6).r3.length != 4) fail_assert(114);
	if (AllRef.new(2).r5.id != 7) fail_assert(115);
	if (AllPrim.new(2).p5 != true) fail_assert(116);
	if (AllPrim.new(1).p5 != false) fail_assert(117);
	if (AllPrim.new(0).p2 != 0x0000_7F00_0000_0000L) fail_assert(118);
}

//======================================================================
// Section 2: reference arrays adjacent to primitive arrays
//======================================================================
def adjacentArrays() {
	var pairs = 300;
	var prims = Array<Array<int>>.new(pairs);
	var refs = Array<Array<Cell>>.new(pairs);
	var longs = Array<Array<long>>.new(pairs);
	var bytes = Array<Array<byte>>.new(pairs);
	// allocate them interleaved, so a primitive array is between two ref arrays
	for (i < pairs) {
		prims[i] = Array<int>.new(1 + (i % 12));
		for (j < prims[i].length) prims[i][j] = poison(i * 16 + j);
		refs[i] = Array<Cell>.new(1 + (i % 9));
		for (j < refs[i].length) refs[i][j] = Cell.new(i * 16 + j);
		longs[i] = Array<long>.new(1 + (i % 5));
		for (j < longs[i].length) longs[i][j] = poisonl(i * 16 + j);
		bytes[i] = Array<byte>.new(1 + (i % 7));
		for (j < bytes[i].length) bytes[i][j] = byte.view(i + j);
	}
	acci(mix(0, churn(400)));
	var h = 0;
	var bad = 0;
	for (i < pairs) {
		for (j < prims[i].length) {
			if (prims[i][j] != poison(i * 16 + j)) bad++;
			h = mix(h, prims[i][j]);
		}
		for (j < refs[i].length) {
			if (refs[i][j].id != i * 16 + j) bad++;
			h = mix(h, refs[i][j].fp());
		}
		for (j < longs[i].length) {
			if (longs[i][j] != poisonl(i * 16 + j)) bad++;
			h = mixl(h, longs[i][j]);
		}
		for (j < bytes[i].length) h = mix(h, int.!(bytes[i][j]));
	}
	acci(h);
	if (bad != 0) fail_assert(201);
	if (prims[11].length != 12) fail_assert(202);
	if (refs[8].length != 9) fail_assert(203);
	if (longs[4].length != 5) fail_assert(204);
	if (bytes[6].length != 7) fail_assert(205);
	if (poison(5) != 0x4000_0028) fail_assert(206);
	if (poisonl(5) != 0x0000_7F00_0000_0050L) fail_assert(207);
	// a primitive array holding pointer-looking values is never treated as refs
	var trap = Array<int>.new(64);
	for (i < trap.length) trap[i] = poison(i * 1000);
	acci(mix(0, churn(200)));
	var t = 0;
	for (i < trap.length) {
		if (trap[i] != poison(i * 1000)) fail_assert(208);
		t = mix(t, trap[i]);
	}
	acci(t);
}

//======================================================================
// Section 3: tuples mixing references and primitives
//======================================================================
var gTup: (Cell, int, Cell, long, Array<Cell>);
def tuples() {
	gTup = (null, 0, null, 0, null);		// reset: this section writes a global
	var n = 250;
	var tups = Array<(Cell, int, Cell, long)>.new(n);
	for (i < n) tups[i] = (Cell.new(i), poison(i), Cell.new(i + 1), poisonl(i));
	gTup = (Cell.new(90), poison(90), Cell.new(91), poisonl(90), Array<Cell>.new(16));
	for (i < gTup.4.length) gTup.4[i] = Cell.new(500 + i);

	acci(mix(0, churn(400)));

	var h = 0;
	var bad = 0;
	for (i < n) {
		var t = tups[i];
		if (t.0.id != i) bad++;
		if (t.1 != poison(i)) bad++;
		if (t.2.id != i + 1) bad++;
		if (t.3 != poisonl(i)) bad++;
		h = mix(h, t.0.fp());
		h = mix(h, t.1);
		h = mix(h, t.2.fp());
		h = mixl(h, t.3);
	}
	acci(h);
	if (bad != 0) fail_assert(301);
	if (gTup.0.id != 90) fail_assert(302);
	if (gTup.2.id != 91) fail_assert(303);
	if (gTup.4.length != 16) fail_assert(304);
	if (gTup.4[15].id != 515) fail_assert(305);

	// tuples returned from calls, destructured into locals
	var g = 0;
	for (i < 120) {
		var t = makeTuple(i);
		var a = t.0, b = t.1, c = t.2, d = t.3;
		g = mix(g, a.fp());
		g = mix(g, b);
		g = mix(g, c.fp());
		g = mixl(g, d);
		if (a.id != i) fail_assert(306);
		if (c.id != i * 2) fail_assert(307);
	}
	acci(g);
	var q = makeTuple(4);
	if (q.0.id != 4) fail_assert(308);
	if (q.1 != 0x4000_0020) fail_assert(309);
	if (q.2.id != 8) fail_assert(310);
	if (q.3 != 0x0000_7F00_0000_0080L) fail_assert(311);
	gTup = (null, 0, null, 0, null);
}
def makeTuple(i: int) -> (Cell, int, Cell, long) {
	var junk = Array<Cell>.new(4);
	for (k < junk.length) junk[k] = Cell.new(i + k);
	return (Cell.new(i), poison(i), Cell.new(i * 2), poisonl(i * 2));
}

//======================================================================
// Section 4: variants carrying references
//======================================================================
def variants() {
	var n = 400;
	var vs = Array<Mixed>.new(n);
	for (i < n) {
		match (i % 6) {
			0 => vs[i] = Mixed.Prim(poison(i), poisonl(i));
			1 => vs[i] = Mixed.One(Cell.new(i));
			2 => vs[i] = Mixed.Two(Cell.new(i), Cell.new(i + 1));
			3 => vs[i] = Mixed.WithPrim(Cell.new(i), poison(i), poisonl(i));
			4 => {
				var a = Array<Cell>.new(1 + (i % 5));
				for (j < a.length) a[j] = Cell.new(i * 8 + j);
				vs[i] = Mixed.Arr(a);
			}
			_ => vs[i] = Mixed.Empty;
		}
	}
	// a nested variant: a variant holding an array of variants
	var inner = Array<Mixed>.new(24);
	for (i < inner.length) inner[i] = Mixed.Two(Cell.new(i + 700), Cell.new(i + 800));
	var nest: Mixed = Mixed.Nest(inner);	// parent type: a case-typed local
						// would make the match arms below ambiguous

	acci(mix(0, churn(500)));

	var h = 0;
	var counts = Array<int>.new(7);
	for (i < n) {
		match (vs[i]) {
			Prim(a, b) => { h = mix(h, a); h = mixl(h, b); counts[0]++; }
			One(c) => { h = mix(h, c.fp()); counts[1]++; }
			Two(c, d) => { h = mix(h, c.fp() ^ d.fp()); counts[2]++; }
			WithPrim(c, k, l) => { h = mix(h, c.fp() ^ k); h = mixl(h, l); counts[3]++; }
			Arr(a) => { for (j < a.length) h = mix(h, a[j].fp()); counts[4]++; }
			Nest(m) => { counts[5]++; }
			Empty => counts[6]++;
		}
	}
	acci(h);
	// 400 values over a 6-cycle: 400 = 66*6 + 4, so tags 0..3 appear 67 times
	if (counts[0] != 67) fail_assert(401);
	if (counts[1] != 67) fail_assert(402);
	if (counts[2] != 67) fail_assert(403);
	if (counts[3] != 67) fail_assert(404);
	if (counts[4] != 66) fail_assert(405);
	if (counts[5] != 0) fail_assert(406);
	if (counts[6] != 66) fail_assert(407);

	var g = 0;
	match (nest) {
		Nest(m) => {
			if (m.length != 24) fail_assert(408);
			for (i < m.length) match (m[i]) {
				Two(c, d) => {
					if (c.id != i + 700) fail_assert(409);
					if (d.id != i + 800) fail_assert(410);
					g = mix(g, c.fp() ^ d.fp());
				}
				_ => fail_assert(411);
			}
		}
		_ => fail_assert(412);
	}
	acci(g);
	// tags are declaration order
	if (Mixed.Prim(1, 2).tag != 0) fail_assert(413);
	if (Mixed.Empty.tag != 6) fail_assert(414);
	if (Mixed.One(null).tag != 1) fail_assert(415);
	// a variant holding the same reference twice compares equal to itself
	var c9 = Cell.new(9);
	var t1: Mixed = Mixed.Two(c9, c9);
	var t2: Mixed = Mixed.Two(c9, c9);
	if (t1 != t2) fail_assert(416);
	var t3: Mixed = Mixed.Two(c9, Cell.new(9));
	if (t1 == t3) fail_assert(417);		// distinct objects, compared by reference
	if (Mixed.Empty.?(t1)) fail_assert(418);
	if (!Mixed.Two.?(t1)) fail_assert(419);
}

//======================================================================
// Section 5: nested containers
//======================================================================
def nested() {
	var d1 = 20, d2 = 12, d3 = 6;
	var cube = Array<Array<Array<Cell>>>.new(d1);
	for (i < d1) {
		cube[i] = Array<Array<Cell>>.new(d2);
		for (j < d2) {
			cube[i][j] = Array<Cell>.new(d3);
			for (k < d3) cube[i][j][k] = Cell.new(i * 1000 + j * 10 + k);
		}
	}
	// a parallel primitive cube, so mis-scanning one would hit the other
	var pcube = Array<Array<Array<int>>>.new(d1);
	for (i < d1) {
		pcube[i] = Array<Array<int>>.new(d2);
		for (j < d2) {
			pcube[i][j] = Array<int>.new(d3);
			for (k < d3) pcube[i][j][k] = poison(i * 1000 + j * 10 + k);
		}
	}
	acci(mix(0, churn(400)));
	var h = 0;
	var cells = 0;
	var bad = 0;
	for (i < d1) for (j < d2) for (k < d3) {
		var c = cube[i][j][k];
		if (c.id != i * 1000 + j * 10 + k) bad++;
		if (pcube[i][j][k] != poison(i * 1000 + j * 10 + k)) bad++;
		h = mix(h, c.fp());
		h = mix(h, pcube[i][j][k]);
		cells++;
	}
	acci(h);
	if (bad != 0) fail_assert(501);
	if (cells != 1440) fail_assert(502);		// 20*12*6
	// an object holding an array of objects holding arrays
	var holder = Array<Alt>.new(64);
	for (i < holder.length) holder[i] = Alt.new(i);
	acci(mix(0, churn(300)));
	var g = 0;
	for (i < holder.length) {
		if (holder[i].r4[1].id != i * 4 + 1) fail_assert(503);
		if (holder[i].r3[3] != poison(i + 3)) fail_assert(504);
		g = mix(g, holder[i].fp());
	}
	acci(g);
	if (cube.length != 20) fail_assert(505);
	if (cube[0].length != 12) fail_assert(506);
	if (cube[0][0].length != 6) fail_assert(507);
	if (cube[19][11][5].id != 19115) fail_assert(508);
}

//======================================================================
// Section 6: inheritance -- adding reference fields to a primitive base
//======================================================================
class Base {
	def id: int;
	var bp: int;
	var bl: long;
	new(id) { bp = poison(id); bl = poisonl(id); }
	def fp() -> int {
		return id ^ bp ^ int.view(u32.view(bl)) ^ int.view(u32.view(bl >> 32));
	}
	def baseFp() -> int {
		return id ^ bp ^ int.view(u32.view(bl)) ^ int.view(u32.view(bl >> 32));
	}
}
class SubRef extends Base {
	var r0: Cell;
	var r1: Array<Cell>;
	new(id: int) : super(id) {
		r0 = Cell.new(id + 1);
		r1 = Array<Cell>.new(3);
		for (i < r1.length) r1[i] = Cell.new(id * 5 + i);
	}
	def fp() -> int {
		var s = baseFp() ^ r0.fp();
		for (i < r1.length) s = s ^ r1[i].fp();
		return s;
	}
}
class SubPrim extends Base {
	var q0: int;
	var q1: long;
	new(id: int) : super(id) { q0 = poison(id + 100); q1 = poisonl(id + 100); }
	def fp() -> int {
		return baseFp() ^ q0 ^ int.view(u32.view(q1)) ^ int.view(u32.view(q1 >> 32));
	}
}
class SubSub extends SubRef {
	var s0: Cell;
	var s1: int;
	new(id: int) : super(id) { s0 = Cell.new(id + 2); s1 = poison(id + 200); }
	def fp() -> int {
		var s = baseFp() ^ r0.fp() ^ s0.fp() ^ s1;
		for (i < r1.length) s = s ^ r1[i].fp();
		return s;
	}
}
def inherited() {
	var n = 300;
	var objs = Array<Base>.new(n);
	for (i < n) {
		match (i % 4) {
			0 => objs[i] = Base.new(i);
			1 => objs[i] = SubRef.new(i);
			2 => objs[i] = SubPrim.new(i);
			_ => objs[i] = SubSub.new(i);
		}
	}
	var prints = Array<int>.new(n);
	for (i < n) prints[i] = objs[i].fp();
	acci(mix(0, churn(500)));
	var h = 0;
	var kinds = Array<int>.new(4);
	for (i < n) {
		if (objs[i].fp() != prints[i]) fail_assert(601);
		if (objs[i].id != i) fail_assert(602);
		h = mix(h, objs[i].fp());
		if (SubSub.?(objs[i])) kinds[3]++;
		else if (SubRef.?(objs[i])) kinds[1]++;
		else if (SubPrim.?(objs[i])) kinds[2]++;
		else kinds[0]++;
	}
	acci(h);
	if (kinds[0] != 75) fail_assert(603);
	if (kinds[1] != 75) fail_assert(604);
	if (kinds[2] != 75) fail_assert(605);
	if (kinds[3] != 75) fail_assert(606);
	// virtual dispatch picks the right fp() for each shape
	var b: Base = SubRef.new(4);
	if (b.fp() == Base.new(4).fp()) fail_assert(607);
	if (SubRef.!(b).r1.length != 3) fail_assert(608);
	if (SubRef.!(b).r1[2].id != 22) fail_assert(609);
	if (SubPrim.new(1).q0 != poison(101)) fail_assert(610);
	if (SubSub.new(1).s0.id != 3) fail_assert(611);
	if (!Base.?(SubSub.new(1))) fail_assert(612);
	if (!SubRef.?(SubSub.new(1))) fail_assert(613);
	if (SubSub.?(SubRef.new(1))) fail_assert(614);
}

//======================================================================
// Section 7: sub-word element arrays next to reference arrays
//======================================================================
def subword() {
	var n = 120;
	var b8 = Array<Array<byte>>.new(n);
	var sh = Array<Array<i16>>.new(n);
	var u16s = Array<Array<u16>>.new(n);
	var bools = Array<Array<bool>>.new(n);
	var cells = Array<Array<Cell>>.new(n);
	for (i < n) {
		var len = 1 + (i % 17);
		b8[i] = Array<byte>.new(len);
		sh[i] = Array<i16>.new(len);
		u16s[i] = Array<u16>.new(len);
		bools[i] = Array<bool>.new(len);
		cells[i] = Array<Cell>.new(len);
		for (j < len) {
			b8[i][j] = byte.view(i * 3 + j);
			sh[i][j] = i16.view(i * 257 + j - 1000);
			u16s[i][j] = u16.view(i * 511 + j);
			bools[i][j] = ((i + j) & 1) == 0;
			cells[i][j] = Cell.new(i * 32 + j);
		}
	}
	acci(mix(0, churn(400)));
	var h = 0;
	var bad = 0;
	for (i < n) {
		var len = 1 + (i % 17);
		for (j < len) {
			if (b8[i][j] != byte.view(i * 3 + j)) bad++;
			if (sh[i][j] != i16.view(i * 257 + j - 1000)) bad++;
			if (u16s[i][j] != u16.view(i * 511 + j)) bad++;
			if (bools[i][j] != (((i + j) & 1) == 0)) bad++;
			if (cells[i][j].id != i * 32 + j) bad++;
			h = mix(h, int.!(b8[i][j]));
			h = mix(h, int.!(sh[i][j]));
			h = mix(h, int.!(u16s[i][j]));
			h = mixb(h, bools[i][j]);
			h = mix(h, cells[i][j].fp());
		}
	}
	acci(h);
	if (bad != 0) fail_assert(701);
	if (b8[16].length != 17) fail_assert(702);
	if (i16.view(-1000) != -1000) fail_assert(703);
	if (u16.view(511) != 511) fail_assert(704);
	if (byte.view(258) != 2) fail_assert(705);
	if (int.!(u16.view(65535)) != 65535) fail_assert(706);
	if (int.!(i16.view(-1)) != -1) fail_assert(707);
}

//======================================================================
// Section 8: reference slots overwritten with null and re-filled
//======================================================================
def nulling() {
	var n = 400;
	var slots = Array<Cell>.new(n);
	var alts = Array<Alt>.new(n / 4);
	for (i < n) slots[i] = Cell.new(i);
	for (i < alts.length) alts[i] = Alt.new(i);
	var h = 0;
	for (round < 6) {
		// null out every third slot, then churn, then refill
		for (i < n) if ((i % 3) == round % 3) slots[i] = null;
		h = mix(h, churn(150));
		var nulls = 0;
		for (i < n) if (slots[i] == null) nulls++;
		h = mix(h, nulls);
		for (i < n) if (slots[i] == null) slots[i] = Cell.new(i);
		for (i < n) if (slots[i].id != i) fail_assert(801);
	}
	acci(h);
	// nulling a reference field inside an object, across a collection
	for (i < alts.length) {
		alts[i].r0 = null;
		alts[i].r4[0] = null;
	}
	acci(mix(0, churn(250)));
	var g = 0;
	for (i < alts.length) {
		if (alts[i].r0 != null) fail_assert(802);
		if (alts[i].r4[0] != null) fail_assert(803);
		if (alts[i].r4[1].id != i * 4 + 1) fail_assert(804);
		if (alts[i].r1.id != i + 1) fail_assert(805);
		g = mix(g, alts[i].r1.fp());
		g = mix(g, alts[i].e);
	}
	acci(g);
	for (i < alts.length) alts[i].r0 = Cell.new(i);
	acci(mix(0, churn(200)));
	var q = 0;
	for (i < alts.length) {
		if (alts[i].r0.id != i) fail_assert(806);
		q = mix(q, alts[i].r0.fp());
	}
	acci(q);
	if (n != 400) fail_assert(807);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) layouts();
	if (a == 0 || a == 2) adjacentArrays();
	if (a == 0 || a == 3) tuples();
	if (a == 0 || a == 4) variants();
	if (a == 0 || a == 5) nested();
	if (a == 0 || a == 6) inherited();
	if (a == 0 || a == 7) subword();
	if (a == 0 || a == 8) nulling();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
