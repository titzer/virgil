//@execute 0=405025928; 1=-1244780766; 2=-994019995; 3=1749932660; 4=-1030115272; 5=-57182423; 6=1327759989; 7=-390403968; 8=119499616; 9=1680735711; 10=-2003775530; 11=1837427176; 12=-251170697; 13=877613016
//@heap-size=200000
// Smoke test: 32-bit floating point.
// Each section exercises a group of float operations and mixes the results into
// a running CRC that main() returns, so no computation can be deleted as dead.
// Interleaved with those are assert()s whose operands are compile-time
// constants: the optimizer is expected to fold them away entirely, so a folding
// bug shows up as a set failure flag rather than a wrong CRC.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
// NaN bit patterns are not guaranteed identical across backends, so all NaNs
// mix in one canonical marker; every other value mixes exact bits (which
// distinguishes 0.0 from -0.0).
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def VALS: Array<float> = [
	0f, -0.0f, 1f, -1f, 0.5f, -0.5f, 2f, 3.5f,
	-7.25f, 1e-10f, 1e10f, 16777216f, 16777217f,
	float.infinity, -float.infinity, float.nan
];
def INTS: Array<int> = [
	0, 1, -1, 2, 127, -128, 65535, 16777216, 16777217,
	2147483647, -2147483648, 1000000, -1000000
];
def LONGS: Array<long> = [
	0, 1, -1, 1024, -1024, 16777217, 4294967296,
	9007199254740993, -9007199254740993, 1234567890123
];

//======================================================================
// Section 1: arithmetic
//======================================================================
def arith() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = mixf(0, -a);
		for (j < VALS.length) {
			var b = VALS[j];
			h = mixf(h, a + b);
			h = mixf(h, a - b);
			h = mixf(h, a * b);
			h = mixf(h, a / b);
		}
		acci(h);
	}
	// compound assignment forms
	var x = 1.5f;
	x += 2.25f;
	x -= 0.5f;
	x *= 4f;
	x /= 3f;
	acci(mixf(0, x));

	if (1.5f + 2.25f != 3.75f) fail_assert(101);
	if (1.5f * 4f != 6f) fail_assert(102);
	if (7f / 2f != 3.5f) fail_assert(103);
	if (-0.0f + 0f != 0f) fail_assert(104);
	if (int.view(-0.0f * 1f) != int.view(-0.0f)) fail_assert(105);
	if (int.view(-0.0f + 0f) != int.view(0f)) fail_assert(106);
	if (float.infinity - float.infinity == float.infinity) fail_assert(107);
}

//======================================================================
// Section 2: comparisons
//======================================================================
def compare() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = 0;
		for (j < VALS.length) {
			var b = VALS[j];
			h = mixb(h, a == b);
			h = mixb(h, a != b);
			h = mixb(h, a < b);
			h = mixb(h, a <= b);
			h = mixb(h, a > b);
			h = mixb(h, a >= b);
		}
		acci(h);
	}
	// identities that hold only under IEEE semantics
	if (float.nan == float.nan) fail_assert(201);
	if (!(float.nan != float.nan)) fail_assert(202);
	if (float.nan < 1f) fail_assert(203);
	if (float.nan >= 1f) fail_assert(204);
	if (!(0f == -0.0f)) fail_assert(205);
	if (int.view(0f) == int.view(-0.0f)) fail_assert(206);
	if (!(float.infinity > 3.4028235e38f)) fail_assert(207);
	if (!(-float.infinity < -3.4028235e38f)) fail_assert(208);
}

//======================================================================
// Section 3: bit-level structure and special values
//======================================================================
def bits() {
	var h = 0;
	for (i < VALS.length) {
		var a = VALS[i];
		h = mix(h, a.sign);
		h = mix(h, a.exponent);
		h = mix(h, a.fraction);
		h = mixf(h, float.view(int.view(a)));	// round trip through raw bits
		h = mix(h, int.view(a));
	}
	acci(h);
	var g = mixf(0, 1f / 0f);
	g = mixf(g, -1f / 0f);
	g = mixf(g, 0f / 0f);
	g = mixf(g, 1f / -0.0f);
	g = mixf(g, float.view(1));		// smallest denormal
	g = mixf(g, float.view(0x007FFFFF));	// largest denormal
	g = mixf(g, float.view(0x7F7FFFFF));	// float.max
	acci(g);

	if ((-0.0f).sign != 1) fail_assert(301);
	if ((0f).sign != 0) fail_assert(302);
	if ((1f).exponent != 0) fail_assert(303);
	if ((1e10f).exponent != 33) fail_assert(304);
	if ((1.5f).fraction != 0x400000) fail_assert(305);
	if (int.view(1f / 0f) != int.view(float.infinity)) fail_assert(306);
	if (int.view(1f / -0.0f) != int.view(-float.infinity)) fail_assert(307);
	if (0f / 0f == 0f / 0f) fail_assert(308);
	if (float.view(0x7F7FFFFF) != 3.4028235e38f) fail_assert(309);
	if (float.view(1) == 0f) fail_assert(310);
}

//======================================================================
// Section 4: math operations
//======================================================================
def math() {
	var h = 0;
	for (i < VALS.length) {
		var a = VALS[i];
		h = mixf(h, float.abs(a));
		h = mixf(h, float.ceil(a));
		h = mixf(h, float.floor(a));
		h = mixf(h, float.sqrt(a));
		h = mixf(h, float.round(a));
	}
	acci(h);
	def HALVES: Array<float> = [-2.5f, -1.5f, -0.5f, 0.5f, 1.5f, 2.5f, 3.5f];
	var g = 0;
	for (i < HALVES.length) {
		g = mixf(g, float.round(HALVES[i]));
		g = mixf(g, float.ceil(HALVES[i]));
		g = mixf(g, float.floor(HALVES[i]));
	}
	acci(g);

	// round is round-half-to-even
	if (float.round(-2.5f) != -2f) fail_assert(401);
	if (float.round(-1.5f) != -2f) fail_assert(402);
	if (float.round(0.5f) != 0f) fail_assert(403);
	if (float.round(1.5f) != 2f) fail_assert(404);
	if (float.round(2.5f) != 2f) fail_assert(405);
	if (float.round(3.5f) != 4f) fail_assert(406);
	if (int.view(float.round(-0.5f)) != int.view(-0.0f)) fail_assert(407);
	// ceil/floor sign-of-zero behavior
	if (int.view(float.ceil(-0.5f)) != int.view(-0.0f)) fail_assert(408);
	if (float.floor(-0.5f) != -1f) fail_assert(409);
	if (float.ceil(float.infinity) != float.infinity) fail_assert(410);
	// sqrt
	if (float.sqrt(9f) != 3f) fail_assert(411);
	if (float.sqrt(-1f) == float.sqrt(-1f)) fail_assert(412);	// NaN
	if (int.view(float.sqrt(-0.0f)) != int.view(-0.0f)) fail_assert(413);
	if (float.sqrt(float.infinity) != float.infinity) fail_assert(414);
	// abs clears the sign bit
	if (int.view(float.abs(-0.0f)) != int.view(0f)) fail_assert(415);
	if (float.abs(-float.infinity) != float.infinity) fail_assert(416);
}

//======================================================================
// Section 5: conversions into float
//======================================================================
def convIn() {
	var h = 0;
	for (i < INTS.length) {
		var v = INTS[i];
		h = mixf(h, float.roundi(v));
		h = mixf(h, float.roundi(long.!(v)));
		h = mixb(h, float.?(v));
	}
	for (i < LONGS.length) {
		h = mixf(h, float.roundi(LONGS[i]));
		h = mixb(h, float.?(LONGS[i]));
	}
	acci(h);
	def U32S: Array<u32> = [0, 1, 255, 16777217, 2147483648u, 4294967295u];
	def U64S: Array<u64> = [0, 1, 9007199254740993, 18446744073709551615uL];
	def DBLS: Array<double> = [0d, -0.0d, 1.25d, 1e300d, -1e300d, 1e-300d, 0.1d];
	var g = 0;
	for (i < U32S.length) g = mixf(g, float.roundi(U32S[i]));
	for (i < U64S.length) g = mixf(g, float.roundi(U64S[i]));
	for (i < DBLS.length) g = mixf(g, float.roundd(DBLS[i]));
	acci(g);

	// 24-bit mantissa: 16777217 is not representable, ties round to even
	if (float.roundi(16777216) != 16777216f) fail_assert(501);
	if (float.roundi(16777217) != 16777216f) fail_assert(502);
	if (float.roundi(16777219) != 16777220f) fail_assert(503);
	if (16777217f != 16777216f) fail_assert(504);
	if (float.roundi(2147483647) != 2147483648f) fail_assert(505);
	if (float.roundi(-2147483648) != -2147483648f) fail_assert(506);
	if (float.roundi(4294967295u) != 4294967296f) fail_assert(507);
	if (float.roundi(9007199254740993L) != 9007199254740992f) fail_assert(508);
	if (float.roundi(18446744073709551615uL) != 18446744073709551616f) fail_assert(509);
	// double -> float
	if (float.roundd(1e300d) != float.infinity) fail_assert(510);
	if (float.roundd(-1e300d) != -float.infinity) fail_assert(511);
	if (float.roundd(1e-300d) != 0f) fail_assert(512);
	if (int.view(float.roundd(-0.0d)) != int.view(-0.0f)) fail_assert(513);
	if (float.roundd(1.25d) != 1.25f) fail_assert(514);
	// exact-representability queries
	if (!float.?(16777216)) fail_assert(515);
	if (float.?(16777217)) fail_assert(516);
}

//======================================================================
// Section 6: conversions out of float
//======================================================================
def convOut() {
	def SAFE: Array<float> = [
		0f, -0.0f, 1f, -1f, 0.5f, -0.5f, 3.9f, -3.9f,
		127f, -128f, 65535f, 16777216f, 1e10f, -1e10f
	];
	var h = 0;
	for (i < SAFE.length) {
		var f = SAFE[i];
		h = mix(h, int.truncf(f));
		h = mixl(h, long.truncf(f));
		var d: double = f;	// implicit promotion
		h = mixd(h, d);
		h = mixb(h, int.?(f));
		h = mixb(h, long.?(f));
		h = mixb(h, u32.?(f));
	}
	acci(h);
	def NONNEG: Array<float> = [0f, 1f, 0.5f, 3.9f, 127f, 65535f, 16777216f, 1e10f];
	var g = 0;
	for (i < NONNEG.length) {
		g = mix(g, int.view(u32.truncf(NONNEG[i])));
		g = mixl(g, long.view(u64.truncf(NONNEG[i])));
	}
	acci(g);

	// truncation is toward zero
	if (int.truncf(3.9f) != 3) fail_assert(601);
	if (int.truncf(-3.9f) != -3) fail_assert(602);
	if (int.truncf(-0.0f) != 0) fail_assert(603);
	if (long.truncf(1e10f) != 10000000000L) fail_assert(604);
	// exact casts that must succeed
	if (int.!(3f) != 3) fail_assert(605);
	if (int.!(-4f) != -4) fail_assert(606);
	if (long.!(1e10f) != 10000000000L) fail_assert(607);
	// queries
	if (!int.?(3f)) fail_assert(608);
	if (int.?(3.5f)) fail_assert(609);
	if (int.?(float.nan)) fail_assert(610);
	if (int.?(1e10f)) fail_assert(611);		// out of int range
	if (!long.?(1e10f)) fail_assert(612);
	if (u32.?(-1f)) fail_assert(613);
	// promotion to double is exact
	var d: double = 3.5f;
	if (d != 3.5d) fail_assert(614);
}

//======================================================================
// Section 7: floats in arrays and ranges
//======================================================================
def arrays() {
	var a = Array<float>.new(64);
	for (i < a.length) a[i] = float.roundi(i) * 0.25f - 4f;
	var h = 0;
	for (i < a.length) h = mixf(h, a[i]);
	acci(h);

	var r: Range<float> = a;
	var mid = r[16 ... 48];
	var tail = r[48 ...];
	var g = mix(0, mid.length);
	for (i < mid.length) g = mixf(g, mid[i]);
	for (i < tail.length) g = mixf(g, tail[i]);
	acci(g);

	// range writes alias the backing array
	for (i < mid.length) mid[i] = mid[i] * -2f;
	var k = 0;
	for (i < a.length) k = mixf(k, a[i]);
	acci(k);
	// the aliased write is visible through the backing array
	if (a[20] != (float.roundi(20) * 0.25f - 4f) * -2f) fail_assert(700);
	if (mid.length != 32) fail_assert(701);
	if (tail.length != 16) fail_assert(702);

	// two-dimensional
	var m = Array<Array<float>>.new(8);
	for (i < m.length) {
		m[i] = Array<float>.new(8);
		for (j < 8) m[i][j] = float.roundi(i * 8 + j) / 3f;
	}
	var sum = 0f;
	for (i < m.length) for (j < 8) sum += m[i][j];
	acci(mixf(0, sum));

	// arrays preserve NaN and signed zero across a copy
	var sp: Array<float> = [float.nan, float.infinity, -float.infinity, -0.0f];
	var cp = Array<float>.new(sp.length);
	for (i < sp.length) cp[i] = sp[i];
	var c = 0;
	for (i < cp.length) c = mixf(c, cp[i]);
	acci(c);
	if (cp[0] == cp[0]) fail_assert(703);			// NaN survived
	if (int.view(cp[3]) != int.view(-0.0f)) fail_assert(704);	// -0.0 survived
}

//======================================================================
// Section 8: floats in tuples
//======================================================================
def swapf(t: (float, float)) -> (float, float) {
	return (t.1, t.0);
}
def three(a: float, b: float, c: float) -> (float, float, float) {
	return (a + b, b + c, c + a);
}
def tuples() {
	var h = 0;
	for (i < VALS.length) {
		var t = (VALS[i], VALS[(i + 3) % VALS.length]);
		var s = swapf(t);
		h = mixf(h, t.0);
		h = mixf(h, t.1);
		h = mixf(h, s.0);
		h = mixf(h, s.1);
		h = mixb(h, t == s);
	}
	acci(h);
	var ts = Array<(float, float, int)>.new(16);
	for (i < ts.length) ts[i] = (float.roundi(i) * 1.5f, float.roundi(i) / 7f, i);
	var g = 0;
	for (i < ts.length) {
		var t = ts[i];
		g = mixf(g, t.0);
		g = mixf(g, t.1);
		g = mix(g, t.2);
	}
	acci(g);
	var q = three(1.5f, -2.25f, 8f);
	var n = ((1f, 2f), (3f, (4f, 5f)));	// nested tuples
	var k = mixf(0, q.0);
	k = mixf(k, q.1);
	k = mixf(k, q.2);
	k = mixf(k, n.0.0);
	k = mixf(k, n.0.1);
	k = mixf(k, n.1.0);
	k = mixf(k, n.1.1.0);
	k = mixf(k, n.1.1.1);
	acci(k);

	if (q.0 != -0.75f) fail_assert(801);
	if (q.1 != 5.75f) fail_assert(802);
	if (q.2 != 9.5f) fail_assert(803);
	if (n.1.1.1 != 5f) fail_assert(804);
	if (swapf((1f, 2f)).0 != 2f) fail_assert(805);
	if ((1f, 2f) == (2f, 1f)) fail_assert(806);
	if (!((1f, 2f) == (1f, 2f))) fail_assert(807);
}

//======================================================================
// Section 9: floats in globals and components
//======================================================================
var gf: float;
var gt: (float, float);
var ga: Array<float>;

component Store {
	var cur: float = 1.5f;
	def base: float = -0.75f;
	var hist: Array<float> = Array<float>.new(8);
	var n: int;

	def push(f: float) -> float {
		cur = cur + f;
		hist[n % hist.length] = cur;
		n++;
		return cur;
	}
}
def globals() {
	// Reset all mutable global state; the harness may run several inputs in one
	// process, so a section must never depend on what ran before it.
	gf = 0f;
	gt = (0f, 0f);
	Store.cur = 1.5f;
	Store.n = 0;
	Store.hist = Array<float>.new(8);

	ga = Array<float>.new(VALS.length);
	var h = 0;
	for (i < VALS.length) {
		gf = VALS[i];
		gt = (gf, gf * 2f);
		ga[i] = gf - 1f;
		h = mixf(h, gf);
		h = mixf(h, gt.0);
		h = mixf(h, gt.1);
		h = mixf(h, ga[i]);
	}
	acci(h);
	var g = mixf(0, Store.base);
	for (i < 20) g = mixf(g, Store.push(float.roundi(i) * 0.125f));
	for (i < Store.hist.length) g = mixf(g, Store.hist[i]);
	g = mix(g, Store.n);
	g = mixf(g, Store.cur);
	acci(g);

	if (Store.base != -0.75f) fail_assert(901);
	if (Store.n != 20) fail_assert(902);
}

//======================================================================
// Section 10: floats in class fields
//======================================================================
class FBox {
	var v: float;
	def tag: int;
	new(v, tag) { }
	def value() -> float { return v; }
	def scaled() -> float { return v; }
}
class FScale extends FBox {
	def k: float;
	new(v: float, tag: int, k) super(v, tag) { }
	def scaled() -> float { return v * k; }
}
class FPair extends FScale {
	var other: FBox;
	new(v: float, k: float, other) super(v, 2, k) { }
	def scaled() -> float { return if(other == null, v, v * k + other.value()); }
}
def classes() {
	var objs = Array<FBox>.new(3 * VALS.length);
	for (i < VALS.length) {
		var v = VALS[i];
		objs[3 * i + 0] = FBox.new(v, i);
		objs[3 * i + 1] = FScale.new(v, i, 0.5f);
		objs[3 * i + 2] = FPair.new(v, -2f, objs[3 * i + 0]);
	}
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mixf(h, o.value());
		h = mixf(h, o.scaled());	// virtual dispatch over 3 implementations
		h = mix(h, o.tag);
		h = mixb(h, FScale.?(o));
		h = mixb(h, FPair.?(o));
	}
	acci(h);
	// mutate through the array and re-read
	for (i < objs.length) objs[i].v = objs[i].v + 1f;
	var g = 0;
	for (i < objs.length) g = mixf(g, objs[i].scaled());
	acci(g);

	var b = FBox.new(3f, 7);
	var s = FScale.new(3f, 7, 0.5f);
	var p = FPair.new(3f, 4f, null);
	if (b.scaled() != 3f) fail_assert(1001);
	if (s.scaled() != 1.5f) fail_assert(1002);
	if (p.scaled() != 3f) fail_assert(1003);		// null other
	if (FPair.new(3f, 4f, b).scaled() != 15f) fail_assert(1004);
	if (!FScale.?(p)) fail_assert(1005);
	if (FPair.?(s)) fail_assert(1006);
	if (b.tag != 7) fail_assert(1007);
}

//======================================================================
// Section 11: floats in variants
//======================================================================
type FVal {
	case Scalar(f: float);
	case Pair(a: float, b: float);
	case Boxed(o: FBox);
	case Nothing;
}
type FUnboxed #unboxed {
	case One(f: float);
	case Two(f: float, g: float);
	case Zero;
}
def evalv(v: FVal) -> float {
	match (v) {
		Scalar(f) => return f;
		Pair(a, b) => return a * b;
		Boxed(o) => return if(o == null, -1f, o.v);
		Nothing => return 0f;
	}
}
def evalu(v: FUnboxed) -> float {
	match (v) {
		One(f) => return f;
		Two(f, g) => return f - g;
		Zero => return -0.0f;
	}
}
def variants() {
	var h = 0;
	for (i < VALS.length) {
		var v = VALS[i];
		var b: FVal = FVal.Scalar(v);
		var p: FVal = FVal.Pair(v, 0.25f);
		var o: FVal = FVal.Boxed(FBox.new(v, i));
		var n: FVal = FVal.Nothing;
		h = mixf(h, evalv(b));
		h = mixf(h, evalv(p));
		h = mixf(h, evalv(o));
		h = mixf(h, evalv(n));
		h = mix(h, b.tag);
		h = mix(h, p.tag);
		h = mix(h, o.tag);
		h = mix(h, n.tag);
		h = mixb(h, b == p);
		h = mixb(h, FVal.Pair.?(p));

		var u1: FUnboxed = FUnboxed.One(v);
		var u2: FUnboxed = FUnboxed.Two(v, 1.5f);
		var u3: FUnboxed = FUnboxed.Zero;
		h = mixf(h, evalu(u1));
		h = mixf(h, evalu(u2));
		h = mixf(h, evalu(u3));
		h = mixb(h, u1 == u2);
		// NaN payloads are excluded from variant equality: it constant-folds to
		// true but evaluates to false at runtime. See test/variants/eq_nan*.v3.
		var ev = if(v != v, 1.5f, v);
		h = mixb(h, FUnboxed.One(ev) == FUnboxed.One(ev));
		h = mixb(h, FUnboxed.One(ev) == FUnboxed.One(ev + 1f));
		h = mixb(h, FUnboxed.One(ev) == FUnboxed.Zero);
		h = mix(h, u2.tag);
	}
	acci(h);
	var arr = Array<FUnboxed>.new(VALS.length);
	var barr = Array<FVal>.new(VALS.length);
	for (i < arr.length) {
		arr[i] = FUnboxed.Two(VALS[i], float.roundi(i));
		barr[i] = FVal.Pair(VALS[i], float.roundi(i));
	}
	var g = 0;
	for (i < arr.length) {
		g = mixf(g, evalu(arr[i]));
		g = mixf(g, evalv(barr[i]));
	}
	acci(g);

	if (evalv(FVal.Scalar(2.5f)) != 2.5f) fail_assert(1101);
	if (evalv(FVal.Pair(2f, 4f)) != 8f) fail_assert(1102);
	if (evalv(FVal.Nothing) != 0f) fail_assert(1103);
	if (evalu(FUnboxed.Two(5f, 2f)) != 3f) fail_assert(1104);
	if (int.view(evalu(FUnboxed.Zero)) != int.view(-0.0f)) fail_assert(1105);
	if (FVal.Scalar(1f).tag != 0) fail_assert(1106);
	if (FVal.Nothing.tag != 3) fail_assert(1107);
	if (!(FUnboxed.One(2f) == FUnboxed.One(2f))) fail_assert(1108);
	if (FUnboxed.One(2f) == FUnboxed.One(3f)) fail_assert(1109);
	if (FUnboxed.One(0f) == FUnboxed.One(-0.0f)) fail_assert(1110);	// bitwise
}

//======================================================================
// Section 12: floats through functions
//======================================================================
def addf(a: float, b: float) -> float { return a + b; }
def applyf(f: (float, float) -> float, a: float, b: float) -> float { return f(a, b); }
def foldf(f: (float, float) -> float, init: float, a: Array<float>) -> float {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def makeAdder(a: float) -> float -> float {
	return fun (b: float) => a + b;
}
def funcs() {
	def OPS: Array<(float, float) -> float> = [float.+, float.-, float.*, float./, addf];
	for (k < OPS.length) {
		var h = 0;
		for (i < VALS.length) h = mixf(h, applyf(OPS[k], VALS[i], 2.5f));
		h = mixf(h, foldf(OPS[k], 1f, VALS));
		acci(h);
	}
	var inc = addf(1f, _);			// partial application
	var dec = addf(_, -1f);
	var g = 0;
	for (i < VALS.length) {
		g = mixf(g, inc(VALS[i]));
		g = mixf(g, dec(VALS[i]));
	}
	acci(g);
	var adders = Array<float -> float>.new(8);
	for (i < adders.length) adders[i] = makeAdder(float.roundi(i) * 0.5f);
	var k = 0;
	for (i < adders.length) for (j < VALS.length) k = mixf(k, adders[i](VALS[j]));
	var v: float -> float = float.sqrt;
	for (i < VALS.length) k = mixf(k, v(VALS[i]));
	acci(k);

	if (applyf(float.+, 1.5f, 2.5f) != 4f) fail_assert(1201);
	if (applyf(float.*, 1.5f, 4f) != 6f) fail_assert(1202);
	if (addf(1f, _)(2.5f) != 3.5f) fail_assert(1203);
	if (addf(_, -1f)(2.5f) != 1.5f) fail_assert(1204);
	if (makeAdder(3f)(4f) != 7f) fail_assert(1205);
}

//======================================================================
// Section 13: allocation churn with live float data
//======================================================================
class Node(val: float, next: Node) { }
def churn() {
	var head: Node;
	var live = Array<Node>.new(16);
	for (i < 2000) {
		var f = float.roundi(i) * 0.5f - 100f;
		head = Node.new(f, head);
		if ((i % 97) == 0) live[(i / 97) % live.length] = head;
		if ((i % 13) == 0) head = null;		// drop most of the chain
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mixf(h, p.val);
			p = p.next;
			n++;
			if (n > 100000) { acci(h); return; }
		}
	}
	h = mix(h, n);
	var p = head;
	while (p != null) { h = mixf(h, p.val); p = p.next; }
	acci(h);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) arith();
	if (a == 0 || a == 2) compare();
	if (a == 0 || a == 3) bits();
	if (a == 0 || a == 4) math();
	if (a == 0 || a == 5) convIn();
	if (a == 0 || a == 6) convOut();
	if (a == 0 || a == 7) arrays();
	if (a == 0 || a == 8) tuples();
	if (a == 0 || a == 9) globals();
	if (a == 0 || a == 10) classes();
	if (a == 0 || a == 11) variants();
	if (a == 0 || a == 12) funcs();
	if (a == 0 || a == 13) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
