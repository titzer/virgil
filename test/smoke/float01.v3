//@execute 0=-552596058; 1=-450280339; 2=243348859; 3=-1861673175; 4=1310209611; 5=-1297120143; 6=-1790161575; 7=-280523454; 8=-963131165; 9=1857142848; 10=2047618217; 11=-1981632773; 12=1673425102; 13=1747964674
// Smoke test: 32-bit floating point.
// Each section exercises a group of float operations and folds every observed
// result into a running CRC, so no check can be optimized away as dead code.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// CRC accumulator
//======================================================================
var crc: int;

def acci(x: int) {
	var h = crc ^ x;
	h = h * 0x01000193;
	crc = h ^ (h >>> 15);
}
def accl(x: long) {
	acci(int.view(u32.view(x)));
	acci(int.view(u32.view(x >> 32)));
}
def accb(x: bool) {
	acci(if(x, 0x5A5A5A5A, 0x0F0F0F0F));
}
// NaN bit patterns are not guaranteed identical across backends, so all NaNs
// accumulate one canonical marker; every other value accumulates exact bits
// (which distinguishes 0.0 from -0.0).
def accf(f: float) {
	if (f != f) acci(0x4E614E00);
	else acci(int.view(f));
}
def accd(d: double) {
	if (d != d) acci(0x4E614E01);
	else accl(long.view(d));
}

//======================================================================
// Shared data
//======================================================================
def VALS: Array<float> = [
	0f, -0.0f, 1f, -1f, 0.5f, -0.5f, 2f, 3.5f,
	-7.25f, 1e-10f, 1e10f, 16777216f, 16777217f,
	float.infinity, -float.infinity, float.nan
];
def INTS: Array<int> = [
	0, 1, -1, 2, 127, -128, 65535, 16777216, 16777217,
	2147483647, -2147483648, 1000000, -1000000
];
def LONGS: Array<long> = [
	0, 1, -1, 1024, -1024, 16777217, 4294967296,
	9007199254740993, -9007199254740993, 1234567890123
];

//======================================================================
// Section 1: arithmetic
//======================================================================
def arith() {
	for (i < VALS.length) {
		var a = VALS[i];
		accf(-a);
		for (j < VALS.length) {
			var b = VALS[j];
			accf(a + b);
			accf(a - b);
			accf(a * b);
			accf(a / b);
		}
	}
	// compound assignment forms
	var x = 1.5f;
	x += 2.25f; accf(x);
	x -= 0.5f;  accf(x);
	x *= 4f;    accf(x);
	x /= 3f;    accf(x);
}

//======================================================================
// Section 2: comparisons
//======================================================================
def compare() {
	for (i < VALS.length) {
		var a = VALS[i];
		for (j < VALS.length) {
			var b = VALS[j];
			accb(a == b);
			accb(a != b);
			accb(a < b);
			accb(a <= b);
			accb(a > b);
			accb(a >= b);
		}
	}
	// identities that hold only under IEEE semantics
	accb(float.nan != float.nan);
	accb(0f == -0.0f);
	accb(int.view(0f) != int.view(-0.0f));
	accb(float.infinity > 3.4028235e38f);
}

//======================================================================
// Section 3: bit-level structure and special values
//======================================================================
def bits() {
	for (i < VALS.length) {
		var a = VALS[i];
		acci(a.sign);
		acci(a.exponent);
		acci(a.fraction);
		accf(float.view(int.view(a)));	// round trip through raw bits
		acci(int.view(a));
	}
	accf(float.nan);
	accf(float.infinity);
	accf(-float.infinity);
	accf(1f / 0f);
	accf(-1f / 0f);
	accf(0f / 0f);
	accf(1f / -0.0f);
	accf(float.view(1));		// smallest denormal
	accf(float.view(0x007FFFFF));	// largest denormal
	accf(float.view(0x7F7FFFFF));	// float.max
}

//======================================================================
// Section 4: math operations
//======================================================================
def math() {
	for (i < VALS.length) {
		var a = VALS[i];
		accf(float.abs(a));
		accf(float.ceil(a));
		accf(float.floor(a));
		accf(float.sqrt(a));
		accf(float.round(a));
	}
	// half-way rounding behavior
	def HALVES: Array<float> = [-2.5f, -1.5f, -0.5f, 0.5f, 1.5f, 2.5f, 3.5f];
	for (i < HALVES.length) {
		accf(float.round(HALVES[i]));
		accf(float.ceil(HALVES[i]));
		accf(float.floor(HALVES[i]));
	}
}

//======================================================================
// Section 5: conversions into float
//======================================================================
def convIn() {
	for (i < INTS.length) {
		var v = INTS[i];
		accf(float.roundi(v));
		accf(float.roundi(long.!(v)));
		accb(float.?(v));
	}
	for (i < LONGS.length) {
		var v = LONGS[i];
		accf(float.roundi(v));
		accb(float.?(v));
	}
	def U32S: Array<u32> = [0, 1, 255, 16777217, 2147483648u, 4294967295u];
	for (i < U32S.length) accf(float.roundi(U32S[i]));
	def U64S: Array<u64> = [0, 1, 9007199254740993, 18446744073709551615uL];
	for (i < U64S.length) accf(float.roundi(U64S[i]));
	def DBLS: Array<double> = [0d, -0.0d, 1.25d, 1e300d, -1e300d, 1e-300d, 0.1d];
	for (i < DBLS.length) accf(float.roundd(DBLS[i]));
}

//======================================================================
// Section 6: conversions out of float
//======================================================================
def convOut() {
	def SAFE: Array<float> = [
		0f, -0.0f, 1f, -1f, 0.5f, -0.5f, 3.9f, -3.9f,
		127f, -128f, 65535f, 16777216f, 1e10f, -1e10f
	];
	for (i < SAFE.length) {
		var f = SAFE[i];
		acci(int.truncf(f));
		accl(long.truncf(f));
		var d: double = f;	// implicit promotion
		accd(d);
		accb(int.?(f));
		accb(long.?(f));
		accb(u32.?(f));
	}
	def NONNEG: Array<float> = [0f, 1f, 0.5f, 3.9f, 127f, 65535f, 16777216f, 1e10f];
	for (i < NONNEG.length) {
		acci(int.view(u32.truncf(NONNEG[i])));
		accl(long.view(u64.truncf(NONNEG[i])));
	}
	// exact casts that must succeed
	acci(int.!(3f));
	acci(int.!(-4f));
	accl(long.!(1e10f));
}

//======================================================================
// Section 7: floats in arrays and ranges
//======================================================================
def arrays() {
	var a = Array<float>.new(64);
	for (i < a.length) a[i] = float.roundi(i) * 0.25f - 4f;
	for (i < a.length) accf(a[i]);

	var r: Range<float> = a;
	var mid = r[16 ... 48];
	acci(mid.length);
	for (i < mid.length) accf(mid[i]);
	var tail = r[48 ...];
	for (i < tail.length) accf(tail[i]);

	// range writes alias the backing array
	for (i < mid.length) mid[i] = mid[i] * -2f;
	for (i < a.length) accf(a[i]);

	// two-dimensional
	var m = Array<Array<float>>.new(8);
	for (i < m.length) {
		m[i] = Array<float>.new(8);
		for (j < 8) m[i][j] = float.roundi(i * 8 + j) / 3f;
	}
	var sum = 0f;
	for (i < m.length) for (j < 8) sum += m[i][j];
	accf(sum);

	// array of NaN and infinity survives copy
	var sp: Array<float> = [float.nan, float.infinity, -float.infinity, -0.0f];
	var cp = Array<float>.new(sp.length);
	for (i < sp.length) cp[i] = sp[i];
	for (i < cp.length) accf(cp[i]);
}

//======================================================================
// Section 8: floats in tuples
//======================================================================
def swapf(t: (float, float)) -> (float, float) {
	return (t.1, t.0);
}
def three(a: float, b: float, c: float) -> (float, float, float) {
	return (a + b, b + c, c + a);
}
def tuples() {
	for (i < VALS.length) {
		var t = (VALS[i], VALS[(i + 3) % VALS.length]);
		accf(t.0);
		accf(t.1);
		var s = swapf(t);
		accf(s.0);
		accf(s.1);
		accb(t == s);
	}
	var ts = Array<(float, float, int)>.new(16);
	for (i < ts.length) ts[i] = (float.roundi(i) * 1.5f, float.roundi(i) / 7f, i);
	for (i < ts.length) {
		var t = ts[i];
		accf(t.0);
		accf(t.1);
		acci(t.2);
	}
	var q = three(1.5f, -2.25f, 8f);
	accf(q.0);
	accf(q.1);
	accf(q.2);
	// nested tuples
	var n = ((1f, 2f), (3f, (4f, 5f)));
	accf(n.0.0);
	accf(n.0.1);
	accf(n.1.0);
	accf(n.1.1.0);
	accf(n.1.1.1);
}

//======================================================================
// Section 9: floats in globals and components
//======================================================================
var gf: float;
var gt: (float, float);
var ga: Array<float>;

component Store {
	var cur: float = 1.5f;
	def base: float = -0.75f;
	var hist: Array<float> = Array<float>.new(8);
	var n: int;

	def push(f: float) -> float {
		cur = cur + f;
		hist[n % hist.length] = cur;
		n++;
		return cur;
	}
}
def globals() {
	// Reset all mutable global state; the harness may run several inputs in one
	// process, so a section must never depend on what ran before it.
	gf = 0f;
	gt = (0f, 0f);
	Store.cur = 1.5f;
	Store.n = 0;
	Store.hist = Array<float>.new(8);

	ga = Array<float>.new(VALS.length);
	for (i < VALS.length) {
		gf = VALS[i];
		gt = (gf, gf * 2f);
		ga[i] = gf - 1f;
		accf(gf);
		accf(gt.0);
		accf(gt.1);
		accf(ga[i]);
	}
	accf(Store.base);
	for (i < 20) accf(Store.push(float.roundi(i) * 0.125f));
	for (i < Store.hist.length) accf(Store.hist[i]);
	acci(Store.n);
	accf(Store.cur);
}

//======================================================================
// Section 10: floats in class fields
//======================================================================
class FBox {
	var v: float;
	def tag: int;
	new(v, tag) { }
	def value() -> float { return v; }
	def scaled() -> float { return v; }
}
class FScale extends FBox {
	def k: float;
	new(v: float, tag: int, k) super(v, tag) { }
	def scaled() -> float { return v * k; }
}
class FPair extends FScale {
	var other: FBox;
	new(v: float, k: float, other) super(v, 2, k) { }
	def scaled() -> float { return if(other == null, v, v * k + other.value()); }
}
def classes() {
	var objs = Array<FBox>.new(3 * VALS.length);
	for (i < VALS.length) {
		var v = VALS[i];
		objs[3 * i + 0] = FBox.new(v, i);
		objs[3 * i + 1] = FScale.new(v, i, 0.5f);
		objs[3 * i + 2] = FPair.new(v, -2f, objs[3 * i + 0]);
	}
	for (i < objs.length) {
		var o = objs[i];
		accf(o.value());
		accf(o.scaled());		// virtual dispatch over 3 implementations
		acci(o.tag);
		accb(FScale.?(o));
		accb(FPair.?(o));
	}
	// mutate through the array and re-read
	for (i < objs.length) objs[i].v = objs[i].v + 1f;
	for (i < objs.length) accf(objs[i].scaled());
	var np: FPair = FPair.new(3f, 4f, null);
	accf(np.scaled());
}

//======================================================================
// Section 11: floats in variants
//======================================================================
type FVal {
	case Scalar(f: float);
	case Pair(a: float, b: float);
	case Boxed(o: FBox);
	case Nothing;
}
type FUnboxed #unboxed {
	case One(f: float);
	case Two(f: float, g: float);
	case Zero;
}
def evalv(v: FVal) -> float {
	match (v) {
		Scalar(f) => return f;
		Pair(a, b) => return a * b;
		Boxed(o) => return if(o == null, -1f, o.v);
		Nothing => return 0f;
	}
}
def evalu(v: FUnboxed) -> float {
	match (v) {
		One(f) => return f;
		Two(f, g) => return f - g;
		Zero => return -0.0f;
	}
}
def variants() {
	for (i < VALS.length) {
		var v = VALS[i];
		var b: FVal = FVal.Scalar(v);
		var p: FVal = FVal.Pair(v, 0.25f);
		var o: FVal = FVal.Boxed(FBox.new(v, i));
		var n: FVal = FVal.Nothing;
		accf(evalv(b));
		accf(evalv(p));
		accf(evalv(o));
		accf(evalv(n));
		acci(b.tag);
		acci(p.tag);
		acci(o.tag);
		acci(n.tag);
		accb(b == p);
		accb(FVal.Pair.?(p));

		var u1: FUnboxed = FUnboxed.One(v);
		var u2: FUnboxed = FUnboxed.Two(v, 1.5f);
		var u3: FUnboxed = FUnboxed.Zero;
		accf(evalu(u1));
		accf(evalu(u2));
		accf(evalu(u3));
		accb(u1 == u2);
		// NaN payloads are excluded here: variant equality over a NaN float
		// field constant-folds to true but evaluates to false at runtime, so
		// the result is not portable. Everything else about NaN is covered above.
		var ev = if(v != v, 1.5f, v);
		accb(FUnboxed.One(ev) == FUnboxed.One(ev));
		accb(FUnboxed.One(ev) == FUnboxed.One(ev + 1f));
		accb(FUnboxed.One(ev) == FUnboxed.Zero);
		acci(u2.tag);
	}
	// variants stored in arrays
	var arr = Array<FUnboxed>.new(VALS.length);
	for (i < arr.length) arr[i] = FUnboxed.Two(VALS[i], float.roundi(i));
	for (i < arr.length) accf(evalu(arr[i]));
	var barr = Array<FVal>.new(VALS.length);
	for (i < barr.length) barr[i] = FVal.Pair(VALS[i], float.roundi(i));
	for (i < barr.length) accf(evalv(barr[i]));
}

//======================================================================
// Section 12: floats through functions
//======================================================================
def addf(a: float, b: float) -> float { return a + b; }
def applyf(f: (float, float) -> float, a: float, b: float) -> float { return f(a, b); }
def foldf(f: (float, float) -> float, init: float, a: Array<float>) -> float {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def makeAdder(a: float) -> float -> float {
	return fun (b: float) => a + b;
}
def funcs() {
	def OPS: Array<(float, float) -> float> = [float.+, float.-, float.*, float./, addf];
	for (k < OPS.length) {
		for (i < VALS.length) accf(applyf(OPS[k], VALS[i], 2.5f));
		accf(foldf(OPS[k], 1f, VALS));
	}
	var inc = addf(1f, _);			// partial application
	var dec = addf(_, -1f);
	for (i < VALS.length) {
		accf(inc(VALS[i]));
		accf(dec(VALS[i]));
	}
	var adders = Array<float -> float>.new(8);
	for (i < adders.length) adders[i] = makeAdder(float.roundi(i) * 0.5f);
	for (i < adders.length) for (j < VALS.length) accf(adders[i](VALS[j]));

	var q: (float, float) -> float = if(VALS.length > 0, float.*, float./);
	accf(q(3f, 4f));
	var v: float -> float = float.sqrt;
	for (i < VALS.length) accf(v(VALS[i]));
}

//======================================================================
// Section 13: allocation churn with live float data
//======================================================================
class Node(val: float, next: Node) { }
def churn() {
	var head: Node;
	var live = Array<Node>.new(16);
	for (i < 2000) {
		var f = float.roundi(i) * 0.5f - 100f;
		head = Node.new(f, head);
		if ((i % 97) == 0) live[(i / 97) % live.length] = head;
		if ((i % 13) == 0) head = null;		// drop most of the chain
	}
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			accf(p.val);
			p = p.next;
			n++;
			if (n > 100000) return;
		}
	}
	acci(n);
	var p = head;
	while (p != null) { accf(p.val); p = p.next; }
}

//======================================================================
def run(a: int) {
	crc = a * 0x9E3779B9;
	if (a == 0 || a == 1) arith();
	if (a == 0 || a == 2) compare();
	if (a == 0 || a == 3) bits();
	if (a == 0 || a == 4) math();
	if (a == 0 || a == 5) convIn();
	if (a == 0 || a == 6) convOut();
	if (a == 0 || a == 7) arrays();
	if (a == 0 || a == 8) tuples();
	if (a == 0 || a == 9) globals();
	if (a == 0 || a == 10) classes();
	if (a == 0 || a == 11) variants();
	if (a == 0 || a == 12) funcs();
	if (a == 0 || a == 13) churn();
}
def main(a: int) -> int {
	run(a);
	return crc;
}
