//@execute 0=1541062172; 1=-1234929017; 2=-1510994937; 3=150287331; 4=-1703946648; 5=93486628; 6=306774398; 7=746758989; 8=1364878227
//@heap-size=48000000
// Smoke test: bit-twiddling workloads.
// A CRC-32 implementation (table-driven, checked against the standard published
// check values), an MD5-style four-round mixing function built out of rotations
// and modular additions, and arbitrary-precision addition and multiplication
// over arrays of u32 limbs. These are dense integer, shift and unsigned
// arithmetic workloads whose outputs are exactly checkable: the CRC of "abc",
// (2^32-1)^2 in limbs, 20! compared against the same value computed in u64, and
// so on. Results are mixed into a running CRC that main() returns.
// Interleaved are assert()s over compile-time constants and hand-derived
// values; a folding or codegen bug shows up as the assertion id instead.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixu(h: int, x: u32) -> int { return mix(h, int.view(x)); }
def mixu64(h: int, x: u64) -> int { return mixl(h, long.view(x)); }
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

//======================================================================
// Bit primitives
//======================================================================
def rotl32(x: u32, n: byte) -> u32 {
	if (n == 0) return x;
	return (x << n) | (x >> byte.view(32 - int.!(n)));
}
def rotr32(x: u32, n: byte) -> u32 {
	if (n == 0) return x;
	return (x >> n) | (x << byte.view(32 - int.!(n)));
}
def popcount(x: u32) -> int {
	var c = 0;
	var v = x;
	while (v != 0) { c = c + int.view(v & 1u); v = v >> 1; }
	return c;
}
def bswap32(x: u32) -> u32 {
	return ((x & 0x000000FFu) << 24) | ((x & 0x0000FF00u) << 8) |
		((x & 0x00FF0000u) >> 8) | ((x & 0xFF000000u) >> 24);
}
def clz32(x: u32) -> int {
	if (x == 0) return 32;
	var n = 0;
	var v = x;
	while ((v & 0x80000000u) == 0) { n++; v = v << 1; }
	return n;
}
def reverseBits(x: u32) -> u32 {
	var r: u32 = 0;
	var v = x;
	for (i < 32) {
		r = (r << 1) | (v & 1u);
		v = v >> 1;
	}
	return r;
}

//======================================================================
// Section 1: bit primitives
//======================================================================
def bits() {
	if (rotl32(0x80000001u, 1) != 0x00000003u) fail_assert(101);
	if (rotl32(0x11223344u, 8) != 0x22334411u) fail_assert(102);
	if (rotr32(0x11223344u, 8) != 0x44112233u) fail_assert(103);
	if (rotl32(0x12345678u, 0) != 0x12345678u) fail_assert(104);
	if (rotl32(0xFFFFFFFFu, 13) != 0xFFFFFFFFu) fail_assert(105);
	if (rotr32(rotl32(0xDEADBEEFu, 7), 7) != 0xDEADBEEFu) fail_assert(106);
	if (popcount(0u) != 0) fail_assert(107);
	if (popcount(0xFFFFFFFFu) != 32) fail_assert(108);
	if (popcount(0x80000001u) != 2) fail_assert(109);
	if (popcount(0x0F0F0F0Fu) != 16) fail_assert(110);
	if (bswap32(0x11223344u) != 0x44332211u) fail_assert(111);
	if (bswap32(bswap32(0xCAFEBABEu)) != 0xCAFEBABEu) fail_assert(112);
	if (clz32(0u) != 32) fail_assert(113);
	if (clz32(1u) != 31) fail_assert(114);
	if (clz32(0x80000000u) != 0) fail_assert(115);
	if (clz32(0x00FF0000u) != 8) fail_assert(116);
	if (reverseBits(1u) != 0x80000000u) fail_assert(117);
	if (reverseBits(0x80000000u) != 1u) fail_assert(118);
	if (reverseBits(reverseBits(0x12345678u)) != 0x12345678u) fail_assert(119);
	if (reverseBits(0xFFFFFFFFu) != 0xFFFFFFFFu) fail_assert(120);
	// unsigned shifts do not sign-extend
	if ((0xFFFFFFFFu >> 31) != 1u) fail_assert(121);
	if (int.view(0x80000000u) != -2147483648) fail_assert(122);

	srand(0x8175);
	var h = 0;
	var bitsSeen = 0;
	for (i < 4000) {
		var x = u32.view(rand());
		h = mixu(h, rotl32(x, byte.view(i % 32)));
		h = mixu(h, rotr32(x, byte.view(i % 32)));
		h = mixu(h, bswap32(x));
		h = mixu(h, reverseBits(x));
		h = mix(h, popcount(x));
		h = mix(h, clz32(x));
		bitsSeen = bitsSeen + popcount(x);
		// identities that must hold for every value
		if (bswap32(bswap32(x)) != x) fail_assert(123);
		if (reverseBits(reverseBits(x)) != x) fail_assert(124);
		if (popcount(reverseBits(x)) != popcount(x)) fail_assert(125);
		if (popcount(bswap32(x)) != popcount(x)) fail_assert(126);
	}
	acci(h);
	acci(mix(0, bitsSeen));
	if (bitsSeen < 4000) fail_assert(127);
	if (bitsSeen > 128000) fail_assert(128);
}

//======================================================================
// CRC-32 (the standard reflected polynomial 0xEDB88320)
//======================================================================
def CRC_TABLE: Array<u32> = makeCrcTable();
def makeCrcTable() -> Array<u32> {
	var t = Array<u32>.new(256);
	for (i < 256) {
		var c = u32.view(i);
		for (k < 8) {
			if ((c & 1u) != 0) c = 0xEDB88320u ^ (c >> 1);
			else c = c >> 1;
		}
		t[i] = c;
	}
	return t;
}
def crc32Update(c: u32, b: byte) -> u32 {
	return CRC_TABLE[int.view((c ^ u32.!(b)) & 0xFFu)] ^ (c >> 8);
}
def crc32(data: Array<byte>) -> u32 {
	var c = 0xFFFFFFFFu;
	for (i < data.length) c = crc32Update(c, data[i]);
	return c ^ 0xFFFFFFFFu;
}
// bitwise reference implementation, used to cross-check the table version
def crc32Slow(data: Array<byte>) -> u32 {
	var c = 0xFFFFFFFFu;
	for (i < data.length) {
		c = c ^ u32.!(data[i]);
		for (k < 8) {
			if ((c & 1u) != 0) c = 0xEDB88320u ^ (c >> 1);
			else c = c >> 1;
		}
	}
	return c ^ 0xFFFFFFFFu;
}

//======================================================================
// Section 2: CRC-32 against the published check values
//======================================================================
def crcKnown() {
	if (CRC_TABLE.length != 256) fail_assert(201);
	if (CRC_TABLE[0] != 0u) fail_assert(202);
	if (CRC_TABLE[1] != 0x77073096u) fail_assert(203);
	if (CRC_TABLE[255] != 0x2D02EF8Du) fail_assert(204);
	// the standard CRC-32 check values
	if (crc32("") != 0u) fail_assert(205);
	if (crc32("a") != 0xE8B7BE43u) fail_assert(206);
	if (crc32("abc") != 0x352441C2u) fail_assert(207);
	if (crc32("123456789") != 0xCBF43926u) fail_assert(208);
	if (crc32("message digest") != 0x20159D7Fu) fail_assert(209);
	if (crc32("abcdefghijklmnopqrstuvwxyz") != 0x4C2750BDu) fail_assert(210);
	// the two implementations must agree
	if (crc32Slow("") != crc32("")) fail_assert(211);
	if (crc32Slow("abc") != crc32("abc")) fail_assert(212);
	if (crc32Slow("123456789") != crc32("123456789")) fail_assert(213);
	// a single differing bit changes the result
	if (crc32("abc") == crc32("abd")) fail_assert(214);
	if (crc32("ab") == crc32("ba")) fail_assert(215);
	var h = 0;
	for (i < CRC_TABLE.length) h = mixu(h, CRC_TABLE[i]);
	acci(h);
	acci(mixu(0, crc32("the quick brown fox jumps over the lazy dog")));
}

//======================================================================
// Section 3: CRC-32 over generated buffers, incremental and one-shot
//======================================================================
def crcBulk() {
	srand(0x8375);
	var h = 0;
	for (round < 60) {
		var n = randn(600);
		var data = Array<byte>.new(n);
		for (i < n) data[i] = byte.view(rand());
		var one = crc32(data);
		// incremental over the same bytes must match the one-shot value
		var c = 0xFFFFFFFFu;
		for (i < n) c = crc32Update(c, data[i]);
		if ((c ^ 0xFFFFFFFFu) != one) fail_assert(301);
		if (n < 200 && crc32Slow(data) != one) fail_assert(302);
		h = mixu(h, one);
	}
	acci(h);
	// appending a byte changes the CRC
	var base = Array<byte>.new(64);
	for (i < base.length) base[i] = byte.view(i * 7);
	var b0 = crc32(base);
	var longer = Array<byte>.new(65);
	for (i < base.length) longer[i] = base[i];
	longer[64] = 0;
	if (crc32(longer) == b0) fail_assert(303);
	// an all-zero buffer of length 1 has a fixed CRC: table[0xFF] path
	var z1 = Array<byte>.new(1);
	if (crc32(z1) != 0xD202EF8Du) fail_assert(304);
	var z2 = Array<byte>.new(2);
	if (crc32(z2) != 0x41D912FFu) fail_assert(305);
	var z4 = Array<byte>.new(4);
	if (crc32(z4) != 0x2144DF1Cu) fail_assert(306);
	acci(mixu(mixu(mixu(0, crc32(z1)), crc32(z2)), crc32(z4)));
	// a big buffer, to keep the loop hot
	var big = Array<byte>.new(20000);
	for (i < big.length) big[i] = byte.view(i * 31 + 7);
	var bc = crc32(big);
	if (bc != crc32Slow(big)) fail_assert(307);
	acci(mixu(0, bc));
	if (big.length != 20000) fail_assert(308);
}

//======================================================================
// An MD5-style mixing function: the four auxiliary functions and a
// four-round compression over 16-word blocks.
//======================================================================
def fF(x: u32, y: u32, z: u32) -> u32 { return (x & y) | (~x & z); }
def fG(x: u32, y: u32, z: u32) -> u32 { return (x & z) | (y & ~z); }
def fH(x: u32, y: u32, z: u32) -> u32 { return x ^ y ^ z; }
def fI(x: u32, y: u32, z: u32) -> u32 { return y ^ (x | ~z); }
def SHIFTS: Array<byte> = [7, 12, 17, 22, 5, 9, 14, 20, 4, 11, 16, 23, 6, 10, 15, 21];
def KVALS: Array<u32> = [
	0xD76AA478u, 0xE8C7B756u, 0x242070DBu, 0xC1BDCEEEu,
	0xF57C0FAFu, 0x4787C62Au, 0xA8304613u, 0xFD469501u,
	0x698098D8u, 0x8B44F7AFu, 0xFFFF5BB1u, 0x895CD7BEu,
	0x6B901122u, 0xFD987193u, 0xA679438Eu, 0x49B40821u
];
class Digest {
	var a = 0x67452301u;
	var b = 0xEFCDAB89u;
	var c = 0x98BADCFEu;
	var d = 0x10325476u;
	def block(m: Array<u32>) {
		var aa = a, bb = b, cc = c, dd = d;
		for (i < 16) {
			var f: u32;
			var g: int;
			var round = i / 4;
			if (round == 0) { f = fF(bb, cc, dd); g = i; }
			else if (round == 1) { f = fG(bb, cc, dd); g = (5 * i + 1) & 15; }
			else if (round == 2) { f = fH(bb, cc, dd); g = (3 * i + 5) & 15; }
			else { f = fI(bb, cc, dd); g = (7 * i) & 15; }
			var tmp = dd;
			dd = cc;
			cc = bb;
			var sum = aa + f + KVALS[i] + m[g];
			bb = bb + rotl32(sum, SHIFTS[i]);
			aa = tmp;
		}
		a = a + aa;
		b = b + bb;
		c = c + cc;
		d = d + dd;
	}
	def fold() -> int { return mixu(mixu(mixu(mixu(0, a), b), c), d); }
}
def digestOf(data: Array<byte>) -> Digest {
	var dg = Digest.new();
	var m = Array<u32>.new(16);
	var i = 0;
	while (i + 64 <= data.length) {
		for (k < 16) {
			var o = i + k * 4;
			m[k] = u32.!(data[o]) | (u32.!(data[o + 1]) << 8) |
				(u32.!(data[o + 2]) << 16) | (u32.!(data[o + 3]) << 24);
		}
		dg.block(m);
		i = i + 64;
	}
	// the tail is padded with zeros into one final block
	for (k < 16) m[k] = 0;
	var rem = data.length - i;
	for (k < rem) {
		var w = k / 4, s = byte.view((k % 4) * 8);
		m[w] = m[w] | (u32.!(data[i + k]) << s);
	}
	m[15] = u32.view(data.length);
	dg.block(m);
	return dg;
}

//======================================================================
// Section 4: the mixing function
//======================================================================
def mixer() {
	// the auxiliary functions, on hand-checkable inputs
	if (fF(0xFFFFFFFFu, 0xAAAAAAAAu, 0x55555555u) != 0xAAAAAAAAu) fail_assert(401);
	if (fF(0u, 0xAAAAAAAAu, 0x55555555u) != 0x55555555u) fail_assert(402);
	if (fG(0xFFFFFFFFu, 0xAAAAAAAAu, 0x55555555u) != 0xFFFFFFFFu) fail_assert(403);
	if (fG(0u, 0xAAAAAAAAu, 0xFFFFFFFFu) != 0u) fail_assert(404);
	if (fH(0xF0F0F0F0u, 0x0F0F0F0Fu, 0u) != 0xFFFFFFFFu) fail_assert(405);
	if (fH(0xFFFFFFFFu, 0xFFFFFFFFu, 0x12345678u) != 0x12345678u) fail_assert(406);
	if (fI(0u, 0u, 0xFFFFFFFFu) != 0u) fail_assert(407);
	if (fI(0u, 0xFFFFFFFFu, 0xFFFFFFFFu) != 0xFFFFFFFFu) fail_assert(408);
	if (~0u != 0xFFFFFFFFu) fail_assert(409);
	if (SHIFTS.length != 16) fail_assert(410);
	if (KVALS.length != 16) fail_assert(411);
	if (SHIFTS[3] != 22) fail_assert(412);
	if (KVALS[0] != 0xD76AA478u) fail_assert(413);

	// the initial state, and the fact that mixing changes it
	var d0 = Digest.new();
	if (d0.a != 0x67452301u) fail_assert(414);
	if (d0.d != 0x10325476u) fail_assert(415);
	var zeros = Array<u32>.new(16);
	d0.block(zeros);
	if (d0.a == 0x67452301u) fail_assert(416);

	// determinism: the same input always gives the same digest
	var t1 = digestOf("hello world");
	var t2 = digestOf("hello world");
	if (t1.a != t2.a) fail_assert(417);
	if (t1.b != t2.b) fail_assert(418);
	if (t1.c != t2.c) fail_assert(419);
	if (t1.d != t2.d) fail_assert(420);
	if (t1.fold() != t2.fold()) fail_assert(421);
	// avalanche: a one-bit change changes the digest
	if (digestOf("hello world").fold() == digestOf("hello worle").fold()) fail_assert(422);
	if (digestOf("").fold() == digestOf("a").fold()) fail_assert(423);
	// length is part of the input, so these differ despite equal prefixes
	if (digestOf("aa").fold() == digestOf("aaa").fold()) fail_assert(424);

	srand(0x8475);
	var h = 0;
	var same = 0;
	for (round < 120) {
		var n = randn(300);
		var data = Array<byte>.new(n);
		for (i < n) data[i] = byte.view(rand());
		var dg = digestOf(data);
		var again = digestOf(data);
		if (dg.fold() != again.fold()) same++;
		h = mix(h, dg.fold());
		h = mixu(h, dg.a);
		h = mixu(h, dg.d);
	}
	acci(h);
	if (same != 0) fail_assert(425);
	// long inputs exercise the multi-block path
	var big = Array<byte>.new(4096);
	for (i < big.length) big[i] = byte.view(i * 13 + 5);
	acci(mix(0, digestOf(big).fold()));
	if (digestOf(big).fold() != digestOf(big).fold()) fail_assert(426);
}

//======================================================================
// Arbitrary precision arithmetic over little-endian u32 limbs
//======================================================================
def bnFromU64(v: u64) -> Array<u32> {
	var a = Array<u32>.new(2);
	a[0] = u32.view(v);
	a[1] = u32.view(v >> 32);
	return a;
}
def bnFromInt(v: int) -> Array<u32> {
	var a = Array<u32>.new(1);
	a[0] = u32.view(v);
	return a;
}
def bnLen(a: Array<u32>) -> int {			// significant limbs
	var n = a.length;
	while (n > 0 && a[n - 1] == 0) n--;
	return n;
}
def bnAdd(a: Array<u32>, b: Array<u32>) -> Array<u32> {
	var n = if(a.length > b.length, a.length, b.length);
	var r = Array<u32>.new(n + 1);
	var carry: u64 = 0;
	for (i < n) {
		var s = carry;
		if (i < a.length) s = s + u64.!(a[i]);
		if (i < b.length) s = s + u64.!(b[i]);
		r[i] = u32.view(s);
		carry = s >> 32;
	}
	r[n] = u32.view(carry);
	return r;
}
def bnMul(a: Array<u32>, b: Array<u32>) -> Array<u32> {
	var r = Array<u32>.new(a.length + b.length);
	for (i < a.length) {
		if (a[i] == 0) continue;
		var carry: u64 = 0;
		for (j < b.length) {
			var t = u64.!(a[i]) * u64.!(b[j]) + u64.!(r[i + j]) + carry;
			r[i + j] = u32.view(t);
			carry = t >> 32;
		}
		var k = i + b.length;
		while (carry != 0) {
			var t = u64.!(r[k]) + carry;
			r[k] = u32.view(t);
			carry = t >> 32;
			k++;
		}
	}
	return r;
}
def bnMulSmall(a: Array<u32>, m: u32) -> Array<u32> {
	var r = Array<u32>.new(a.length + 1);
	var carry: u64 = 0;
	for (i < a.length) {
		var t = u64.!(a[i]) * u64.!(m) + carry;
		r[i] = u32.view(t);
		carry = t >> 32;
	}
	r[a.length] = u32.view(carry);
	return r;
}
def bnCmp(a: Array<u32>, b: Array<u32>) -> int {
	var la = bnLen(a), lb = bnLen(b);
	if (la != lb) return if(la < lb, -1, 1);
	for (i = la - 1; i >= 0; i--) {
		if (a[i] != b[i]) return if(a[i] < b[i], -1, 1);
	}
	return 0;
}
def bnToU64(a: Array<u32>) -> u64 {
	var v: u64 = 0;
	if (a.length > 0) v = u64.!(a[0]);
	if (a.length > 1) v = v | (u64.!(a[1]) << 32);
	return v;
}
def bnFold(a: Array<u32>) -> int {
	var n = bnLen(a);
	var h = mix(0, n);
	for (i < n) h = mixu(h, a[i]);
	return h;
}

//======================================================================
// Section 5: big-integer addition
//======================================================================
def bigAdd() {
	// 0xFFFFFFFF + 1 carries into a second limb
	var m1 = bnFromInt(-1);				// 0xFFFFFFFF
	if (m1[0] != 0xFFFFFFFFu) fail_assert(501);
	var s = bnAdd(m1, bnFromInt(1));
	if (s[0] != 0u) fail_assert(502);
	if (s[1] != 1u) fail_assert(503);
	if (bnLen(s) != 2) fail_assert(504);
	// 0xFFFFFFFF + 0xFFFFFFFF = 0x1FFFFFFFE
	var t = bnAdd(m1, m1);
	if (t[0] != 0xFFFFFFFEu) fail_assert(505);
	if (t[1] != 1u) fail_assert(506);
	// adding zero changes nothing
	var z = bnFromInt(0);
	if (bnLen(z) != 0) fail_assert(507);
	if (bnCmp(bnAdd(m1, z), m1) != 0) fail_assert(508);
	if (bnCmp(z, z) != 0) fail_assert(509);
	if (bnCmp(m1, z) != 1) fail_assert(510);
	if (bnCmp(z, m1) != -1) fail_assert(511);

	// carry propagating through many all-ones limbs
	var ones = Array<u32>.new(8);
	for (i < ones.length) ones[i] = 0xFFFFFFFFu;
	var inc = bnAdd(ones, bnFromInt(1));
	if (bnLen(inc) != 9) fail_assert(512);
	for (i < 8) if (inc[i] != 0u) fail_assert(513);
	if (inc[8] != 1u) fail_assert(514);
	acci(bnFold(inc));

	// repeated addition agrees with u64 arithmetic
	srand(0x8575);
	var h = 0;
	for (round < 200) {
		var x = u64.view(long.view(rand()) & 0xFFFFFFFFL);
		var y = u64.view(long.view(rand()) & 0xFFFFFFFFL);
		var bx = bnFromU64(x), by = bnFromU64(y);
		var r = bnAdd(bx, by);
		if (bnToU64(r) != x + y) fail_assert(515);
		h = mix(h, bnFold(r));
	}
	acci(h);
	// a long accumulation: sum of 1..2000 built up limb by limb
	var acc = bnFromInt(0);
	for (i = 1; i <= 2000; i++) acc = bnAdd(acc, bnFromInt(i));
	if (bnToU64(acc) != 2001000uL) fail_assert(516);
	if (bnLen(acc) != 1) fail_assert(517);
	acci(bnFold(acc));
	// addition is commutative and associative on these inputs
	var a = bnFromU64(0x1234_5678_9ABC_DEF0uL);
	var b = bnFromU64(0x0FED_CBA9_8765_4321uL);
	var c = bnFromU64(0x1111_1111_1111_1111uL);
	if (bnCmp(bnAdd(a, b), bnAdd(b, a)) != 0) fail_assert(518);
	if (bnCmp(bnAdd(bnAdd(a, b), c), bnAdd(a, bnAdd(b, c))) != 0) fail_assert(519);
	if (bnToU64(bnAdd(a, b)) != 0x2222_2222_2222_2211uL) fail_assert(520);
	acci(bnFold(bnAdd(bnAdd(a, b), c)));
}

//======================================================================
// Section 6: big-integer multiplication
//======================================================================
def bigMul() {
	// (2^32 - 1)^2 = 0xFFFFFFFE00000001
	var m1 = bnFromInt(-1);
	var sq = bnMul(m1, m1);
	if (sq[0] != 1u) fail_assert(601);
	if (sq[1] != 0xFFFFFFFEu) fail_assert(602);
	if (bnLen(sq) != 2) fail_assert(603);
	// 1000000 * 1000000 = 10^12 = 0xE8D4A51000
	var mm = bnMul(bnFromInt(1000000), bnFromInt(1000000));
	if (mm[0] != 0xD4A51000u) fail_assert(604);
	if (mm[1] != 0xE8u) fail_assert(605);
	if (bnToU64(mm) != 1000000000000uL) fail_assert(606);
	// multiplying by zero and by one
	var z = bnFromInt(0), one = bnFromInt(1);
	if (bnLen(bnMul(m1, z)) != 0) fail_assert(607);
	if (bnCmp(bnMul(m1, one), m1) != 0) fail_assert(608);
	if (bnCmp(bnMulSmall(m1, 1u), m1) != 0) fail_assert(609);
	if (bnToU64(bnMulSmall(m1, 2u)) != 0x1FFFFFFFEuL) fail_assert(610);

	// products agree with u64 arithmetic when they fit
	srand(0x8675);
	var h = 0;
	for (round < 200) {
		var x = u64.view(long.view(rand() & 0xFFFF));
		var y = u64.view(long.view(rand() & 0xFFFF));
		var r = bnMul(bnFromU64(x), bnFromU64(y));
		if (bnToU64(r) != x * y) fail_assert(611);
		h = mix(h, bnFold(r));
	}
	acci(h);
	// commutativity and distributivity over the same inputs
	var a = bnFromU64(0x1234_5678uL), b = bnFromU64(0x9ABC_DEF0uL), c = bnFromU64(0x0F0F_0F0FuL);
	if (bnCmp(bnMul(a, b), bnMul(b, a)) != 0) fail_assert(612);
	var lhs = bnMul(a, bnAdd(b, c));
	var rhs = bnAdd(bnMul(a, b), bnMul(a, c));
	if (bnCmp(lhs, rhs) != 0) fail_assert(613);
	acci(bnFold(lhs));
	// 2^n by repeated doubling: 2^64 is 1 in limb 2
	var p = bnFromInt(1);
	for (i < 64) p = bnMulSmall(p, 2u);
	if (bnLen(p) != 3) fail_assert(614);
	if (p[2] != 1u) fail_assert(615);
	if (p[0] != 0u) fail_assert(616);
	if (p[1] != 0u) fail_assert(617);
	acci(bnFold(p));
	// 2^100 has 4 limbs, with bit 4 set in the top one
	var q = bnFromInt(1);
	for (i < 100) q = bnMulSmall(q, 2u);
	if (bnLen(q) != 4) fail_assert(618);
	if (q[3] != 16u) fail_assert(619);			// 2^100 = 2^96 * 16
	acci(bnFold(q));
}

//======================================================================
// Section 7: factorials and Fibonacci, cross-checked against u64
//======================================================================
def bigSequences() {
	// 20! = 2432902008176640000 fits in u64
	var f = bnFromInt(1);
	var uf: u64 = 1;
	for (i = 1; i <= 20; i++) {
		f = bnMulSmall(f, u32.view(i));
		uf = uf * u64.view(long.!(i));
		if (bnToU64(f) != uf) fail_assert(701);
	}
	if (uf != 2432902008176640000uL) fail_assert(702);
	if (bnToU64(f) != 2432902008176640000uL) fail_assert(703);
	if (bnLen(f) != 2) fail_assert(704);
	acci(bnFold(f));
	// keep going to 100!, which no machine integer can hold
	for (i = 21; i <= 100; i++) f = bnMulSmall(f, u32.view(i));
	var n100 = bnLen(f);
	// 100! is about 9.33e157, which needs 525 bits, i.e. 17 limbs
	if (n100 != 17) fail_assert(705);
	acci(bnFold(f));
	acci(mix(0, n100));

	// Fibonacci: F(90) = 2880067194370816120 still fits in u64
	var a = bnFromInt(0), b = bnFromInt(1);
	var ua: u64 = 0, ub: u64 = 1;
	for (i < 90) {
		var t = bnAdd(a, b);
		a = b;
		b = t;
		var ut = ua + ub;
		ua = ub;
		ub = ut;
		if (bnToU64(a) != ua) fail_assert(706);
	}
	if (ua != 2880067194370816120uL) fail_assert(707);
	if (bnToU64(a) != 2880067194370816120uL) fail_assert(708);
	acci(bnFold(a));
	// and on to F(500), which does not
	for (i = 90; i < 500; i++) {
		var t = bnAdd(a, b);
		a = b;
		b = t;
	}
	// F(500) is about 1.39e104, needing 347 bits, i.e. 11 limbs
	if (bnLen(a) != 11) fail_assert(709);
	acci(bnFold(a));
	acci(mix(0, bnLen(a)));
	// the sequence is strictly increasing from F(2) on
	if (bnCmp(a, b) != -1) fail_assert(710);
}

//======================================================================
// Section 8: mixed workload, hashing big-integer digits
//======================================================================
def combinedBits() {
	srand(0x8875);
	var h = 0;
	for (round < 80) {
		// build a random big integer, then CRC its limbs as bytes
		var limbs = 1 + randn(8);
		var x = Array<u32>.new(limbs);
		for (i < limbs) x[i] = u32.view(rand());
		var y = Array<u32>.new(limbs);
		for (i < limbs) y[i] = u32.view(rand());
		var p = bnMul(x, y);
		var s = bnAdd(x, y);
		// the product of two n-limb numbers needs at most 2n limbs
		if (bnLen(p) > 2 * limbs) fail_assert(801);
		if (bnLen(s) > limbs + 1) fail_assert(802);
		// serialize the product little-endian and CRC it
		var bytes = Array<byte>.new(p.length * 4);
		for (i < p.length) {
			bytes[i * 4] = byte.view(p[i]);
			bytes[i * 4 + 1] = byte.view(p[i] >> 8);
			bytes[i * 4 + 2] = byte.view(p[i] >> 16);
			bytes[i * 4 + 3] = byte.view(p[i] >> 24);
		}
		h = mixu(h, crc32(bytes));
		h = mix(h, digestOf(bytes).fold());
		h = mix(h, bnFold(p));
		h = mix(h, bnFold(s));
	}
	acci(h);
	// round-tripping limbs through bytes preserves them
	var v = Array<u32>.new(4);
	v[0] = 0x11223344u; v[1] = 0xAABBCCDDu; v[2] = 0u; v[3] = 0xFFFFFFFFu;
	var b = Array<byte>.new(16);
	for (i < 4) {
		b[i * 4] = byte.view(v[i]);
		b[i * 4 + 1] = byte.view(v[i] >> 8);
		b[i * 4 + 2] = byte.view(v[i] >> 16);
		b[i * 4 + 3] = byte.view(v[i] >> 24);
	}
	if (b[0] != 0x44) fail_assert(803);
	if (b[3] != 0x11) fail_assert(804);
	if (b[4] != 0xDD) fail_assert(805);
	if (b[15] != 0xFF) fail_assert(806);
	var back = Array<u32>.new(4);
	for (i < 4) {
		back[i] = u32.!(b[i * 4]) | (u32.!(b[i * 4 + 1]) << 8) |
			(u32.!(b[i * 4 + 2]) << 16) | (u32.!(b[i * 4 + 3]) << 24);
	}
	for (i < 4) if (back[i] != v[i]) fail_assert(807);
	acci(bnFold(back));
	acci(mixu(0, crc32(b)));
	acci(mix(0, digestOf(b).fold()));
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) bits();
	if (a == 0 || a == 2) crcKnown();
	if (a == 0 || a == 3) crcBulk();
	if (a == 0 || a == 4) mixer();
	if (a == 0 || a == 5) bigAdd();
	if (a == 0 || a == 6) bigMul();
	if (a == 0 || a == 7) bigSequences();
	if (a == 0 || a == 8) combinedBits();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
