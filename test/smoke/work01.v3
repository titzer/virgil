//@execute 0=-1465536795; 1=-2005092644; 2=10898673; 3=-481260718; 4=-1801677976; 5=2089074012; 6=-2135041152; 7=-2105026960; 8=-1377893619
//@heap-size=6000000
// Smoke test: a realistic data-structure workload.
// An open-addressing hash map with string (byte array) keys and int values,
// including tombstoned deletion and rehashing, plus quicksort and mergesort over
// arrays of ints and over arrays of objects sorted by key. Everything is written
// out longhand -- no library is available to a standalone test -- so the file
// exercises string handling, array copying, recursion, comparisons and a large
// amount of allocation all at once.
// Results are mixed into a running CRC that main() returns, so nothing can be
// deleted as dead. Interleaved are assert()s over compile-time constants and
// small hand-checked inputs; a folding or codegen bug shows up as the assertion
// id instead of a hash.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

//======================================================================
// String helpers
//======================================================================
def streq(a: string, b: string) -> bool {
	if (a == b) return true;
	if (a == null || b == null) return false;
	if (a.length != b.length) return false;
	for (i < a.length) if (a[i] != b[i]) return false;
	return true;
}
// lexicographic; negative if a < b
def strcmp(a: string, b: string) -> int {
	var n = if(a.length < b.length, a.length, b.length);
	for (i < n) {
		if (a[i] != b[i]) return int.!(a[i]) - int.!(b[i]);
	}
	return a.length - b.length;
}
// FNV-1a over the bytes
def strhash(s: string) -> int {
	var h = 0x811C9DC5;
	for (i < s.length) {
		h = h ^ int.!(s[i]);
		h = h * 0x01000193;
	}
	return h;
}
// "k" followed by five decimal digits
def keyFor(n: int) -> string {
	var s = Array<byte>.new(6);
	s[0] = 'k';
	var v = n;
	for (i = 5; i >= 1; i--) {
		s[i] = byte.view('0' + (v % 10));
		v = v / 10;
	}
	return s;
}
// a key whose low hash bits are forced to collide: prefix + fixed suffix
def collideKey(n: int) -> string {
	var s = Array<byte>.new(4);
	s[0] = 'c';
	s[1] = byte.view('a' + (n % 26));
	s[2] = byte.view('a' + ((n / 26) % 26));
	s[3] = 'z';
	return s;
}

//======================================================================
// Section 1: string primitives
//======================================================================
def strings() {
	var k0 = keyFor(0), k1 = keyFor(1), k42 = keyFor(42), k99999 = keyFor(99999);
	if (k0.length != 6) fail_assert(101);
	if (k0[0] != 'k') fail_assert(102);
	if (k0[5] != '0') fail_assert(103);
	if (k1[5] != '1') fail_assert(104);
	if (k42[4] != '4') fail_assert(105);
	if (k42[5] != '2') fail_assert(106);
	if (k42[3] != '0') fail_assert(107);
	if (k99999[1] != '9') fail_assert(108);
	if (!streq(k42, keyFor(42))) fail_assert(109);
	if (streq(k42, keyFor(43))) fail_assert(110);
	if (streq(k42, null)) fail_assert(111);
	if (!streq(null, null)) fail_assert(112);
	if (strcmp(keyFor(1), keyFor(2)) >= 0) fail_assert(113);
	if (strcmp(keyFor(2), keyFor(1)) <= 0) fail_assert(114);
	if (strcmp(keyFor(7), keyFor(7)) != 0) fail_assert(115);
	if (strcmp("abc", "abd") != -1) fail_assert(116);
	if (strcmp("abc", "ab") != 1) fail_assert(117);
	if (strhash(keyFor(5)) != strhash(keyFor(5))) fail_assert(118);
	// FNV-1a of the single byte 'a' (0x61): (0x811C9DC5 ^ 0x61) * 0x01000193
	if (strhash("") != 0x811C9DC5) fail_assert(119);
	if (strhash("a") != mulFnv(0x811C9DC5 ^ 0x61)) fail_assert(120);

	var h = 0;
	for (i < 3000) {
		var k = keyFor(i);
		h = mix(h, strhash(k));
		h = mixs(h, k);
	}
	acci(h);
	var g = 0;
	var inversions = 0;
	for (i < 500) {
		var a = keyFor(i), b = keyFor(i + 1);
		if (strcmp(a, b) >= 0) inversions++;
		g = mix(g, strcmp(a, b));
	}
	acci(g);
	// keyFor is zero-padded, so numeric order and lexicographic order agree
	if (inversions != 0) fail_assert(121);
	var c = 0;
	for (i < 800) c = mixs(c, collideKey(i));
	acci(c);
	if (collideKey(0)[1] != 'a') fail_assert(122);
	if (collideKey(27)[1] != 'b') fail_assert(123);
	if (collideKey(27)[2] != 'b') fail_assert(124);
	if (collideKey(5)[3] != 'z') fail_assert(125);
}
def mulFnv(x: int) -> int { return x * 0x01000193; }

//======================================================================
// The hash map: open addressing, linear probing, tombstoned deletes.
//======================================================================
def EMPTY: byte = 0;
def FULL: byte = 1;
def DEAD: byte = 2;

class HashMap {
	var keys: Array<string>;
	var vals: Array<int>;
	var state: Array<byte>;
	var count: int;			// live entries
	var used: int;			// live entries + tombstones
	new(cap: int) {
		keys = Array<string>.new(cap);
		vals = Array<int>.new(cap);
		state = Array<byte>.new(cap);
	}
	// index of the key, or -1
	def find(k: string) -> int {
		var mask = keys.length - 1;
		var i = strhash(k) & mask;
		for (probe < keys.length) {
			if (state[i] == EMPTY) return -1;
			if (state[i] == FULL && streq(keys[i], k)) return i;
			i = (i + 1) & mask;
		}
		return -1;
	}
	// returns true if the key was newly inserted
	def put(k: string, v: int) -> bool {
		if ((used + 1) * 4 >= keys.length * 3) grow();
		var mask = keys.length - 1;
		var i = strhash(k) & mask;
		var firstDead = -1;
		for (probe < keys.length) {
			if (state[i] == EMPTY) {
				if (firstDead >= 0) i = firstDead;
				else used++;
				keys[i] = k;
				vals[i] = v;
				state[i] = FULL;
				count++;
				return true;
			}
			if (state[i] == DEAD) {
				if (firstDead < 0) firstDead = i;
			} else if (streq(keys[i], k)) {
				vals[i] = v;
				return false;
			}
			i = (i + 1) & mask;
		}
		return false;			// unreachable: the table is never full
	}
	def get(k: string, dflt: int) -> int {
		var i = find(k);
		return if(i < 0, dflt, vals[i]);
	}
	def has(k: string) -> bool { return find(k) >= 0; }
	def remove(k: string) -> bool {
		var i = find(k);
		if (i < 0) return false;
		state[i] = DEAD;
		keys[i] = null;
		vals[i] = 0;
		count--;
		return true;
	}
	def grow() {
		var oldk = keys, oldv = vals, olds = state;
		var ncap = keys.length * 2;
		keys = Array<string>.new(ncap);
		vals = Array<int>.new(ncap);
		state = Array<byte>.new(ncap);
		count = 0;
		used = 0;
		for (i < oldk.length) {
			if (olds[i] == FULL) put(oldk[i], oldv[i]);
		}
	}
	// deterministic fold over the table in slot order
	def fold() -> int {
		var h = mix(0, count);
		for (i < keys.length) {
			if (state[i] == FULL) {
				h = mixs(h, keys[i]);
				h = mix(h, vals[i]);
			}
		}
		return h;
	}
	def sumValues() -> int {
		var s = 0;
		for (i < keys.length) if (state[i] == FULL) s = s + vals[i];
		return s;
	}
}

//======================================================================
// Section 2: hash map basics on a hand-checkable set
//======================================================================
def mapBasics() {
	var m = HashMap.new(8);
	if (m.count != 0) fail_assert(201);
	if (m.get(keyFor(1), -5) != -5) fail_assert(202);
	if (m.has(keyFor(1))) fail_assert(203);
	if (!m.put(keyFor(1), 100)) fail_assert(204);
	if (m.count != 1) fail_assert(205);
	if (m.get(keyFor(1), -5) != 100) fail_assert(206);
	if (m.put(keyFor(1), 101)) fail_assert(207);	// overwrite, not new
	if (m.count != 1) fail_assert(208);
	if (m.get(keyFor(1), -5) != 101) fail_assert(209);
	for (i = 2; i <= 5; i++) m.put(keyFor(i), i * 100);
	if (m.count != 5) fail_assert(210);
	if (m.get(keyFor(5), 0) != 500) fail_assert(211);
	if (m.sumValues() != 101 + 200 + 300 + 400 + 500) fail_assert(212);
	if (!m.remove(keyFor(3))) fail_assert(213);
	if (m.remove(keyFor(3))) fail_assert(214);
	if (m.count != 4) fail_assert(215);
	if (m.has(keyFor(3))) fail_assert(216);
	if (m.get(keyFor(4), -1) != 400) fail_assert(217);	// probe past the tombstone
	if (m.sumValues() != 1201) fail_assert(218);
	if (!m.put(keyFor(3), 333)) fail_assert(219);		// reuses the tombstone
	if (m.count != 5) fail_assert(220);
	if (m.get(keyFor(3), 0) != 333) fail_assert(221);
	acci(m.fold());

	// a key looked up by an equal-but-distinct string still hits
	var alias = Array<byte>.new(6);
	var src = keyFor(4);
	for (i < src.length) alias[i] = src[i];
	if (alias == src) fail_assert(222);
	if (!streq(alias, src)) fail_assert(223);
	if (m.get(alias, -1) != 400) fail_assert(224);
	acci(mix(0, m.count));
}

//======================================================================
// Section 3: bulk insert / lookup / delete
//======================================================================
def mapBulk() {
	var n = 4000;
	var m = HashMap.new(16);
	for (i < n) m.put(keyFor(i), i * 3 + 1);
	if (m.count != n) fail_assert(301);
	// sum of (3i+1) for i in [0,4000) = 3*3999*2000 + 4000 = 23994000 + 4000
	if (m.sumValues() != 23998000) fail_assert(302);
	var h = 0;
	var misses = 0;
	for (i < n) {
		var v = m.get(keyFor(i), -1);
		if (v != i * 3 + 1) misses++;
		h = mix(h, v);
	}
	acci(h);
	if (misses != 0) fail_assert(303);
	// absent keys
	var found = 0;
	for (i = n; i < n + 500; i++) if (m.has(keyFor(i))) found++;
	if (found != 0) fail_assert(304);

	// delete every third key
	var removed = 0;
	for (i < n) if ((i % 3) == 0) { if (m.remove(keyFor(i))) removed++; }
	if (removed != 1334) fail_assert(305);			// ceil(4000/3)
	if (m.count != n - 1334) fail_assert(306);
	var bad = 0;
	for (i < n) {
		var present = m.has(keyFor(i));
		if (present != ((i % 3) != 0)) bad++;
	}
	if (bad != 0) fail_assert(307);
	acci(mix(0, m.sumValues()));

	// reinsert them with new values, forcing tombstone reuse and rehashing
	for (i < n) if ((i % 3) == 0) m.put(keyFor(i), i * 7 + 2);
	if (m.count != n) fail_assert(308);
	var g = 0;
	for (i < n) {
		var want = if((i % 3) == 0, i * 7 + 2, i * 3 + 1);
		if (m.get(keyFor(i), -1) != want) fail_assert(309);
		g = mix(g, want);
	}
	acci(g);
	acci(m.fold());
	// the table stays a power of two and never more than 3/4 used
	if ((m.keys.length & (m.keys.length - 1)) != 0) fail_assert(310);
	if (m.used * 4 > m.keys.length * 3) fail_assert(311);
}

//======================================================================
// Section 4: probing under heavy collision pressure
//======================================================================
def mapCollisions() {
	var m = HashMap.new(8);
	var n = 676;					// 26*26 distinct collideKey values
	for (i < n) m.put(collideKey(i), i);
	if (m.count != n) fail_assert(401);
	var bad = 0;
	for (i < n) if (m.get(collideKey(i), -1) != i) bad++;
	if (bad != 0) fail_assert(402);
	// duplicates: collideKey repeats with period 676
	for (i < n) m.put(collideKey(i + 676), i + 10000);
	if (m.count != n) fail_assert(403);
	var h = 0;
	for (i < n) {
		var v = m.get(collideKey(i), -1);
		if (v != i + 10000) fail_assert(404);
		h = mix(h, v);
	}
	acci(h);
	// remove half, then check the survivors are still reachable past tombstones
	var removed = 0;
	for (i < n) if ((i & 1) == 0) { if (m.remove(collideKey(i))) removed++; }
	if (removed != 338) fail_assert(405);
	if (m.count != 338) fail_assert(406);
	var g = 0;
	for (i < n) {
		var present = m.has(collideKey(i));
		if (present != ((i & 1) == 1)) fail_assert(407);
		if (present) g = mix(g, m.get(collideKey(i), -1));
	}
	acci(g);
	acci(m.fold());
}

//======================================================================
// Sorting
//======================================================================
def isort(a: Array<int>, lo: int, hi: int) {
	for (i = lo + 1; i <= hi; i++) {
		var v = a[i];
		var j = i - 1;
		while (j >= lo && a[j] > v) { a[j + 1] = a[j]; j--; }
		a[j + 1] = v;
	}
}
def qsort(a: Array<int>, lo: int, hi: int) {
	if (hi - lo < 12) { isort(a, lo, hi); return; }
	// median of three
	var mid = lo + (hi - lo) / 2;
	if (a[mid] < a[lo]) swapi(a, mid, lo);
	if (a[hi] < a[lo]) swapi(a, hi, lo);
	if (a[hi] < a[mid]) swapi(a, hi, mid);
	var pivot = a[mid];
	var i = lo, j = hi;
	while (i <= j) {
		while (a[i] < pivot) i++;
		while (a[j] > pivot) j--;
		if (i <= j) { swapi(a, i, j); i++; j--; }
	}
	if (lo < j) qsort(a, lo, j);
	if (i < hi) qsort(a, i, hi);
}
def swapi(a: Array<int>, i: int, j: int) { var t = a[i]; a[i] = a[j]; a[j] = t; }

def msort(a: Array<int>) -> Array<int> {
	if (a.length <= 1) return a;
	var tmp = Array<int>.new(a.length);
	msortRange(a, tmp, 0, a.length - 1);
	return a;
}
def msortRange(a: Array<int>, tmp: Array<int>, lo: int, hi: int) {
	if (lo >= hi) return;
	var mid = lo + (hi - lo) / 2;
	msortRange(a, tmp, lo, mid);
	msortRange(a, tmp, mid + 1, hi);
	var i = lo, j = mid + 1, k = lo;
	while (i <= mid && j <= hi) {
		if (a[i] <= a[j]) { tmp[k] = a[i]; i++; } else { tmp[k] = a[j]; j++; }
		k++;
	}
	while (i <= mid) { tmp[k] = a[i]; i++; k++; }
	while (j <= hi) { tmp[k] = a[j]; j++; k++; }
	for (x = lo; x <= hi; x++) a[x] = tmp[x];
}
def sorted(a: Array<int>) -> bool {
	for (i = 1; i < a.length; i++) if (a[i - 1] > a[i]) return false;
	return true;
}
def checksum(a: Array<int>) -> int {
	var s = 0;
	for (i < a.length) s = s + a[i];
	return s;
}
def foldArr(a: Array<int>) -> int {
	var h = mix(0, a.length);
	for (i < a.length) h = mix(h, a[i]);
	return h;
}
def copyArr(a: Array<int>) -> Array<int> {
	var b = Array<int>.new(a.length);
	for (i < a.length) b[i] = a[i];
	return b;
}

//======================================================================
// Section 5: sorting integer arrays
//======================================================================
def sortInts() {
	// a hand-checked five element array
	var small = [5, 3, 9, 1, 7];
	qsort(small, 0, 4);
	if (small[0] != 1) fail_assert(501);
	if (small[1] != 3) fail_assert(502);
	if (small[2] != 5) fail_assert(503);
	if (small[3] != 7) fail_assert(504);
	if (small[4] != 9) fail_assert(505);
	var dup = [4, 4, 2, 4, 2, 1];
	qsort(dup, 0, 5);
	if (dup[0] != 1) fail_assert(506);
	if (dup[1] != 2) fail_assert(507);
	if (dup[2] != 2) fail_assert(508);
	if (dup[5] != 4) fail_assert(509);
	var one = [42];
	qsort(one, 0, 0);
	if (one[0] != 42) fail_assert(510);

	srand(0x50A7);
	var h = 0;
	for (round < 30) {
		var n = 50 + randn(400);
		var a = Array<int>.new(n);
		for (i < n) a[i] = rand() % 10000;
		var before = checksum(a);
		var mirror = copyArr(a);
		qsort(a, 0, n - 1);
		msort(mirror);
		if (!sorted(a)) fail_assert(511);
		if (!sorted(mirror)) fail_assert(512);
		if (checksum(a) != before) fail_assert(513);
		for (i < n) if (a[i] != mirror[i]) fail_assert(514);
		h = mix(h, foldArr(a));
	}
	acci(h);

	// adversarial inputs: already sorted, reversed, all equal
	var n = 2000;
	var asc = Array<int>.new(n), desc = Array<int>.new(n), same = Array<int>.new(n);
	for (i < n) { asc[i] = i; desc[i] = n - i; same[i] = 77; }
	qsort(asc, 0, n - 1);
	qsort(desc, 0, n - 1);
	qsort(same, 0, n - 1);
	if (!sorted(asc)) fail_assert(515);
	if (!sorted(desc)) fail_assert(516);
	if (!sorted(same)) fail_assert(517);
	if (asc[0] != 0) fail_assert(518);
	if (asc[n - 1] != 1999) fail_assert(519);
	if (desc[0] != 1) fail_assert(520);
	if (desc[n - 1] != 2000) fail_assert(521);
	if (same[1000] != 77) fail_assert(522);
	// sum of 1..2000 = 2001000
	if (checksum(desc) != 2001000) fail_assert(523);
	acci(mix(foldArr(asc), foldArr(desc)));
	acci(foldArr(same));

	// negative values and the extremes
	var ex = [0, -1, 1, -2147483648, 2147483647, -100, 100];
	qsort(ex, 0, 6);
	if (ex[0] != -2147483648) fail_assert(524);
	if (ex[1] != -100) fail_assert(525);
	if (ex[3] != 0) fail_assert(526);
	if (ex[6] != 2147483647) fail_assert(527);
	acci(foldArr(ex));
}

//======================================================================
// Sorting objects by key
//======================================================================
class Item {
	def key: int;
	def tag: int;
	var payload: string;
	new(key, tag) { payload = keyFor(key); }
	def fp() -> int { return key * 31 + tag; }
}
def swapo(a: Array<Item>, i: int, j: int) { var t = a[i]; a[i] = a[j]; a[j] = t; }
def qsortObj(a: Array<Item>, lo: int, hi: int) {
	if (lo >= hi) return;
	if (hi - lo < 10) {
		for (i = lo + 1; i <= hi; i++) {
			var v = a[i];
			var j = i - 1;
			while (j >= lo && a[j].key > v.key) { a[j + 1] = a[j]; j--; }
			a[j + 1] = v;
		}
		return;
	}
	var pivot = a[lo + (hi - lo) / 2].key;
	var i = lo, j = hi;
	while (i <= j) {
		while (a[i].key < pivot) i++;
		while (a[j].key > pivot) j--;
		if (i <= j) { swapo(a, i, j); i++; j--; }
	}
	if (lo < j) qsortObj(a, lo, j);
	if (i < hi) qsortObj(a, i, hi);
}
// stable merge sort on objects, by key
def msortObj(a: Array<Item>) {
	if (a.length <= 1) return;
	var tmp = Array<Item>.new(a.length);
	msortObjRange(a, tmp, 0, a.length - 1);
}
def msortObjRange(a: Array<Item>, tmp: Array<Item>, lo: int, hi: int) {
	if (lo >= hi) return;
	var mid = lo + (hi - lo) / 2;
	msortObjRange(a, tmp, lo, mid);
	msortObjRange(a, tmp, mid + 1, hi);
	var i = lo, j = mid + 1, k = lo;
	while (i <= mid && j <= hi) {
		if (a[i].key <= a[j].key) { tmp[k] = a[i]; i++; } else { tmp[k] = a[j]; j++; }
		k++;
	}
	while (i <= mid) { tmp[k] = a[i]; i++; k++; }
	while (j <= hi) { tmp[k] = a[j]; j++; k++; }
	for (x = lo; x <= hi; x++) a[x] = tmp[x];
}

//======================================================================
// Section 6: sorting arrays of objects
//======================================================================
def sortObjects() {
	srand(0x50B6);
	var h = 0;
	for (round < 12) {
		var n = 100 + randn(500);
		var a = Array<Item>.new(n);
		for (i < n) a[i] = Item.new(randn(1000), i);
		var keySum = 0;
		for (i < n) keySum = keySum + a[i].key;
		qsortObj(a, 0, n - 1);
		var ok = true;
		var s = 0;
		for (i < n) {
			s = s + a[i].key;
			if (i > 0 && a[i - 1].key > a[i].key) ok = false;
			// the payload must still belong to the object it was built with
			if (!streq(a[i].payload, keyFor(a[i].key))) fail_assert(601);
		}
		if (!ok) fail_assert(602);
		if (s != keySum) fail_assert(603);
		var t = mix(0, n);
		for (i < n) t = mix(t, a[i].fp());
		h = mix(h, t);
	}
	acci(h);

	// stability: merge sort must keep equal keys in insertion (tag) order
	var m = 400;
	var b = Array<Item>.new(m);
	for (i < m) b[i] = Item.new(i % 8, i);
	msortObj(b);
	var stable = true;
	for (i = 1; i < m; i++) {
		if (b[i - 1].key > b[i].key) stable = false;
		if (b[i - 1].key == b[i].key && b[i - 1].tag > b[i].tag) stable = false;
	}
	if (!stable) fail_assert(604);
	// 400 items over 8 keys: 50 of each, key 0 first
	if (b[0].key != 0) fail_assert(605);
	if (b[0].tag != 0) fail_assert(606);
	if (b[49].key != 0) fail_assert(607);
	if (b[49].tag != 392) fail_assert(608);			// last i < 400 with i%8==0
	if (b[50].key != 1) fail_assert(609);
	if (b[399].key != 7) fail_assert(610);
	if (b[399].tag != 399) fail_assert(611);
	var g = 0;
	for (i < m) g = mix(g, b[i].fp());
	acci(g);
	if (Item.new(3, 4).fp() != 97) fail_assert(612);	// 3*31 + 4
	if (Item.new(0, 0).payload.length != 6) fail_assert(613);
}

//======================================================================
// Section 7: the map and the sorts used together
//======================================================================
def combined() {
	var n = 2500;
	var m = HashMap.new(16);
	srand(0x50C7);
	var keys = Array<int>.new(n);
	for (i < n) {
		var k = randn(100000);
		keys[i] = k;
		m.put(keyFor(k), k * 2);
	}
	// distinct keys only
	var distinct = copyArr(keys);
	qsort(distinct, 0, n - 1);
	var uniq = 0;
	for (i < n) if (i == 0 || distinct[i] != distinct[i - 1]) uniq++;
	if (m.count != uniq) fail_assert(701);
	if (!sorted(distinct)) fail_assert(702);

	// collect the live keys back out of the table and sort them
	var out = Array<int>.new(m.count);
	var p = 0;
	for (i < m.keys.length) {
		if (m.state[i] == FULL) {
			out[p] = m.vals[i] / 2;
			p++;
		}
	}
	if (p != m.count) fail_assert(703);
	qsort(out, 0, p - 1);
	if (!sorted(out)) fail_assert(704);
	// the sorted distinct keys and the sorted table keys must agree
	var q = 0;
	var mismatch = 0;
	for (i < n) {
		if (i == 0 || distinct[i] != distinct[i - 1]) {
			if (out[q] != distinct[i]) mismatch++;
			q++;
		}
	}
	if (mismatch != 0) fail_assert(705);
	if (q != uniq) fail_assert(706);
	acci(foldArr(out));
	acci(m.fold());

	// delete everything, one key at a time
	var deleted = 0;
	for (i < p) if (m.remove(keyFor(out[i]))) deleted++;
	if (deleted != uniq) fail_assert(707);
	if (m.count != 0) fail_assert(708);
	if (m.sumValues() != 0) fail_assert(709);
	// the table still works after being emptied
	m.put(keyFor(7), 70);
	if (m.get(keyFor(7), -1) != 70) fail_assert(710);
	if (m.count != 1) fail_assert(711);
	acci(m.fold());
}

//======================================================================
// Section 8: many small maps, allocated and dropped
//======================================================================
def churnMaps() {
	srand(0x50D8);
	var h = 0;
	var keep = Array<HashMap>.new(15);		// rounds 0,8,...,112
	for (round < 120) {
		var m = HashMap.new(8);
		var cnt = 20 + randn(60);
		for (i < cnt) m.put(keyFor(round * 100 + i), i);
		if (m.count != cnt) fail_assert(801);
		var sum = 0;
		for (i < cnt) sum = sum + m.get(keyFor(round * 100 + i), -1);
		// sum of 0..cnt-1
		if (sum != cnt * (cnt - 1) / 2) fail_assert(802);
		h = mix(h, sum);
		if ((round % 8) == 0) keep[round / 8] = m;
	}
	acci(h);
	// the retained maps survived the churn intact
	var g = 0;
	for (k < keep.length) {
		var m = keep[k];
		if (m == null) fail_assert(803);
		var round = k * 8;
		var found = 0;
		for (i < m.count) if (m.has(keyFor(round * 100 + i))) found++;
		if (found != m.count) fail_assert(804);
		g = mix(g, m.fold());
	}
	acci(g);
	if (keep[0].has(keyFor(99999))) fail_assert(805);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) strings();
	if (a == 0 || a == 2) mapBasics();
	if (a == 0 || a == 3) mapBulk();
	if (a == 0 || a == 4) mapCollisions();
	if (a == 0 || a == 5) sortInts();
	if (a == 0 || a == 6) sortObjects();
	if (a == 0 || a == 7) combined();
	if (a == 0 || a == 8) churnMaps();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
