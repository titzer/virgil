//@execute 0=689528756; 1=!NullCheckException; 2=!NullCheckException; 3=!NullCheckException; 4=!NullCheckException; 5=!BoundsCheckException; 6=!BoundsCheckException; 7=!BoundsCheckException; 8=!LengthCheckException; 9=!DivideByZeroException; 10=!DivideByZeroException; 11=!DivideByZeroException; 12=!DivideByZeroException; 13=!TypeCheckException; 14=!TypeCheckException; 15=!TypeCheckException
//@heap-size=400000
// Smoke test: runtime failures.
// Unlike the other files in this directory, this one maps most of its inputs to
// an expected exception rather than a CRC. Every failing input reaches its trap
// several frames deep, with objects and arrays held live in the intervening
// frames, so the unwind has to walk real stack maps. Input 0 is the opposite:
// it drives all the SAME code paths with values that stay in range -- index 0,
// index length-1, a zero-length allocation, a non-zero divisor, a cast that
// succeeds -- and accumulates the results into a CRC that main() returns.
//
//   1  null field load          9  int division by zero
//   2  null method call        10  int modulus by zero
//   3  null array load         11  long division by zero
//   4  null array store        12  long modulus by zero
//   5  index below zero        13  bad class downcast
//   6  index above length      14  bad variant case cast
//   7  store above length      15  out-of-range integer narrowing
//   8  negative array length

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Payload types and mutable state
//======================================================================
class Rec {
	def label: string;
	var tag: int;
	var vals: Array<int>;
	new(label, vals) { tag = label.length * 7; }
	def sum() -> int {
		var s = tag;
		for (i < vals.length) s = s + vals[i];
		return s;
	}
}
class Base {
	def id: int;
	new(id) { }
	def kind() -> int { return 0; }
}
class Left extends Base {
	new(id: int) super(id) { }
	def kind() -> int { return 1; }
}
class Right extends Base {
	new(id: int) super(id) { }
	def kind() -> int { return 2; }
}
type Shape {
	case Dot;
	case Line(a: int);
	case Poly(n: int, label: string);
}

// Globals are rebuilt by setup() on every run so that the "all inputs in one
// process" and "one process per input" execution models agree.
var recs: Array<Rec>;		// recs[3] is deliberately null
var data: Array<Array<int>>;	// data[2] is deliberately null
var bases: Array<Base>;
var shapes: Array<Shape>;
var longs: Array<long>;
var setups: int;

def LABELS: Array<string> = ["alpha", "beta", "gamma", "delta", "eps", "zeta"];
def SEED: Array<int> = [3, -7, 11, 0, 255, -256, 1024, 65535];

def setup() {
	setups = 0;
	recs = Array<Rec>.new(6);
	for (i < recs.length) {
		if (i == 3) continue;			// leave one null slot
		var v = Array<int>.new(i + 1);
		for (j < v.length) v[j] = SEED[j % SEED.length] + i;
		recs[i] = Rec.new(LABELS[i], v);
	}
	data = Array<Array<int>>.new(5);
	for (i < data.length) {
		if (i == 2) continue;			// leave one null slot
		data[i] = Array<int>.new(i * 3 + 1);
		for (j < data[i].length) data[i][j] = j * 13 - i;
	}
	bases = Array<Base>.new(6);
	for (i < bases.length) {
		if ((i % 3) == 0) bases[i] = Base.new(i);
		else if ((i % 3) == 1) bases[i] = Left.new(i);
		else bases[i] = Right.new(i);
	}
	shapes = Array<Shape>.new(6);
	for (i < shapes.length) {
		if ((i % 3) == 0) shapes[i] = Shape.Dot;
		else if ((i % 3) == 1) shapes[i] = Shape.Line(i * 5);
		else shapes[i] = Shape.Poly(i, LABELS[i]);
	}
	longs = Array<long>.new(8);
	for (i < longs.length) longs[i] = long.!(SEED[i]) * 1000000007L;
	setups++;
}

//======================================================================
// Section 1: null checks, reached three frames down
//======================================================================
def nullDeep1(kind: int, r: Rec, d: Array<int>) -> int {
	var held = Rec.new("held1", [1, 2, 3]);
	var out = nullDeep2(kind, r, d, held);
	return out + held.sum();		// held is live across the call
}
def nullDeep2(kind: int, r: Rec, d: Array<int>, held: Rec) -> int {
	var buf = Array<int>.new(8);
	for (i < buf.length) buf[i] = i * 3 + held.tag;
	var out = nullDeep3(kind, r, d, held, buf);
	return out + buf[7] + held.vals[0];	// buf and held live across the call
}
def nullDeep3(kind: int, r: Rec, d: Array<int>, held: Rec, buf: Array<int>) -> int {
	var t = held.sum() + buf[0] + buf[buf.length - 1];
	match (kind) {
		0 => return t + r.tag;			// null field load
		1 => return t + r.sum();		// null method call
		2 => return t + d[0];			// null array load
		3 => { d[0] = t; return t; }		// null array store
		_ => return t;
	}
}
def okNulls() {
	var h = 0;
	for (kind < 4) {
		for (i < recs.length) {
			if (recs[i] == null) { h = mix(h, -1); continue; }
			for (j < data.length) {
				if (data[j] == null) { h = mix(h, -2); continue; }
				h = mix(h, nullDeep1(kind, recs[i], data[j]));
			}
		}
		acci(h);
	}
	// null-guarded traversals: the guard must actually prevent the load
	var g = 0;
	for (i < recs.length) {
		var r = recs[i];
		g = mixb(g, r == null);
		if (r != null && r.vals.length > 0) g = mix(g, r.vals[0]);
		g = mix(g, if(r == null, -3, r.tag));
		g = mixs(g, if(r == null, "none", r.label));
	}
	for (i < data.length) {
		var d = data[i];
		g = mixb(g, d == null);
		g = mix(g, if(d == null, -4, d.length));
	}
	acci(g);

	if (recs[3] != null) fail_assert(101);
	if (recs[0] == null) fail_assert(102);
	if (data[2] != null) fail_assert(103);
	if (data[0] == null) fail_assert(104);
	var nr: Rec;
	if (nr != null) fail_assert(105);
	var nd: Array<int>;
	if (nd != null) fail_assert(106);
	if (Rec.new("x", [1]).tag != 7) fail_assert(107);
	if (Rec.new("x", [1]).sum() != 8) fail_assert(108);
}

//======================================================================
// Section 2: bounds checks, reached three frames down
//======================================================================
def boundsDeep1(kind: int, d: Array<int>, idx: int) -> int {
	var held = Rec.new("held2", d);
	var out = boundsDeep2(kind, d, idx, held);
	return out + held.tag;
}
def boundsDeep2(kind: int, d: Array<int>, idx: int, held: Rec) -> int {
	var scratch = Array<int>.new(4);
	for (i < scratch.length) scratch[i] = i + idx;
	var out = boundsDeep3(kind, d, idx, held, scratch);
	return out + scratch[3] + held.vals.length;
}
def boundsDeep3(kind: int, d: Array<int>, idx: int, held: Rec, scratch: Array<int>) -> int {
	var t = scratch[0] + held.tag;
	match (kind) {
		0 => return t + d[idx];			// load
		1 => { d[idx] = t; return t + d[0]; }	// store
		_ => return t;
	}
}
def okBounds() {
	var h = 0;
	for (i < data.length) {
		var d = data[i];
		if (d == null) continue;
		// the two boundary indices, plus everything in between
		h = mix(h, boundsDeep1(0, d, 0));
		h = mix(h, boundsDeep1(0, d, d.length - 1));
		for (j < d.length) h = mix(h, boundsDeep1(0, d, j));
		h = mix(h, boundsDeep1(1, d, 0));
		h = mix(h, boundsDeep1(1, d, d.length - 1));
	}
	acci(h);
	// index arithmetic that stays in range by construction
	var g = 0;
	var d = data[4];
	for (i < 200) {
		var j = (i * 7919) & 0x7FFFFFFF;
		g = mix(g, d[j % d.length]);
		d[(j / 3) % d.length] = g;
	}
	for (i < d.length) g = mix(g, d[i]);
	acci(g);
	// strings are arrays too
	var k = 0;
	for (i < LABELS.length) {
		var s = LABELS[i];
		k = mix(k, s[0]);
		k = mix(k, s[s.length - 1]);
		for (j < s.length) k = mix(k, s[j]);
	}
	acci(k);

	if (data[0].length != 1) fail_assert(201);
	if (data[1].length != 4) fail_assert(202);
	if (data[4].length != 13) fail_assert(203);
	// the globals have been written by the store paths above, so check the
	// element formula on a freshly built array instead
	var fresh = Array<int>.new(4);
	for (i < fresh.length) fresh[i] = i * 13 - 1;
	if (fresh[0] != -1) fail_assert(204);
	if (fresh[3] != 38) fail_assert(205);			// 3*13 - 1
	if (LABELS[0].length != 5) fail_assert(206);
	if (LABELS[0][0] != 'a') fail_assert(207);
	if (LABELS[0][4] != 'a') fail_assert(208);
}

//======================================================================
// Section 3: allocation lengths
//======================================================================
def allocDeep1(n: int) -> int {
	var held = Array<int>.new(6);
	for (i < held.length) held[i] = i * i;
	return allocDeep2(n, held) + held[5];
}
def allocDeep2(n: int, held: Array<int>) -> int {
	var also = Rec.new("alloc", held);
	return allocDeep3(n, held, also) + also.tag;
}
def allocDeep3(n: int, held: Array<int>, also: Rec) -> int {
	var fresh = Array<int>.new(n);		// LengthCheckException when n < 0
	for (i < fresh.length) fresh[i] = held[i % held.length] + also.tag;
	var s = fresh.length;
	for (i < fresh.length) s = s + fresh[i];
	return s;
}
def okAlloc() {
	var h = 0;
	for (n < 40) h = mix(h, allocDeep1(n));
	h = mix(h, allocDeep1(0));			// zero-length is legal
	h = mix(h, allocDeep1(1));
	h = mix(h, allocDeep1(255));
	acci(h);
	// allocation sizes computed from data, all non-negative
	var g = 0;
	for (i < SEED.length) {
		var n = SEED[i] & 0x3FF;
		var a = Array<int>.new(n);
		for (j < a.length) a[j] = j ^ n;
		g = mix(g, a.length);
		if (a.length > 0) {
			g = mix(g, a[0]);
			g = mix(g, a[a.length - 1]);
		}
	}
	var strs = Array<string>.new(0);
	g = mix(g, strs.length);
	var grid = Array<Array<int>>.new(8);
	for (i < grid.length) grid[i] = Array<int>.new(i);
	for (i < grid.length) g = mix(g, grid[i].length);
	acci(g);

	if (Array<int>.new(0).length != 0) fail_assert(301);
	if (Array<int>.new(7).length != 7) fail_assert(302);
	if (Array<int>.new(0 + 0).length != 0) fail_assert(303);
	if (allocDeep1(0) != 60) fail_assert(304);	// s=0, tag=35, held[5]=25
	if (Rec.new("alloc", [1]).tag != 35) fail_assert(305);
}

//======================================================================
// Section 4: division and modulus
//======================================================================
def divDeep1(kind: int, a: int, b: int, la: long, lb: long) -> int {
	var held = Rec.new("div", [a, b]);
	return divDeep2(kind, a, b, la, lb, held) + held.tag;
}
def divDeep2(kind: int, a: int, b: int, la: long, lb: long, held: Rec) -> int {
	var buf = Array<long>.new(4);
	for (i < buf.length) buf[i] = la + i;
	return divDeep3(kind, a, b, la, lb, held, buf) + int.view(u32.view(buf[3]));
}
def divDeep3(kind: int, a: int, b: int, la: long, lb: long,
	     held: Rec, buf: Array<long>) -> int {
	var t = held.tag + int.view(u32.view(buf[0]));
	match (kind) {
		0 => return t + a / b;				// int divide
		1 => return t + a % b;				// int modulus
		2 => return t + int.view(u32.view(la / lb));	// long divide
		3 => return t + int.view(u32.view(la % lb));	// long modulus
		_ => return t;
	}
}
def okDivide() {
	var h = 0;
	for (i < SEED.length) for (j < SEED.length) {
		var b = SEED[j];
		if (b == 0) continue;
		if (b == -1 && SEED[i] == -2147483648) continue;	// overflow, not a trap
		h = mix(h, divDeep1(0, SEED[i], b, 1L, 1L));
		h = mix(h, divDeep1(1, SEED[i], b, 1L, 1L));
	}
	acci(h);
	var g = 0;
	for (i < longs.length) for (j < longs.length) {
		var lb = longs[j];
		if (lb == 0) continue;
		g = mix(g, divDeep1(2, 1, 1, longs[i], lb));
		g = mix(g, divDeep1(3, 1, 1, longs[i], lb));
	}
	// divisors that are small but never zero
	for (i < 64) {
		var b = (i % 7) + 1;
		g = mix(g, divDeep1(0, i * 1234567 - 40000000, b, 1L, 1L));
		g = mix(g, divDeep1(1, i * 1234567 - 40000000, -b, 1L, 1L));
	}
	acci(g);
	// guarded division: the guard must prevent the trap
	var k = 0;
	for (i < SEED.length) {
		var b = SEED[i];
		k = mix(k, if(b == 0, -1, 1000000 / if(b == 0, 1, b)));
		if (b != 0 && (1000000 / b) > 0) k = mix(k, b);
	}
	acci(k);

	if (7 / 2 != 3) fail_assert(401);
	if (-7 / 2 != -3) fail_assert(402);			// truncation toward zero
	if (7 % 2 != 1) fail_assert(403);
	if (-7 % 2 != -1) fail_assert(404);
	if (7 % -2 != 1) fail_assert(405);
	if (7L / 2L != 3L) fail_assert(406);
	if (-7L % 2L != -1L) fail_assert(407);
	if (1 / 1 != 1) fail_assert(408);
	if (0 / 5 != 0) fail_assert(409);
	if (0 % 5 != 0) fail_assert(410);
}

//======================================================================
// Section 5: casts and type queries
//======================================================================
def castDeep1(kind: int, b: Base, s: Shape, x: int) -> int {
	var held = Rec.new("cast", [x]);
	return castDeep2(kind, b, s, x, held) + held.tag;
}
def castDeep2(kind: int, b: Base, s: Shape, x: int, held: Rec) -> int {
	var buf = Array<Base>.new(3);
	for (i < buf.length) buf[i] = bases[i];
	return castDeep3(kind, b, s, x, held, buf) + buf[0].id;
}
def castDeep3(kind: int, b: Base, s: Shape, x: int, held: Rec, buf: Array<Base>) -> int {
	var t = held.tag + buf[2].kind();
	match (kind) {
		0 => return t + Left.!(b).kind();		// bad class downcast
		1 => return t + Shape.Line.!(s).a;		// bad variant case cast
		2 => return t + int.!(byte.!(x));		// out-of-range narrowing
		_ => return t;
	}
}
def okCasts() {
	var h = 0;
	for (i < bases.length) {
		var b = bases[i];
		h = mixb(h, Left.?(b));
		h = mixb(h, Right.?(b));
		h = mixb(h, Base.?(b));
		h = mix(h, b.kind());
		h = mix(h, b.id);
		if (Left.?(b)) h = mix(h, castDeep1(0, b, shapes[0], 0));
	}
	acci(h);
	var g = 0;
	for (i < shapes.length) {
		var s = shapes[i];
		g = mixb(g, Shape.Dot.?(s));
		g = mixb(g, Shape.Line.?(s));
		g = mixb(g, Shape.Poly.?(s));
		g = mix(g, s.tag);
		if (Shape.Line.?(s)) g = mix(g, castDeep1(1, bases[1], s, 0));
		match (s) {
			Dot => g = mix(g, -1);
			Line(a) => g = mix(g, a);
			Poly(n, l) => { g = mix(g, n); g = mixs(g, l); }
		}
	}
	acci(g);
	// narrowing casts that stay in range, and views that never check
	var k = 0;
	for (i < 256) {
		k = mix(k, int.!(byte.!(i)));
		k = mix(k, castDeep1(2, bases[1], shapes[1], i));
	}
	for (i < SEED.length) {
		k = mix(k, int.!(byte.view(SEED[i])));
		k = mix(k, int.view(u32.view(SEED[i])));
		k = mixl(k, long.!(SEED[i]));
	}
	acci(k);

	if (!Left.?(bases[1])) fail_assert(501);
	if (Left.?(bases[2])) fail_assert(502);
	if (!Right.?(bases[2])) fail_assert(503);
	if (bases[0].kind() != 0) fail_assert(504);
	if (bases[1].kind() != 1) fail_assert(505);
	if (bases[2].kind() != 2) fail_assert(506);
	if (Left.!(bases[1]).id != 1) fail_assert(507);
	if (!Shape.Line.?(shapes[1])) fail_assert(508);
	if (Shape.Line.?(shapes[0])) fail_assert(509);
	if (Shape.Line.!(shapes[1]).a != 5) fail_assert(510);
	if (int.!(byte.!(255)) != 255) fail_assert(511);
	if (int.!(byte.!(0)) != 0) fail_assert(512);
	if (int.!(byte.view(256)) != 0) fail_assert(513);	// view never checks
	var nb: Base;
	if (Left.?(nb)) fail_assert(514);			// a null query is false
	if (Left.!(nb) != null) fail_assert(515);		// but a null cast succeeds
}

//======================================================================
// Section 6: the safe paths driven together
//======================================================================
def okMixed() {
	var h = 0;
	for (i < 400) {
		var ri = i % recs.length;
		var di = i % data.length;
		var r = recs[ri], d = data[di];
		if (r == null || d == null) { h = mix(h, -9); continue; }
		var idx = (i * 31) % d.length;
		var div = (i % 11) + 1;
		h = mix(h, r.sum() / div);
		h = mix(h, d[idx] % div);
		d[idx] = d[idx] ^ i;
		var b = bases[i % bases.length];
		h = mix(h, if(Left.?(b), Left.!(b).id, -1));
		var s = shapes[i % shapes.length];
		h = mix(h, if(Shape.Poly.?(s), Shape.Poly.!(s).n, -2));
		var fresh = Array<int>.new(i % 9);
		h = mix(h, fresh.length);
	}
	acci(h);
	var g = 0;
	for (i < recs.length) if (recs[i] != null) g = mix(g, recs[i].sum());
	for (i < data.length) if (data[i] != null) for (j < data[i].length) g = mix(g, data[i][j]);
	acci(g);
	if (setups != 1) fail_assert(601);
	if (recs.length != 6) fail_assert(602);
	if (data.length != 5) fail_assert(603);
	if (bases.length != 6) fail_assert(604);
	if (shapes.length != 6) fail_assert(605);
	if (Shape.Dot.tag != 0) fail_assert(606);
	if (Shape.Line(1).tag != 1) fail_assert(607);
	if (Shape.Poly(1, "x").tag != 2) fail_assert(608);
}

//======================================================================
// Section 7: the failing paths
//======================================================================
// Each of these is reached only for its own input. The poison values are taken
// from the globals set up above (a null slot, a length, a zero) or derived from
// the argument, so the traps are real rather than folded.
def trap(a: int) {
	var nullRec = recs[3];			// null
	var nullArr = data[2];			// null
	var live = data[4];			// 13 elements
	var below = -1 - (a - 5);		// -1 for input 5
	var above = live.length + (a - 6);	// live.length for input 6
	match (a) {
		1 => acci(nullDeep1(0, nullRec, live));
		2 => acci(nullDeep1(1, nullRec, live));
		3 => acci(nullDeep1(2, recs[0], nullArr));
		4 => acci(nullDeep1(3, recs[0], nullArr));
		5 => acci(boundsDeep1(0, live, below));
		6 => acci(boundsDeep1(0, live, above));
		7 => acci(boundsDeep1(1, live, live.length + (a - 7)));
		8 => acci(allocDeep1(-1 - (a - 8)));
		9 => acci(divDeep1(0, live.length, a - 9, 1L, 1L));
		10 => acci(divDeep1(1, live.length, a - 10, 1L, 1L));
		11 => acci(divDeep1(2, 1, 1, longs[4], long.!(a - 11)));
		12 => acci(divDeep1(3, 1, 1, longs[4], long.!(a - 12)));
		13 => acci(castDeep1(0, bases[2], shapes[1], 0));	// Right as Left
		14 => acci(castDeep1(1, bases[1], shapes[0], 0));	// Dot as Line
		15 => acci(castDeep1(2, bases[1], shapes[1], 256 + a - 15));
		_ => acci(0);
	}
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	setup();
	if (a == 0) {
		okNulls();
		okBounds();
		okAlloc();
		okDivide();
		okCasts();
		okMixed();
	} else {
		trap(a);
	}
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
