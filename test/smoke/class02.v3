//@execute 0=156405576; 1=116193098; 2=1324219863; 3=997261753; 4=488198588; 5=1461523785; 6=1071759797; 7=-1304005270; 8=-935722934
//@heap-size=1000000
// Smoke test: polymorphic (type-parameterized) classes.
// Generic containers instantiated at many types in one program, methods with
// their own type parameters, polymorphic inheritance (both `Sub<T> extends
// Base<T>` and `Sub extends Base<int>`), generic functions over class
// hierarchies, and generic delegates. Results are mixed into a running CRC that
// main() returns, so no computation can be deleted as dead. Interleaved are
// assert()s over compile-time constants, which the optimizer is expected to
// fold away; a folding bug sets the failure flag instead.
// Input selects the section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

def WORDS: Array<string> = ["a", "bb", "ccc", "dddd", "eeeee", "ffffff"];
def NUMS: Array<int> = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5, 8];

//======================================================================
// The generic container used throughout.
//======================================================================
class Vec<T> {
	var arr = Array<T>.new(4);
	var n: int;

	def add(x: T) -> this {
		if (n == arr.length) {
			var na = Array<T>.new(n * 2);
			for (i < n) na[i] = arr[i];
			arr = na;
		}
		arr[n++] = x;
	}
	def addAll(a: Array<T>) -> this { for (i < a.length) add(a[i]); }
	def get(i: int) -> T { return arr[i]; }
	def set(i: int, x: T) -> this { arr[i] = x; }
	def length() -> int { return n; }
	def clear() -> this { n = 0; }
	def defval() -> T { var d: T; return d; }
	def indexOf(x: T) -> int {
		for (i < n) if (arr[i] == x) return i;
		return -1;
	}
	def contains(x: T) -> bool { return indexOf(x) >= 0; }
	// a method with its own type parameter, distinct from the class parameter
	def map<R>(f: T -> R) -> Vec<R> {
		var v = Vec<R>.new();
		for (i < n) v.add(f(arr[i]));
		return v;
	}
	def fold<R>(init: R, f: (R, T) -> R) -> R {
		var acc = init;
		for (i < n) acc = f(acc, arr[i]);
		return acc;
	}
	def filter(p: T -> bool) -> Vec<T> {
		var v = Vec<T>.new();
		for (i < n) if (p(arr[i])) v.add(arr[i]);
		return v;
	}
	def hash(f: (int, T) -> int) -> int {
		var h = mix(0, n);
		for (i < n) h = f(h, arr[i]);
		return h;
	}
}

class Pair<A, B> {
	def a: A;
	def b: B;
	new(a, b) { }
	def swap() -> Pair<B, A> { return Pair<B, A>.new(b, a); }
	def first() -> A { return a; }
	def second() -> B { return b; }
}

//======================================================================
// Section 1: one generic container, many instantiations
//======================================================================
def strlen(s: string) -> int { return s.length; }
def dbl(x: int) -> int { return x * 2; }
def isOdd(x: int) -> bool { return (x & 1) == 1; }
def addi(a: int, b: int) -> int { return a + b; }
def catlen(a: int, b: string) -> int { return a + b.length; }
def containers() {
	var vi = Vec<int>.new();
	var vb = Vec<byte>.new();
	var vs = Vec<string>.new();
	var vt = Vec<(int, string)>.new();
	var vl = Vec<long>.new();
	var vz = Vec<bool>.new();
	vi.addAll(NUMS);
	for (i < WORDS.length) {
		vs.add(WORDS[i]);
		vb.add(WORDS[i][0]);
		vt.add((i, WORDS[i]));
		vl.add(long.!(i) * 1000000007L);
		vz.add((i & 1) == 0);
	}
	var h = vi.hash(mix);
	h = vs.hash(mixs);
	h = vb.hash(fun (g: int, b: byte) => mix(g, b));
	h = vl.hash(mixl);
	h = vz.hash(mixb);
	h = vt.hash(fun (g: int, t: (int, string)) => mixs(mix(g, t.0), t.1));
	acci(h);

	// map/fold/filter across instantiations
	var lens = vs.map(strlen);
	var dbls = vi.map(dbl);
	var odds = vi.filter(isOdd);
	var g = mix(0, vi.fold(0, addi));
	g = mix(g, lens.fold(0, addi));
	g = mix(g, dbls.fold(0, addi));
	g = mix(g, odds.length());
	g = mix(g, vs.fold(0, catlen));
	g = lens.hash(mix);
	g = dbls.hash(mix);
	acci(g);

	if (vi.length() != NUMS.length) fail_assert(101);
	if (vi.fold(0, addi) != 52) fail_assert(102);		// NUMS sums to 52
	if (vi.get(0) != 3) fail_assert(103);
	if (vi.indexOf(9) != 5) fail_assert(104);
	if (vi.indexOf(100) != -1) fail_assert(105);
	if (!vi.contains(6)) fail_assert(106);
	if (vs.length() != 6) fail_assert(107);
	if (lens.fold(0, addi) != 21) fail_assert(108);		// 1+2+3+4+5+6
	if (dbls.fold(0, addi) != 104) fail_assert(109);
	if (odds.length() != 8) fail_assert(110);		// 3,1,1,5,9,5,3,5
	if (vs.fold(0, catlen) != 21) fail_assert(111);
	if (vb.get(2) != 'c') fail_assert(112);
	if (vl.get(2) != 2000000014L) fail_assert(113);
	if (vz.get(0) != true) fail_assert(114);
	if (vz.get(1) != false) fail_assert(115);
	if (vt.get(3).1.length != 4) fail_assert(116);
	// default values differ per instantiation
	if (vi.defval() != 0) fail_assert(117);
	if (vb.defval() != 0) fail_assert(118);
	if (vs.defval() != null) fail_assert(119);
	if (vl.defval() != 0) fail_assert(120);
	if (vz.defval() != false) fail_assert(121);
	// growth preserves contents
	var big = Vec<int>.new();
	for (i < 500) big.add(i * i);
	if (big.length() != 500) fail_assert(122);
	if (big.get(499) != 499 * 499) fail_assert(123);
	if (big.get(0) != 0) fail_assert(124);
	acci(big.hash(mix));
	big.clear();
	if (big.length() != 0) fail_assert(125);
}

//======================================================================
// Section 2: multi-parameter generics and nesting
//======================================================================
def pairs() {
	var p1 = Pair<int, string>.new(7, WORDS[3]);
	var p2 = p1.swap();
	var p3 = Pair<Pair<int, int>, string>.new(Pair<int, int>.new(1, 2), WORDS[1]);
	var h = mix(0, p1.first());
	h = mixs(h, p1.second());
	h = mixs(h, p2.first());
	h = mix(h, p2.second());
	h = mix(h, p3.first().a);
	h = mix(h, p3.first().b);
	h = mixs(h, p3.second());
	acci(h);

	if (p1.a != 7) fail_assert(201);
	if (p1.b.length != 4) fail_assert(202);
	if (p2.a.length != 4) fail_assert(203);
	if (p2.b != 7) fail_assert(204);
	if (p1.swap().swap().a != 7) fail_assert(205);
	if (p3.a.a + p3.a.b != 3) fail_assert(206);
	if (p3.b.length != 2) fail_assert(207);

	// a vector of pairs, and a pair of vectors
	var vp = Vec<Pair<int, string>>.new();
	for (i < WORDS.length) vp.add(Pair<int, string>.new(i * i, WORDS[i]));
	var vi = Vec<int>.new().addAll(NUMS);
	var vs = Vec<string>.new().addAll(WORDS);
	var pv = Pair<Vec<int>, Vec<string>>.new(vi, vs);
	var g = mix(0, vp.length());
	for (i < vp.length()) {
		g = mix(g, vp.get(i).a);
		g = mixs(g, vp.get(i).b);
	}
	g = mix(g, pv.a.fold(0, addi));
	g = mix(g, pv.b.fold(0, catlen));
	acci(g);
	if (vp.get(4).a != 16) fail_assert(208);
	if (pv.a.length() != NUMS.length) fail_assert(209);
	if (pv.b.length() != WORDS.length) fail_assert(210);
	if (pv.first() != vi) fail_assert(211);			// identity preserved
	if (pv.swap().second() != vi) fail_assert(212);

	// nested vectors
	var vv = Vec<Vec<int>>.new();
	for (i < 20) {
		var inner = Vec<int>.new();
		for (j < i) inner.add(i * j);
		vv.add(inner);
	}
	var k = mix(0, vv.length());
	for (i < vv.length()) {
		k = mix(k, vv.get(i).length());
		k = mix(k, vv.get(i).fold(0, addi));
	}
	acci(k);
	if (vv.length() != 20) fail_assert(213);
	if (vv.get(0).length() != 0) fail_assert(214);
	if (vv.get(5).fold(0, addi) != 50) fail_assert(215);	// 5*(0+1+2+3+4)
	if (vv.defval() != null) fail_assert(216);
}

//======================================================================
// Section 3: polymorphic inheritance
//======================================================================
class Cell<T> {
	var v: T;
	new(v) { }
	def get() -> T { return v; }
	def rank() -> int { return 0; }
	def describe() -> int { return rank() * 10 + depth(); }
	def depth() -> int { return 1; }
}
class Labeled<T> extends Cell<T> {
	def tag: int;
	new(v: T, tag) super(v) { }
	def rank() -> int { return 1; }
	def depth() -> int { return 2; }
}
class Counted<T> extends Labeled<T> {
	var hits: int;
	new(v: T, tag: int) super(v, tag) { }
	def get() -> T { hits++; return v; }
	def rank() -> int { return 2; }
	def depth() -> int { return 3; }
}
// a monomorphic subclass of a generic base
class IntCell extends Cell<int> {
	new(v: int) super(v) { }
	def rank() -> int { return 3; }
	def get() -> int { return v * 2; }
}
class StrCell extends Labeled<string> {
	new(v: string) super(v, 99) { }
	def rank() -> int { return 4; }
}
def polyinherit() {
	var ci = Array<Cell<int>>.new(80);
	for (i < ci.length) {
		match (i % 4) {
			0 => ci[i] = Cell<int>.new(i);
			1 => ci[i] = Labeled<int>.new(i, i * 3);
			2 => ci[i] = Counted<int>.new(i, i * 5);
			_ => ci[i] = IntCell.new(i);
		}
	}
	var h = 0;
	for (i < ci.length) {
		var c = ci[i];
		h = mix(h, c.get());
		h = mix(h, c.rank());
		h = mix(h, c.describe());
		h = mixb(h, Labeled<int>.?(c));
		h = mixb(h, Counted<int>.?(c));
		h = mixb(h, IntCell.?(c));
	}
	acci(h);

	var cs = Array<Cell<string>>.new(40);
	for (i < cs.length) {
		match (i % 3) {
			0 => cs[i] = Cell<string>.new(WORDS[i % WORDS.length]);
			1 => cs[i] = Counted<string>.new(WORDS[i % WORDS.length], i);
			_ => cs[i] = StrCell.new(WORDS[i % WORDS.length]);
		}
	}
	var g = 0;
	for (i < cs.length) {
		g = mixs(g, cs[i].get());
		g = mix(g, cs[i].rank());
		g = mix(g, cs[i].describe());
	}
	acci(g);

	var c0 = Cell<int>.new(5);
	var c1 = Labeled<int>.new(5, 7);
	var c2 = Counted<int>.new(5, 7);
	var c3 = IntCell.new(5);
	var c4 = StrCell.new(WORDS[2]);
	if (c0.get() != 5) fail_assert(301);
	if (c1.get() != 5) fail_assert(302);
	if (c2.get() != 5) fail_assert(303);
	if (c3.get() != 10) fail_assert(304);
	if (c2.hits != 1) fail_assert(305);
	if (c0.rank() != 0) fail_assert(306);
	if (c1.rank() != 1) fail_assert(307);
	if (c2.rank() != 2) fail_assert(308);
	if (c3.rank() != 3) fail_assert(309);
	if (c4.rank() != 4) fail_assert(310);
	if (c0.describe() != 1) fail_assert(311);
	if (c1.describe() != 12) fail_assert(312);
	if (c2.describe() != 23) fail_assert(313);
	if (c3.describe() != 31) fail_assert(314);	// IntCell inherits depth() == 1
	if (c4.describe() != 42) fail_assert(315);	// StrCell inherits depth() == 2
	if (c1.tag != 7) fail_assert(316);
	if (c4.tag != 99) fail_assert(317);
	// query and cast across the polymorphic hierarchy
	var up: Cell<int> = c2;
	if (!Labeled<int>.?(up)) fail_assert(318);
	if (!Counted<int>.?(up)) fail_assert(319);
	if (IntCell.?(up)) fail_assert(320);
	if (Counted<int>.!(up).tag != 7) fail_assert(321);
	if (Labeled<int>.!(up).tag != 7) fail_assert(322);
	var up2: Cell<int> = c3;
	if (Labeled<int>.?(up2)) fail_assert(323);
	if (!IntCell.?(up2)) fail_assert(324);
	var ups: Cell<string> = c4;
	if (!Labeled<string>.?(ups)) fail_assert(325);
	if (Counted<string>.?(ups)) fail_assert(326);
}

//======================================================================
// Section 4: generic functions over class hierarchies
//======================================================================
def bestBy<T>(a: Array<T>, score: T -> int) -> T {
	var best: T, bs = -2147483648;
	for (i < a.length) {
		var s = score(a[i]);
		if (s > bs) { bs = s; best = a[i]; }
	}
	return best;
}
def countIf<T>(a: Array<T>, p: T -> bool) -> int {
	var n = 0;
	for (i < a.length) if (p(a[i])) n++;
	return n;
}
def firstOf<T, U>(a: Array<T>, q: T -> bool, f: T -> U, dflt: U) -> U {
	for (i < a.length) if (q(a[i])) return f(a[i]);
	return dflt;
}
def swapT<A, B>(t: (A, B)) -> (B, A) { return (t.1, t.0); }
def idOf<T>(x: T) -> T { return x; }
def rankOfCell(c: Cell<int>) -> int { return c.rank(); }
def valOfCell(c: Cell<int>) -> int { return c.v; }
def genmethods() {
	var ci = Array<Cell<int>>.new(60);
	for (i < ci.length) {
		match (i % 4) {
			0 => ci[i] = Cell<int>.new(i);
			1 => ci[i] = Labeled<int>.new(i, i * 3);
			2 => ci[i] = Counted<int>.new(i, i * 5);
			_ => ci[i] = IntCell.new(i);
		}
	}
	var h = mix(0, bestBy<Cell<int>>(ci, valOfCell).v);
	h = mix(h, bestBy<Cell<int>>(ci, rankOfCell).rank());
	h = mix(h, countIf<Cell<int>>(ci, Labeled<int>.?));
	h = mix(h, countIf<Cell<int>>(ci, Counted<int>.?));
	h = mix(h, countIf<Cell<int>>(ci, IntCell.?));
	h = mix(h, firstOf<Cell<int>, int>(ci, IntCell.?, valOfCell, -1));
	h = mixs(h, firstOf<Cell<int>, string>(ci, Counted<int>.?, fun (c: Cell<int>) => WORDS[c.rank()], null));
	acci(h);

	var g = mix(0, bestBy<int>(NUMS, idOf));
	g = mix(g, countIf<int>(NUMS, isOdd));
	g = mix(g, bestBy<string>(WORDS, strlen).length);
	g = mix(g, countIf<string>(WORDS, fun (s: string) -> bool { return s.length > 3; }));
	g = mixs(g, firstOf<int, string>(NUMS, isOdd, fun (x: int) => WORDS[x], null));
	acci(g);

	if (bestBy<int>(NUMS, idOf) != 9) fail_assert(401);
	if (countIf<int>(NUMS, isOdd) != 8) fail_assert(402);
	if (bestBy<string>(WORDS, strlen).length != 6) fail_assert(403);
	if (countIf<string>(WORDS, fun (s: string) -> bool { return s.length > 3; }) != 3) fail_assert(404);
	if (countIf<Cell<int>>(ci, Labeled<int>.?) != 30) fail_assert(405);	// i%4 in {1,2}
	if (countIf<Cell<int>>(ci, Counted<int>.?) != 15) fail_assert(406);
	if (countIf<Cell<int>>(ci, IntCell.?) != 15) fail_assert(407);
	if (bestBy<Cell<int>>(ci, valOfCell).v != 59) fail_assert(408);
	if (firstOf<Cell<int>, int>(ci, IntCell.?, valOfCell, -1) != 3) fail_assert(409);
	if (firstOf<int, int>(NUMS, fun (x: int) -> bool { return x > 100; }, dbl, -7) != -7) fail_assert(410);
	// generic identity and tuple swap at several instantiations
	if (idOf(5) != 5) fail_assert(411);
	if (idOf(WORDS[1]).length != 2) fail_assert(412);
	if (swapT((1, 'z')).1 != 1) fail_assert(413);
	if (swapT((1, 'z')).0 != 'z') fail_assert(414);
	if (swapT(swapT((3, 4))).0 != 3) fail_assert(415);
	var vv = Vec<int>.new().addAll(NUMS);
	if (idOf(vv) != vv) fail_assert(416);
}

//======================================================================
// Section 5: generic delegates and partial application
//======================================================================
def makeAdder(k: int) -> int -> int { return fun (x: int) => x + k; }
def apply2<A, B>(f: A -> B, x: A) -> B { return f(x); }
def compose<A, B, C>(f: A -> B, g: B -> C) -> A -> C {
	return fun (x: A) => g(f(x));
}
def delegates() {
	var v = Vec<int>.new().addAll(NUMS);
	var adders = Array<int -> int>.new(8);
	for (i < adders.length) adders[i] = makeAdder(i * 3);
	var h = 0;
	for (i < adders.length) h = mix(h, v.map(adders[i]).fold(0, addi));
	acci(h);

	var lenThenDbl = compose(strlen, dbl);
	var dblThenAdd = compose(dbl, makeAdder(5));
	var g = 0;
	for (i < WORDS.length) g = mix(g, lenThenDbl(WORDS[i]));
	for (i < NUMS.length) g = mix(g, dblThenAdd(NUMS[i]));
	g = mix(g, apply2(strlen, WORDS[4]));
	g = mix(g, apply2(dbl, 21));
	acci(g);

	// bound generic-class methods as first-class values
	var vs = Vec<string>.new();
	var push = vs.add;
	for (i < WORDS.length) void(push(WORDS[i]));
	var k = mix(0, vs.length());
	k = vs.hash(mixs);
	acci(k);

	if (lenThenDbl(WORDS[5]) != 12) fail_assert(501);
	if (dblThenAdd(10) != 25) fail_assert(502);
	if (apply2(strlen, WORDS[2]) != 3) fail_assert(503);
	if (apply2(dbl, 21) != 42) fail_assert(504);
	if (makeAdder(7)(3) != 10) fail_assert(505);
	if (vs.length() != WORDS.length) fail_assert(506);
	if (v.map(makeAdder(1)).fold(0, addi) != 52 + NUMS.length) fail_assert(507);
	if (v.map(dbl).fold(0, addi) != 104) fail_assert(508);
	// map to a different type parameter, then back
	if (Vec<string>.new().addAll(WORDS).map(strlen).fold(0, addi) != 21) fail_assert(509);
	if (v.map(fun (x: int) => WORDS[x % WORDS.length]).map(strlen).fold(0, addi) != 46) fail_assert(510);
}

//======================================================================
// Section 6: generic recursive structures
//======================================================================
class Link<T> {
	def val: T;
	var next: Link<T>;
	new(val, next) { }
	def count() -> int {
		var n = 0, p: Link<T> = this;
		while (p != null) { n++; p = p.next; }
		return n;
	}
	def rev() -> Link<T> {
		var acc: Link<T>, p: Link<T> = this;
		while (p != null) { acc = Link<T>.new(p.val, acc); p = p.next; }
		return acc;
	}
	def nth(i: int) -> T {
		var p: Link<T> = this;
		while (i > 0 && p != null) { p = p.next; i--; }
		return if(p == null, defval(), p.val);
	}
	def defval() -> T { var d: T; return d; }
}
class Tree2<T> {
	def key: int;
	def val: T;
	var left: Tree2<T>;
	var right: Tree2<T>;
	new(key, val) { }
}
def insert2<T>(t: Tree2<T>, k: int, v: T) -> Tree2<T> {
	if (t == null) return Tree2<T>.new(k, v);
	if (k < t.key) t.left = insert2(t.left, k, v);
	else if (k > t.key) t.right = insert2(t.right, k, v);
	return t;
}
def size2<T>(t: Tree2<T>) -> int {
	if (t == null) return 0;
	return 1 + size2(t.left) + size2(t.right);
}
def walk2<T>(t: Tree2<T>, h: int, f: (int, T) -> int) -> int {
	if (t == null) return mix(h, 0x11EA5);
	var g = walk2(t.left, h, f);
	g = mix(g, t.key);
	g = f(g, t.val);
	return walk2(t.right, g, f);
}
def recursive() {
	srand(0x5EED61);
	var li: Link<int>;
	for (i < 300) li = Link<int>.new(randn(1000), li);
	var ls: Link<string>;
	for (i < 60) ls = Link<string>.new(WORDS[i % WORDS.length], ls);
	var h = mix(0, li.count());
	h = mix(h, ls.count());
	h = mix(h, li.rev().count());
	var p = li;
	while (p != null) { h = mix(h, p.val); p = p.next; }
	var q = ls.rev();
	while (q != null) { h = mixs(h, q.val); q = q.next; }
	acci(h);

	srand(0x5EED62);
	var ti: Tree2<int>;
	var ts: Tree2<string>;
	for (i < 400) {
		var k = randn(800);
		ti = insert2(ti, k, k * 3);
		ts = insert2(ts, k, WORDS[k % WORDS.length]);
	}
	var g = mix(0, size2(ti));
	g = mix(g, size2(ts));
	g = walk2(ti, g, mix);
	g = walk2(ts, g, mixs);
	acci(g);

	var l3 = Link<int>.new(1, Link<int>.new(2, Link<int>.new(3, null)));
	if (l3.count() != 3) fail_assert(601);
	if (l3.nth(0) != 1) fail_assert(602);
	if (l3.nth(2) != 3) fail_assert(603);
	if (l3.nth(9) != 0) fail_assert(604);			// past the end: default
	if (l3.rev().nth(0) != 3) fail_assert(605);
	if (l3.rev().rev().nth(0) != 1) fail_assert(606);
	var s2 = Link<string>.new(WORDS[0], null);
	if (s2.nth(4) != null) fail_assert(607);
	if (s2.defval() != null) fail_assert(608);
	var t: Tree2<int>;
	t = insert2(t, 5, 50);
	t = insert2(t, 3, 30);
	t = insert2(t, 7, 70);
	t = insert2(t, 5, 99);					// duplicate key: no growth
	if (size2(t) != 3) fail_assert(609);
	if (t.val != 50) fail_assert(610);
	if (t.left.key != 3) fail_assert(611);
	if (t.right.val != 70) fail_assert(612);
	if (size2<int>(null) != 0) fail_assert(613);
}

//======================================================================
// Section 7: identity, defaults and queries on instantiated types
//======================================================================
var gvi: Vec<int>;
var gvs: Vec<string>;
var gp: Pair<int, string>;
def queries() {
	gvi = null;
	gvs = null;
	gp = null;

	var a = Vec<int>.new();
	var b = Vec<int>.new();
	var c: Vec<int> = a;
	var h = mixb(0, a == b);
	h = mixb(h, a == c);
	h = mixb(h, gvi == null);
	acci(h);
	if (a == b) fail_assert(701);
	if (!(a == c)) fail_assert(702);
	if (gvi != null) fail_assert(703);

	gvi = a.addAll(NUMS);
	gvs = Vec<string>.new().addAll(WORDS);
	gp = Pair<int, string>.new(3, WORDS[0]);
	var g = mix(0, gvi.fold(0, addi));
	g = mix(g, gvs.fold(0, catlen));
	g = mix(g, gp.a);
	g = mixs(g, gp.b);
	acci(g);
	if (gvi.length() != NUMS.length) fail_assert(704);
	if (gvi != a) fail_assert(705);
	if (gvs.get(5).length != 6) fail_assert(706);

	// distinct instantiations are distinct types
	var oi: Cell<int> = Cell<int>.new(1);
	var os: Cell<string> = Cell<string>.new(WORDS[0]);
	if (!Cell<int>.?(oi)) fail_assert(707);
	if (!Cell<string>.?(os)) fail_assert(708);
	if (Labeled<int>.?(oi)) fail_assert(709);
	// arrays of instantiated types, held in a generic container
	var vv = Vec<Vec<int>>.new();
	for (i < 40) vv.add(Vec<int>.new().addAll(NUMS));
	var k = mix(0, vv.length());
	for (i < vv.length()) k = mix(k, vv.get(i).fold(0, addi));
	k = mixb(k, vv.get(0) == vv.get(1));
	k = mixb(k, vv.get(0) == vv.get(0));
	acci(k);
	if (vv.get(0) == vv.get(1)) fail_assert(710);
	if (!(vv.get(3) == vv.get(3))) fail_assert(711);
	if (vv.indexOf(vv.get(7)) != 7) fail_assert(712);
	if (vv.indexOf(a) != -1) fail_assert(713);
}

//======================================================================
// Section 8: allocation churn across instantiations
//======================================================================
def churn() {
	srand(0x5EED81);
	var keepI = Array<Vec<int>>.new(12);
	var keepS = Array<Vec<string>>.new(12);
	var keepC = Array<Cell<int>>.new(12);
	for (i < 1500) {
		var vi = Vec<int>.new();
		for (j < 12) vi.add(randn(500));
		var vs = Vec<string>.new();
		for (j < 6) vs.add(WORDS[randn(WORDS.length)]);
		var cc: Cell<int> = if((i & 1) == 0,
			Counted<int>.new(i, i * 2),
			IntCell.new(i));
		if ((i % 61) == 0) {
			keepI[(i / 61) % keepI.length] = vi;
			keepS[(i / 61) % keepS.length] = vs;
			keepC[(i / 61) % keepC.length] = cc;
		}
	}
	var h = 0;
	for (i < keepI.length) {
		if (keepI[i] != null) h = mix(h, keepI[i].fold(0, addi));
		if (keepS[i] != null) h = mix(h, keepS[i].fold(0, catlen));
		if (keepC[i] != null) {
			h = mix(h, keepC[i].get());
			h = mix(h, keepC[i].rank());
		}
	}
	acci(h);

	// a long-lived generic structure built while short-lived ones churn
	var live = Vec<Link<int>>.new();
	for (i < 40) {
		var l: Link<int>;
		for (j < 20) l = Link<int>.new(randn(1000), l);
		live.add(l);
		for (j < 20) {
			var junk = Vec<(int, string)>.new();
			for (m < 8) junk.add((randn(100), WORDS[randn(WORDS.length)]));
		}
	}
	var g = mix(0, live.length());
	for (i < live.length()) {
		g = mix(g, live.get(i).count());
		var p = live.get(i);
		while (p != null) { g = mix(g, p.val); p = p.next; }
	}
	acci(g);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) containers();
	if (a == 0 || a == 2) pairs();
	if (a == 0 || a == 3) polyinherit();
	if (a == 0 || a == 4) genmethods();
	if (a == 0 || a == 5) delegates();
	if (a == 0 || a == 6) recursive();
	if (a == 0 || a == 7) queries();
	if (a == 0 || a == 8) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
