//@execute 0=1798746484; 1=2009159436; 2=27191417; 3=-662579280; 4=-434327214; 5=-1877885779; 6=1720469464; 7=111920595; 8=-697011054
//@heap-size=500000
// Smoke test: first-class functions.
// Operator references, bound method delegates, partial application, closures,
// and function values stored in arrays, tuples, globals, class fields and
// variant cases -- then composed and applied in bulk. Results are mixed into a
// running CRC that main() returns, so nothing can be deleted as dead code.
// Interleaved are assert()s over compile-time constants, which the optimizer is
// expected to fold away; a folding bug sets the failure flag instead.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

def ARGS: Array<int> = [
	0, 1, -1, 2, -2, 7, -7, 31, -31, 255, -256,
	65535, -65536, 1000000, -1000000, 2147483647, -2147483648
];
def NAMES: Array<string> = ["add", "sub", "mul", "and", "or", "xor"];

//======================================================================
// Section 1: operator references and plain function values
//======================================================================
def add(a: int, b: int) -> int { return a + b; }
def sub(a: int, b: int) -> int { return a - b; }
def safediv(a: int, b: int) -> int {
	if (b == 0) return 0;
	if (b == -1) return 0 - a;	// avoid int.min / -1 overflow
	return a / b;
}
def opsrefs() {
	def OPS: Array<(int, int) -> int> = [
		int.+, int.-, int.*, int.&, int.|, int.^, add, sub, safediv
	];
	// shift operators take a byte amount, not an int
	def SHIFTS: Array<(int, byte) -> int> = [int.<<, int.>>, int.>>>];
	for (k < SHIFTS.length) {
		var f = SHIFTS[k], h = 0;
		for (i < ARGS.length) for (b < 40) h = mix(h, f(ARGS[i], byte.view(b)));
		acci(h);
	}
	for (k < OPS.length) {
		var f = OPS[k], h = 0;
		for (i < ARGS.length) for (j < ARGS.length) h = mix(h, f(ARGS[i], ARGS[j]));
		acci(h);
	}
	def CMPS: Array<(int, int) -> bool> = [int.<, int.<=, int.>, int.>=, int.==, int.!=];
	for (k < CMPS.length) {
		var f = CMPS[k], h = 0;
		for (i < ARGS.length) for (j < ARGS.length) h = mixb(h, f(ARGS[i], ARGS[j]));
		acci(h);
	}
	// function values compared and selected at runtime
	var g: (int, int) -> int = if(ARGS.length > 0, int.+, int.-);
	var p: (int, int) -> int = add, q: (int, int) -> int = sub;
	var h = mix(0, g(3, 4));
	h = mix(h, g(-7, 31));
	h = mixb(h, g == int.+);
	h = mixb(h, g == int.-);
	h = mixb(h, add == add);
	h = mixb(h, add == sub);
	h = mixb(h, p == add);
	h = mixb(h, p == q);
	acci(h);
	// unary and conversion operators as values
	def U: Array<int -> long> = [long.!, long.view];
	var u = 0;
	for (k < U.length) for (i < ARGS.length) u = mixl(u, U[k](ARGS[i]));
	var tb: int -> byte = byte.view;
	for (i < ARGS.length) u = mix(u, int.!(tb(ARGS[i])));
	acci(u);

	if (int.+(3, 4) != 7) fail_assert(101);
	if (int.-(3, 4) != -1) fail_assert(102);
	if (int.*(3, 4) != 12) fail_assert(103);
	if (int.^(0xF0, 0x0F) != 0xFF) fail_assert(104);
	if (int.<<(1, byte.view(31)) != -2147483648) fail_assert(105);
	if (int.>>(-8, byte.view(1)) != -4) fail_assert(106);
	if (int.>>>(-8, byte.view(1)) != 2147483644) fail_assert(107);
	if (int.<<(1, byte.view(32)) != 0) fail_assert(108);	// shifts >= width are 0
	if (!(int.<(1, 2))) fail_assert(109);
	if (safediv(-2147483648, -1) != -2147483648) fail_assert(110);
	if (add != add) fail_assert(111);
	if (add == sub) fail_assert(112);
	if (long.view(-1) != -1L) fail_assert(113);
	if (int.!(byte.view(511)) != 255) fail_assert(114);
}

//======================================================================
// Section 2: bound method delegates and virtual dispatch
//======================================================================
class Acc {
	var total: int;
	def name: string;
	new(name) { }
	def step(x: int) -> int { total = total + x; return total; }
	def kind() -> string { return "acc"; }
	def combine(a: int, b: int) -> int { return a + b; }
}
class MulAcc extends Acc {
	new(name: string) super(name) { }
	def step(x: int) -> int { total = total * 2 + x; return total; }
	def kind() -> string { return "mul"; }
	def combine(a: int, b: int) -> int { return a * b; }
}
class XorAcc extends Acc {
	new(name: string) super(name) { }
	def step(x: int) -> int { total = total ^ (x * 3); return total; }
	def kind() -> string { return "xor"; }
	def combine(a: int, b: int) -> int { return a ^ b; }
}
def delegates() {
	var objs: Array<Acc> = [
		Acc.new("a"), MulAcc.new("m"), XorAcc.new("x"),
		Acc.new("a2"), MulAcc.new("m2"), XorAcc.new("x2")
	];
	// delegates bound to each receiver; dispatch is fixed at bind time
	var steps = Array<int -> int>.new(objs.length);
	var kinds = Array<void -> string>.new(objs.length);
	var combines = Array<(int, int) -> int>.new(objs.length);
	for (i < objs.length) {
		steps[i] = objs[i].step;
		kinds[i] = objs[i].kind;
		combines[i] = objs[i].combine;
	}
	var h = 0;
	for (r < 4) {
		for (i < steps.length) {
			for (j < ARGS.length) h = mix(h, steps[i](ARGS[j]));
			h = mixs(h, kinds[i]());
		}
	}
	acci(h);
	var g = 0;
	for (i < objs.length) {
		g = mix(g, objs[i].total);
		g = mixs(g, objs[i].name);
		g = mixb(g, MulAcc.?(objs[i]));
		g = mixb(g, XorAcc.?(objs[i]));
	}
	for (i < combines.length) {
		for (j < ARGS.length) g = mix(g, combines[i](ARGS[j], ARGS[(j + 1) % ARGS.length]));
	}
	// unbound method references applied to an explicit receiver
	var um: (Acc, int) -> int = Acc.step;
	for (i < objs.length) g = mix(g, um(objs[i], 5));
	acci(g);
	// delegate identity
	var d1 = objs[0].step, d2 = objs[0].step, d3 = objs[1].step;
	var nf: int -> int;
	var k = mixb(0, d1 == d2);
	k = mixb(k, d1 == d3);
	k = mixb(k, nf == null);
	k = mixb(k, d1 == null);
	acci(k);

	var a = Acc.new("t"), m = MulAcc.new("t"), x = XorAcc.new("t");
	if (a.step(5) != 5) fail_assert(201);
	if (a.step(5) != 10) fail_assert(202);			// state accumulates
	if (m.step(3) != 3) fail_assert(203);			// 0*2+3
	if (m.step(3) != 9) fail_assert(204);			// 3*2+3
	if (x.step(1) != 3) fail_assert(205);			// 0^(1*3)
	if (a.combine(3, 4) != 7) fail_assert(206);
	if (m.combine(3, 4) != 12) fail_assert(207);
	if (x.combine(3, 4) != 7) fail_assert(208);
	// a delegate bound to a subclass receiver dispatches to the override
	var bound: int -> int = m.step;
	if (bound(0) != 18) fail_assert(209);			// 9*2+0
	var ubound: (Acc, int) -> int = Acc.step;
	if (ubound(x, 0) != 3) fail_assert(210);		// still the XorAcc override
	if (!MulAcc.?(m)) fail_assert(211);
	if (MulAcc.?(a)) fail_assert(212);
	if (!Strings.equal(m.kind(), "mul")) fail_assert(213);
}
// tiny local helper so the assertions above can compare strings
component Strings {
	def equal(a: string, b: string) -> bool {
		if (a == b) return true;
		if (a == null || b == null) return false;
		if (a.length != b.length) return false;
		for (i < a.length) if (a[i] != b[i]) return false;
		return true;
	}
}

//======================================================================
// Section 3: partial application
//======================================================================
def four(a: int, b: int, c: int, d: int) -> int {
	return a * 1000 + b * 100 + c * 10 + d;
}
def mixed(a: int, s: string, b: bool) -> int {
	return a + s.length + if(b, 1, 0);
}
class Pair(a: int, b: int) {
	def sum() -> int { return a + b; }
}
def partial() {
	var f1 = four(1, _, _, _);
	var f2 = four(_, 2, _, _);
	var f3 = four(_, _, 3, _);
	var f4 = four(_, _, _, 4);
	var g1 = four(1, 2, _, _);
	var g2 = four(_, _, 3, 4);
	var g3 = four(1, _, 3, _);
	var h1 = four(1, 2, 3, _);
	var h2 = four(_, 2, 3, 4);
	var h = 0;
	for (i < ARGS.length) {
		var v = ARGS[i] % 10;
		h = mix(h, f1(v, v, v));
		h = mix(h, f2(v, v, v));
		h = mix(h, f3(v, v, v));
		h = mix(h, f4(v, v, v));
		h = mix(h, g1(v, v));
		h = mix(h, g2(v, v));
		h = mix(h, g3(v, v));
		h = mix(h, h1(v));
		h = mix(h, h2(v));
	}
	acci(h);
	var inc = int.+(1, _);
	var dec = int.-(_, 1);
	var neg = int.-(0, _);
	var g = 0;
	for (i < ARGS.length) {
		g = mix(g, inc(ARGS[i]));
		g = mix(g, dec(ARGS[i]));
		g = mix(g, neg(ARGS[i]));
	}
	var m1 = mixed(_, "hello", true);
	var m2 = mixed(10, _, false);
	var m3 = mixed(10, "xy", _);
	for (i < ARGS.length) g = mix(g, m1(ARGS[i] % 100));
	for (i < NAMES.length) g = mix(g, m2(NAMES[i]));
	g = mix(g, m3(true));
	g = mix(g, m3(false));
	acci(g);
	// partially applied bound method, and a partially applied constructor
	var acc = Acc.new("p");
	var st = acc.step;
	var pa = acc.combine(7, _);
	var mk = Pair.new(3, _);
	var k = 0;
	for (i < ARGS.length) {
		k = mix(k, st(ARGS[i] % 50));
		k = mix(k, pa(ARGS[i] % 50));
		k = mix(k, mk(ARGS[i]).sum());
	}
	k = mix(k, acc.total);
	acci(k);

	if (four(1, 2, 3, 4) != 1234) fail_assert(301);
	if (four(1, _, _, _)(2, 3, 4) != 1234) fail_assert(302);
	if (four(_, 2, _, _)(1, 3, 4) != 1234) fail_assert(303);
	if (four(_, _, _, 4)(1, 2, 3) != 1234) fail_assert(304);
	if (four(1, 2, _, _)(3, 4) != 1234) fail_assert(305);
	if (four(_, _, 3, 4)(1, 2) != 1234) fail_assert(306);
	if (four(1, _, 3, _)(2, 4) != 1234) fail_assert(307);
	if (four(1, 2, 3, _)(4) != 1234) fail_assert(308);
	if (int.+(1, _)(41) != 42) fail_assert(309);
	if (int.-(_, 1)(43) != 42) fail_assert(310);
	if (int.-(0, _)(-42) != 42) fail_assert(311);
	if (mixed(_, "hello", true)(0) != 6) fail_assert(312);
	if (mixed(10, _, false)("xy") != 12) fail_assert(313);
	if (Pair.new(3, _)(4).sum() != 7) fail_assert(314);
}

//======================================================================
// Section 4: closures
//======================================================================
def makeAdder(n: int) -> int -> int {
	return fun (x: int) => x + n;
}
// Closures capture locals by value, so mutable counter state has to live on the
// heap; each call to makeCounter() must produce an independent counter.
class Counter { var n: int; }
def makeCounter() -> void -> int {
	var c = Counter.new();
	return fun () -> int {
		c.n++;
		return c.n;
	};
}
def makeChain(n: int) -> int -> int {
	var f: int -> int = fun (x: int) => x;
	for (i < n) {
		var k = i + 1;			// fresh capture each iteration
		var prev = f;
		f = fun (x: int) => prev(x) + k;
	}
	return f;
}
def closures() {
	var adders = Array<int -> int>.new(16);
	for (i < adders.length) adders[i] = makeAdder(i * 7 - 40);
	var h = 0;
	for (i < adders.length) for (j < ARGS.length) h = mix(h, adders[i](ARGS[j]));
	acci(h);

	// each counter must own its captured state
	var c1 = makeCounter(), c2 = makeCounter();
	var g = 0;
	for (i < 20) { g = mix(g, c1()); if ((i % 3) == 0) g = mix(g, c2()); }
	g = mix(g, c1());
	g = mix(g, c2());
	// capture of a loop variable: each closure keeps its own copy
	var chain = makeChain(12);
	for (i < ARGS.length) g = mix(g, chain(ARGS[i] % 1000));
	acci(g);

	// closure capturing a mutable object rather than a value
	var acc = Acc.new("c");
	var bump = fun (x: int) -> int { return acc.step(x); };
	var k = 0;
	for (i < ARGS.length) k = mix(k, bump(ARGS[i] % 30));
	k = mix(k, acc.total);
	// closure capturing an array and a tuple
	var data = Array<int>.new(32);
	for (i < data.length) data[i] = i * i - 100;
	var t = (3, 5);
	var probe = fun (i: int) -> int { return data[(i & 0x7FFFFFFF) % data.length] + t.0 * t.1; };
	for (i < ARGS.length) k = mix(k, probe(ARGS[i]));
	// mutating the captured array is visible through the closure
	for (i < data.length) data[i] = data[i] * -1;
	for (i < ARGS.length) k = mix(k, probe(ARGS[i]));
	acci(k);

	if (makeAdder(3)(4) != 7) fail_assert(401);
	if (makeAdder(-3)(4) != 1) fail_assert(402);
	// independent counters
	var q1 = makeCounter(), q2 = makeCounter();
	if (q1() != 1) fail_assert(403);
	if (q1() != 2) fail_assert(404);
	if (q2() != 1) fail_assert(405);
	if (q1() != 3) fail_assert(406);
	// makeChain(n) adds 1+2+...+n
	if (makeChain(0)(5) != 5) fail_assert(407);
	if (makeChain(1)(5) != 6) fail_assert(408);
	if (makeChain(3)(5) != 11) fail_assert(409);
	if (makeChain(12)(0) != 78) fail_assert(410);
	// a closure sees later writes through a captured array reference
	var arr = Array<int>.new(2);
	arr[0] = 7;
	var peek = fun () -> int { return arr[0]; };
	if (peek() != 7) fail_assert(411);
	arr[0] = 9;
	if (peek() != 9) fail_assert(412);
	// but a captured local is copied at capture time
	var loc = 7;
	var snap = fun () -> int { return loc; };
	loc = 9;
	if (snap() != 7) fail_assert(413);
}

//======================================================================
// Section 5: functions inside data structures
//======================================================================
type Op {
	case Bin(label: string, f: (int, int) -> int);
	case Un(f: int -> int);
	case None;
}
class Handler {
	var fn: int -> int;
	def tag: int;
	new(tag, fn) { }
}
component Registry {
	var table: Array<(int, int) -> int> = [int.+, int.-, int.*];
	var fallback: (int, int) -> int = int.^;
	def pick(i: int) -> (int, int) -> int {
		if (i < 0 || i >= table.length) return fallback;
		return table[i];
	}
}
var gfun: int -> int;
var gtup: (int -> int, (int, int) -> int);

def applyOp(o: Op, a: int, b: int) -> int {
	match (o) {
		Bin(_, f) => return f(a, b);
		Un(f) => return f(a);
		None => return -1;
	}
}
def stored() {
	// reset globals: the harness may run several inputs in one process
	gfun = null;
	gtup = (null, null);
	Registry.table = [int.+, int.-, int.*];
	Registry.fallback = int.^;

	var ops: Array<Op> = [
		Op.Bin("add", int.+), Op.Bin("sub", int.-), Op.Bin("mul", int.*),
		Op.Bin("and", int.&), Op.Un(makeAdder(5)), Op.Un(int.-(0, _)),
		Op.None
	];
	var h = 0;
	for (k < ops.length) {
		h = mix(h, ops[k].tag);
		for (i < ARGS.length) h = mix(h, applyOp(ops[k], ARGS[i], ARGS[(i + 2) % ARGS.length]));
	}
	match (ops[0]) {
		Bin(label, _) => h = mixs(h, label);
		_ => h = mix(h, -2);
	}
	acci(h);

	// functions in class fields, dispatched through an array of handlers
	var hs = Array<Handler>.new(8);
	for (i < hs.length) hs[i] = Handler.new(i, makeAdder(i * 3));
	var g = 0;
	for (i < hs.length) {
		g = mix(g, hs[i].tag);
		for (j < ARGS.length) g = mix(g, hs[i].fn(ARGS[j]));
	}
	for (i < hs.length) hs[i].fn = int.-(_, i);	// overwrite the field
	for (i < hs.length) for (j < ARGS.length) g = mix(g, hs[i].fn(ARGS[j]));
	acci(g);

	// functions in a component, in globals, and in tuples inside arrays
	var k = 0;
	for (i = -1; i < 4; i++) {
		var f = Registry.pick(i);
		for (j < ARGS.length) k = mix(k, f(ARGS[j], 3));
	}
	gfun = makeAdder(100);
	gtup = (gfun, int.*);
	for (i < ARGS.length) {
		k = mix(k, gfun(ARGS[i]));
		k = mix(k, gtup.0(ARGS[i]));
		k = mix(k, gtup.1(ARGS[i], 2));
	}
	var pairs = Array<(int -> int, int)>.new(8);
	for (i < pairs.length) pairs[i] = (makeAdder(i), i * i);
	for (i < pairs.length) for (j < ARGS.length) k = mix(k, pairs[i].0(ARGS[j]) + pairs[i].1);
	acci(k);

	if (applyOp(Op.Bin("add", int.+), 3, 4) != 7) fail_assert(501);
	if (applyOp(Op.Bin("mul", int.*), 3, 4) != 12) fail_assert(502);
	if (applyOp(Op.Un(makeAdder(5)), 3, 4) != 8) fail_assert(503);
	if (applyOp(Op.None, 3, 4) != -1) fail_assert(504);
	if (Op.Bin("x", int.+).tag != 0) fail_assert(505);
	if (Op.Un(int.-(0, _)).tag != 1) fail_assert(506);
	if (Op.None.tag != 2) fail_assert(507);
	if (Registry.pick(0)(3, 4) != 7) fail_assert(508);
	if (Registry.pick(2)(3, 4) != 12) fail_assert(509);
	if (Registry.pick(99)(0xF0, 0x0F) != 0xFF) fail_assert(510);	// fallback
	if (Handler.new(1, makeAdder(2)).fn(3) != 5) fail_assert(511);
}

//======================================================================
// Section 6: higher-order combinators
//======================================================================
def mapa(f: int -> int, a: Array<int>) -> Array<int> {
	var r = Array<int>.new(a.length);
	for (i < a.length) r[i] = f(a[i]);
	return r;
}
def folda(f: (int, int) -> int, init: int, a: Array<int>) -> int {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def filtera(p: int -> bool, a: Array<int>) -> Array<int> {
	var n = 0;
	for (i < a.length) if (p(a[i])) n++;
	var r = Array<int>.new(n);
	var k = 0;
	for (i < a.length) if (p(a[i])) { r[k] = a[i]; k++; }
	return r;
}
def compose(f: int -> int, g: int -> int) -> int -> int {
	return fun (x: int) => g(f(x));
}
def curry(f: (int, int) -> int) -> int -> (int -> int) {
	return fun (a: int) => f(a, _);
}
def twice(f: int -> int) -> int -> int {
	return fun (x: int) => f(f(x));
}
def higher() {
	var data = Array<int>.new(48);
	for (i < data.length) data[i] = (i * 37) % 101 - 50;

	def FS: Array<int -> int> = [makeAdder(3), int.*(_, 2), int.-(0, _), makeAdder(-9)];
	for (k < FS.length) {
		var m = mapa(FS[k], data), h = 0;
		for (i < m.length) h = mix(h, m[i]);
		h = mix(h, folda(int.+, 0, m));
		h = mix(h, folda(int.^, -1, m));
		acci(h);
	}
	def PS: Array<int -> bool> = [int.<(_, 0), int.>(_, 0), int.==(_, 0)];
	var g = 0;
	for (k < PS.length) {
		var f = filtera(PS[k], data);
		g = mix(g, f.length);
		for (i < f.length) g = mix(g, f[i]);
	}
	acci(g);
	// composition, currying, repeated application
	var c1 = compose(makeAdder(5), int.*(_, 3));
	var c2 = compose(c1, makeAdder(-2));
	var c3 = compose(c2, c2);
	var cur = curry(int.+);
	var add10 = cur(10);
	var t2 = twice(makeAdder(7));
	var t4 = twice(t2);
	var k = 0;
	for (i < ARGS.length) {
		k = mix(k, c1(ARGS[i] % 1000));
		k = mix(k, c2(ARGS[i] % 1000));
		k = mix(k, c3(ARGS[i] % 1000));
		k = mix(k, add10(ARGS[i]));
		k = mix(k, t2(ARGS[i]));
		k = mix(k, t4(ARGS[i]));
	}
	acci(k);
	// a pipeline of composed closures over the whole array
	var pipe: int -> int = fun (x: int) => x;
	for (i < 8) pipe = compose(pipe, makeAdder(i * i));
	var out = mapa(pipe, data);
	var o = 0;
	for (i < out.length) o = mix(o, out[i]);
	o = mix(o, folda(int.+, 0, out));
	acci(o);

	if (compose(makeAdder(5), int.*(_, 3))(1) != 18) fail_assert(601);	// (1+5)*3
	if (compose(int.*(_, 3), makeAdder(5))(1) != 8) fail_assert(602);	// (1*3)+5
	if (curry(int.+)(10)(32) != 42) fail_assert(603);
	if (twice(makeAdder(7))(0) != 14) fail_assert(604);
	if (twice(twice(makeAdder(7)))(0) != 28) fail_assert(605);
	if (folda(int.+, 0, [1, 2, 3, 4]) != 10) fail_assert(606);
	if (folda(int.*, 1, [1, 2, 3, 4]) != 24) fail_assert(607);
	if (mapa(makeAdder(1), [1, 2, 3])[2] != 4) fail_assert(608);
	if (filtera(int.<(_, 0), [-1, 2, -3, 4]).length != 2) fail_assert(609);
	if (filtera(int.>(_, 0), [-1, 2, -3, 4])[1] != 4) fail_assert(610);
}

//======================================================================
// Section 7: polymorphic functions
//======================================================================
def ident<T>(x: T) -> T { return x; }
def applyp<A, B>(f: A -> B, a: A) -> B { return f(a); }
def mapp<A, B>(f: A -> B, a: Array<A>) -> Array<B> {
	var r = Array<B>.new(a.length);
	for (i < a.length) r[i] = f(a[i]);
	return r;
}
def foldp<A, B>(f: (B, A) -> B, init: B, a: Array<A>) -> B {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def swap<A, B>(t: (A, B)) -> (B, A) { return (t.1, t.0); }
def strlen(s: string) -> int { return s.length; }
def polymorphic() {
	var h = 0;
	for (i < ARGS.length) {
		h = mix(h, ident(ARGS[i]));
		h = mixl(h, ident(long.!(ARGS[i])));
		h = mixb(h, ident(ARGS[i] > 0));
	}
	for (i < NAMES.length) h = mixs(h, ident(NAMES[i]));
	acci(h);

	var lens = mapp(strlen, NAMES);
	var g = mix(0, applyp(strlen, "hello"));
	g = mix(g, applyp(makeAdder(4), 38));
	g = mixb(g, applyp(int.<(_, 0), -5));
	for (i < lens.length) g = mix(g, lens[i]);
	g = mix(g, foldp(int.+, 0, lens));
	acci(g);

	var data = Array<int>.new(24);
	for (i < data.length) data[i] = i * 13 - 100;
	var strs = mapp(fun (x: int) => NAMES[(x & 0x7FFFFFFF) % NAMES.length], data);
	var k = 0;
	for (i < strs.length) k = mixs(k, strs[i]);
	k = mix(k, foldp(fun (b: int, s: string) => b + s.length, 0, strs));
	var t = swap((3, "abc"));
	var u = swap(swap((7, true)));
	k = mixs(k, t.0);
	k = mix(k, t.1);
	k = mix(k, u.0);
	k = mixb(k, u.1);
	// polymorphic function stored as a value at two instantiations
	var fi: int -> int = ident<int>;
	var fs: string -> string = ident<string>;
	for (i < ARGS.length) k = mix(k, fi(ARGS[i]));
	for (i < NAMES.length) k = mixs(k, fs(NAMES[i]));
	acci(k);

	if (ident(42) != 42) fail_assert(701);
	if (ident(true) != true) fail_assert(702);
	if (ident<int>(42) != 42) fail_assert(703);
	if (applyp(strlen, "hello") != 5) fail_assert(704);
	if (applyp(makeAdder(4), 38) != 42) fail_assert(705);
	if (swap((3, 4)).0 != 4) fail_assert(706);
	if (swap(swap((7, 8))).0 != 7) fail_assert(707);
	if (foldp(int.+, 0, [1, 2, 3]) != 6) fail_assert(708);
	if (mapp(strlen, ["a", "bb"])[1] != 2) fail_assert(709);
}

//======================================================================
// Section 8: closure allocation churn
//======================================================================
def churn() {
	var keep = Array<int -> int>.new(12);
	for (i < keep.length) keep[i] = int.+(0, _);
	var live: int -> int = int.+(0, _);
	var h = 0;
	for (i < 1500) {
		// most of these closures are immediately garbage
		var k = i % 251;
		var f = fun (x: int) => x + k;
		if ((i % 61) == 0) {
			keep[(i / 61) % keep.length] = f;
			live = compose(live, f);
		}
		if ((i % 17) == 0) h = mix(h, f(i));
	}
	acci(h);
	var g = 0;
	for (i < keep.length) for (j < ARGS.length) g = mix(g, keep[i](ARGS[j]));
	for (i < ARGS.length) g = mix(g, live(ARGS[i] % 10000));
	acci(g);
	// closures capturing freshly allocated objects
	var objs = Array<void -> int>.new(64);
	for (i < objs.length) {
		var a = Acc.new("n");
		a.total = i * 3;
		var n = i;
		objs[i] = fun () -> int { return a.step(n); };
	}
	var k = 0;
	for (r < 3) for (i < objs.length) k = mix(k, objs[i]());
	acci(k);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) opsrefs();
	if (a == 0 || a == 2) delegates();
	if (a == 0 || a == 3) partial();
	if (a == 0 || a == 4) closures();
	if (a == 0 || a == 5) stored();
	if (a == 0 || a == 6) higher();
	if (a == 0 || a == 7) polymorphic();
	if (a == 0 || a == 8) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
