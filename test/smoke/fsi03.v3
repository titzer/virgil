//@execute 0=1314335303; 1=-1897425201; 2=463267798; 3=962250207; 4=1592077205; 5=623161870; 6=-1324588208; 7=-1158783147; 8=-1463344476; 9=2074992482; 10=-602994734; 11=983800549; 12=-797735041
//@heap-size=200000
// Smoke test: conversions between fixed-size integer types. The subject is the
// three-way relationship between
//   T.view(x)  reinterpret: reduce x mod 2^width(T), read under T's signedness
//   T.?(x)     query:       true exactly when T.view(x) == x
//   T.!(x)     checked:     the value of T.view(x), but traps when T.?(x) is false
// so every out-of-range case here is exercised through the query, never through
// a trapping cast: `.!` is only ever applied where `.?` has already said yes.
//
// Note also what is NOT here. When the source type promotes to the target type
// (i8 into i16, u8 into i16, u31 into i33, anything into long), a query is
// statically pointless and the compiler rejects `T.?(x)` outright, so the
// promoting direction is covered by `.view` and `.!` alone.
//
// Values flow into a CRC that main() returns so nothing is dead; interleaved
// assert()s over compile-time constants are expected to fold away entirely.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixu(h: int, x: u64) -> int {
	return mixl(h, long.view(x));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def VALS: Array<long> = [
	0, 1, -1, 2, -2, 127, -128, 128, -129, 255, -256, 256,
	32767, -32768, 32768, 65535, -65536, 65536,
	4194303, -4194304, 4194304, 8388607, -8388608,
	2147483647, -2147483648, 2147483648L, 4294967295L, -4294967296L, 4294967296L,
	140737488355327L, -140737488355328L,
	4611686018427387903L, -4611686018427387904L,
	9223372036854775807L, -9223372036854775808L, 1234567890123456789L
];
def I8S: Array<i8> = [-128, -1, 0, 1, 127];
def U8S: Array<u8> = [0, 1, 127, 128, 255];
def I16S: Array<i16> = [-32768, -129, -1, 0, 127, 128, 32767];
def U16S: Array<u16> = [0, 127, 128, 255, 256, 32768, 65535];
def I23S: Array<i23> = [-4194304, -65537, -1, 0, 65535, 65536, 4194303];
def U31S: Array<u31> = [0, 1, 65535, 2147483646, 2147483647];
def I33S: Array<i33> = [-4294967296, -2147483649, -1, 0, 2147483647, 2147483648, 4294967295];
def U47S: Array<u47> = [0, 1, 4294967295, 4294967296, 140737488355327];
def I63S: Array<i63> = [-4611686018427387904, -1, 0, 1, 4611686018427387903];
def U64S: Array<u64> = [0, 1, 2147483648uL, 9223372036854775807uL, 9223372036854775808uL, 18446744073709551615uL];

// The full set of views of one long value, in a fixed order.
def viewAll(h0: int, v: long) -> int {
	var h = h0;
	h = mixl(h, i1.view(v));
	h = mixl(h, u1.view(v));
	h = mixl(h, i8.view(v));
	h = mixl(h, u8.view(v));
	h = mixl(h, i16.view(v));
	h = mixl(h, u16.view(v));
	h = mixl(h, i23.view(v));
	h = mixl(h, u23.view(v));
	h = mixl(h, i31.view(v));
	h = mixl(h, u31.view(v));
	h = mixl(h, i32.view(v));
	h = mixl(h, u32.view(v));
	h = mixl(h, i33.view(v));
	h = mixl(h, u33.view(v));
	h = mixl(h, i47.view(v));
	h = mixl(h, u47.view(v));
	h = mixl(h, i63.view(v));
	h = mixl(h, u63.view(v));
	h = mixu(h, u64.view(v));
	return h;
}
// The full set of queries of one long value, in the same order.
def queryAll(h0: int, v: long) -> int {
	var h = h0;
	h = mixb(h, i1.?(v));
	h = mixb(h, u1.?(v));
	h = mixb(h, i8.?(v));
	h = mixb(h, u8.?(v));
	h = mixb(h, i16.?(v));
	h = mixb(h, u16.?(v));
	h = mixb(h, i23.?(v));
	h = mixb(h, u23.?(v));
	h = mixb(h, i31.?(v));
	h = mixb(h, u31.?(v));
	h = mixb(h, i32.?(v));
	h = mixb(h, u32.?(v));
	h = mixb(h, i33.?(v));
	h = mixb(h, u33.?(v));
	h = mixb(h, i47.?(v));
	h = mixb(h, u47.?(v));
	h = mixb(h, i63.?(v));
	h = mixb(h, u63.?(v));
	h = mixb(h, u64.?(v));
	return h;
}
// Every checked cast that the corresponding query permits.
def castAll(h0: int, v: long) -> int {
	var h = h0;
	if (i8.?(v)) h = mixl(h, i8.!(v));
	if (u8.?(v)) h = mixl(h, u8.!(v));
	if (i16.?(v)) h = mixl(h, i16.!(v));
	if (u16.?(v)) h = mixl(h, u16.!(v));
	if (i23.?(v)) h = mixl(h, i23.!(v));
	if (u31.?(v)) h = mixl(h, u31.!(v));
	if (i32.?(v)) h = mixl(h, i32.!(v));
	if (u32.?(v)) h = mixl(h, u32.!(v));
	if (i33.?(v)) h = mixl(h, i33.!(v));
	if (u47.?(v)) h = mixl(h, u47.!(v));
	if (i63.?(v)) h = mixl(h, i63.!(v));
	if (u64.?(v)) h = mixu(h, u64.!(v));
	return h;
}

//======================================================================
// Section 1: same width, opposite signedness
//======================================================================
def sameWidth() {
	var h = 0;
	for (i < I8S.length) {
		h = mixl(h, u8.view(I8S[i]));
		h = mixb(h, u8.?(I8S[i]));
	}
	for (i < U8S.length) {
		h = mixl(h, i8.view(U8S[i]));
		h = mixb(h, i8.?(U8S[i]));
	}
	for (i < I16S.length) {
		h = mixl(h, u16.view(I16S[i]));
		h = mixb(h, u16.?(I16S[i]));
	}
	for (i < U16S.length) {
		h = mixl(h, i16.view(U16S[i]));
		h = mixb(h, i16.?(U16S[i]));
	}
	for (i < I23S.length) {
		h = mixl(h, u23.view(I23S[i]));
		h = mixb(h, u23.?(I23S[i]));
	}
	for (i < I33S.length) {
		h = mixl(h, u33.view(I33S[i]));
		h = mixb(h, u33.?(I33S[i]));
	}
	for (i < U64S.length) {
		h = mixl(h, long.view(U64S[i]));
		h = mixb(h, long.?(U64S[i]));
	}
	acci(h);

	// the bits are untouched; only the interpretation of the top bit changes
	if (u8.view(i8.view(-1)) != 255) fail_assert(101);
	if (i8.view(u8.view(255)) != -1) fail_assert(102);
	if (u8.view(i8.view(-128)) != 128) fail_assert(103);
	if (u16.view(i16.view(-32768)) != 32768) fail_assert(104);
	if (u23.view(i23.view(-1)) != 8388607) fail_assert(105);
	if (u32.view(-1) != 4294967295L) fail_assert(106);
	if (u47.view(i47.view(-1)) != 140737488355327L) fail_assert(107);
	if (long.view(u64.max) != -1) fail_assert(108);
	// the query is false exactly when the sign bit of the width is set
	if (u8.?(i8.view(-1))) fail_assert(109);
	if (!u8.?(i8.view(127))) fail_assert(110);
	if (i8.?(u8.view(255))) fail_assert(111);
	if (!i8.?(u8.view(127))) fail_assert(112);
	if (i16.?(u16.view(32768))) fail_assert(113);
	if (!i16.?(u16.view(32767))) fail_assert(114);
	if (i23.?(u23.view(8388607))) fail_assert(115);
	if (int.?(u32.view(4294967295L))) fail_assert(116);
	if (!int.?(u32.view(2147483647))) fail_assert(117);
	if (long.?(u64.max)) fail_assert(118);
	if (!long.?(u64.view(9223372036854775807uL))) fail_assert(119);
	if (u64.?(-1L)) fail_assert(120);
}

//======================================================================
// Section 2: narrowing, same signedness
//======================================================================
def narrow() {
	var h = 0;
	for (i < I16S.length) {
		h = mixl(h, i8.view(I16S[i]));
		h = mixb(h, i8.?(I16S[i]));
	}
	for (i < U16S.length) {
		h = mixl(h, u8.view(U16S[i]));
		h = mixb(h, u8.?(U16S[i]));
	}
	for (i < I33S.length) {
		h = mixl(h, i23.view(I33S[i]));
		h = mixb(h, i23.?(I33S[i]));
		h = mixl(h, i16.view(I33S[i]));
		h = mixb(h, i16.?(I33S[i]));
	}
	for (i < U47S.length) {
		h = mixl(h, u31.view(U47S[i]));
		h = mixb(h, u31.?(U47S[i]));
		h = mixl(h, u16.view(U47S[i]));
		h = mixb(h, u16.?(U47S[i]));
	}
	for (i < I63S.length) {
		h = mixl(h, i33.view(I63S[i]));
		h = mixb(h, i33.?(I63S[i]));
	}
	acci(h);

	// narrowing keeps the low bits, then reads them under the target's sign
	if (i8.view(i16.view(300)) != 44) fail_assert(201);
	if (i8.view(i16.view(-129)) != 127) fail_assert(202);
	if (u8.view(u16.view(300)) != 44) fail_assert(203);
	if (i23.view(i33.view(4194304)) != -4194304) fail_assert(204);
	if (i16.view(i33.view(65536)) != 0) fail_assert(205);
	if (u31.view(u47.view(4294967296L)) != 0) fail_assert(206);
	if (i33.view(i63.view(-4611686018427387904L)) != 0) fail_assert(207);
	// the query is false exactly when a bit was lost
	if (i8.?(i16.view(300))) fail_assert(208);
	if (i8.?(i16.view(-129))) fail_assert(209);
	if (!i8.?(i16.view(-128))) fail_assert(210);
	if (!i8.?(i16.view(127))) fail_assert(211);
	if (u8.?(u16.view(256))) fail_assert(212);
	if (!u8.?(u16.view(255))) fail_assert(213);
	if (i23.?(i33.view(4194304))) fail_assert(214);
	if (!i23.?(i33.view(4194303))) fail_assert(215);
	if (i17.?(i23.view(65536))) fail_assert(216);
	if (!i17.?(i23.view(65535))) fail_assert(217);
	if (u31.?(u47.view(2147483648L))) fail_assert(218);
	if (!u31.?(u47.view(2147483647))) fail_assert(219);
	if (i33.?(i63.view(4294967296L))) fail_assert(220);
	if (!i33.?(i63.view(4294967295L))) fail_assert(221);
}

//======================================================================
// Section 3: the promoting direction, where no query exists
//======================================================================
def widen() {
	var h = 0;
	for (i < I8S.length) {
		var a = I8S[i];
		h = mixl(h, i16.view(a));	// sign-extends
		h = mixl(h, i23.view(a));
		h = mixl(h, i33.view(a));
		h = mixl(h, long.view(a));
		h = mixl(h, i16.!(a));		// a widening checked cast always succeeds
		h = mixl(h, long.!(a));
	}
	for (i < U8S.length) {
		var a = U8S[i];
		h = mixl(h, u16.view(a));	// zero-extends
		h = mixl(h, i16.view(a));	// unsigned into wider signed also promotes
		h = mixl(h, u47.view(a));
		h = mixl(h, i16.!(a));
		h = mixl(h, u47.!(a));
		h = mixl(h, long.!(a));
	}
	for (i < U31S.length) {
		var a = U31S[i];
		h = mixl(h, i33.view(a));
		h = mixl(h, u47.view(a));
		h = mixl(h, i33.!(a));
		h = mixl(h, long.!(a));
	}
	acci(h);

	// a promoting view is the identity on the mathematical value
	if (i16.view(i8.view(-1)) != -1) fail_assert(301);
	if (i16.view(i8.view(-128)) != -128) fail_assert(302);
	if (long.view(i8.view(-128)) != -128) fail_assert(303);
	if (i16.view(u8.view(255)) != 255) fail_assert(304);
	if (u16.view(u8.view(255)) != 255) fail_assert(305);
	if (i33.view(u31.view(2147483647)) != 2147483647) fail_assert(306);
	if (u47.view(u31.view(2147483647)) != 2147483647) fail_assert(307);
	if (long.view(i23.view(-4194304)) != -4194304) fail_assert(308);
	// and so is a promoting checked cast, which can never trap
	if (i16.!(i8.view(-128)) != -128) fail_assert(309);
	if (long.!(i8.view(-128)) != -128) fail_assert(310);
	if (i33.!(u31.view(2147483647)) != 2147483647) fail_assert(311);
	if (u47.!(u8.view(255)) != 255) fail_assert(312);
	if (long.!(u63.view(-1L)) != 9223372036854775807L) fail_assert(313);
}

//======================================================================
// Section 4: signed source into a wider unsigned target
//======================================================================
def signedToUnsigned() {
	var h = 0;
	for (i < I8S.length) {
		var a = I8S[i];
		h = mixl(h, u16.view(a));
		h = mixb(h, u16.?(a));
		h = mixl(h, u31.view(a));
		h = mixb(h, u31.?(a));
		h = mixu(h, u64.view(a));
		h = mixb(h, u64.?(a));
	}
	for (i < I23S.length) {
		var a = I23S[i];
		h = mixl(h, u33.view(a));
		h = mixb(h, u33.?(a));
		h = mixl(h, u47.view(a));
		h = mixb(h, u47.?(a));
	}
	for (i < I63S.length) {
		var a = I63S[i];
		h = mixu(h, u64.view(a));
		h = mixb(h, u64.?(a));
	}
	acci(h);

	// the view wraps modulo the target width, so a negative value becomes large
	if (u16.view(i8.view(-1)) != 65535) fail_assert(401);
	if (u16.view(i8.view(-128)) != 65408) fail_assert(402);
	if (u47.view(i23.view(-1)) != 140737488355327L) fail_assert(403);
	if (u33.view(i23.view(-4194304)) != 8585740288L) fail_assert(404);
	if (long.view(u64.view(i8.view(-1))) != -1) fail_assert(405);
	if (long.view(u64.view(i63.view(-1L))) != -1) fail_assert(406);
	// the query is true exactly for the non-negative values
	if (u16.?(i8.view(-1))) fail_assert(407);
	if (!u16.?(i8.view(127))) fail_assert(408);
	if (u31.?(i8.view(-128))) fail_assert(409);
	if (!u31.?(i8.view(0))) fail_assert(410);
	if (u47.?(i23.view(-1))) fail_assert(411);
	if (!u47.?(i23.view(4194303))) fail_assert(412);
	if (u64.?(i63.view(-1L))) fail_assert(413);
	if (!u64.?(i63.view(4611686018427387903L))) fail_assert(414);
}

//======================================================================
// Section 5: unsigned source into a signed target of no greater width
//======================================================================
def unsignedToSigned() {
	var h = 0;
	for (i < U16S.length) {
		var a = U16S[i];
		h = mixl(h, i16.view(a));
		h = mixb(h, i16.?(a));
		h = mixl(h, i8.view(a));
		h = mixb(h, i8.?(a));
	}
	for (i < U31S.length) {
		var a = U31S[i];
		h = mixl(h, i23.view(a));
		h = mixb(h, i23.?(a));
		h = mixl(h, i31.view(a));
		h = mixb(h, i31.?(a));
	}
	for (i < U47S.length) {
		var a = U47S[i];
		h = mixl(h, i47.view(a));
		h = mixb(h, i47.?(a));
		h = mixl(h, i33.view(a));
		h = mixb(h, i33.?(a));
	}
	for (i < U64S.length) {
		var a = U64S[i];
		h = mixl(h, i63.view(a));
		h = mixb(h, i63.?(a));
		h = mixl(h, i47.view(a));
		h = mixb(h, i47.?(a));
		h = mixl(h, int.view(a));
		h = mixb(h, int.?(a));
	}
	acci(h);

	if (i8.view(u16.view(255)) != -1) fail_assert(501);
	if (i31.view(u31.view(2147483647)) != -1) fail_assert(502);
	if (i23.view(u31.view(2147483648L)) != 0) fail_assert(503);	// 2^31 mod 2^23
	if (i47.view(u64.max) != -1) fail_assert(504);
	if (int.view(u64.view(4294967295uL)) != -1) fail_assert(505);
	if (i63.view(u64.view(9223372036854775808uL)) != 0) fail_assert(506);
	if (i8.?(u16.view(255))) fail_assert(507);
	if (!i8.?(u16.view(127))) fail_assert(508);
	if (i31.?(u31.view(2147483647))) fail_assert(509);
	if (!i31.?(u31.view(1073741823))) fail_assert(510);
	if (i47.?(u64.max)) fail_assert(511);
	if (!i63.?(u64.view(1))) fail_assert(512);
	if (int.?(u64.view(2147483648uL))) fail_assert(513);
	if (!int.?(u64.view(2147483647uL))) fail_assert(514);
}

//======================================================================
// Section 6: the law relating .? and .view, over the whole value set
//======================================================================
def law() {
	var h = 0;
	for (i < VALS.length) {
		var v = VALS[i];
		h = viewAll(h, v);
		h = queryAll(h, v);
		// The query is exactly "the value survives a round trip through the
		// view". This is checked at runtime for the whole matrix; the folded
		// constant cases live in the sections above.
		if (i8.?(v) != (i8.view(v) == v)) fail_assert(601);
		if (u8.?(v) != (u8.view(v) == v)) fail_assert(602);
		if (i16.?(v) != (i16.view(v) == v)) fail_assert(603);
		if (u16.?(v) != (u16.view(v) == v)) fail_assert(604);
		if (i23.?(v) != (i23.view(v) == v)) fail_assert(605);
		if (u23.?(v) != (u23.view(v) == v)) fail_assert(606);
		if (i31.?(v) != (i31.view(v) == v)) fail_assert(607);
		if (u31.?(v) != (u31.view(v) == v)) fail_assert(608);
		if (i32.?(v) != (i32.view(v) == v)) fail_assert(609);
		if (u32.?(v) != (u32.view(v) == v)) fail_assert(610);
		if (i33.?(v) != (i33.view(v) == v)) fail_assert(611);
		if (u33.?(v) != (u33.view(v) == v)) fail_assert(612);
		if (i47.?(v) != (i47.view(v) == v)) fail_assert(613);
		if (u47.?(v) != (u47.view(v) == v)) fail_assert(614);
		if (i63.?(v) != (i63.view(v) == v)) fail_assert(615);
		if (u63.?(v) != (u63.view(v) == v)) fail_assert(616);
		// u64 does not compare against long, so its law is stated directly
		if (u64.?(v) != (v >= 0)) fail_assert(617);
	}
	acci(h);
}

//======================================================================
// Section 7: checked casts, always guarded by their query
//======================================================================
def checked() {
	var h = 0;
	for (i < VALS.length) h = castAll(h, VALS[i]);
	acci(h);

	// where the query says yes, the cast agrees with the view
	var g = 0;
	for (i < VALS.length) {
		var v = VALS[i];
		if (i8.?(v)) {
			g = mixl(g, i8.!(v));
			if (i8.!(v) != i8.view(v)) fail_assert(701);
		}
		if (u31.?(v)) {
			g = mixl(g, u31.!(v));
			if (u31.!(v) != u31.view(v)) fail_assert(702);
		}
		if (i33.?(v)) {
			g = mixl(g, i33.!(v));
			if (i33.!(v) != i33.view(v)) fail_assert(703);
		}
		if (u64.?(v)) {
			g = mixu(g, u64.!(v));
			if (long.view(u64.!(v)) != long.view(u64.view(v))) fail_assert(704);
		}
	}
	acci(g);

	if (i8.!(127) != 127) fail_assert(705);
	if (i8.!(-128) != -128) fail_assert(706);
	if (u8.!(255) != 255) fail_assert(707);
	if (i23.!(4194303) != 4194303) fail_assert(708);
	if (u31.!(2147483647) != 2147483647) fail_assert(709);
	if (i33.!(4294967295L) != 4294967295L) fail_assert(710);
	if (u47.!(140737488355327L) != 140737488355327L) fail_assert(711);
	if (long.view(u64.!(9223372036854775807L)) != 9223372036854775807L) fail_assert(712);
}

//======================================================================
// Section 8: conversion chains
//======================================================================
def chains() {
	var h = 0;
	for (i < VALS.length) {
		var v = VALS[i];
		// narrow then widen: information is lost once and never recovered
		h = mixl(h, long.view(i8.view(v)));
		h = mixl(h, long.view(u8.view(v)));
		h = mixl(h, i33.view(i23.view(v)));
		h = mixl(h, u47.view(u23.view(v)));
		// widen then narrow: the identity
		h = mixl(h, i8.view(long.view(i8.view(v))));
		h = mixl(h, u31.view(u64.view(u31.view(v))));
		// a chain through the opposite signedness at the same width
		h = mixl(h, i16.view(u16.view(i16.view(v))));
		h = mixl(h, u23.view(i23.view(u23.view(v))));
	}
	acci(h);

	// narrowing is idempotent, and widening after it changes nothing
	if (i8.view(long.view(i8.view(-1))) != -1) fail_assert(801);
	if (u8.view(int.view(u8.view(200))) != 200) fail_assert(802);
	if (i23.view(i33.view(i23.view(-4194304))) != -4194304) fail_assert(803);
	if (u47.view(u64.view(u47.view(-1L))) != 140737488355327L) fail_assert(804);
	// two narrowings compose into the narrower of the two
	if (i8.view(i16.view(65535)) != i8.view(65535)) fail_assert(805);
	if (u8.view(u23.view(-1)) != u8.view(-1)) fail_assert(806);
	// a sign flip at the same width is its own inverse
	if (i16.view(u16.view(i16.view(-32768))) != -32768) fail_assert(807);
	if (long.view(u64.view(-1L)) != -1) fail_assert(808);
	// widening a negative value through an unsigned stop loses the sign
	if (long.view(u16.view(i8.view(-1))) != 65535) fail_assert(809);
	if (i33.view(u23.view(i23.view(-1))) != 8388607) fail_assert(810);
}

//======================================================================
// Section 9: conversions of values held in arrays, ranges and tuples
//======================================================================
def convertRange(r: Range<i33>, out: Range<i23>) {
	for (i < r.length) out[i] = i23.view(r[i]);
}
def aggregates() {
	var src = Array<i33>.new(48);
	for (i < src.length) src[i] = i33.view(i * 178956971L - 4294967296L);
	var dst = Array<i23>.new(48);
	convertRange(src, dst);
	var h = 0;
	for (i < src.length) {
		h = mixl(h, src[i]);
		h = mixl(h, dst[i]);
		h = mixb(h, i23.?(src[i]));
	}
	acci(h);

	// the same value seen through several element types
	var a8 = Array<i8>.new(48);
	var a16 = Array<u16>.new(48);
	var a64 = Array<u64>.new(48);
	for (i < src.length) {
		a8[i] = i8.view(src[i]);
		a16[i] = u16.view(src[i]);
		a64[i] = u64.view(src[i]);
	}
	var g = 0;
	for (i < src.length) {
		g = mixl(g, a8[i]);
		g = mixl(g, a16[i]);
		g = mixu(g, a64[i]);
		// every narrower view agrees with the wider one, bit for bit
		if (a8[i] != i8.view(a16[i])) fail_assert(901);
		if (a16[i] != u16.view(a64[i])) fail_assert(902);
	}
	acci(g);

	var ts = Array<(i8, u16, i33, u64)>.new(32);
	for (i < ts.length) {
		var v = VALS[i % VALS.length];
		ts[i] = (i8.view(v), u16.view(v), i33.view(v), u64.view(v));
	}
	var k = 0;
	for (i < ts.length) {
		var t = ts[i];
		k = mixl(k, t.0);
		k = mixl(k, t.1);
		k = mixl(k, t.2);
		k = mixu(k, t.3);
		if (t.0 != i8.view(t.2)) fail_assert(903);
		if (t.1 != u16.view(t.3)) fail_assert(904);
	}
	acci(k);
	if (dst.length != 48) fail_assert(905);
}

//======================================================================
// Section 10: conversions in class fields and variant payloads
//======================================================================
class Conv {
	var narrow: i8;
	var mid: u16;
	var wide: i33;
	var full: u64;
	new(v: long) {
		narrow = i8.view(v);
		mid = u16.view(v);
		wide = i33.view(v);
		full = u64.view(v);
	}
	def consistent() -> bool {
		return narrow == i8.view(mid) && mid == u16.view(wide) && wide == i33.view(full);
	}
}
type CVal {
	case Narrow(v: i8);
	case Mid(v: u16);
	case Wide(v: i33);
	case Full(v: u64);
}
def widthOf(c: CVal) -> int {
	match (c) {
		Narrow => return 8;
		Mid => return 16;
		Wide => return 33;
		Full => return 64;
	}
}
def asLong(c: CVal) -> long {
	match (c) {
		Narrow(v) => return v;
		Mid(v) => return v;
		Wide(v) => return v;
		Full(v) => return long.view(v);
	}
}
def objects() {
	var objs = Array<Conv>.new(VALS.length);
	for (i < VALS.length) objs[i] = Conv.new(VALS[i]);
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mixl(h, o.narrow);
		h = mixl(h, o.mid);
		h = mixl(h, o.wide);
		h = mixu(h, o.full);
		h = mixb(h, o.consistent());
		if (!o.consistent()) fail_assert(1001);
	}
	acci(h);

	var cs = Array<CVal>.new(4 * VALS.length);
	for (i < VALS.length) {
		var v = VALS[i];
		cs[4 * i + 0] = CVal.Narrow(i8.view(v));
		cs[4 * i + 1] = CVal.Mid(u16.view(v));
		cs[4 * i + 2] = CVal.Wide(i33.view(v));
		cs[4 * i + 3] = CVal.Full(u64.view(v));
	}
	var g = 0;
	for (i < cs.length) {
		g = mixl(g, asLong(cs[i]));
		g = mix(g, widthOf(cs[i]));
		g = mix(g, cs[i].tag);
	}
	acci(g);

	if (asLong(CVal.Narrow(i8.view(-1))) != -1) fail_assert(1002);
	if (asLong(CVal.Mid(u16.view(-1))) != 65535) fail_assert(1003);
	if (asLong(CVal.Wide(i33.view(-1))) != -1) fail_assert(1004);
	if (asLong(CVal.Full(u64.view(-1L))) != -1) fail_assert(1005);
	if (widthOf(CVal.Full(u64.view(0))) != 64) fail_assert(1006);
	if (CVal.Wide(i33.view(0)).tag != 2) fail_assert(1007);
	// a payload truncates on construction, so two sources can collide
	if (CVal.Narrow(i8.view(300)) != CVal.Narrow(i8.view(44))) fail_assert(1008);
}

//======================================================================
// Section 11: conversions as first-class function values
//======================================================================
def applyv(f: long -> i23, v: long) -> i23 { return f(v); }
def applyq(f: long -> bool, v: long) -> bool { return f(v); }
def firstClass() {
	def VIEWS: Array<long -> i23> = [i23.view<long>, i23.view<long>];
	def QUERIES: Array<long -> bool> = [i8.?<long>, u8.?<long>, i23.?<long>, u31.?<long>, i33.?<long>, u47.?<long>, u64.?<long>];
	var h = 0;
	for (i < VALS.length) {
		h = mixl(h, applyv(VIEWS[i % VIEWS.length], VALS[i]));
		for (k < QUERIES.length) h = mixb(h, applyq(QUERIES[k], VALS[i]));
	}
	acci(h);

	var toU8: i33 -> u8 = u8.view<i33>;
	var upI33: i23 -> i33 = i33.!<i23>;
	var g = 0;
	for (i < I33S.length) g = mixl(g, toU8(I33S[i]));
	for (i < I23S.length) g = mixl(g, upI33(I23S[i]));
	acci(g);

	if (applyv(i23.view<long>, 4194304L) != -4194304) fail_assert(1101);
	if (applyq(i8.?<long>, 128L)) fail_assert(1102);
	if (!applyq(i8.?<long>, 127L)) fail_assert(1103);
	if (applyq(u64.?<long>, -1L)) fail_assert(1104);
	if (u8.view<i33>(i33.view(-1)) != 255) fail_assert(1105);
	if (i33.!<i23>(i23.view(-4194304)) != -4194304) fail_assert(1106);
}

//======================================================================
// Section 12: allocation churn over converted values
//======================================================================
class CLink(a: i8, b: u16, c: i33, d: u64, next: CLink) { }
def churn() {
	var head: CLink;
	var live = Array<CLink>.new(16);
	for (i < 2000) {
		var v = i * 1234567891L - 1000000000000L;
		head = CLink.new(i8.view(v), u16.view(v), i33.view(v), u64.view(v), head);
		if ((i % 97) == 0) live[(i / 97) % live.length] = head;
		if ((i % 13) == 0) head = null;		// drop most of the chain
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mixl(h, p.a);
			h = mixl(h, p.b);
			h = mixl(h, p.c);
			h = mixu(h, p.d);
			if (p.a != i8.view(p.c)) fail_assert(1201);
			p = p.next;
			n++;
			if (n > 100000) { acci(h); return; }
		}
	}
	h = mix(h, n);
	acci(h);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) sameWidth();
	if (a == 0 || a == 2) narrow();
	if (a == 0 || a == 3) widen();
	if (a == 0 || a == 4) signedToUnsigned();
	if (a == 0 || a == 5) unsignedToSigned();
	if (a == 0 || a == 6) law();
	if (a == 0 || a == 7) checked();
	if (a == 0 || a == 8) chains();
	if (a == 0 || a == 9) aggregates();
	if (a == 0 || a == 10) objects();
	if (a == 0 || a == 11) firstClass();
	if (a == 0 || a == 12) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
