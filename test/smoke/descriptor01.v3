//@execute 0=-1608771383; 1=1740335420; 2=-883077098; 3=-1701256735; 4=-1464506847; 5=-468423122; 6=-1629811895; 7=-1628354118
//@heap-size=1000000
// Smoke test: descriptors (requires -lang:descriptors, see descriptor01.v3.flags).
//
// A `class D describes A` is the descriptor type for `class A descriptor D`.
// Every instance of A carries a D, supplied as the first constructor argument
// and read back through `a.descriptor`. Descriptors form their own inheritance
// hierarchy that parallels the described classes, can themselves be described,
// can be polymorphic, and their fields stay mutable through `.descriptor`.
//
// Results are mixed into a running CRC that main() returns; interleaved are
// assert()s over compile-time constants which the optimizer should fold away.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

def SEEDS: Array<int> = [0, 1, -1, 7, -7, 255, -256, 65535, 1000003, -2147483648];

//======================================================================
// Section 1: basic construction and descriptor access
//======================================================================
class DBase(kind: int) describes Base {
	def describe() -> string { return "base"; }
	def weight() -> int { return kind; }
}
class Base(payload: int) descriptor DBase {
	def total() -> int { return payload + this.descriptor.weight(); }
}
def basics() {
	var d = DBase.new(10);
	var h = 0;
	for (i < SEEDS.length) {
		var b = Base.new(d, SEEDS[i]);
		h = mix(h, b.payload);
		h = mix(h, b.descriptor.kind);
		h = mix(h, b.total());
		h = mixs(h, b.descriptor.describe());
		h = mixb(h, b.descriptor == d);
	}
	acci(h);

	// every object built with the same descriptor shares it
	var b1 = Base.new(d, 1), b2 = Base.new(d, 2);
	var g = mixb(0, b1.descriptor == b2.descriptor);
	g = mixb(g, b1 == b2);
	g = mixb(g, b1.descriptor != null);
	acci(g);

	if (Base.new(DBase.new(5), 3).payload != 3) fail_assert(101);
	if (Base.new(DBase.new(5), 3).descriptor.kind != 5) fail_assert(102);
	if (Base.new(DBase.new(5), 3).total() != 8) fail_assert(103);
	if (Base.new(DBase.new(0), 0).total() != 0) fail_assert(104);
	if (b1.descriptor != b2.descriptor) fail_assert(105);
	if (b1 == b2) fail_assert(106);
	if (b1.descriptor == null) fail_assert(107);
}

//======================================================================
// Section 2: parallel inheritance hierarchies
//======================================================================
class DMid extends DBase describes Mid {
	new(k: int) super(k) { }
	def describe() -> string { return "mid"; }
	def weight() -> int { return kind * 2; }
}
class DLeaf extends DMid describes Leaf {
	new(k: int) super(k) { }
	def describe() -> string { return "leaf"; }
	def weight() -> int { return kind * 3; }
}
class Mid extends Base descriptor DMid {
	new(payload: int) super(payload) { }
}
class Leaf extends Mid descriptor DLeaf {
	new(payload: int) super(payload) { }
}
def hierarchy() {
	var objs: Array<Base> = [
		Base.new(DBase.new(1), 100),
		Mid.new(DMid.new(2), 200),
		Leaf.new(DLeaf.new(3), 300),
		Base.new(DBase.new(4), 400),
		Leaf.new(DLeaf.new(5), 500)
	];
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mix(h, o.payload);
		h = mix(h, o.total());			// virtual through the descriptor
		h = mixs(h, o.descriptor.describe());	// virtual on the descriptor
		h = mix(h, o.descriptor.kind);
		h = mixb(h, Mid.?(o));
		h = mixb(h, Leaf.?(o));
		h = mixb(h, DMid.?(o.descriptor));
		h = mixb(h, DLeaf.?(o.descriptor));
	}
	acci(h);

	// the descriptor hierarchy mirrors the described hierarchy
	var b = Base.new(DBase.new(7), 0);
	var m = Mid.new(DMid.new(7), 0);
	var l = Leaf.new(DLeaf.new(7), 0);
	if (b.descriptor.weight() != 7) fail_assert(201);
	if (m.descriptor.weight() != 14) fail_assert(202);
	if (l.descriptor.weight() != 21) fail_assert(203);
	if (b.total() != 7) fail_assert(204);
	if (m.total() != 14) fail_assert(205);
	if (l.total() != 21) fail_assert(206);
	var bb: Base = b, bm: Base = m, bl: Base = l;
	if (DMid.?(bb.descriptor)) fail_assert(207);
	if (!DMid.?(bm.descriptor)) fail_assert(208);
	if (!DMid.?(bl.descriptor)) fail_assert(209);	// DLeaf extends DMid
	if (DLeaf.?(bm.descriptor)) fail_assert(210);
	if (!DLeaf.?(bl.descriptor)) fail_assert(211);
	if (!Mid.?(l)) fail_assert(212);
	if (Leaf.?(m)) fail_assert(213);
}

//======================================================================
// Section 3: mutable descriptor state
//======================================================================
class DCounter describes Counted {
	var hits: int;
	var last: int;
	def bump(v: int) -> int {
		hits++;
		last = v;
		return hits;
	}
}
class Counted(id: int) descriptor DCounter { }
def mutable() {
	var d = DCounter.new();
	var objs = Array<Counted>.new(16);
	for (i < objs.length) objs[i] = Counted.new(d, i);
	var h = 0;
	for (i < objs.length) {
		h = mix(h, objs[i].descriptor.bump(objs[i].id));
		h = mix(h, objs[i].descriptor.hits);
		h = mix(h, objs[i].descriptor.last);
	}
	// the descriptor is shared, so every object sees the same counter
	h = mix(h, d.hits);
	h = mix(h, objs[0].descriptor.hits);
	acci(h);

	// direct field writes through .descriptor
	var e = DCounter.new();
	var c = Counted.new(e, 99);
	c.descriptor.hits = 5;
	var g = mix(0, c.descriptor.hits);
	c.descriptor.hits += 3;
	g = mix(g, c.descriptor.hits);
	c.descriptor.hits = c.descriptor.hits * 2;
	g = mix(g, c.descriptor.hits);
	acci(g);

	if (e.hits != 16) fail_assert(301);
	if (c.descriptor.hits != 16) fail_assert(302);
	if (c.id != 99) fail_assert(303);
	var f = DCounter.new();
	var c2 = Counted.new(f, 1), c3 = Counted.new(f, 2);
	if (c2.descriptor.bump(7) != 1) fail_assert(304);
	if (c3.descriptor.bump(8) != 2) fail_assert(305);	// shared state
	if (c2.descriptor.last != 8) fail_assert(306);
	if (f.hits != 2) fail_assert(307);
}

//======================================================================
// Section 4: descriptors of descriptors
//======================================================================
class DMeta(level: int) describes DThing { }
class DThing(tag: int) descriptor DMeta describes Thing { }
class Thing(value: int) descriptor DThing { }
def chained() {
	var meta = DMeta.new(3);
	var h = 0;
	for (i < SEEDS.length) {
		var dt = DThing.new(meta, i);
		var t = Thing.new(dt, SEEDS[i]);
		h = mix(h, t.value);
		h = mix(h, t.descriptor.tag);
		h = mix(h, t.descriptor.descriptor.level);	// two levels up
		h = mixb(h, t.descriptor.descriptor == meta);
	}
	acci(h);

	var m = DMeta.new(9);
	var dt = DThing.new(m, 4);
	var t = Thing.new(dt, 42);
	if (t.value != 42) fail_assert(401);
	if (t.descriptor.tag != 4) fail_assert(402);
	if (t.descriptor.descriptor.level != 9) fail_assert(403);
	if (t.descriptor != dt) fail_assert(404);
	if (t.descriptor.descriptor != m) fail_assert(405);
	// two Things sharing a DThing share its DMeta too
	var t2 = Thing.new(dt, 43);
	if (t2.descriptor.descriptor != m) fail_assert(406);
	if (t.descriptor != t2.descriptor) fail_assert(407);
}

//======================================================================
// Section 5: polymorphic descriptors
//======================================================================
class DBox<T> describes Box<T> {
	var made: int;
}
class Box<T>(item: T) descriptor DBox<T> {
	def get() -> T { return item; }
}
class DPair<T, U> describes Pair<T, U> { }
class Pair<T, U>(a: T, b: U) descriptor DPair<T, U> { }

def makeBox<T>(d: DBox<T>, v: T) -> Box<T> {
	d.made++;
	return Box<T>.new(d, v);
}
def poly() {
	var di = DBox<int>.new();
	var ds = DBox<string>.new();
	var db = DBox<bool>.new();
	var h = 0;
	for (i < SEEDS.length) {
		var bi = makeBox<int>(di, SEEDS[i]);
		h = mix(h, bi.get());
		h = mix(h, bi.descriptor.made);
	}
	var bs = makeBox<string>(ds, "alpha");
	var bb = makeBox<bool>(db, true);
	h = mixs(h, bs.get());
	h = mixb(h, bb.get());
	h = mix(h, ds.made);
	h = mix(h, db.made);
	acci(h);

	// boxes of boxes, and a two-parameter descriptor
	var dbb = DBox<Box<int>>.new();
	var inner = makeBox<int>(di, 7);
	var outer = makeBox<Box<int>>(dbb, inner);
	var dp = DPair<int, string>.new();
	var p = Pair<int, string>.new(dp, 5, "beta");
	var g = mix(0, outer.get().get());
	g = mix(g, dbb.made);
	g = mix(g, p.a);
	g = mixs(g, p.b);
	g = mixb(g, p.descriptor == dp);
	acci(g);

	if (makeBox<int>(DBox<int>.new(), 5).get() != 5) fail_assert(501);
	if (makeBox<int>(DBox<int>.new(), 5).descriptor.made != 1) fail_assert(502);
	var d2 = DBox<int>.new();
	if (makeBox<int>(d2, 1).descriptor.made != 1) fail_assert(503);
	if (makeBox<int>(d2, 2).descriptor.made != 2) fail_assert(504);
	if (Pair<int, bool>.new(DPair<int, bool>.new(), 3, true).a != 3) fail_assert(505);
	if (Box<int>.new(DBox<int>.new(), 8).get() != 8) fail_assert(506);
}

//======================================================================
// Section 6: descriptors in containers, and the descriptor getter
//======================================================================
type Holder {
	case Obj(b: Base);
	case Desc(d: DBase);
	case Nothing;
}
def hv(h: Holder) -> int {
	match (h) {
		Obj(b) => return if(b == null, -1, b.total());
		Desc(d) => return if(d == null, -2, d.weight());
		Nothing => return -3;
	}
}
def containers() {
	// `A.descriptor` used as a first-class getter function
	var get: Base -> DBase = Base.descriptor;
	var objs = Array<Base>.new(24);
	var descs = Array<DBase>.new(24);
	for (i < objs.length) {
		match (i % 3) {
			0 => objs[i] = Base.new(DBase.new(i), i * 10);
			1 => objs[i] = Mid.new(DMid.new(i), i * 10);
			_ => objs[i] = Leaf.new(DLeaf.new(i), i * 10);
		}
		descs[i] = get(objs[i]);
	}
	var h = 0;
	for (i < objs.length) {
		h = mix(h, objs[i].total());
		h = mix(h, descs[i].weight());
		h = mixs(h, descs[i].describe());
		h = mixb(h, descs[i] == objs[i].descriptor);
	}
	acci(h);

	// descriptors and described objects inside variants and tuples
	var hs = Array<Holder>.new(24);
	for (i < hs.length) {
		match (i % 3) {
			0 => hs[i] = Holder.Obj(objs[i]);
			1 => hs[i] = Holder.Desc(descs[i]);
			_ => hs[i] = Holder.Nothing;
		}
	}
	var g = 0;
	for (i < hs.length) {
		g = mix(g, hv(hs[i]));
		g = mix(g, hs[i].tag);
	}
	g = mix(g, hv(Holder.Obj(null)));
	g = mix(g, hv(Holder.Desc(null)));
	var tups = Array<(Base, DBase, int)>.new(12);
	for (i < tups.length) tups[i] = (objs[i], descs[i], i);
	for (i < tups.length) {
		g = mix(g, tups[i].0.total());
		g = mix(g, tups[i].1.weight());
		g = mix(g, tups[i].2);
	}
	acci(g);

	var b = Base.new(DBase.new(6), 1);
	if (get(b) != b.descriptor) fail_assert(601);
	if (get(b).weight() != 6) fail_assert(602);
	if (hv(Holder.Nothing) != -3) fail_assert(603);
	if (hv(Holder.Obj(null)) != -1) fail_assert(604);
	if (hv(Holder.Desc(null)) != -2) fail_assert(605);
	if (hv(Holder.Obj(b)) != 7) fail_assert(606);		// payload 1 + weight 6
	if (Holder.Obj(b).tag != 0) fail_assert(607);
	if (Holder.Nothing.tag != 2) fail_assert(608);
}

//======================================================================
// Section 7: allocation churn with shared descriptors
//======================================================================
def churn() {
	var shared = DBase.new(2);
	var sharedMid = DMid.new(3);
	var keep = Array<Base>.new(16);
	for (i < keep.length) keep[i] = Base.new(shared, i);
	var h = 0;
	for (i < 3000) {
		// most of these are immediately garbage; the descriptor is not
		var b: Base = if((i % 2) == 0,
			Base.new(shared, i),
			Mid.new(sharedMid, i));
		if ((i % 211) == 0) keep[(i / 211) % keep.length] = b;
		if ((i % 419) == 0) h = mix(h, b.total());
	}
	acci(h);
	var g = 0;
	for (i < keep.length) {
		g = mix(g, keep[i].payload);
		g = mix(g, keep[i].total());
		g = mix(g, keep[i].descriptor.kind);
		g = mixs(g, keep[i].descriptor.describe());
	}
	acci(g);
	// the shared descriptors survived every collection intact
	if (shared.kind != 2) fail_assert(701);
	if (sharedMid.kind != 3) fail_assert(702);
	if (shared.weight() != 2) fail_assert(703);
	if (sharedMid.weight() != 6) fail_assert(704);
	for (i < keep.length) {
		if (keep[i].descriptor == null) fail_assert(705);
	}
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) basics();
	if (a == 0 || a == 2) hierarchy();
	if (a == 0 || a == 3) mutable();
	if (a == 0 || a == 4) chained();
	if (a == 0 || a == 5) poly();
	if (a == 0 || a == 6) containers();
	if (a == 0 || a == 7) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
