//@execute 0=1153751514; 1=-443813464; 2=1587601420; 3=-1158865914; 4=-1893683465; 5=25623761; 6=1937684026; 7=1332697547; 8=1634499073; 9=-1631732872; 10=1366604849
//@heap-size=200000
// Smoke test: 32-bit signed integer arithmetic, comparison and bit operations.
// Each section drives a group of operations from `def` arrays (so no section can
// be folded away wholesale) and mixes every result into a running CRC that
// main() returns, keeping the computation live. Interleaved are assert()s whose
// operands are compile-time constants: the optimizer is expected to fold them
// away entirely, so a folding bug shows up as a set failure flag rather than a
// wrong CRC. Input selects the section; input 0 runs every section in one body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def VALS: Array<int> = [
	0, 1, -1, 2, -2, 3, -3, 7, -7, 10, -10,
	255, -256, 65535, 65536, 1000000, -1000000,
	0x12345678, -0x12345678, 0x7FFFFFFF, -2147483648,
	1431655765, -1431655766
];
// Divisors: never zero, so division and remainder never trap. int.min / -1 IS
// included on purpose -- Virgil defines it to wrap to int.min rather than trap.
def NZ: Array<int> = [
	1, -1, 2, -2, 3, -3, 7, 10, -10, 255, -256,
	65536, 1000003, 0x7FFFFFFF, -2147483648
];
// Shift amounts, including several at and beyond the 32-bit width. Virgil does
// NOT mask the shift amount: a shift of 32 or more shifts everything out.
def SHIFTS: Array<byte> = [
	0, 1, 2, 3, 4, 5, 6, 7, 8, 12, 15, 16, 17, 23, 24,
	30, 31, 32, 33, 34, 35, 39, 40
];

//======================================================================
// Section 1: arithmetic
//======================================================================
def arith() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = mix(0, -a);
		for (j < NZ.length) {
			var b = NZ[j];
			h = mix(h, a + b);
			h = mix(h, a - b);
			h = mix(h, a * b);
			h = mix(h, a / b);
			h = mix(h, a % b);
		}
		acci(h);
	}
	// compound assignment forms
	var x = 10;
	x += 5;		// 15
	x -= 3;		// 12
	x *= 4;		// 48
	x /= 5;		// 9
	x %= 4;		// 1
	acci(mix(0, x));
	if (x != 1) fail_assert(101);

	// truncating division and a remainder that takes the sign of the dividend
	if (7 / 2 != 3) fail_assert(102);
	if (-7 / 2 != -3) fail_assert(103);
	if (7 / -2 != -3) fail_assert(104);
	if (-7 / -2 != 3) fail_assert(105);
	if (7 % 2 != 1) fail_assert(106);
	if (-7 % 2 != -1) fail_assert(107);
	if (7 % -2 != 1) fail_assert(108);
	if (-7 % -2 != -1) fail_assert(109);
	// a/b*b + a%b == a
	if (-7 / 2 * 2 + -7 % 2 != -7) fail_assert(110);
	if (6 * 7 != 42) fail_assert(111);
	if (-(-5) != 5) fail_assert(112);
	if (0 - 5 != -5) fail_assert(113);
	// NOTE: the literal `-0` is deliberately NOT tested here. In the current
	// compiler it does not denote the integer zero at all: `var b = -0;` infers
	// type `double` and yields a garbage value (int.truncd(b) == -253 on both
	// v3i and -ra). Reported separately; `0 - 0` is used instead.
	if (0 - 0 != 0) fail_assert(114);
	if (100 / 1 != 100) fail_assert(115);
	if (100 % 1 != 0) fail_assert(116);
	if (0 / 17 != 0) fail_assert(117);
	if (0 % 17 != 0) fail_assert(118);
}

//======================================================================
// Section 2: precedence and associativity
//======================================================================
def precedence() {
	var h = 0;
	for (i < VALS.length) {
		var a = VALS[i], b = NZ[i % NZ.length], c = VALS[(i + 5) % VALS.length];
		h = mix(h, a + b * c);
		h = mix(h, (a + b) * c);
		h = mix(h, a - b - c);
		h = mix(h, a - (b - c));
		h = mix(h, a & b | c);
		h = mix(h, a | b & c);
		h = mix(h, a ^ b & c);
		h = mix(h, a + b << 3);		// (a + b) << 3
	}
	acci(h);

	// * binds tighter than +
	if (2 + 3 * 4 != 14) fail_assert(201);
	if ((2 + 3) * 4 != 20) fail_assert(202);
	if (2 * 3 + 4 % 5 != 10) fail_assert(203);
	// - and / are left-associative
	if (100 - 20 - 5 != 75) fail_assert(204);
	if (100 - (20 - 5) != 85) fail_assert(205);
	if (100 / 5 / 2 != 10) fail_assert(206);
	if (100 / (5 / 2) != 50) fail_assert(207);
	if (100 % 7 % 3 != 2) fail_assert(208);
	// & binds tighter than ^, which binds tighter than |
	if ((1 | 2 ^ 3 & 6) != 1) fail_assert(209);
	if ((1 | (2 ^ (3 & 6))) != 1) fail_assert(210);
	if ((((1 | 2) ^ 3) & 6) != 0) fail_assert(211);
	// shifts bind LOOSER than + : `1 + 2 << 3` is `(1 + 2) << 3`
	if (1 + 2 << 3 != 24) fail_assert(212);
	if (1 + (2 << 3) != 17) fail_assert(213);
	// shifts are left-associative
	if (1 << 3 >> 1 != 4) fail_assert(214);
	// unary minus binds tighter than *
	if (-2 * 3 != -6) fail_assert(215);
	// comparison binds tighter than the bitwise operators
	if ((1 < 2 == true) != true) fail_assert(216);
}

//======================================================================
// Section 3: comparisons
//======================================================================
def compare() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = 0;
		for (j < VALS.length) {
			var b = VALS[j];
			h = mixb(h, a == b);
			h = mixb(h, a != b);
			h = mixb(h, a < b);
			h = mixb(h, a <= b);
			h = mixb(h, a > b);
			h = mixb(h, a >= b);
		}
		acci(h);
	}
	// signed ordering: the top bit is a sign, not a magnitude bit
	if (!(-1 < 0)) fail_assert(301);
	if (!(-2147483648 < 2147483647)) fail_assert(302);
	if (-2147483648 > 0) fail_assert(303);
	if (!(2147483647 > -1)) fail_assert(304);
	if (!(-1 <= -1)) fail_assert(305);
	if (!(-1 >= -1)) fail_assert(306);
	if (-1 < -1) fail_assert(307);
	if (-1 > -1) fail_assert(308);
	// (`-0` as a literal is broken in the current compiler -- see section 1.)
	if (!(0 == 0 - 0)) fail_assert(309);
	if (0 != 0 - 0) fail_assert(310);
	// unsigned view reverses the ordering of negatives
	if (!(u32.view(-1) > u32.view(1))) fail_assert(311);
	if (!(u32.view(-2147483648) > u32.view(2147483647))) fail_assert(312);
	// transitivity over a triple taken from the table
	var lo = -2147483648, mid = 0, hi = 2147483647;
	if (!(lo < mid && mid < hi && lo < hi)) fail_assert(313);
}

//======================================================================
// Section 4: bitwise and, or, xor, complement
//======================================================================
def bitwise() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = mix(0, ~a);
		for (j < VALS.length) {
			var b = VALS[j];
			h = mix(h, a & b);
			h = mix(h, a | b);
			h = mix(h, a ^ b);
			h = mix(h, a & ~b);
			h = mix(h, ~(a | b));
		}
		acci(h);
	}
	// compound bitwise assignment
	var x = 0xF0F0;
	x &= 0x0FF0;	// 0x00F0
	x |= 0x0003;	// 0x00F3
	x ^= 0x00FF;	// 0x000C
	acci(mix(0, x));
	if (x != 0x000C) fail_assert(401);

	if ((0xF0F0 & 0x0FF0) != 0x00F0) fail_assert(402);
	if ((0xF0F0 | 0x0FF0) != 0xFFF0) fail_assert(403);
	if ((0xF0F0 ^ 0x0FF0) != 0xFF00) fail_assert(404);
	if (~0 != -1) fail_assert(405);
	if (~5 != -6) fail_assert(406);
	if (~(-1) != 0) fail_assert(407);
	if (~2147483647 != -2147483648) fail_assert(408);
	if (~(-2147483648) != 2147483647) fail_assert(409);
	// ~a == -a - 1
	if (~1234 != -1234 - 1) fail_assert(410);
	// identities
	if ((0x1234 & ~0x1234) != 0) fail_assert(411);
	if ((0x1234 | ~0x1234) != -1) fail_assert(412);
	if ((0x1234 ^ 0x1234) != 0) fail_assert(413);
	if ((0x1234 ^ 0) != 0x1234) fail_assert(414);
	if ((0x1234 ^ -1) != ~0x1234) fail_assert(415);
	if ((0x12345678 & -1) != 0x12345678) fail_assert(416);
	if ((0x12345678 | 0) != 0x12345678) fail_assert(417);
	// de Morgan
	if (~(0x0F0F & 0x3333) != (~0x0F0F | ~0x3333)) fail_assert(418);
}

//======================================================================
// Section 5: shifts, including counts at and past the width
//======================================================================
def shifts() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = 0;
		for (j < SHIFTS.length) {
			var s = SHIFTS[j];
			h = mix(h, a << s);
			h = mix(h, a >> s);
			h = mix(h, a >>> s);
		}
		acci(h);
	}
	// every shift amount 0..40 against a fixed pattern
	var h = 0;
	for (s < 41) {
		var b = byte.view(s);
		h = mix(h, 0x12345678 << b);
		h = mix(h, 0x12345678 >> b);
		h = mix(h, 0x12345678 >>> b);
		h = mix(h, -1 << b);
		h = mix(h, -1 >> b);
		h = mix(h, -1 >>> b);
	}
	acci(h);
	// compound shift assignment
	var x = 1;
	x <<= 20;	// 0x100000
	x >>= 4;	// 0x10000
	x >>>= 8;	// 0x100
	acci(mix(0, x));
	if (x != 0x100) fail_assert(501);

	// shift by zero is the identity
	if (5 << 0 != 5) fail_assert(502);
	if (-5 >> 0 != -5) fail_assert(503);
	if (-5 >>> 0 != -5) fail_assert(504);
	// in-range shifts
	if (1 << 30 != 1073741824) fail_assert(505);
	if (1 << 31 != -2147483648) fail_assert(506);
	if (0x12345678 << 4 != 0x23456780) fail_assert(507);
	if (0x12345678 >> 4 != 0x01234567) fail_assert(508);
	if (0x12345678 >>> 4 != 0x01234567) fail_assert(509);
	if (255 << 24 != -16777216) fail_assert(510);
	if ((255 << 24) >> 24 != -1) fail_assert(511);		// sign fill
	if ((255 << 24) >>> 24 != 255) fail_assert(512);	// zero fill
	if (-1 >> 1 != -1) fail_assert(513);
	if (-1 >>> 1 != 2147483647) fail_assert(514);
	if (-2147483648 >> 31 != -1) fail_assert(515);
	if (-2147483648 >>> 31 != 1) fail_assert(516);
	// shift counts at and beyond the width are NOT masked: everything shifts out
	if (1 << 32 != 0) fail_assert(517);
	if (1 << 33 != 0) fail_assert(518);
	if (1 << 40 != 0) fail_assert(519);
	if (-1 >>> 32 != 0) fail_assert(520);
	if (-1 >>> 40 != 0) fail_assert(521);
	if (0x12345678 >> 32 != 0) fail_assert(522);
	// arithmetic right shift saturates at the sign
	if (-1 >> 32 != -1) fail_assert(523);
	if (-1 >> 40 != -1) fail_assert(524);
	if (-2147483648 >> 40 != -1) fail_assert(525);
	if (-2147483648 >>> 40 != 0) fail_assert(526);
	// a left shift is a multiply by a power of two (modulo wraparound)
	if (3 << 5 != 3 * 32) fail_assert(527);
	// an arithmetic right shift is NOT a truncating divide for negatives
	if (-7 >> 1 != -4) fail_assert(528);
	if (-7 / 2 != -3) fail_assert(529);
}

//======================================================================
// Section 6: ints in arrays and ranges
//======================================================================
def arrays() {
	var a = Array<int>.new(96);
	for (i < a.length) a[i] = VALS[i % VALS.length] ^ (i * 0x9E3779B9);
	var h = 0;
	for (i < a.length) h = mix(h, a[i]);
	acci(h);

	var r: Range<int> = a;
	var mid = r[24 ... 72];
	var tail = r[72 ...];
	var g = mix(0, mid.length);
	for (i < mid.length) g = mix(g, mid[i]);
	for (i < tail.length) g = mix(g, tail[i]);
	acci(g);
	if (mid.length != 48) fail_assert(601);
	if (tail.length != 24) fail_assert(602);

	// range writes alias the backing array
	for (i < mid.length) mid[i] = mid[i] & 0xFFFF;
	var k = 0;
	for (i < a.length) k = mix(k, a[i]);
	acci(k);
	if (a[30] != ((VALS[30 % VALS.length] ^ (30 * 0x9E3779B9)) & 0xFFFF)) fail_assert(603);
	if ((a[30] & ~0xFFFF) != 0) fail_assert(604);

	// two-dimensional, with a prefix-sum that carries wraparound through
	var m = Array<Array<int>>.new(12);
	for (i < m.length) {
		m[i] = Array<int>.new(12);
		for (j < 12) m[i][j] = (i * 12 + j) * 0x01000193;
	}
	var sum = 0;
	for (i < m.length) for (j < 12) sum = sum + m[i][j];
	acci(mix(0, sum));

	// arrays of small types promote on read
	var bs = Array<byte>.new(16);
	for (i < bs.length) bs[i] = byte.view(i * 17);
	var b2 = 0;
	for (i < bs.length) b2 = mix(b2, bs[i]);		// byte widens to int
	acci(b2);
	if (bs[15] != 255) fail_assert(605);
	if (bs[15] + 1 != 256) fail_assert(606);		// promoted, does not wrap
}

//======================================================================
// Section 7: ints in tuples
//======================================================================
def swapi(t: (int, int)) -> (int, int) {
	return (t.1, t.0);
}
def divmod(a: int, b: int) -> (int, int) {
	return (a / b, a % b);
}
def tuples() {
	var h = 0;
	for (i < VALS.length) {
		var t = (VALS[i], NZ[i % NZ.length]);
		var s = swapi(t);
		var q = divmod(t.0, t.1);
		h = mix(h, t.0);
		h = mix(h, t.1);
		h = mix(h, s.0);
		h = mix(h, s.1);
		h = mix(h, q.0);
		h = mix(h, q.1);
		h = mixb(h, t == s);
	}
	acci(h);

	var ts = Array<(int, int, byte)>.new(32);
	for (i < ts.length) ts[i] = (VALS[i % VALS.length], i * i, byte.view(i));
	var g = 0;
	for (i < ts.length) {
		var t = ts[i];
		g = mix(g, t.0);
		g = mix(g, t.1);
		g = mix(g, t.2);
	}
	acci(g);

	var n = ((1, 2), (3, (4, 5)));		// nested tuples
	var k = mix(0, n.0.0);
	k = mix(k, n.0.1);
	k = mix(k, n.1.0);
	k = mix(k, n.1.1.0);
	k = mix(k, n.1.1.1);
	acci(k);

	if (divmod(-7, 2).0 != -3) fail_assert(701);
	if (divmod(-7, 2).1 != -1) fail_assert(702);
	if (swapi((1, 2)).0 != 2) fail_assert(703);
	if (n.1.1.1 != 5) fail_assert(704);
	if ((1, 2) == (2, 1)) fail_assert(705);
	if (!((1, 2) == (1, 2))) fail_assert(706);
}

//======================================================================
// Section 8: ints in globals and a component
//======================================================================
var gi: int;
var gt: (int, int);
var ga: Array<int>;

component Counter {
	var cur: int = 1;
	def base: int = 0x0100_0193;
	var hist: Array<int> = Array<int>.new(8);
	var n: int;

	def step(x: int) -> int {
		cur = cur * 31 + x;
		hist[n % hist.length] = cur;
		n++;
		return cur;
	}
}
def globals() {
	// Reset all mutable global state; the harness may run several inputs in one
	// process, so a section must never depend on what ran before it.
	gi = 0;
	gt = (0, 0);
	Counter.cur = 1;
	Counter.n = 0;
	Counter.hist = Array<int>.new(8);

	ga = Array<int>.new(VALS.length);
	var h = 0;
	for (i < VALS.length) {
		gi = VALS[i];
		gt = (gi, gi ^ -1);
		ga[i] = gi - 1;
		h = mix(h, gi);
		h = mix(h, gt.0);
		h = mix(h, gt.1);
		h = mix(h, ga[i]);
	}
	acci(h);

	var g = mix(0, Counter.base);
	for (i < 40) g = mix(g, Counter.step(VALS[i % VALS.length]));
	for (i < Counter.hist.length) g = mix(g, Counter.hist[i]);
	g = mix(g, Counter.n);
	g = mix(g, Counter.cur);
	acci(g);

	if (Counter.base != 0x01000193) fail_assert(801);
	if (Counter.n != 40) fail_assert(802);
	// the last global written by the loop above
	if (gi != VALS[VALS.length - 1]) fail_assert(803);
	if (gt.1 != ~gi) fail_assert(804);
}

//======================================================================
// Section 9: ints in class fields
//======================================================================
class IBox {
	var v: int;
	def tag: int;
	new(v, tag) { }
	def value() -> int { return v; }
	def combine() -> int { return v; }
}
class IScale extends IBox {
	def k: int;
	new(v: int, tag: int, k) super(v, tag) { }
	def combine() -> int { return v * k; }
}
class IPair extends IScale {
	var other: IBox;
	new(v: int, k: int, other) super(v, 2, k) { }
	def combine() -> int { return if(other == null, v, v * k + other.value()); }
}
def classes() {
	var objs = Array<IBox>.new(3 * VALS.length);
	for (i < VALS.length) {
		var v = VALS[i];
		objs[3 * i + 0] = IBox.new(v, i);
		objs[3 * i + 1] = IScale.new(v, i, 3);
		objs[3 * i + 2] = IPair.new(v, -2, objs[3 * i + 0]);
	}
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mix(h, o.value());
		h = mix(h, o.combine());	// virtual dispatch over 3 implementations
		h = mix(h, o.tag);
		h = mixb(h, IScale.?(o));
		h = mixb(h, IPair.?(o));
	}
	acci(h);
	// mutate through the array and re-read
	for (i < objs.length) objs[i].v = objs[i].v ^ 0x5A5A5A5A;
	var g = 0;
	for (i < objs.length) g = mix(g, objs[i].combine());
	acci(g);

	var b = IBox.new(5, 7);
	var s = IScale.new(5, 7, 3);
	var p = IPair.new(5, 4, null);
	if (b.combine() != 5) fail_assert(901);
	if (s.combine() != 15) fail_assert(902);
	if (p.combine() != 5) fail_assert(903);			// null other
	if (IPair.new(5, 4, b).combine() != 25) fail_assert(904);
	if (!IScale.?(p)) fail_assert(905);
	if (IPair.?(s)) fail_assert(906);
	if (b.tag != 7) fail_assert(907);
}

//======================================================================
// Section 10: ints through function values and a mixed pipeline
//======================================================================
def addi(a: int, b: int) -> int { return a + b; }
def applyi(f: (int, int) -> int, a: int, b: int) -> int { return f(a, b); }
def foldi(f: (int, int) -> int, init: int, a: Array<int>) -> int {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def makeAdder(a: int) -> int -> int {
	return fun (b: int) => a + b;
}
def funcs() {
	def OPS: Array<(int, int) -> int> = [int.+, int.-, int.*, int.&, int.|, int.^, addi];
	for (k < OPS.length) {
		var h = 0;
		for (i < VALS.length) h = mix(h, applyi(OPS[k], VALS[i], 0x1234567));
		h = mix(h, foldi(OPS[k], 1, VALS));
		acci(h);
	}
	var inc = addi(1, _);			// partial application
	var dec = addi(_, -1);
	var g = 0;
	for (i < VALS.length) {
		g = mix(g, inc(VALS[i]));
		g = mix(g, dec(VALS[i]));
	}
	acci(g);
	var adders = Array<int -> int>.new(8);
	for (i < adders.length) adders[i] = makeAdder(i * 1000);
	var k = 0;
	for (i < adders.length) for (j < VALS.length) k = mix(k, adders[i](VALS[j]));
	acci(k);

	if (applyi(int.+, 3, 4) != 7) fail_assert(1001);
	if (applyi(int.*, 3, 4) != 12) fail_assert(1002);
	if (applyi(int.-, 3, 4) != -1) fail_assert(1003);
	if (applyi(int.&, 0xF0, 0x3C) != 0x30) fail_assert(1004);
	if (applyi(int.|, 0xF0, 0x0C) != 0xFC) fail_assert(1005);
	if (applyi(int.^, 0xFF, 0x0F) != 0xF0) fail_assert(1006);
	if (addi(1, _)(41) != 42) fail_assert(1007);
	if (addi(_, -1)(43) != 42) fail_assert(1008);
	if (makeAdder(30)(12) != 42) fail_assert(1009);
	// shift operator references take a byte, not an int
	def SHL: (int, byte) -> int = int.<<;
	if (SHL(1, 10) != 1024) fail_assert(1010);
	if (SHL(1, 32) != 0) fail_assert(1011);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) arith();
	if (a == 0 || a == 2) precedence();
	if (a == 0 || a == 3) compare();
	if (a == 0 || a == 4) bitwise();
	if (a == 0 || a == 5) shifts();
	if (a == 0 || a == 6) arrays();
	if (a == 0 || a == 7) tuples();
