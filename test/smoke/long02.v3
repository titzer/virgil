//@execute 0=1555903688; 1=1612560173; 2=-1143768785; 3=387788246; 4=-530603782; 5=1529183712; 6=66448788; 7=-796027667; 8=-1689239823
//@heap-size=200000
// Smoke test: 64-bit signed integer edge cases.
// The 64-bit mirror of int02.v3. Where long01.v3 covers the bulk of the operator
// set, this file pins down the facts at the boundaries: two's-complement
// wraparound on +, -, *; the long.min/long.max identities; the exact truncation
// direction of / and %; the long.min / -1 special case (which wraps rather than
// trapping); and the int <-> long conversion family in both directions,
// including where a widening sign-extends and where it zero-extends.
// Assertions carry most of the weight -- their operands are compile-time
// constants that the optimizer is expected to fold away, so a folding bug shows
// up as a set failure flag. The CRC keeps the non-constant versions of the same
// computations live. Input selects the section; input 0 runs every section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data. Values clustered around the representable boundaries and
// around the 32-bit boundary, where a 64-bit lowering is most likely to slip.
//======================================================================
def EDGE: Array<long> = [
	-9223372036854775808L, -9223372036854775807L, -4611686018427387904L,
	-4294967297L, -4294967296L, -4294967295L, -2147483649L, -2147483648L,
	-2147483647L, -65536L, -1L, 0L, 1L, 65536L,
	2147483647L, 2147483648L, 4294967295L, 4294967296L, 4294967297L,
	4611686018427387903L, 9223372036854775806L, 9223372036854775807L
];
// Divisors: never zero. -1 and long.min are present on purpose.
def DIV: Array<long> = [
	1L, -1L, 2L, -2L, 3L, -3L, 7L, 65536L, -65536L,
	4294967296L, -4294967296L, 1000000007L,
	9223372036854775807L, -9223372036854775808L
];
// 32-bit values, to be pushed up into 64 bits and pulled back down again.
def INTS: Array<int> = [
	-2147483648, -2147483647, -65536, -256, -1, 0, 1,
	255, 256, 65535, 65536, 2147483646, 2147483647
];

//======================================================================
// Section 1: wraparound on addition and subtraction
//======================================================================
def overflowAdd() {
	for (i < EDGE.length) {
		var a = EDGE[i];
		var h = mixl(0, -a);
		for (j < EDGE.length) {
			var b = EDGE[j];
			h = mixl(h, a + b);
			h = mixl(h, a - b);
			h = mixl(h, b - a);
			// adding then subtracting the same value always round-trips
			h = mixb(h, (a + b) - b == a);
			h = mixb(h, a + b == b + a);
		}
		acci(h);
	}
	if (long.max + 1L != long.min) fail_assert(101);
	if (long.max + 2L != -9223372036854775807L) fail_assert(102);
	if (long.min - 1L != long.max) fail_assert(103);
	if (long.min - 2L != 9223372036854775806L) fail_assert(104);
	if (long.max + long.max != -2L) fail_assert(105);
	if (long.min + long.min != 0L) fail_assert(106);
	if (long.max - long.min != -1L) fail_assert(107);
	if (long.min - long.max != 1L) fail_assert(108);
	// negation of long.min is long.min: there is no positive counterpart
	if (0L - long.min != long.min) fail_assert(109);
	if (-long.min != long.min) fail_assert(110);
	// carries that must propagate across the 32-bit half boundary
	if (4294967295L + 1L != 4294967296L) fail_assert(111);
	if (4294967296L - 1L != 4294967295L) fail_assert(112);
	if (0L - 1L != -1L) fail_assert(113);
	if (-4294967296L + 1L != -4294967295L) fail_assert(114);
	if (0x00000000FFFFFFFFL + 0x00000000FFFFFFFFL != 0x1FFFFFFFEL) fail_assert(115);
	if (0x7FFFFFFFFFFFFFFFL + 0x0000000100000000L != -9223372032559808513L) fail_assert(116);
	// x + ~x == -1 for every x, including the boundaries
	if (long.max + ~long.max != -1L) fail_assert(117);
	if (long.min + ~long.min != -1L) fail_assert(118);
	// the wrap survives regrouping
	if ((long.max + 1L) + 1L != -9223372036854775807L) fail_assert(119);
	if (long.max + (1L + 1L) != -9223372036854775807L) fail_assert(120);
}

//======================================================================
// Section 2: wraparound on multiplication
//======================================================================
def overflowMul() {
	for (i < EDGE.length) {
		var a = EDGE[i];
		var h = 0;
		for (j < EDGE.length) {
			var b = EDGE[j];
			var p = a * b;
			h = mixl(h, p);
			h = mixb(h, p == b * a);
			h = mixl(h, p + a);
		}
		acci(h);
	}
	if (4294967296L * 4294967296L != 0L) fail_assert(201);
	// 4294967295^2 == 18446744065119617025, which is 2^64 - 8589934591
	if (4294967295L * 4294967295L != -8589934591L) fail_assert(202);
	if (3037000500L * 3037000500L != -9223372036709301616L) fail_assert(203);
	if (1000000000000000000L * 10L != -8446744073709551616L) fail_assert(204);
	if (long.max * 2L != -2L) fail_assert(205);
	if (long.max * 3L != 9223372036854775805L) fail_assert(206);
	if (long.max * long.max != 1L) fail_assert(207);
	if (long.min * long.min != 0L) fail_assert(208);
	if (long.min * 2L != 0L) fail_assert(209);
	// long.min has no negation, so multiplying it by -1 leaves it alone
	if (long.min * -1L != long.min) fail_assert(210);
	if (long.max * -1L != -9223372036854775807L) fail_assert(211);
	if (0x123456789ABCDEF0L * 0x123456789ABCDEF0L != -6493618294075612928L) fail_assert(212);
	// multiplication by a power of two equals the corresponding left shift
	if (0x123456789ABCDEF0L * 16L != 0x123456789ABCDEF0L << 4) fail_assert(213);
	if (-1L * 4294967296L != -1L << 32) fail_assert(214);
	if (long.max * 4L != long.max << 2) fail_assert(215);
	// distributivity survives wraparound
	if (long.max * (2L + 3L) != long.max * 2L + long.max * 3L) fail_assert(216);
	if (0L * long.min != 0L) fail_assert(217);
	if (1L * long.min != long.min) fail_assert(218);
	// a product whose exact value needs 64 bits but does not overflow
	if (2147483647L * 4294967296L != 9223372032559808512L) fail_assert(219);
}

//======================================================================
// Section 3: long.min / long.max boundary identities
//======================================================================
def boundaries() {
	var h = 0;
	for (i < EDGE.length) {
		var a = EDGE[i];
		h = mixb(h, a >= long.min);
		h = mixb(h, a <= long.max);
		h = mixb(h, a == long.min);
		h = mixb(h, a == long.max);
		h = mixl(h, a - long.min);
		h = mixl(h, long.max - a);
		h = mixl(h, a ^ long.min);
		h = mixl(h, long.view(u64.view(a)));
	}
	acci(h);

	if (long.min != -9223372036854775808L) fail_assert(301);
	if (long.max != 9223372036854775807L) fail_assert(302);
	if (long.min + long.max != -1L) fail_assert(303);
	if (~long.min != long.max) fail_assert(304);
	if (~long.max != long.min) fail_assert(305);
	if (long.min != 1L << 63) fail_assert(306);
	if (long.max != ~(1L << 63)) fail_assert(307);
	if (long.max + 1L != long.min) fail_assert(308);
	if (long.min - 1L != long.max) fail_assert(309);
	if ((long.min & long.max) != 0L) fail_assert(310);
	if ((long.min | long.max) != -1L) fail_assert(311);
	if ((long.min ^ long.max) != -1L) fail_assert(312);
	if (!(long.min < long.max)) fail_assert(313);
	if (long.min >>> 63 != 1L) fail_assert(314);
	if (long.max >>> 63 != 0L) fail_assert(315);
	if (long.min >> 63 != -1L) fail_assert(316);
	if (long.min >>> 32 != 2147483648L) fail_assert(317);
	if (long.max >>> 32 != 2147483647L) fail_assert(318);
	// i64 is the same type as long
	if (i64.min != long.min) fail_assert(319);
	if (i64.max != long.max) fail_assert(320);
	// unsigned view: long.min is the LARGER of the two
	if (!(u64.view(long.min) > u64.view(long.max))) fail_assert(321);
	if (u64.view(long.min) != 9223372036854775808uL) fail_assert(322);
	if (u64.view(-1L) != u64.max) fail_assert(323);
	if (long.view(u64.max) != -1L) fail_assert(324);
	if (u64.max != 18446744073709551615uL) fail_assert(325);
}

//======================================================================
// Section 4: division and modulo, including negative operands
//======================================================================
def divmod() {
	for (i < EDGE.length) {
		var a = EDGE[i];
		var h = 0;
		for (j < DIV.length) {
			var b = DIV[j];
			var q = a / b, r = a % b;
			h = mixl(h, q);
			h = mixl(h, r);
			// the division identity holds under wraparound
			h = mixb(h, q * b + r == a);
			// the remainder takes the sign of the dividend (or is zero)
			h = mixb(h, r == 0 || (r < 0) == (a < 0));
		}
		acci(h);
	}
	// truncation toward zero, in all four sign combinations
	if (17L / 5L != 3L) fail_assert(401);
	if (-17L / 5L != -3L) fail_assert(402);
	if (17L / -5L != -3L) fail_assert(403);
	if (-17L / -5L != 3L) fail_assert(404);
	if (17L % 5L != 2L) fail_assert(405);
	if (-17L % 5L != -2L) fail_assert(406);
	if (17L % -5L != 2L) fail_assert(407);
	if (-17L % -5L != -2L) fail_assert(408);
	// quotients that would round the other way under floor division
	if (-1L / 2L != 0L) fail_assert(409);
	if (-1L % 2L != -1L) fail_assert(410);
	if (1L / -2L != 0L) fail_assert(411);
	if (1L % -2L != 1L) fail_assert(412);
	if (-3L / 4L != 0L) fail_assert(413);
	if (-5L / 4L != -1L) fail_assert(414);
	// an arithmetic right shift floors, so it disagrees with / for negatives
	if (-3L >> 2 != -1L) fail_assert(415);
	if (-3L / 4L != 0L) fail_assert(416);
	// division across the 32-bit half boundary
	if (4294967296L / 2L != 2147483648L) fail_assert(417);
	if (-4294967296L / 2L != -2147483648L) fail_assert(418);
	if (4294967295L / 65536L != 65535L) fail_assert(419);
	if (4294967295L % 65536L != 65535L) fail_assert(420);
	if (-4294967295L / 65536L != -65535L) fail_assert(421);
	if (-4294967295L % 65536L != -65535L) fail_assert(422);
	// boundary quotients
	if (long.max / long.max != 1L) fail_assert(423);
	if (long.min / long.min != 1L) fail_assert(424);
	if (long.min % long.min != 0L) fail_assert(425);
	if (long.min / long.max != -1L) fail_assert(426);
	if (long.min % long.max != -1L) fail_assert(427);
	if (long.max / long.min != 0L) fail_assert(428);
	if (long.max % long.min != long.max) fail_assert(429);
	if (long.min / 2L != -4611686018427387904L) fail_assert(430);
	if (long.min / -2L != 4611686018427387904L) fail_assert(431);
	if (long.min / 3L != -3074457345618258602L) fail_assert(432);
	if (long.min % 3L != -2L) fail_assert(433);
	if (long.max / 2L != 4611686018427387903L) fail_assert(434);
	if (long.max % 2L != 1L) fail_assert(435);
}

//======================================================================
// Section 5: long.min / -1, the one signed division that overflows
//======================================================================
var minv: long;
var negone: long;
def divOverflow() {
	// Reset the globals this section writes.
	minv = 0;
	negone = 0;
	// Drive the values through globals so the operands are not compile-time
	// constants: this is the runtime path, not the folded one.
	minv = EDGE[0];			// long.min
	negone = DIV[1];		// -1
	var q = minv / negone;		// must WRAP to long.min, not trap
	var r = minv % negone;		// must be 0, not trap
	acci(mixl(mixl(0, q), r));
	if (q != long.min) fail_assert(501);
	if (r != 0L) fail_assert(502);

	var qs = Array<long>.new(EDGE.length);
	var rs = Array<long>.new(EDGE.length);
	for (i < EDGE.length) {
		qs[i] = EDGE[i] / negone;
		rs[i] = EDGE[i] % negone;
	}
	var h = 0;
	for (i < EDGE.length) {
		h = mixl(h, qs[i]);
		h = mixl(h, rs[i]);
		// x / -1 == -x for every x, including long.min (where -x is x)
		h = mixb(h, qs[i] == 0L - EDGE[i]);
		h = mixb(h, rs[i] == 0L);
	}
	acci(h);

	// the constant-folded forms must agree with the runtime ones
	if (long.min / -1L != long.min) fail_assert(503);
	if (long.min % -1L != 0L) fail_assert(504);
	if (long.max / -1L != -9223372036854775807L) fail_assert(505);
	if (long.max % -1L != 0L) fail_assert(506);
	if (0L / -1L != 0L) fail_assert(507);
	if (1L / -1L != -1L) fail_assert(508);
	if (-1L / -1L != 1L) fail_assert(509);
	if (-1L % -1L != 0L) fail_assert(510);
	if (long.min / -1L * -1L != long.min) fail_assert(511);
	// the 32-bit boundary value is unremarkable at 64 bits: it DOES negate
	if (-2147483648L / -1L != 2147483648L) fail_assert(512);
	if (-2147483648L % -1L != 0L) fail_assert(513);
}

//======================================================================
// Section 6: narrowing conversions, long -> int
//======================================================================
def narrow() {
	var h = 0;
	for (i < EDGE.length) {
		var l = EDGE[i];
		h = mix(h, int.view(l));		// always defined: the low 32 bits
		h = mix(h, int.view(l >> 32));		// the high 32 bits
		h = mixb(h, int.?(l));
		h = mix(h, int.view(u32.view(l)));
		h = mix(h, byte.view(l));
		// int.! is only safe when the query says so
		if (int.?(l)) h = mix(h, int.!(l));
	}
	acci(h);

	// int.view keeps the low 32 bits, reinterpreting bit 31 as a sign
	if (int.view(0L) != 0) fail_assert(601);
	if (int.view(-1L) != -1) fail_assert(602);
	if (int.view(long.min) != 0) fail_assert(603);
	if (int.view(long.max) != -1) fail_assert(604);
	if (int.view(4294967296L) != 0) fail_assert(605);
	if (int.view(4294967295L) != -1) fail_assert(606);
	if (int.view(2147483648L) != -2147483648) fail_assert(607);
	if (int.view(0x100000001L) != 1) fail_assert(608);
	if (int.view(0x1234567890ABCDEFL) != -1867788817) fail_assert(609);
	if (int.view(0x123456789ABCDEF0L >> 32) != 0x12345678) fail_assert(610);
	// u32.view and byte.view truncate from 64 bits directly
	if (u32.view(0x123456789ABCDEF0L) != 0x9ABCDEF0u) fail_assert(611);
	if (byte.view(0x123456789ABCDEF0L) != 0xF0) fail_assert(612);
	if (u32.view(long.min) != 0u) fail_assert(613);
	if (u32.view(-1L) != u32.max) fail_assert(614);
	// int.? is exact-representability, not truncation
	if (!int.?(2147483647L)) fail_assert(615);
	if (int.?(2147483648L)) fail_assert(616);
	if (!int.?(-2147483648L)) fail_assert(617);
	if (int.?(-2147483649L)) fail_assert(618);
	if (int.?(4294967295L)) fail_assert(619);
	if (int.?(long.min)) fail_assert(620);
	if (int.?(long.max)) fail_assert(621);
	if (!int.?(0L)) fail_assert(622);
	// int.! on values the query accepts
	if (int.!(2147483647L) != 2147483647) fail_assert(623);
	if (int.!(-2147483648L) != -2147483648) fail_assert(624);
	if (int.!(-1L) != -1) fail_assert(625);
	// u32.? / u32.! over the unsigned 32-bit window
	if (!u32.?(4294967295L)) fail_assert(626);
	if (u32.?(4294967296L)) fail_assert(627);
	if (u32.?(-1L)) fail_assert(628);
	if (u32.!(4294967295L) != u32.max) fail_assert(629);
	// long -> u64 is a view, not a value-preserving cast, for negatives
	if (u64.?(-1L)) fail_assert(630);
	if (!u64.?(1L)) fail_assert(631);
	if (long.?(18446744073709551615uL)) fail_assert(632);
	if (long.!(9223372036854775807uL) != long.max) fail_assert(633);
}

//======================================================================
// Section 7: widening conversions, int -> long
//======================================================================
def widen() {
	var h = 0;
	for (i < INTS.length) {
		var a = INTS[i];
		h = mixl(h, long.!(a));			// sign-extends
		h = mixl(h, long.view(a));		// also sign-extends: int is signed
		h = mixl(h, long.view(u32.view(a)));	// zero-extends: u32 is unsigned
		h = mixl(h, long.!(u32.view(a)));	// likewise
		h = mixb(h, int.view(long.view(a)) == a);
		h = mixl(h, a + 0L);			// implicit promotion in arithmetic
		h = mixl(h, long.!(a) * long.!(a));
	}
	acci(h);

	// int -> long sign-extends, whether by cast, view or implicit promotion
	if (long.!(-1) != -1L) fail_assert(701);
	if (long.view(-1) != -1L) fail_assert(702);
	if (long.!(int.min) != -2147483648L) fail_assert(703);
	if (long.view(int.min) != -2147483648L) fail_assert(704);
	if (long.!(int.max) != 2147483647L) fail_assert(705);
	// u32 -> long zero-extends
	if (long.view(u32.view(-1)) != 4294967295L) fail_assert(706);
	if (long.!(u32.view(-1)) != 4294967295L) fail_assert(707);
	if (long.view(u32.view(int.min)) != 2147483648L) fail_assert(708);
	if (long.!(u32.max) != 4294967295L) fail_assert(709);
	if (long.!(2147483648u) != 2147483648L) fail_assert(710);
	// byte and i8 differ the same way at the narrow end
	if (long.!(byte.view(-1)) != 255L) fail_assert(711);
	if (long.!(i8.view(byte.view(-1))) != -1L) fail_assert(712);
	// the round trip is the identity for every int
	if (int.view(long.view(int.min)) != int.min) fail_assert(713);
	if (int.view(long.view(int.max)) != int.max) fail_assert(714);
	if (int.view(long.view(-12345)) != -12345) fail_assert(715);
	// but stepping outside the window and back is not
	if (int.view(long.view(int.min) - 1L) != int.max) fail_assert(716);
	if (int.view(long.view(int.max) + 1L) != int.min) fail_assert(717);
	// implicit promotion happens BEFORE the arithmetic, so 64-bit math does not
	// wrap where the corresponding 32-bit math would
	var mx = 2147483647;
	if (mx + 1 != int.min) fail_assert(718);		// 32-bit: wraps
	if (mx + 1L != 2147483648L) fail_assert(719);		// 64-bit: does not
	if (mx * 2 != -2) fail_assert(720);
	if (mx * 2L != 4294967294L) fail_assert(721);
	var mn = -2147483648;
	if (mn - 1 != int.max) fail_assert(722);
	if (mn - 1L != -2147483649L) fail_assert(723);
	if (mn * mn != 0) fail_assert(724);
	if (long.!(mn) * long.!(mn) != 4611686018427387904L) fail_assert(725);
	// a long divided by an int promotes the int
	if (4294967296L / 2 != 2147483648L) fail_assert(726);
	if (-4294967296L / mx != -2L) fail_assert(727);
}

//======================================================================
// Section 8: edge values routed through the storage forms
//======================================================================
var ge: long;
var gp: (long, long);
var garr: Array<long>;

component Edges {
	var lo: long = long.max;
	var hi: long = long.min;
	var acc: long;
	var n: int;
	def step(x: long) -> long {
		acc = acc * 6364136223846793005L + x;	// deliberately overflows
		if (x < lo) lo = x;
		if (x > hi) hi = x;
		n++;
		return acc;
	}
}
class ECell {
	var v: long;
	def tag: int;
	new(v, tag) { }
	def wrapped() -> long { return v * v + v; }
}
class EPair extends ECell {
	var other: ECell;
	new(v: long, tag: int, other) super(v, tag) { }
	def wrapped() -> long { return if(other == null, v, v * other.v); }
}
type EVal {
	case Plain(v: long);
	case Span(lo: long, hi: long);
	case None;
}
type EFlat #unboxed {
	case Lo(v: long);
	case Hi(v: long);
	case Zero;
}
def spanOf(e: EVal) -> long {
	match (e) {
		Plain(v) => return v;
		Span(lo, hi) => return hi - lo;		// wraps for the full range
		None => return 0L;
	}
}
def flatOf(e: EFlat) -> long {
	match (e) {
		Lo(v) => return v;
		Hi(v) => return v >>> 32;
		Zero => return 0L;
	}
}
def route() {
	// Reset all mutable global state.
	ge = 0;
	gp = (0, 0);
	Edges.lo = long.max;
	Edges.hi = long.min;
	Edges.acc = 0;
	Edges.n = 0;

	garr = Array<long>.new(EDGE.length);
	var h = 0;
	for (i < EDGE.length) {
		ge = EDGE[i];
		gp = (ge, ge + 1L);		// wraps at long.max
		garr[i] = ge - 1L;		// wraps at long.min
		h = mixl(h, ge);
		h = mixl(h, gp.0);
		h = mixl(h, gp.1);
		h = mixl(h, garr[i]);
	}
	acci(h);
	if (garr[0] != long.max) fail_assert(801);		// long.min - 1 wrapped
	if (gp.1 != long.min) fail_assert(802);			// long.max + 1 wrapped

	var g = 0;
	for (i < EDGE.length) g = mixl(g, Edges.step(EDGE[i]));
	g = mixl(g, Edges.lo);
	g = mixl(g, Edges.hi);
	g = mix(g, Edges.n);
	acci(g);
	if (Edges.lo != long.min) fail_assert(803);
	if (Edges.hi != long.max) fail_assert(804);
	if (Edges.n != EDGE.length) fail_assert(805);

	var cells = Array<ECell>.new(2 * EDGE.length);
	for (i < EDGE.length) {
		cells[2 * i + 0] = ECell.new(EDGE[i], i);
		cells[2 * i + 1] = EPair.new(EDGE[i], i, cells[2 * i + 0]);
	}
	var k = 0;
	for (i < cells.length) {
		k = mixl(k, cells[i].v);
		k = mixl(k, cells[i].wrapped());
		k = mix(k, cells[i].tag);
		k = mixb(k, EPair.?(cells[i]));
	}
	acci(k);
	// 4294967296^2 wraps to 0, so wrapped() is just v
	if (ECell.new(4294967296L, 0).wrapped() != 4294967296L) fail_assert(806);
	if (ECell.new(long.min, 0).wrapped() != long.min) fail_assert(807);
	if (EPair.new(3L, 0, null).wrapped() != 3L) fail_assert(808);
	if (EPair.new(4294967296L, 0, ECell.new(4294967296L, 0)).wrapped() != 0L) fail_assert(809);

	var vs = Array<EVal>.new(EDGE.length + 1);
	var fs = Array<EFlat>.new(EDGE.length + 1);
	for (i < EDGE.length) {
		vs[i] = if(i % 2 == 0, EVal.Plain(EDGE[i]), EVal.Span(EDGE[i], EDGE[EDGE.length - 1 - i]));
		fs[i] = if(i % 2 == 0, EFlat.Lo(EDGE[i]), EFlat.Hi(EDGE[i]));
	}
	vs[EDGE.length] = EVal.None;
	fs[EDGE.length] = EFlat.Zero;
	var m = 0;
	for (i < vs.length) {
		m = mixl(m, spanOf(vs[i]));
		m = mix(m, vs[i].tag);
		m = mixl(m, flatOf(fs[i]));
		m = mix(m, fs[i].tag);
	}
	acci(m);
	if (spanOf(EVal.Span(long.min, long.max)) != -1L) fail_assert(810);	// wraps
	if (spanOf(EVal.Plain(long.min)) != long.min) fail_assert(811);
	if (spanOf(EVal.None) != 0L) fail_assert(812);
	if (EVal.None.tag != 2) fail_assert(813);
	if (flatOf(EFlat.Hi(long.min)) != 2147483648L) fail_assert(814);
	if (flatOf(EFlat.Lo(long.min)) != long.min) fail_assert(815);
	if (!(EFlat.Lo(long.min) == EFlat.Lo(long.min))) fail_assert(816);
	if (EFlat.Lo(long.min) == EFlat.Hi(long.min)) fail_assert(817);

	// tuples of boundary values compare componentwise
	var t1 = (long.min, long.max);
	var t2 = (long.min, long.max);
	var t3 = (long.max, long.min);
	if (!(t1 == t2)) fail_assert(818);
	if (t1 == t3) fail_assert(819);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) overflowAdd();
	if (a == 0 || a == 2) overflowMul();
	if (a == 0 || a == 3) boundaries();
	if (a == 0 || a == 4) divmod();
	if (a == 0 || a == 5) divOverflow();
	if (a == 0 || a == 6) narrow();
	if (a == 0 || a == 7) widen();
	if (a == 0 || a == 8) route();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
