//@execute 0=1557085446; 1=-1074844952; 2=469897574; 3=689707727; 4=-1578077250; 5=191197476; 6=2096852395; 7=538286076; 8=-1126222143
//@heap-size=500000
// Smoke test: casts and type queries over a class hierarchy.
// A four-level inheritance tree with two extra branches is exercised from every
// direction: queries up and down, checked casts where the answer is known,
// null, elements of arrays typed at the base class, casts inside variant
// payloads, casts held as first-class function values and casts interleaved
// with virtual dispatch. Every observed answer is folded into a running CRC
// that main() returns, so nothing can be deleted as dead; interleaved assert()s
// over compile-time constants encode what the answers must be.
// `T.!` is only ever applied where the cast is known to succeed; the negative
// cases are expressed with `T.?`, which returns false instead of trapping.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// The hierarchy
//
//   Shape
//    +-- Poly
//    |    +-- Rect
//    |    |    +-- Square
//    |    +-- Tri
//    +-- Circle
//======================================================================
class Shape {
	def id: int;
	new(id) { }
	def area() -> int { return 0; }
	def label() -> string { return "shape"; }
}
class Poly extends Shape {
	def sides: int;
	new(id: int, sides) super(id) { }
	def area() -> int { return sides; }
	def label() -> string { return "poly"; }
}
class Rect extends Poly {
	def w: int;
	def h: int;
	new(id: int, w, h) super(id, 4) { }
	def area() -> int { return w * h; }
	def label() -> string { return "rect"; }
}
class Square extends Rect {
	new(id: int, s: int) super(id, s, s) { }
	def label() -> string { return "square"; }
}
class Tri extends Poly {
	def b: int;
	def th: int;
	new(id: int, b, th) super(id, 3) { }
	def area() -> int { return (b * th) / 2; }
	def label() -> string { return "tri"; }
}
class Circle extends Shape {
	def r: int;
	new(id: int, r) super(id) { }
	def area() -> int { return 3 * r * r; }
	def label() -> string { return "circle"; }
}

// Builds one instance of each concrete class, always seen as a Shape so that no
// query below is statically decidable from the declared type alone.
def mk(i: int) -> Shape {
	match (i % 6) {
		0 => return Shape.new(i);
		1 => return Poly.new(i, 5);
		2 => return Rect.new(i, 3, 4);
		3 => return Square.new(i, 6);
		4 => return Tri.new(i, 8, 5);
		_ => return Circle.new(i, 2);
	}
}
def POP: Array<Shape> = [
	Shape.new(100), Poly.new(101, 5), Rect.new(102, 3, 4),
	Square.new(103, 6), Tri.new(104, 8, 5), Circle.new(105, 2),
	null
];

//======================================================================
// Section 1: queries across the whole hierarchy
//======================================================================
def queries() {
	var h = 0;
	for (i < POP.length) {
		var s = POP[i];
		h = mixb(h, Shape.?(s));
		h = mixb(h, Poly.?(s));
		h = mixb(h, Rect.?(s));
		h = mixb(h, Square.?(s));
		h = mixb(h, Tri.?(s));
		h = mixb(h, Circle.?(s));
		h = mixb(h, s == null);
	}
	acci(h);
	// the same queries reached through a factory, one instance per iteration
	var g = 0;
	for (i < 60) {
		var s = mk(i);
		g = mixb(g, Poly.?(s));
		g = mixb(g, Rect.?(s));
		g = mixb(g, Square.?(s));
		g = mix(g, s.area());
		g = mixs(g, s.label());
	}
	acci(g);
	// a narrower static type still admits queries toward the leaves
	var k = 0;
	for (i < POP.length) {
		var s = POP[i];
		if (Poly.?(s)) {
			var p = Poly.!(s);
			k = mix(k, p.sides);
			k = mixb(k, Rect.?(p));
			k = mixb(k, Square.?(p));
			k = mixb(k, Tri.?(p));
		} else {
			k = mix(k, -1);
		}
	}
	acci(k);

	// every instance is a Shape
	if (!Shape.?(Square.new(1, 2))) fail_assert(101);
	if (!Shape.?(Circle.new(1, 2))) fail_assert(102);
	// a Square is a Rect is a Poly
	if (!Poly.?(Square.new(1, 2))) fail_assert(103);
	if (!Rect.?(Square.new(1, 2))) fail_assert(104);
	// but a Rect is not a Square
	if (Square.?(Rect.new(1, 2, 3))) fail_assert(105);
	// siblings are unrelated, asked at their common ancestor
	if (Circle.?(mk(3))) fail_assert(106);
	if (Poly.?(mk(5))) fail_assert(107);
	if (!Circle.?(mk(5))) fail_assert(108);
	if (!Tri.?(mk(4))) fail_assert(109);
	if (Rect.?(mk(4))) fail_assert(110);
	if (!Square.?(mk(3))) fail_assert(111);
	if (Poly.?(mk(0))) fail_assert(112);
}

//======================================================================
// Section 2: checked casts that are known to succeed
//======================================================================
def casts() {
	var h = 0;
	for (i < POP.length) {
		var s = POP[i];
		// widening never fails, including for null
		var w: Shape = Shape.!(s);
		h = mixb(h, w == s);
		if (Rect.?(s)) {
			var r = Rect.!(s);
			h = mix(h, r.w * r.h);
			h = mix(h, r.sides);
			// a Rect is still a Poly and a Shape
			var p = Poly.!(r);
			h = mix(h, p.sides);
			h = mixs(h, Shape.!(p).label());
		}
		if (Square.?(s)) {
			var q = Square.!(s);
			h = mix(h, q.w);
			h = mixb(h, q.w == q.h);
		}
	}
	acci(h);
	// a query/cast pipeline over freshly allocated objects
	var g = 0;
	for (i < 90) {
		var s = mk(i);
		var a = 0;
		if (Square.?(s)) a = Square.!(s).w;
		else if (Rect.?(s)) a = Rect.!(s).h;
		else if (Tri.?(s)) a = Tri.!(s).b;
		else if (Poly.?(s)) a = Poly.!(s).sides;
		else if (Circle.?(s)) a = Circle.!(s).r;
		else a = s.id;
		g = mix(g, a);
		g = mix(g, s.area());
	}
	acci(g);
	// double-casting back and forth must be the identity
	var k = 0;
	for (i < POP.length) {
		var s = POP[i];
		if (Square.?(s)) {
			var q = Square.!(s);
			var back = Square.!(Rect.!(Poly.!(Shape.!(q))));
			k = mixb(k, back == q);
			k = mix(k, back.w);
		}
	}
	acci(k);

	if (Rect.!(mk(2)).w != 3) fail_assert(201);
	if (Rect.!(mk(2)).h != 4) fail_assert(202);
	if (Square.!(mk(3)).w != 6) fail_assert(203);
	if (Poly.!(mk(3)).sides != 4) fail_assert(204);		// a Square has 4 sides
	if (Tri.!(mk(4)).b != 8) fail_assert(205);
	if (Circle.!(mk(5)).r != 2) fail_assert(206);
	if (Shape.!(mk(3)).area() != 36) fail_assert(207);
	if (Rect.new(1, 3, 4).area() != 12) fail_assert(208);
	if (Square.new(1, 6).area() != 36) fail_assert(209);
	if (Tri.new(1, 8, 5).area() != 20) fail_assert(210);
	if (Circle.new(1, 2).area() != 12) fail_assert(211);
	if (Poly.new(1, 5).area() != 5) fail_assert(212);
	if (Shape.new(1).area() != 0) fail_assert(213);
}

//======================================================================
// Section 3: null flows through every cast and query
//======================================================================
def nulls() {
	var ns = Array<Shape>.new(8);		// all null
	var h = 0;
	for (i < ns.length) {
		var s = ns[i];
		h = mixb(h, s == null);
		h = mixb(h, Shape.?(s));
		h = mixb(h, Poly.?(s));
		h = mixb(h, Square.?(s));
		// a checked cast of null succeeds and yields null
		var p = Poly.!(s);
		h = mixb(h, p == null);
		var q = Square.!(s);
		h = mixb(h, q == null);
	}
	acci(h);
	// null mixed in with real objects, so the branch is not statically known
	var mixedArr = Array<Shape>.new(24);
	for (i < mixedArr.length) mixedArr[i] = if((i % 4) == 3, null, mk(i));
	var g = 0;
	var nulls = 0, polys = 0;
	for (i < mixedArr.length) {
		var s = mixedArr[i];
		if (s == null) { nulls++; g = mix(g, -1); continue; }
		if (Poly.?(s)) polys++;
		g = mix(g, s.area());
	}
	acci(mix(mix(g, nulls), polys));

	// a query on null is false for every class, including the static type
	var z: Shape = null;
	if (Shape.?(z)) fail_assert(301);
	if (Poly.?(z)) fail_assert(302);
	if (Square.?(z)) fail_assert(303);
	if (Circle.?(z)) fail_assert(304);
	// but a checked cast of null succeeds
	if (Poly.!(z) != null) fail_assert(305);
	if (Square.!(z) != null) fail_assert(306);
	if (Shape.!(z) != null) fail_assert(307);
	if (nulls != 6) fail_assert(308);
	if (mixedArr.length != 24) fail_assert(309);
	if (POP[6] != null) fail_assert(310);
}

//======================================================================
// Section 4: casts through arrays typed at the base class
//======================================================================
def arrays() {
	var n = 120;
	var all = Array<Shape>.new(n);
	for (i < n) all[i] = mk(i);
	// partition into per-class buckets by query, then read through the buckets
	var polys = Array<Poly>.new(n);
	var rects = Array<Rect>.new(n);
	var np = 0, nr = 0;
	for (i < n) {
		var s = all[i];
		if (Poly.?(s)) polys[np++] = Poly.!(s);
		if (Rect.?(s)) rects[nr++] = Rect.!(s);
	}
	var h = mix(mix(0, np), nr);
	for (i < np) h = mix(h, polys[i].sides);
	for (i < nr) h = mix(h, rects[i].w * rects[i].h);
	acci(h);

	// writing a subclass instance into an Array<Shape> and reading it back
	var back = Array<Shape>.new(nr);
	for (i < nr) back[i] = rects[i];
	var g = 0;
	for (i < nr) {
		g = mixb(g, Rect.?(back[i]));
		g = mixb(g, Square.?(back[i]));
		g = mix(g, Rect.!(back[i]).w);
		g = mixb(g, back[i] == rects[i]);
	}
	acci(g);

	// ranges over a base-typed array preserve the dynamic types
	var r: Range<Shape> = all;
	var mid = r[24 ... 96];
	var k = mix(0, mid.length);
	for (i < mid.length) {
		k = mixb(k, Square.?(mid[i]));
		if (Poly.?(mid[i])) k = mix(k, Poly.!(mid[i]).sides);
		else k = mix(k, -2);
	}
	acci(k);
	// an aliased write through the range is visible with its dynamic type
	mid[0] = Square.new(999, 7);
	if (!Square.?(all[24])) fail_assert(400);
	if (Square.!(all[24]).w != 7) fail_assert(401);
	if (mid.length != 72) fail_assert(402);
	// mk cycles with period 6 over 120 elements: 20 of each
	if (np != 80) fail_assert(403);		// Poly, Rect, Square and Tri
	if (nr != 40) fail_assert(404);		// Rect and Square
	if (all.length != 120) fail_assert(405);
}

//======================================================================
// Section 5: casts inside variant payloads
//======================================================================
type Holder {
	case One(s: Shape);
	case Two(a: Shape, b: Shape);
	case Tagged(s: Shape, k: int);
	case Empty;
}
def areaOf(hd: Holder) -> int {
	match (hd) {
		One(s) => return if(s == null, -1, s.area());
		Two(a, b) => return (if(a == null, 0, a.area())) + (if(b == null, 0, b.area()));
		Tagged(s, k) => return if(s == null, k, s.area() + k);
		Empty => return 0;
	}
}
// Digs the most specific known width out of whatever the payload turns out to be.
def widthOf(hd: Holder) -> int {
	match (hd) {
		One(s) => {
			if (Square.?(s)) return Square.!(s).w;
			if (Rect.?(s)) return Rect.!(s).w;
			if (Poly.?(s)) return Poly.!(s).sides;
			return -1;
		}
		Two(a, b) => return widthOf(Holder.One(a)) + widthOf(Holder.One(b));
		Tagged(s, k) => return widthOf(Holder.One(s)) * k;
		Empty => return 0;
	}
}
def variants() {
	var hs = Array<Holder>.new(48);
	for (i < hs.length) {
		match (i % 4) {
			0 => hs[i] = Holder.One(mk(i));
			1 => hs[i] = Holder.Two(mk(i), mk(i + 1));
			2 => hs[i] = Holder.Tagged(mk(i), i);
			_ => hs[i] = Holder.Empty;
		}
	}
	var h = 0;
	for (i < hs.length) {
		h = mix(h, areaOf(hs[i]));
		h = mix(h, widthOf(hs[i]));
		h = mix(h, hs[i].tag);
		h = mixb(h, Holder.Two.?(hs[i]));
		h = mixb(h, Holder.Empty.?(hs[i]));
	}
	acci(h);
	// pull the payload back out and query it directly
	var g = 0;
	for (i < hs.length) {
		var hd = hs[i];
		if (Holder.One.?(hd)) {
			var s = Holder.One.!(hd).s;
			g = mixb(g, Poly.?(s));
			g = mixb(g, Circle.?(s));
			if (Rect.?(s)) g = mix(g, Rect.!(s).h);
			else g = mix(g, -3);
		} else if (Holder.Tagged.?(hd)) {
			var t = Holder.Tagged.!(hd);
			g = mix(g, t.k);
			g = mixb(g, Square.?(t.s));
		}
	}
	acci(g);

	if (areaOf(Holder.One(Square.new(1, 6))) != 36) fail_assert(501);
	if (areaOf(Holder.One(null)) != -1) fail_assert(502);
	if (areaOf(Holder.Two(Rect.new(1, 3, 4), Circle.new(2, 2))) != 24) fail_assert(503);
	if (areaOf(Holder.Tagged(Tri.new(1, 8, 5), 7)) != 27) fail_assert(504);
	if (areaOf(Holder.Empty) != 0) fail_assert(505);
	if (widthOf(Holder.One(Square.new(1, 6))) != 6) fail_assert(506);
	if (widthOf(Holder.One(Rect.new(1, 3, 4))) != 3) fail_assert(507);
	if (widthOf(Holder.One(Poly.new(1, 5))) != 5) fail_assert(508);
	if (widthOf(Holder.One(Circle.new(1, 2))) != -1) fail_assert(509);
	if (widthOf(Holder.One(null)) != -1) fail_assert(510);
	if (widthOf(Holder.Tagged(Square.new(1, 6), 3)) != 18) fail_assert(511);
	if (Holder.Empty.tag != 3) fail_assert(512);
}

//======================================================================
// Section 6: casts as first-class function values
//======================================================================
def isPoly: Shape -> bool = Poly.?;
def isRect: Shape -> bool = Rect.?;
def isSquare: Shape -> bool = Square.?;
def isCircle: Shape -> bool = Circle.?;
def toPoly: Shape -> Poly = Poly.!;
def toRect: Shape -> Rect = Rect.!;
def count(f: Shape -> bool, a: Array<Shape>) -> int {
	var n = 0;
	for (i < a.length) if (f(a[i])) n++;
	return n;
}
def firstClass() {
	var n = 60;
	var all = Array<Shape>.new(n);
	for (i < n) all[i] = mk(i);

	def PREDS: Array<Shape -> bool> = [isPoly, isRect, isSquare, isCircle];
	var h = 0;
	for (p < PREDS.length) h = mix(h, count(PREDS[p], all));
	acci(h);

	// applying the cast function only where the matching predicate holds
	var g = 0;
	for (i < n) {
		var s = all[i];
		if (isPoly(s)) g = mix(g, toPoly(s).sides);
		else g = mix(g, -1);
		if (isRect(s)) g = mix(g, toRect(s).w * toRect(s).h);
		else g = mix(g, -2);
	}
	acci(g);

	// predicates stored in a variant payload and behind a class field
	var box = PredBox.new(isSquare, toRect);
	var k = 0;
	for (i < n) {
		var s = all[i];
		k = mixb(k, box.p(s));
		if (isRect(s)) k = mix(k, box.c(s).sides);
	}
	acci(k);

	if (count(isPoly, POP) != 4) fail_assert(601);
	if (count(isRect, POP) != 2) fail_assert(602);
	if (count(isSquare, POP) != 1) fail_assert(603);
	if (count(isCircle, POP) != 1) fail_assert(604);
	if (!isPoly(mk(3))) fail_assert(605);
	if (isPoly(mk(5))) fail_assert(606);
	if (toRect(mk(3)).w != 6) fail_assert(607);
	if (toPoly(mk(4)).sides != 3) fail_assert(608);
	if (box.p(mk(2))) fail_assert(609);
	if (!box.p(mk(3))) fail_assert(610);
}
class PredBox(p: Shape -> bool, c: Shape -> Rect) { }

//======================================================================
// Section 7: casts interleaved with virtual dispatch
//======================================================================
// The cast picks a more specific static type, which may let the optimizer
// devirtualize the following call; the answer must not change either way.
def describe(s: Shape) -> int {
	if (s == null) return -1;
	var v = s.area();			// virtual
	if (Square.?(s)) {
		var q = Square.!(s);
		return v + q.area() + q.w;	// area() may devirtualize to Rect.area
	}
	if (Rect.?(s)) {
		var r = Rect.!(s);
		return v + r.area() + r.w + r.h;
	}
	if (Poly.?(s)) {
		var p = Poly.!(s);
		return v + p.area() + p.sides;
	}
	return v + s.area();
}
def dispatch() {
	var n = 90;
	var h = 0;
	for (i < n) {
		var s = mk(i);
		h = mix(h, describe(s));
		h = mixs(h, s.label());
		// label() through progressively narrower static types
		if (Poly.?(s)) h = mixs(h, Poly.!(s).label());
		if (Rect.?(s)) h = mixs(h, Rect.!(s).label());
		if (Square.?(s)) h = mixs(h, Square.!(s).label());
	}
	acci(h);
	var g = 0;
	for (i < POP.length) g = mix(g, describe(POP[i]));
	acci(g);

	if (describe(null) != -1) fail_assert(701);
	if (describe(Shape.new(1)) != 0) fail_assert(702);
	if (describe(Poly.new(1, 5)) != 15) fail_assert(703);		// 5 + 5 + 5
	if (describe(Rect.new(1, 3, 4)) != 31) fail_assert(704);	// 12 + 12 + 3 + 4
	if (describe(Square.new(1, 6)) != 78) fail_assert(705);		// 36 + 36 + 6
	if (describe(Tri.new(1, 8, 5)) != 43) fail_assert(706);		// 20 + 20 + 3
	if (describe(Circle.new(1, 2)) != 24) fail_assert(707);		// 12 + 12
	// A narrowed static type must not change what label() returns. String
	// equality in Virgil is by reference, so the answers are compared
	// character-wise rather than against a literal.
	if (Poly.!(Square.new(1, 2)).label().length != 6) fail_assert(708);
	if (Poly.!(Square.new(1, 2)).label()[0] != 's') fail_assert(709);
	if (Shape.!(Circle.new(1, 2)).label()[0] != 'c') fail_assert(710);
	if (Shape.!(Rect.new(1, 2, 3)).label()[0] != 'r') fail_assert(711);
	if (Shape.!(Tri.new(1, 2, 3)).label().length != 3) fail_assert(712);
}

//======================================================================
// Section 8: casts over a linked structure under allocation churn
//======================================================================
class Link {
	var head: Shape;
	var next: Link;
	new(head, next) { }
}
def churn() {
	var chain: Link;
	var live = Array<Link>.new(16);
	for (i < 3000) {
		chain = Link.new(mk(i), chain);
		if ((i % 61) == 0) live[(i / 61) % live.length] = chain;
		if ((i % 9) == 0) chain = null;
	}
	var h = 0;
	var seen = 0, squares = 0, polys = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			var s = p.head;
			if (Square.?(s)) { squares++; h = mix(h, Square.!(s).w); }
			else if (Poly.?(s)) { polys++; h = mix(h, Poly.!(s).sides); }
			else h = mix(h, s.area());
			p = p.next;
			seen++;
			if (seen > 200000) { acci(h); return; }
		}
	}
	acci(mix(mix(mix(h, seen), squares), polys));

	// the chain that survived to the end is still walkable and still typed
	var g = 0;
	var p = chain;
	while (p != null) {
		g = mixb(g, Poly.?(p.head));
		g = mix(g, p.head.area());
		p = p.next;
	}
	acci(g);
	if (live.length != 16) fail_assert(801);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) queries();
	if (a == 0 || a == 2) casts();
	if (a == 0 || a == 3) nulls();
	if (a == 0 || a == 4) arrays();
	if (a == 0 || a == 5) variants();
	if (a == 0 || a == 6) firstClass();
	if (a == 0 || a == 7) dispatch();
	if (a == 0 || a == 8) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
