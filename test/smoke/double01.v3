//@execute 0=1292963831; 1=413618019; 2=1185783540; 3=-1822977490; 4=-1562656990; 5=166758841; 6=-853644752; 7=1114606624; 8=27872993; 9=-2103978527; 10=317735466; 11=843738218; 12=2104465532
//@heap-size=400000
// Smoke test: 64-bit floating point.
// The double-precision counterpart of float01.v3: each section exercises a
// group of double operations and mixes the results into a running CRC that
// main() returns, so no computation can be deleted as dead. Interleaved with
// those are assert()s whose operands are compile-time constants: the optimizer
// is expected to fold them away entirely, so a folding bug shows up as a set
// failure flag rather than a wrong CRC.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
// NaN bit patterns are not guaranteed identical across backends, so all NaNs
// mix in one canonical marker; every other value mixes exact bits (which
// distinguishes 0.0 from -0.0).
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def VALS: Array<double> = [
	0d, -0.0d, 1d, -1d, 0.5d, -0.5d, 2d, 3.5d,
	-7.25d, 0.1d, 1e-300d, 1e300d,
	9007199254740992d, 9007199254740993d, -9007199254740993d,
	double.infinity, -double.infinity, double.nan
];
// Values whose magnitudes are tame enough that products and quotients stay
// finite, used where overflow would swamp the interesting bits.
def TAME: Array<double> = [
	0d, -0.0d, 0.25d, -0.75d, 1d, -1d, 2.5d, -3.5d, 100d, -1024d, 0.1d
];
def BITS: Array<long> = [
	0, 0x8000000000000000L,			// +0, -0
	1, 0x000FFFFFFFFFFFFFL,			// smallest, largest subnormal
	0x0010000000000000L,			// smallest normal
	0x3FF0000000000000L,			// 1.0
	0x3FE0000000000000L,			// 0.5
	0x4000000000000000L,			// 2.0
	0x7FEFFFFFFFFFFFFFL,			// double.max
	0x7FF0000000000000L,			// +inf
	0xFFF0000000000000L,			// -inf
	0x3FB999999999999AL			// 0.1
];

//======================================================================
// Section 1: arithmetic
//======================================================================
def arith() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = mixd(0, -a);
		for (j < VALS.length) {
			var b = VALS[j];
			h = mixd(h, a + b);
			h = mixd(h, a - b);
			h = mixd(h, a * b);
			h = mixd(h, a / b);
		}
		acci(h);
	}
	// compound assignment forms
	var x = 1.5d;
	x += 2.25d;
	x -= 0.5d;
	x *= 4d;
	x /= 3d;
	acci(mixd(0, x));
	// accumulate in a way that depends on association order
	var s = 0d, p = 1d;
	for (i < TAME.length) { s += TAME[i]; p *= (TAME[i] + 1.5d); }
	acci(mixd(mixd(0, s), p));

	if (1.5d + 2.25d != 3.75d) fail_assert(101);
	if (1.5d * 4d != 6d) fail_assert(102);
	if (7d / 2d != 3.5d) fail_assert(103);
	// the classic binary-fraction inequality; must NOT be folded to equality
	if (0.1d + 0.2d == 0.3d) fail_assert(104);
	if (0.5d + 0.25d != 0.75d) fail_assert(105);
	if (long.view(-0.0d * 1d) != 0x8000000000000000L) fail_assert(107);	// -0.0 stays negative
	if (long.view(-0.0d + 0d) != 0L) fail_assert(108);	// -0 + +0 is +0
	if (1e300d * 1e300d != double.infinity) fail_assert(109);
	if (1e-300d * 1e-300d != 0d) fail_assert(110);		// underflow to zero
	if (double.infinity - double.infinity == double.infinity) fail_assert(111);
	if (9007199254740992d + 1d != 9007199254740992d) fail_assert(112);
	if (9007199254740992d + 2d != 9007199254740994d) fail_assert(113);
}

//======================================================================
// Section 2: comparisons
//======================================================================
def compare() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = 0;
		for (j < VALS.length) {
			var b = VALS[j];
			h = mixb(h, a == b);
			h = mixb(h, a != b);
			h = mixb(h, a < b);
			h = mixb(h, a <= b);
			h = mixb(h, a > b);
			h = mixb(h, a >= b);
		}
		acci(h);
	}
	// a comparison-driven min/max fold, which the backend may turn into selects
	var lo = double.infinity, hi = -double.infinity, nans = 0;
	for (i < VALS.length) {
		var v = VALS[i];
		if (v != v) { nans++; continue; }
		if (v < lo) lo = v;
		if (v > hi) hi = v;
	}
	acci(mix(mixd(mixd(0, lo), hi), nans));

	// identities that hold only under IEEE semantics
	if (double.nan == double.nan) fail_assert(201);
	if (!(double.nan != double.nan)) fail_assert(202);
	if (double.nan < 1d) fail_assert(203);
	if (double.nan >= 1d) fail_assert(204);
	if (double.nan == double.infinity) fail_assert(205);
	if (!(0d == -0.0d)) fail_assert(206);
	if (0d < -0.0d) fail_assert(207);
	if (long.view(0d) == long.view(-0.0d)) fail_assert(208);
	if (!(double.infinity > 1.7976931348623157e308d)) fail_assert(209);
	if (!(-double.infinity < -1.7976931348623157e308d)) fail_assert(210);
	// 2^53 and 2^53+1 collapse to the same double
	if (9007199254740993d != 9007199254740992d) fail_assert(211);
	if (9007199254740993d == 9007199254740994d) fail_assert(212);
	if (lo != -double.infinity) fail_assert(213);
	if (hi != double.infinity) fail_assert(214);
	if (nans != 1) fail_assert(215);
}

//======================================================================
// Section 3: bit-level structure and special values
//======================================================================
def bits() {
	var h = 0;
	for (i < VALS.length) {
		var a = VALS[i];
		h = mix(h, a.sign);
		h = mix(h, a.exponent);
		h = mixl(h, long.!(a.fraction));
		h = mixd(h, double.view(long.view(a)));	// round trip through raw bits
		h = mixl(h, long.view(a));
	}
	acci(h);
	var g = 0;
	for (i < BITS.length) {
		var d = double.view(BITS[i]);
		g = mixd(g, d);
		g = mix(g, d.sign);
		g = mixl(g, long.view(d) ^ BITS[i]);	// must be zero for every entry
		g = mixd(g, d * 2d);
	}
	acci(g);
	var k = mixd(0, 1d / 0d);
	k = mixd(k, -1d / 0d);
	k = mixd(k, 0d / 0d);
	k = mixd(k, 1d / -0.0d);
	acci(k);

	if ((-0.0d).sign != 1) fail_assert(301);
	if ((0d).sign != 0) fail_assert(302);
	if ((-7.25d).sign != 1) fail_assert(303);
	if ((1d).exponent != 0) fail_assert(304);
	if ((2d).exponent != 1) fail_assert(305);
	if ((0.5d).exponent != -1) fail_assert(306);
	if ((1e10d).exponent != 33) fail_assert(307);
	if ((1d).fraction != 0) fail_assert(308);
	if ((1.5d).fraction != 0x8000000000000uL) fail_assert(309);
	if ((1.75d).fraction != 0xC000000000000uL) fail_assert(310);
	if (long.view(1d) != 0x3FF0000000000000L) fail_assert(311);
	if (long.view(0.5d) != 0x3FE0000000000000L) fail_assert(312);
	if (long.view(-0.0d) != 0x8000000000000000L) fail_assert(313);
	if (double.view(0x7FF0000000000000L) != double.infinity) fail_assert(314);
	if (double.view(0xFFF0000000000000L) != -double.infinity) fail_assert(315);
	if (double.view(0x7FEFFFFFFFFFFFFFL) != 1.7976931348623157e308d) fail_assert(316);
	if (double.view(1L) == 0d) fail_assert(317);		// smallest subnormal
	if (double.view(1L) * 0.5d != 0d) fail_assert(318);	// underflows away
	if (long.view(1d / 0d) != long.view(double.infinity)) fail_assert(319);
	if (long.view(1d / -0.0d) != long.view(-double.infinity)) fail_assert(320);
	if (0d / 0d == 0d / 0d) fail_assert(321);
}

//======================================================================
// Section 4: math operations
//======================================================================
def math() {
	var h = 0;
	for (i < VALS.length) {
		var a = VALS[i];
		h = mixd(h, double.abs(a));
		h = mixd(h, double.ceil(a));
		h = mixd(h, double.floor(a));
		h = mixd(h, double.sqrt(a));
		h = mixd(h, double.round(a));
	}
	acci(h);
	def HALVES: Array<double> = [-3.5d, -2.5d, -1.5d, -0.5d, 0.5d, 1.5d, 2.5d, 3.5d, 4.5d];
	var g = 0;
	for (i < HALVES.length) {
		g = mixd(g, double.round(HALVES[i]));
		g = mixd(g, double.ceil(HALVES[i]));
		g = mixd(g, double.floor(HALVES[i]));
		g = mixd(g, double.abs(HALVES[i]));
	}
	acci(g);
	// ceil(x) - floor(x) is 0 or 1 for every finite value
	var k = 0;
	for (i < TAME.length) {
		var v = TAME[i] + 0.375d;
		k = mixd(k, double.ceil(v) - double.floor(v));
		k = mixd(k, double.sqrt(double.abs(v)));
	}
	acci(k);

	// round is round-half-to-even
	if (double.round(-3.5d) != -4d) fail_assert(401);
	if (double.round(-2.5d) != -2d) fail_assert(402);
	if (double.round(-1.5d) != -2d) fail_assert(403);
	if (double.round(-0.5d) != 0d) fail_assert(404);
	if (double.round(0.5d) != 0d) fail_assert(405);
	if (double.round(1.5d) != 2d) fail_assert(406);
	if (double.round(2.5d) != 2d) fail_assert(407);
	if (double.round(3.5d) != 4d) fail_assert(408);
	if (double.round(4.5d) != 4d) fail_assert(409);
	if (long.view(double.round(-0.5d)) != long.view(-0.0d)) fail_assert(410);
	// ceil/floor
	if (double.ceil(1.0001d) != 2d) fail_assert(411);
	if (double.floor(1.9999d) != 1d) fail_assert(412);
	if (long.view(double.ceil(-0.5d)) != long.view(-0.0d)) fail_assert(413);
	if (double.floor(-0.5d) != -1d) fail_assert(414);
	if (double.ceil(double.infinity) != double.infinity) fail_assert(415);
	if (double.floor(-double.infinity) != -double.infinity) fail_assert(416);
	if (double.ceil(9007199254740992d) != 9007199254740992d) fail_assert(417);
	// sqrt
	if (double.sqrt(9d) != 3d) fail_assert(418);
	if (double.sqrt(0.25d) != 0.5d) fail_assert(419);
	if (double.sqrt(-1d) == double.sqrt(-1d)) fail_assert(420);	// NaN
	if (long.view(double.sqrt(-0.0d)) != long.view(-0.0d)) fail_assert(421);
	if (double.sqrt(double.infinity) != double.infinity) fail_assert(422);
	if (double.sqrt(1e300d) != 1e150d) fail_assert(423);
	// abs clears the sign bit
	if (long.view(double.abs(-0.0d)) != 0L) fail_assert(424);
	if (double.abs(-double.infinity) != double.infinity) fail_assert(425);
	if (double.abs(-7.25d) != 7.25d) fail_assert(426);
	if (double.abs(double.nan) == double.abs(double.nan)) fail_assert(427);
}

//======================================================================
// Section 5: doubles in arrays and ranges
//======================================================================
def arrays() {
	var a = Array<double>.new(96);
	for (i < a.length) a[i] = double.roundi(i) * 0.125d - 6d;
	var h = 0;
	for (i < a.length) h = mixd(h, a[i]);
	acci(h);

	var r: Range<double> = a;
	var mid = r[24 ... 72];
	var tail = r[72 ...];
	var g = mix(0, mid.length);
	for (i < mid.length) g = mixd(g, mid[i]);
	for (i < tail.length) g = mixd(g, tail[i]);
	acci(g);

	// range writes alias the backing array
	for (i < mid.length) mid[i] = mid[i] * -3d;
	var k = 0;
	for (i < a.length) k = mixd(k, a[i]);
	acci(k);
	if (a[30] != (double.roundi(30) * 0.125d - 6d) * -3d) fail_assert(500);
	if (mid.length != 48) fail_assert(501);
	if (tail.length != 24) fail_assert(502);
	if (a[10] != double.roundi(10) * 0.125d - 6d) fail_assert(503);	// outside the slice

	// two-dimensional, with a running reduction
	var m = Array<Array<double>>.new(12);
	for (i < m.length) {
		m[i] = Array<double>.new(12);
		for (j < 12) m[i][j] = double.roundi(i * 12 + j) / 7d;
	}
	var sum = 0d, prod = 1d;
	for (i < m.length) for (j < 12) { sum += m[i][j]; prod *= 1d + m[i][j] * 1e-3d; }
	acci(mixd(mixd(0, sum), prod));

	// arrays preserve NaN and signed zero across a copy
	var sp: Array<double> = [double.nan, double.infinity, -double.infinity, -0.0d, 1e-320d];
	var cp = Array<double>.new(sp.length);
	for (i < sp.length) cp[i] = sp[i];
	var c = 0;
	for (i < cp.length) c = mixd(c, cp[i]);
	acci(c);
	if (cp[0] == cp[0]) fail_assert(504);				// NaN survived
	if (long.view(cp[3]) != long.view(-0.0d)) fail_assert(505);	// -0.0 survived
	if (cp[4] == 0d) fail_assert(506);				// subnormal survived
	if (cp.length != 5) fail_assert(507);
}

//======================================================================
// Section 6: doubles in tuples
//======================================================================
def swapd(t: (double, double)) -> (double, double) {
	return (t.1, t.0);
}
def three(a: double, b: double, c: double) -> (double, double, double) {
	return (a + b, b + c, c + a);
}
def tuples() {
	var h = 0;
	for (i < TAME.length) {
		var t = (TAME[i], TAME[(i + 4) % TAME.length]);
		var s = swapd(t);
		h = mixd(h, t.0);
		h = mixd(h, t.1);
		h = mixd(h, s.0);
		h = mixd(h, s.1);
		h = mixb(h, t == s);
	}
	acci(h);
	var ts = Array<(double, double, int)>.new(24);
	for (i < ts.length) ts[i] = (double.roundi(i) * 1.25d, double.roundi(i) / 11d, i);
	var g = 0;
	for (i < ts.length) {
		var t = ts[i];
		g = mixd(g, t.0);
		g = mixd(g, t.1);
		g = mix(g, t.2);
	}
	acci(g);
	// tuples mixing the two precisions
	var mixedArr = Array<(float, double)>.new(16);
	for (i < mixedArr.length) mixedArr[i] = (float.roundi(i) * 0.5f, double.roundi(i) * 0.5d);
	var j = 0;
	for (i < mixedArr.length) {
		var t = mixedArr[i];
		j = mixf(j, t.0);
		j = mixd(j, t.1);
		j = mixb(j, t.0 == t.1);	// float promoted to double for the compare
	}
	acci(j);

	var q = three(1.5d, -2.25d, 8d);
	var n = ((1d, 2d), (3d, (4d, 5d)));	// nested tuples
	var k = mixd(0, q.0);
	k = mixd(k, q.1);
	k = mixd(k, q.2);
	k = mixd(k, n.0.0);
	k = mixd(k, n.1.1.0);
	k = mixd(k, n.1.1.1);
	acci(k);

	if (q.0 != -0.75d) fail_assert(601);
	if (q.1 != 5.75d) fail_assert(602);
	if (q.2 != 9.5d) fail_assert(603);
	if (n.1.1.1 != 5d) fail_assert(604);
	if (swapd((1d, 2d)).0 != 2d) fail_assert(605);
	if ((1d, 2d) == (2d, 1d)) fail_assert(606);
	if (!((1d, 2d) == (1d, 2d))) fail_assert(607);
	if ((0d, 1d) == (-0.0d, 1d)) fail_assert(608);	// tuple equality is bitwise
}

//======================================================================
// Section 7: doubles in globals and components
//======================================================================
var gd: double;
var gt: (double, double);
var ga: Array<double>;

component DStore {
	var cur: double = 2.25d;
	def base: double = -1.125d;
	var hist: Array<double> = Array<double>.new(12);
	var n: int;

	def push(d: double) -> double {
		cur = cur + d;
		hist[n % hist.length] = cur;
		n++;
		return cur;
	}
	def reset() {
		cur = 2.25d;
		n = 0;
		hist = Array<double>.new(12);
	}
}
def globals() {
	// Reset all mutable global state; the harness may run several inputs in one
	// process, so a section must never depend on what ran before it.
	gd = 0d;
	gt = (0d, 0d);
	DStore.reset();

	ga = Array<double>.new(VALS.length);
	var h = 0;
	for (i < VALS.length) {
		gd = VALS[i];
		gt = (gd, gd * 2d);
		ga[i] = gd - 1d;
		h = mixd(h, gd);
		h = mixd(h, gt.0);
		h = mixd(h, gt.1);
		h = mixd(h, ga[i]);
	}
	acci(h);
	var g = mixd(0, DStore.base);
	for (i < 40) g = mixd(g, DStore.push(double.roundi(i) * 0.0625d));
	for (i < DStore.hist.length) g = mixd(g, DStore.hist[i]);
	g = mix(g, DStore.n);
	g = mixd(g, DStore.cur);
	acci(g);

	if (DStore.base != -1.125d) fail_assert(701);
	if (DStore.n != 40) fail_assert(702);
	if (DStore.hist.length != 12) fail_assert(703);
	if (ga.length != VALS.length) fail_assert(704);
}

//======================================================================
// Section 8: doubles in class fields
//======================================================================
class DBox {
	var v: double;
	def tag: int;
	new(v, tag) { }
	def value() -> double { return v; }
	def scaled() -> double { return v; }
}
class DScale extends DBox {
	def k: double;
	new(v: double, tag: int, k) super(v, tag) { }
	def scaled() -> double { return v * k; }
}
class DPair extends DScale {
	var other: DBox;
	new(v: double, k: double, other) super(v, 2, k) { }
	def scaled() -> double { return if(other == null, v, v * k + other.value()); }
}
def classes() {
	var objs = Array<DBox>.new(3 * TAME.length);
	for (i < TAME.length) {
		var v = TAME[i];
		objs[3 * i + 0] = DBox.new(v, i);
		objs[3 * i + 1] = DScale.new(v, i, 0.25d);
		objs[3 * i + 2] = DPair.new(v, -2.5d, objs[3 * i + 0]);
	}
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mixd(h, o.value());
		h = mixd(h, o.scaled());	// virtual dispatch over 3 implementations
		h = mix(h, o.tag);
		h = mixb(h, DScale.?(o));
		h = mixb(h, DPair.?(o));
	}
	acci(h);
	// mutate through the array and re-read
	for (i < objs.length) objs[i].v = objs[i].v + 0.5d;
	var g = 0;
	for (i < objs.length) g = mixd(g, objs[i].scaled());
	acci(g);

	var b = DBox.new(3d, 7);
	var s = DScale.new(3d, 7, 0.5d);
	var p = DPair.new(3d, 4d, null);
	if (b.scaled() != 3d) fail_assert(801);
	if (s.scaled() != 1.5d) fail_assert(802);
	if (p.scaled() != 3d) fail_assert(803);			// null other
	if (DPair.new(3d, 4d, b).scaled() != 15d) fail_assert(804);
	if (!DScale.?(p)) fail_assert(805);
	if (DPair.?(s)) fail_assert(806);
	if (b.tag != 7) fail_assert(807);
	if (DPair.new(-0.0d, 1d, null).scaled() != 0d) fail_assert(808);
}

//======================================================================
// Section 9: doubles in variants
//======================================================================
type DVal {
	case Scalar(d: double);
	case Pair(a: double, b: double);
	case Boxed(o: DBox);
	case Nothing;
}
type DUnboxed #unboxed {
	case One(d: double);
	case Two(d: double, e: double);
	case Zero;
}
def evalv(v: DVal) -> double {
	match (v) {
		Scalar(d) => return d;
		Pair(a, b) => return a * b;
		Boxed(o) => return if(o == null, -1d, o.v);
		Nothing => return 0d;
	}
}
def evalu(v: DUnboxed) -> double {
	match (v) {
		One(d) => return d;
		Two(d, e) => return d - e;
		Zero => return -0.0d;
	}
}
def variants() {
	var h = 0;
	for (i < VALS.length) {
		var v = VALS[i];
		var b: DVal = DVal.Scalar(v);
		var p: DVal = DVal.Pair(v, 0.25d);
		var o: DVal = DVal.Boxed(DBox.new(v, i));
		var n: DVal = DVal.Nothing;
		h = mixd(h, evalv(b));
		h = mixd(h, evalv(p));
		h = mixd(h, evalv(o));
		h = mixd(h, evalv(n));
		h = mix(h, b.tag);
		h = mix(h, o.tag);
		h = mix(h, n.tag);
		h = mixb(h, b == p);
		h = mixb(h, DVal.Pair.?(p));
		h = mixb(h, DVal.Boxed.?(o));

		var u1: DUnboxed = DUnboxed.One(v);
		var u2: DUnboxed = DUnboxed.Two(v, 1.5d);
		var u3: DUnboxed = DUnboxed.Zero;
		h = mixd(h, evalu(u1));
		h = mixd(h, evalu(u2));
		h = mixd(h, evalu(u3));
		h = mixb(h, u1 == u2);
		// NaN payloads are excluded from variant equality: it constant-folds to
		// true but evaluates to false at runtime. See test/variants/eq_nan*.v3.
		var ev = if(v != v, 1.5d, v);
		h = mixb(h, DUnboxed.One(ev) == DUnboxed.One(ev));
		h = mixb(h, DUnboxed.One(ev) == DUnboxed.One(ev + 1d));
		h = mixb(h, DUnboxed.One(ev) == DUnboxed.Zero);
		h = mix(h, u2.tag);
	}
	acci(h);
	var arr = Array<DUnboxed>.new(VALS.length);
	var barr = Array<DVal>.new(VALS.length);
	for (i < arr.length) {
		arr[i] = DUnboxed.Two(VALS[i], double.roundi(i));
		barr[i] = DVal.Pair(VALS[i], double.roundi(i));
	}
	var g = 0;
	for (i < arr.length) {
		g = mixd(g, evalu(arr[i]));
		g = mixd(g, evalv(barr[i]));
	}
	acci(g);

	if (evalv(DVal.Scalar(2.5d)) != 2.5d) fail_assert(901);
	if (evalv(DVal.Pair(2d, 4d)) != 8d) fail_assert(902);
	if (evalv(DVal.Nothing) != 0d) fail_assert(903);
	if (evalv(DVal.Boxed(null)) != -1d) fail_assert(904);
	if (evalu(DUnboxed.Two(5d, 2d)) != 3d) fail_assert(905);
	if (long.view(evalu(DUnboxed.Zero)) != long.view(-0.0d)) fail_assert(906);
	if (DVal.Scalar(1d).tag != 0) fail_assert(907);
	if (DVal.Nothing.tag != 3) fail_assert(908);
	if (!(DUnboxed.One(2d) == DUnboxed.One(2d))) fail_assert(909);
	if (DUnboxed.One(2d) == DUnboxed.One(3d)) fail_assert(910);
	if (DUnboxed.One(0d) == DUnboxed.One(-0.0d)) fail_assert(911);	// bitwise
	if (DUnboxed.Zero.tag != 2) fail_assert(912);
}

//======================================================================
// Section 10: doubles through functions
//======================================================================
def addd(a: double, b: double) -> double { return a + b; }
def applyd(f: (double, double) -> double, a: double, b: double) -> double { return f(a, b); }
def foldd(f: (double, double) -> double, init: double, a: Array<double>) -> double {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def makeAdder(a: double) -> double -> double {
	return fun (b: double) => a + b;
}
def funcs() {
	def OPS: Array<(double, double) -> double> = [double.+, double.-, double.*, double./, addd];
	for (k < OPS.length) {
		var h = 0;
		for (i < TAME.length) h = mixd(h, applyd(OPS[k], TAME[i], 2.5d));
		h = mixd(h, foldd(OPS[k], 1d, TAME));
		acci(h);
	}
	var inc = addd(1d, _);			// partial application
	var dec = addd(_, -1d);
	var g = 0;
	for (i < VALS.length) {
		g = mixd(g, inc(VALS[i]));
		g = mixd(g, dec(VALS[i]));
	}
	acci(g);
	var adders = Array<double -> double>.new(10);
	for (i < adders.length) adders[i] = makeAdder(double.roundi(i) * 0.5d);
	var k = 0;
	for (i < adders.length) for (j < TAME.length) k = mixd(k, adders[i](TAME[j]));
	def UNARY: Array<double -> double> = [double.sqrt, double.abs, double.ceil, double.floor, double.round];
	for (i < UNARY.length) for (j < VALS.length) k = mixd(k, UNARY[i](VALS[j]));
	acci(k);

	if (applyd(double.+, 1.5d, 2.5d) != 4d) fail_assert(1001);
	if (applyd(double.*, 1.5d, 4d) != 6d) fail_assert(1002);
	if (applyd(double.-, 1.5d, 4d) != -2.5d) fail_assert(1003);
	if (addd(1d, _)(2.5d) != 3.5d) fail_assert(1004);
	if (addd(_, -1d)(2.5d) != 1.5d) fail_assert(1005);
	if (makeAdder(3d)(4d) != 7d) fail_assert(1006);
	if (foldd(addd, 0d, [1d, 2d, 3d, 4d]) != 10d) fail_assert(1007);
}

//======================================================================
// Section 11: precision and rounding at the 53-bit boundary
//======================================================================
def precision() {
	// A Kahan-compensated sum next to a naive one: the two differ, which forces
	// the backend to keep every intermediate rounding step.
	var naive = 0d, kahan = 0d, comp = 0d;
	for (i < 4000) {
		var x = 1d / double.roundi(i + 1);
		naive += x;
		var y = x - comp;
		var t = kahan + y;
		comp = (t - kahan) - y;
		kahan = t;
	}
	acci(mixd(mixd(0, naive), kahan));

	// walk the powers of two and the last representable neighbor of each
	var h = 0;
	var p = 1d;
	for (i < 60) {
		h = mixd(h, p);
		h = mixd(h, p + 1d);
		h = mixd(h, double.view(long.view(p) + 1L));	// next double above p
		h = mix(h, p.exponent);
		p = p * 2d;
	}
	acci(h);

	// integers around 2^53 quantize in steps of 2
	var g = 0;
	var base = 9007199254740992d;
	for (i < 8) {
		var d = base + double.roundi(i);
		g = mixd(g, d);
		g = mixb(g, d == base);
		g = mixl(g, long.truncd(d));
	}
	acci(g);

	if (1d + 1e-16d == 1d + 0d) {
		// 1 + 1e-16 rounds back to exactly 1.0
	} else fail_assert(1101);
	if (1d + 1e-15d == 1d) fail_assert(1102);
	if (9007199254740992d + 1d != 9007199254740992d) fail_assert(1103);
	if (9007199254740993d - 9007199254740992d != 0d) fail_assert(1104);
	if (9007199254740994d - 9007199254740992d != 2d) fail_assert(1105);
	if (double.view(long.view(1d) + 1L) == 1d) fail_assert(1106);
	if (double.view(long.view(1d) + 1L) - 1d != 2.220446049250313e-16d) fail_assert(1107);
	if ((4503599627370496d).exponent != 52) fail_assert(1108);
	if (long.truncd(9007199254740993d) != 9007199254740992L) fail_assert(1109);
}

//======================================================================
// Section 12: allocation churn with live double data
//======================================================================
class DNode(val: double, aux: (double, int), next: DNode) { }
def churn() {
	var head: DNode;
	var live = Array<DNode>.new(24);
	for (i < 3000) {
		var d = double.roundi(i) * 0.25d - 300d;
		head = DNode.new(d, (d * d, i), head);
		if ((i % 89) == 0) live[(i / 89) % live.length] = head;
		if ((i % 11) == 0) head = null;		// drop most of the chain
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mixd(h, p.val);
			h = mixd(h, p.aux.0);
			h = mix(h, p.aux.1);
			p = p.next;
			n++;
			if (n > 200000) { acci(h); return; }
		}
	}
	h = mix(h, n);
	var p = head;
	while (p != null) { h = mixd(h, p.val); p = p.next; }
	acci(h);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) arith();
	if (a == 0 || a == 2) compare();
	if (a == 0 || a == 3) bits();
	if (a == 0 || a == 4) math();
	if (a == 0 || a == 5) arrays();
	if (a == 0 || a == 6) tuples();
	if (a == 0 || a == 7) globals();
	if (a == 0 || a == 8) classes();
	if (a == 0 || a == 9) variants();
	if (a == 0 || a == 10) funcs();
	if (a == 0 || a == 11) precision();
	if (a == 0 || a == 12) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
