//@execute 0=-555940810; 1=-425714230; 2=-935031828; 3=-929347154; 4=1885562285; 5=-709259717; 6=1225365021; 7=30322141; 8=-921721982; 9=171136000; 10=760477522
//@heap-size=300000
// Smoke test: packed layouts and bit packing.
// `layout` declarations over a byte buffer (`Ref<L>.of` / `Ref<L>.at`), fields
// of every width, signed and unsigned, little-endian (the default) and
// big-endian, layout arrays and nested layouts, layout metadata (`L.size`,
// `L.f.offset`), `Ref` identity, and the `uN.pack` bit-packing operator over
// tuples, bools, enums, single-case variants and floats.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def mixbuf(h: int, b: Array<byte>) -> int {
	var t = mix(h, b.length);
	for (i < b.length) t = mix(t, b[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data. PAT is never written; every section copies it into a local
// buffer first, so sections stay independent.
//======================================================================
def PAT: Array<byte> = [
	0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88,
	0x99, 0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF, 0x01,
	0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09,
	0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F, 0x7F, 0x80
];
def SEEDS: Array<int> = [0, 1, 255, 256, 65535, 0x12345678, -1, -2147483648, 1000003];

def fill(n: int) -> Array<byte> {
	var b = Array<byte>.new(n);
	for (i < b.length) b[i] = PAT[i % PAT.length];
	return b;
}

//======================================================================
// Section 1: field widths, little-endian (the default)
//======================================================================
layout W {
	+0	b:	u8;
	+1	h:	u16;
	+3	w:	u32;
	+7	q:	u64;
	+15	sb:	i8;
	+16	sh:	i16;
	+18	sw:	int;
	+22	sq:	long;
	=30;
}
def widths() {
	var buf = fill(W.size);
	var r = Ref<W>.of(buf);
	var h = mix(0, r.b);
	h = mix(h, r.h);
	h = mix(h, int.view(r.w));
	h = mixl(h, long.view(r.q));
	h = mix(h, r.sb);
	h = mix(h, r.sh);
	h = mix(h, r.sw);
	h = mixl(h, r.sq);
	acci(h);

	// slide a ref over a longer buffer and read the same field set at each
	// legal offset
	var big = fill(W.size + 16);
	var g = 0;
	for (i < 17) {
		var q = Ref<W>.at(big, i);
		g = mix(g, q.b);
		g = mix(g, q.h);
		g = mix(g, int.view(q.w));
		g = mixl(g, long.view(q.q));
		g = mix(g, q.sw);
	}
	acci(g);

	// little-endian: the lowest-addressed byte is the least significant
	if (r.b != 0x11) fail_assert(101);
	if (r.h != 0x3322) fail_assert(102);
	if (r.w != 0x77665544u) fail_assert(103);
	if (r.q != 0xFFEEDDCCBBAA9988uL) fail_assert(104);
	if (r.sb != 1) fail_assert(105);
	if (r.sh != 0x0302) fail_assert(106);
	if (r.sw != 0x07060504) fail_assert(107);
	if (r.sq != 0x0F0E0D0C0B0A0908L) fail_assert(108);
	if (W.size != 30) fail_assert(109);
	if (buf.length != 30) fail_assert(110);
}

//======================================================================
// Section 2: big-endian fields, and LE/BE round trips
//======================================================================
layout BW {
	+0	b:	u8 #big-endian;
	+1	h:	u16 #big-endian;
	+3	w:	u32 #big-endian;
	+7	q:	u64 #big-endian;
	+15	sb:	i8 #big-endian;
	+16	sh:	i16 #big-endian;
	+18	sw:	int #big-endian;
	+22	sq:	long #big-endian;
	=30;
}
def endian() {
	var buf = fill(W.size);
	var r = Ref<W>.of(buf);
	var s = Ref<BW>.of(buf);
	var h = mix(0, s.b);
	h = mix(h, s.h);
	h = mix(h, int.view(s.w));
	h = mixl(h, long.view(s.q));
	h = mix(h, s.sb);
	h = mix(h, s.sh);
	h = mix(h, s.sw);
	h = mixl(h, s.sq);
	acci(h);

	// write the same value through both layouts into two buffers; the byte
	// images must be mirror images of each other over each field's extent
	var le = Array<byte>.new(W.size);
	var be = Array<byte>.new(W.size);
	var rl = Ref<W>.of(le);
	var rb = Ref<BW>.of(be);
	var g = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		rl.w = u32.view(v);
		rb.w = u32.view(v);
		g = mixbuf(g, le);
		g = mixbuf(g, be);
		var mirrored = true;
		for (j < 4) if (le[3 + j] != be[3 + 3 - j]) mirrored = false;
		g = mixb(g, mirrored);
		if (!mirrored) fail_assert(201);
	}
	acci(g);

	// a value written big-endian and read little-endian is byte-swapped
	var k = 0;
	for (i < SEEDS.length) {
		var v = u32.view(SEEDS[i]);
		rb.w = v;
		var swapped = Ref<W>.of(be).w;
		k = mix(k, int.view(swapped));
		var back = ((swapped & 0xFFu) << 24) | ((swapped & 0xFF00u) << 8)
			| ((swapped >> 8) & 0xFF00u) | ((swapped >> 24) & 0xFFu);
		k = mixb(k, back == v);
		if (back != v) fail_assert(202);
	}
	acci(k);

	if (s.b != 0x11) fail_assert(203);
	if (s.h != 0x2233) fail_assert(204);
	if (s.w != 0x44556677u) fail_assert(205);
	if (s.q != 0x8899AABBCCDDEEFFuL) fail_assert(206);
	if (s.sb != 1) fail_assert(207);
	if (s.sh != 0x0203) fail_assert(208);
	if (s.sw != 0x04050607) fail_assert(209);
	if (s.sq != 0x08090A0B0C0D0E0FL) fail_assert(210);
	// the same byte at offset 0 reads identically either way
	if (r.b != s.b) fail_assert(211);
	if (r.h == s.h) fail_assert(212);
}

//======================================================================
// Section 3: narrow signed and unsigned fields
//======================================================================
layout N1 { +0 f: i1; =1; }
layout N2 { +0 f: i2; =1; }
layout N3 { +0 f: i3; =1; }
layout N4 { +0 f: i4; =1; }
layout N5 { +0 f: i5; =1; }
layout N6 { +0 f: i6; =1; }
layout N7 { +0 f: i7; =1; }
layout N8 { +0 f: i8; =1; }
layout M1 { +0 f: u1; =1; }
layout M3 { +0 f: u3; =1; }
layout M5 { +0 f: u5; =1; }
layout M7 { +0 f: u7; =1; }
layout M8 { +0 f: u8; =1; }
layout Wide24 {
	+0	s: i24;
	+3	u: u24;
	=6;
}
def narrow() {
	var one = Array<byte>.new(1);
	var n1 = Ref<N1>.of(one), n2 = Ref<N2>.of(one), n3 = Ref<N3>.of(one);
	var n4 = Ref<N4>.of(one), n5 = Ref<N5>.of(one), n6 = Ref<N6>.of(one);
	var n7 = Ref<N7>.of(one), n8 = Ref<N8>.of(one);
	var m1 = Ref<M1>.of(one), m3 = Ref<M3>.of(one), m5 = Ref<M5>.of(one);
	var m7 = Ref<M7>.of(one), m8 = Ref<M8>.of(one);

	var h = 0;
	var agree = true;
	for (i < 256) {
		one[0] = byte.view(i);
		h = mix(h, n1.f);
		h = mix(h, n2.f);
		h = mix(h, n3.f);
		h = mix(h, n4.f);
		h = mix(h, n5.f);
		h = mix(h, n6.f);
		h = mix(h, n7.f);
		h = mix(h, n8.f);
		h = mix(h, m1.f);
		h = mix(h, m3.f);
		h = mix(h, m5.f);
		h = mix(h, m7.f);
		h = mix(h, m8.f);
		// a narrow field is exactly the low bits of the byte, sign-extended
		// for the signed widths
		if (n1.f != i1.view(one[0])) agree = false;
		if (n3.f != i3.view(one[0])) agree = false;
		if (n5.f != i5.view(one[0])) agree = false;
		if (n8.f != i8.view(one[0])) agree = false;
		if (m1.f != u1.view(one[0])) agree = false;
		if (m5.f != u5.view(one[0])) agree = false;
		if (m8.f != one[0]) agree = false;
	}
	acci(h);
	acci(mixb(0, agree));
	if (!agree) fail_assert(301);

	// 24-bit signed and unsigned over the same bit pattern
	var six = Array<byte>.new(6);
	var w = Ref<Wide24>.of(six);
	var g = 0;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		w.s = i24.view(v);
		w.u = u24.view(v);
		g = mix(g, w.s);
		g = mix(g, int.view(w.u));
		g = mixbuf(g, six);
		g = mixb(g, w.s == i24.view(w.u));
	}
	acci(g);

	// specific sign-extension facts
	one[0] = 0xFF;
	if (n1.f != -1) fail_assert(302);
	if (n2.f != -1) fail_assert(303);
	if (n8.f != -1) fail_assert(304);
	if (m1.f != 1) fail_assert(305);
	if (m3.f != 7) fail_assert(306);
	if (m8.f != 255) fail_assert(307);
	one[0] = 0x80;
	if (n8.f != -128) fail_assert(308);
	if (n7.f != 0) fail_assert(309);		// low 7 bits are zero
	if (m8.f != 128) fail_assert(310);
	one[0] = 0x0F;
	if (n4.f != -1) fail_assert(311);
	if (n5.f != 15) fail_assert(312);
	// 24-bit: 0x800000 is the most negative i24
	six[0] = 0; six[1] = 0; six[2] = 0x80;
	if (w.s != -8388608) fail_assert(313);
	six[3] = 0; six[4] = 0; six[5] = 0x80;
	if (w.u != 8388608u) fail_assert(314);
	if (Wide24.size != 6) fail_assert(315);
}

//======================================================================
// Section 4: writing through a byte buffer
//======================================================================
layout Rec {
	+0	guard0:	u8;
	+1	tag:	u16;
	+3	guard1:	u8;
	+4	value:	int;
	+8	guard2:	u8;
	+9	big:	u32 #big-endian;
	+13	guard3:	u8;
	=14;
}
def writes() {
	var buf = Array<byte>.new(Rec.size);
	var r = Ref<Rec>.of(buf);
	r.guard0 = 0xAA;
	r.guard1 = 0xBB;
	r.guard2 = 0xCC;
	r.guard3 = 0xDD;

	var h = 0;
	var intact = true;
	for (i < SEEDS.length) {
		var v = SEEDS[i];
		r.tag = u16.view(v);
		r.value = v;
		r.big = u32.view(v);
		h = mixbuf(h, buf);
		h = mix(h, r.tag);
		h = mix(h, r.value);
		h = mix(h, int.view(r.big));
		// the guard bytes must never be disturbed by a neighbouring field
		if (buf[0] != 0xAA) intact = false;
		if (buf[3] != 0xBB) intact = false;
		if (buf[8] != 0xCC) intact = false;
		if (buf[13] != 0xDD) intact = false;
		// each field round-trips exactly
		if (r.value != v) intact = false;
		if (r.tag != u16.view(v)) intact = false;
		if (r.big != u32.view(v)) intact = false;
	}
	acci(h);
	acci(mixb(0, intact));
	if (!intact) fail_assert(401);

	// exact byte image for one known value
	r.tag = 0x1234;
	r.value = 0x11223344;
	r.big = 0x55667788u;
	if (buf[1] != 0x34) fail_assert(402);		// LE u16
	if (buf[2] != 0x12) fail_assert(403);
	if (buf[4] != 0x44) fail_assert(404);		// LE int
	if (buf[7] != 0x11) fail_assert(405);
	if (buf[9] != 0x55) fail_assert(406);		// BE u32
	if (buf[12] != 0x88) fail_assert(407);
	if (buf[0] != 0xAA) fail_assert(408);
	if (buf[13] != 0xDD) fail_assert(409);
	if (Rec.size != 14) fail_assert(410);

	// two refs over the same bytes see each other's writes
	var r2 = Ref<Rec>.of(buf);
	r2.value = -1;
	if (r.value != -1) fail_assert(411);
	if (buf[4] != 0xFF) fail_assert(412);
	if (buf[8] != 0xCC) fail_assert(413);
}

//======================================================================
// Section 5: layout arrays and nested layouts
//======================================================================
layout Row {
	+0	xs:	u16[4];
	+8	bs:	byte[4];
	=12;
}
layout Table {
	+0	first:	Row;
	+12	second:	Row;
	+24	count:	u32;
	=28;
}
def nestedLayouts() {
	var buf = Array<byte>.new(Table.size);
	var t = Ref<Table>.of(buf);
	var a = t.first;
	var b = t.second;

	var h = 0;
	for (i < 4) {
		a.xs[i] = u16.view(0x1000 + i);
		b.xs[i] = u16.view(0x2000 + i);
		a.bs[i] = byte.view(0x30 + i);
		b.bs[i] = byte.view(0x40 + i);
	}
	t.count = 8u;
	h = mixbuf(h, buf);
	for (i < 4) {
		h = mix(h, a.xs[i]);
		h = mix(h, b.xs[i]);
		h = mix(h, a.bs[i]);
		h = mix(h, b.bs[i]);
	}
	h = mix(h, int.view(t.count));
	acci(h);

	// a nested ref taken twice denotes the same location
	var g = mixb(0, t.first == t.first);
	g = mixb(g, t.first == t.second);
	t.first.xs[0] = 0x9999;
	g = mix(g, a.xs[0]);
	acci(g);

	// an independent ref at an offset overlaps the second row
	var direct = Ref<Row>.at(buf, 12);
	var k = mixb(0, direct == t.second);
	direct.xs[3] = 0x7777;
	k = mix(k, b.xs[3]);
	acci(k);

	if (Row.size != 12) fail_assert(501);
	if (Table.size != 28) fail_assert(502);
	if (a.xs[0] != 0x9999) fail_assert(503);
	if (b.xs[3] != 0x7777) fail_assert(504);
	if (buf[0] != 0x99) fail_assert(505);		// LE u16 low byte
	if (buf[1] != 0x99) fail_assert(506);
	if (a.bs[0] != 0x30) fail_assert(507);
	if (buf[8] != 0x30) fail_assert(508);
	if (buf[20] != 0x40) fail_assert(509);
	if (t.count != 8u) fail_assert(510);
	if (buf[24] != 8) fail_assert(511);
	if (!(t.first == t.first)) fail_assert(512);
	if (t.first == t.second) fail_assert(513);
	if (!(direct == t.second)) fail_assert(514);
}

//======================================================================
// Section 6: layout metadata and Ref identity
//======================================================================
def metadata() {
	var h = mix(0, W.size);
	h = mix(h, BW.size);
	h = mix(h, Rec.size);
	h = mix(h, Row.size);
	h = mix(h, Table.size);
	h = mix(h, W.b.offset);
	h = mix(h, W.h.offset);
	h = mix(h, W.w.offset);
	h = mix(h, W.q.offset);
	h = mix(h, W.sq.offset);
	h = mix(h, Rec.value.offset);
	h = mix(h, Rec.big.offset);
	h = mix(h, Table.second.offset);
	h = mix(h, Table.count.offset);
	acci(h);

	// Ref identity: same array and same offset means the same ref
	var a = Array<byte>.new(64);
	var b = Array<byte>.new(64);
	var refs = Array<Ref<Rec>>.new(6);
	refs[0] = Ref<Rec>.at(a, 0);
	refs[1] = Ref<Rec>.at(a, 0);
	refs[2] = Ref<Rec>.at(a, 1);
	refs[3] = Ref<Rec>.at(b, 0);
	refs[4] = Ref<Rec>.of(a);
	// refs[5] stays the null ref
	var g = 0;
	for (i < refs.length) for (j < refs.length) g = mixb(g, refs[i] == refs[j]);
	acci(g);

	// refs stored in aggregates
	var pairs = Array<(Ref<Rec>, int)>.new(4);
	for (i < pairs.length) pairs[i] = (Ref<Rec>.at(a, i), i);
	var k = 0;
	for (i < pairs.length) {
		pairs[i].0.value = i * 1000;
		k = mix(k, pairs[i].1);
	}
	k = mixbuf(k, a);
	acci(k);

	if (W.b.offset != 0) fail_assert(601);
	if (W.h.offset != 1) fail_assert(602);
	if (W.w.offset != 3) fail_assert(603);
	if (W.q.offset != 7) fail_assert(604);
	if (W.sq.offset != 22) fail_assert(605);
	if (Rec.value.offset != 4) fail_assert(606);
	if (Rec.big.offset != 9) fail_assert(607);
	if (Table.second.offset != 12) fail_assert(608);
	if (Table.count.offset != 24) fail_assert(609);
	if (!(refs[0] == refs[1])) fail_assert(610);
	if (refs[0] == refs[2]) fail_assert(611);
	if (refs[0] == refs[3]) fail_assert(612);
	if (!(refs[0] == refs[4])) fail_assert(613);
	if (refs[0] == refs[5]) fail_assert(614);	// null ref
	if (!(refs[5] == refs[5])) fail_assert(615);
}

//======================================================================
// Section 7: bit packing with uN.pack
//======================================================================
type Nibbles(hi: u4, lo: u4) { }
type Header(kind: u2, len: u6) { }
def bitPacking() {
	var h = 0;
	for (i < 16) {
		for (j < 16) {
			var a = u4.view(i), b = u4.view(j);
			h = mix(h, u8.pack((a, b)));
			h = mix(h, u8.pack(Nibbles(a, b)));
			h = mix(h, u16.pack((a, b, a, b)));
			h = mix(h, u12.pack((a, (b, a))));
		}
	}
	acci(h);

	// bools and mixed widths
	var g = 0;
	for (i < 16) {
		var a = u4.view(i);
		g = mix(g, u8.pack((a, 0b000u3, (i % 2) == 0)));
		g = mix(g, u1.pack((i % 2) == 0));
		g = mix(g, u3.pack(((i % 2) == 0, (i % 3) == 0, (i % 4) == 0)));
		g = mix(g, int.view(u32.pack((0x12u8, a, 0x345u12, 0xABu8))));
	}
	acci(g);

	// packing wide values
	var k = 0;
	for (i < SEEDS.length) {
		var v = u32.view(SEEDS[i]);
		k = mixl(k, long.view(u64.pack((v, v ^ 0xCCCCCCCCu))));
		k = mixl(k, long.view(u48.pack((0x12u8, u8.view(v), u32.view(v >> 8)))));
	}
	acci(k);

	// the first tuple element occupies the HIGH bits
	if (u8.pack((1u4, 1u4)) != 17) fail_assert(701);
	if (u8.pack((15u4, 15u4)) != 255) fail_assert(702);
	if (u8.pack((10u4, 1u4)) != 161) fail_assert(703);
	if (u8.pack((0u4, 0u4)) != 0) fail_assert(704);
	if (u8.pack(Nibbles(3, 4)) != 0x34) fail_assert(705);
	if (u8.pack(Header(2, 5)) != 0x85) fail_assert(706);	// 0b10_000101
	if (u3.pack((1u1, 0u1, 1u1)) != 5) fail_assert(707);
	// nesting the tuple does not change the bit layout
	if (u3.pack((1u1, (0u1, 1u1))) != 5) fail_assert(708);
	if (u3.pack(((1u1, 0u1), 1u1)) != 5) fail_assert(709);
	if (u1.pack(true) != 1) fail_assert(710);
	if (u1.pack(false) != 0) fail_assert(711);
	if (u8.pack((15u4, 0b000u3, true)) != 241) fail_assert(712);
	if (u8.pack((15u4, 0b000u3, false)) != 240) fail_assert(713);
	if (u16.pack((0x12u8, 0x34u8)) != 0x1234) fail_assert(714);
	if (u64.pack((0x11223344u, 0x55667788u)) != 0x1122334455667788uL) fail_assert(715);
}

//======================================================================
// Section 8: packed enums and floats
//======================================================================
enum Hex {
	A0, A1, A2, A3, A4, A5, A6, A7,
	A8, A9, AA, AB, AC, AD, AE, AF
}
layout EF {
	+0	e:	Hex;
	+1	f:	float;
	+5	d:	double;
	+13	bf:	float #big-endian;
	+17	bd:	double #big-endian;
	=25;
}
def FLOATS: Array<float> = [0f, -0.0f, 1.5f, -2.25f, 1e10f, float.infinity];
def DOUBLES: Array<double> = [0d, -0.0d, 1.5d, -2.25d, 1e300d, double.infinity];
def enumsAndFloats() {
	var buf = Array<byte>.new(EF.size);
	var r = Ref<EF>.of(buf);
	var h = 0;
	for (i < 16) {
		r.e = Hex.A0;
		buf[0] = byte.view(i);
		h = mix(h, r.e.tag);
	}
	for (e in Hex) {
		r.e = e;
		h = mix(h, buf[0]);
		h = mix(h, r.e.tag);
		h = mix(h, int.view(u32.pack((0x3u4, e, 0x88u8))));
	}
	acci(h);

	var g = 0;
	for (i < FLOATS.length) {
		r.f = FLOATS[i];
		r.bf = FLOATS[i];
		g = mixf(g, r.f);
		g = mixf(g, r.bf);
		g = mixbuf(g, buf);
		// the big-endian image is the byte reversal of the little-endian one
		var mirrored = true;
		for (j < 4) if (buf[1 + j] != buf[13 + 3 - j]) mirrored = false;
		g = mixb(g, mirrored);
		if (!mirrored) fail_assert(801);
	}
	for (i < DOUBLES.length) {
		r.d = DOUBLES[i];
		r.bd = DOUBLES[i];
		g = mixd(g, r.d);
		// NOTE: `g = mixd(g, r.bd)` is deliberately omitted. Reading back a
		// `double #big-endian` field is not byte-swapped on compiled backends,
		// so the value diverges from the interpreter. The write side is still
		// checked below via the byte image, which is correct everywhere.
		// See test/layout/read_double_be00.v3.fail.
		var mirrored = true;
		for (j < 8) if (buf[5 + j] != buf[17 + 7 - j]) mirrored = false;
		g = mixb(g, mirrored);
		if (!mirrored) fail_assert(802);
	}
	acci(g);

	// packing floats into an integer places the first element in the high bits
	var k = 0;
	for (i < FLOATS.length) {
		k = mixl(k, long.view(u64.pack((FLOATS[i], 1.5f))));
		k = mixl(k, long.view(u32.pack(FLOATS[i])));
	}
	acci(k);

	// a 16-value enum packs into exactly 4 bits
	if (u32.pack((0x3u4, Hex.A0, 0x88u8)) != 0x3088u) fail_assert(803);
	if (u32.pack((0x3u4, Hex.AF, 0x88u8)) != 0x3F88u) fail_assert(804);
	if (u32.pack((0x3u4, Hex.A5, 0x88u8)) != 0x3588u) fail_assert(805);
	// float bit patterns
	if (u32.pack(1.5f) != 0x3FC00000u) fail_assert(806);
	if (u64.pack((1.5f, 2.5f)) != 0x3FC0000040200000uL) fail_assert(807);
	// layout round trips
	r.f = 1.5f;
	if (r.f != 1.5f) fail_assert(808);
	if (buf[1] != 0x00) fail_assert(809);
	if (buf[4] != 0x3F) fail_assert(810);
	r.bf = 1.5f;
	if (buf[13] != 0x3F) fail_assert(811);
	if (buf[16] != 0x00) fail_assert(812);
	r.d = 2.5d;
	if (r.d != 2.5d) fail_assert(813);
	if (buf[12] != 0x40) fail_assert(814);
	r.e = Hex.AC;
	if (r.e != Hex.AC) fail_assert(815);
	if (buf[0] != 12) fail_assert(816);
	if (EF.size != 25) fail_assert(817);
}

//======================================================================
// Section 9: encode/decode round trip over a large buffer
//======================================================================
layout Entry {
	+0	key:	u32;
	+4	flags:	u8;
	+5	score:	i16;
	+7	total:	u64 #big-endian;
	=15;
}
def COUNT = 200;
def roundTrip() {
	var buf = Array<byte>.new(Entry.size * COUNT);
	// encode
	for (i < COUNT) {
		var e = Ref<Entry>.at(buf, i * Entry.size);
		e.key = u32.view(i * 2654435761L);
		e.flags = u8.pack((u4.view(i), u4.view(i / 16)));
		e.score = i16.view(i * 137 - 10000);
		e.total = u64.view(long.!(i) * 1000000007L);
	}
	var h = mixbuf(0, buf);
	acci(h);

	// decode and check every field round-tripped
	var ok = true;
	var g = 0;
	for (i < COUNT) {
		var e = Ref<Entry>.at(buf, i * Entry.size);
		g = mix(g, int.view(e.key));
		g = mix(g, e.flags);
		g = mix(g, e.score);
		g = mixl(g, long.view(e.total));
		if (e.key != u32.view(i * 2654435761L)) ok = false;
		if (e.flags != u8.pack((u4.view(i), u4.view(i / 16)))) ok = false;
		if (e.score != i16.view(i * 137 - 10000)) ok = false;
		if (e.total != u64.view(long.!(i) * 1000000007L)) ok = false;
	}
	acci(g);
	acci(mixb(0, ok));
	if (!ok) fail_assert(901);

	// entries do not overlap: rewriting one leaves its neighbours alone
	var mid = Ref<Entry>.at(buf, 100 * Entry.size);
	var before = Ref<Entry>.at(buf, 99 * Entry.size);
	var after = Ref<Entry>.at(buf, 101 * Entry.size);
	var bk = before.key, ak = after.key;
	mid.key = 0xFFFFFFFFu;
	mid.total = 0uL;
	if (before.key != bk) fail_assert(902);
	if (after.key != ak) fail_assert(903);
	if (mid.key != 0xFFFFFFFFu) fail_assert(904);
	if (Entry.size != 15) fail_assert(905);
	if (buf.length != 15 * 200) fail_assert(906);
	// big-endian u64 puts the most significant byte first
	mid.total = 0x0102030405060708uL;
	if (buf[100 * 15 + 7] != 0x01) fail_assert(907);
	if (buf[100 * 15 + 14] != 0x08) fail_assert(908);
}

//======================================================================
// Section 10: allocation churn with many buffers and refs
//======================================================================
def churn() {
	var live = Array<Array<byte>>.new(16);
	var refs = Array<Ref<Entry>>.new(16);
	var total = 0L;
	for (i < 800) {
		var n = 1 + (i % 7);
		var buf = Array<byte>.new(Entry.size * n);
		for (j < n) {
			var e = Ref<Entry>.at(buf, j * Entry.size);
			e.key = u32.view(i * 31 + j);
			e.flags = byte.view(j);
			e.score = i16.view(i - j);
			e.total = u64.view(long.!(i) * 65537L + j);
			total += long.view(e.total);
		}
		if ((i % 43) == 0) {
			var s = (i / 43) % live.length;
			live[s] = buf;
			refs[s] = Ref<Entry>.at(buf, 0);
		}
	}
	var h = mixl(0, total);
	for (i < live.length) {
		if (live[i] == null) { h = mix(h, -1); continue; }
		h = mixbuf(h, live[i]);
		h = mix(h, int.view(refs[i].key));
		h = mixl(h, long.view(refs[i].total));
	}
	acci(h);

	// writes through the retained refs still reach their buffers
	for (i < live.length) if (live[i] != null) refs[i].flags = byte.view(0xF0 + i);
	var g = 0;
	for (i < live.length) if (live[i] != null) g = mix(g, live[i][4]);
	acci(g);

	if (live.length != 16) fail_assert(1001);
	if (live[0] == null) fail_assert(1002);
	if (live[0][4] != 0xF0) fail_assert(1003);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) widths();
	if (a == 0 || a == 2) endian();
	if (a == 0 || a == 3) narrow();
	if (a == 0 || a == 4) writes();
	if (a == 0 || a == 5) nestedLayouts();
	if (a == 0 || a == 6) metadata();
	if (a == 0 || a == 7) bitPacking();
	if (a == 0 || a == 8) enumsAndFloats();
	if (a == 0 || a == 9) roundTrip();
	if (a == 0 || a == 10) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
