//@execute 0=-57374321; 1=1793586289; 2=1186609564; 3=-505117654; 4=1941818645; 5=-954597712; 6=-42721769; 7=456824556; 8=1848101268
//@heap-size=200000
// Smoke test: 32-bit signed integer edge cases.
// Where int01.v3 covers the bulk of the operator set, this file pins down the
// facts at the boundaries: two's-complement wraparound on +, -, *; the
// int.min/int.max identities; the exact truncation direction of / and %; the
// int.min / -1 special case (which wraps rather than trapping); promotion of the
// narrow integer types; and the int.view / int.! / int.? conversion family.
// Assertions carry most of the weight here -- their operands are compile-time
// constants that the optimizer is expected to fold away, so a folding bug shows
// up as a set failure flag. The CRC keeps the non-constant versions of the same
// computations live. Input selects the section; input 0 runs every section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data. Values clustered around the representable boundaries.
//======================================================================
def EDGE: Array<int> = [
	-2147483648, -2147483647, -2147483646, -1073741824, -65537, -65536, -65535,
	-256, -255, -2, -1, 0, 1, 2, 255, 256, 65535, 65536, 65537,
	1073741823, 1073741824, 2147483645, 2147483646, 2147483647
];
// Divisors: never zero. -1 and int.min are present on purpose.
def DIV: Array<int> = [
	1, -1, 2, -2, 3, -3, 5, 7, -7, 256, -256, 65536,
	1073741824, 2147483647, -2147483648
];
def SMALL: Array<int> = [-129, -128, -127, -1, 0, 1, 126, 127, 128, 254, 255, 256, 32767, 32768, 65535, 65536];
def LONGS: Array<long> = [
	0, 1, -1, 2147483647, 2147483648, -2147483648, -2147483649,
	4294967295, 4294967296, 0x1234567890ABCDEFL,
	9223372036854775807L, -9223372036854775808L
];

//======================================================================
// Section 1: wraparound on addition and subtraction
//======================================================================
def overflowAdd() {
	for (i < EDGE.length) {
		var a = EDGE[i];
		var h = mix(0, -a);
		for (j < EDGE.length) {
			var b = EDGE[j];
			h = mix(h, a + b);
			h = mix(h, a - b);
			h = mix(h, b - a);
			// the wrapped result agrees with the exact 64-bit result truncated
			h = mixb(h, a + b == int.view(long.!(a) + long.!(b)));
			h = mixb(h, a - b == int.view(long.!(a) - long.!(b)));
		}
		acci(h);
	}
	// wraparound is modulo 2^32, two's complement
	if (2147483647 + 1 != -2147483648) fail_assert(101);
	if (2147483647 + 2 != -2147483647) fail_assert(102);
	if (-2147483648 - 1 != 2147483647) fail_assert(103);
	if (-2147483648 - 2 != 2147483646) fail_assert(104);
	if (2147483647 + 2147483647 != -2) fail_assert(105);
	if (-2147483648 + -2147483648 != 0) fail_assert(106);
	if (2147483647 - -2147483648 != -1) fail_assert(107);
	if (-2147483648 - 2147483647 != 1) fail_assert(108);
	// negation of int.min is int.min: there is no positive counterpart
	if (0 - -2147483648 != -2147483648) fail_assert(109);
	if (-(-2147483648) != -2147483648) fail_assert(110);
	// wrapping is associative and commutative even when it overflows
	if ((2147483647 + 1) + 1 != -2147483647) fail_assert(111);
	if (2147483647 + (1 + 1) != -2147483647) fail_assert(112);
	if (1 + 2147483647 != 2147483647 + 1) fail_assert(113);
	// adding then subtracting the same value round-trips through the wrap
	if ((2147483647 + 100) - 100 != 2147483647) fail_assert(114);
	if ((-2147483648 - 100) + 100 != -2147483648) fail_assert(115);
	// x + ~x == -1 for every x, including the boundaries
	if (2147483647 + ~2147483647 != -1) fail_assert(116);
	if (-2147483648 + ~(-2147483648) != -1) fail_assert(117);
}

//======================================================================
// Section 2: wraparound on multiplication
//======================================================================
def overflowMul() {
	for (i < EDGE.length) {
		var a = EDGE[i];
		var h = 0;
		for (j < EDGE.length) {
			var b = EDGE[j];
			var p = a * b;
			h = mix(h, p);
			h = mixb(h, p == b * a);
			// the wrapped product is the low 32 bits of the exact product
			h = mixb(h, p == int.view(long.!(a) * long.!(b)));
			h = mixl(h, long.!(a) * long.!(b));
		}
		acci(h);
	}
	if (65536 * 65536 != 0) fail_assert(201);
	if (65537 * 65537 != 131073) fail_assert(202);
	if (1000000 * 1000000 != -727379968) fail_assert(203);
	if (2147483647 * 2 != -2) fail_assert(204);
	if (2147483647 * 3 != 2147483645) fail_assert(205);
	if (2147483647 * 2147483647 != 1) fail_assert(206);
	if (-2147483648 * -2147483648 != 0) fail_assert(207);
	if (-2147483648 * 2 != 0) fail_assert(208);
	// int.min has no negation, so multiplying it by -1 leaves it alone
	if (-2147483648 * -1 != -2147483648) fail_assert(209);
	if (2147483647 * -1 != -2147483647) fail_assert(210);
	// multiplication by a power of two equals the corresponding left shift
	if (0x12345678 * 16 != 0x12345678 << 4) fail_assert(211);
	if (-1 * 256 != -1 << 8) fail_assert(212);
	if (2147483647 * 4 != 2147483647 << 2) fail_assert(213);
	// distributivity survives wraparound
	if (2147483647 * (2 + 3) != 2147483647 * 2 + 2147483647 * 3) fail_assert(214);
	if (0 * -2147483648 != 0) fail_assert(215);
	if (1 * -2147483648 != -2147483648) fail_assert(216);
}

//======================================================================
// Section 3: int.min / int.max boundary identities
//======================================================================
def boundaries() {
	var h = 0;
	for (i < EDGE.length) {
		var a = EDGE[i];
		h = mixb(h, a >= int.min);
		h = mixb(h, a <= int.max);
		h = mixb(h, a == int.min);
		h = mixb(h, a == int.max);
		h = mix(h, a - int.min);
		h = mix(h, int.max - a);
		h = mix(h, a ^ int.min);
		h = mix(h, int.view(u32.view(a)));
	}
	acci(h);

	if (int.min != -2147483648) fail_assert(301);
	if (int.max != 2147483647) fail_assert(302);
	if (int.min + int.max != -1) fail_assert(303);
	if (int.max - int.min != -1) fail_assert(304);		// wraps
	if (~int.min != int.max) fail_assert(305);
	if (~int.max != int.min) fail_assert(306);
	if (int.min != 1 << 31) fail_assert(307);
	if (int.max != ~(1 << 31)) fail_assert(308);
	if (int.max + 1 != int.min) fail_assert(309);
	if (int.min - 1 != int.max) fail_assert(310);
	if ((int.min & int.max) != 0) fail_assert(311);
	if ((int.min | int.max) != -1) fail_assert(312);
	if ((int.min ^ int.max) != -1) fail_assert(313);
	if (!(int.min < int.max)) fail_assert(314);
	if (int.min >>> 31 != 1) fail_assert(315);
	if (int.max >>> 31 != 0) fail_assert(316);
	if (int.min >> 31 != -1) fail_assert(317);
	// unsigned view: int.min is the LARGEST u32 of the two
	if (!(u32.view(int.min) > u32.view(int.max))) fail_assert(318);
	if (u32.view(int.min) != 2147483648u) fail_assert(319);
	if (u32.view(int.max) != 2147483647u) fail_assert(320);
	if (u32.view(-1) != u32.max) fail_assert(321);
	if (int.view(u32.max) != -1) fail_assert(322);
}

//======================================================================
// Section 4: division and modulo, including negative operands
//======================================================================
def divmod() {
	for (i < EDGE.length) {
		var a = EDGE[i];
		var h = 0;
		for (j < DIV.length) {
			var b = DIV[j];
			var q = a / b, r = a % b;
			h = mix(h, q);
			h = mix(h, r);
			// the division identity holds under wraparound
			h = mixb(h, q * b + r == a);
			// the remainder takes the sign of the dividend (or is zero)
			h = mixb(h, r == 0 || (r < 0) == (a < 0));
		}
		acci(h);
	}
	// truncation toward zero, in all four sign combinations
	if (17 / 5 != 3) fail_assert(401);
	if (-17 / 5 != -3) fail_assert(402);
	if (17 / -5 != -3) fail_assert(403);
	if (-17 / -5 != 3) fail_assert(404);
	if (17 % 5 != 2) fail_assert(405);
	if (-17 % 5 != -2) fail_assert(406);
	if (17 % -5 != 2) fail_assert(407);
	if (-17 % -5 != -2) fail_assert(408);
	// quotients that would round the other way under floor division
	if (-1 / 2 != 0) fail_assert(409);
	if (-1 % 2 != -1) fail_assert(410);
	if (1 / -2 != 0) fail_assert(411);
	if (1 % -2 != 1) fail_assert(412);
	if (-3 / 4 != 0) fail_assert(413);
	if (-4 / 4 != -1) fail_assert(414);
	if (-5 / 4 != -1) fail_assert(415);
	// an arithmetic right shift floors, so it disagrees with / for negatives
	if (-1 >> 1 != -1) fail_assert(416);
	if (-3 >> 2 != -1) fail_assert(417);
	if (-3 / 4 != 0) fail_assert(418);
	// division by a self and by one
	if (2147483647 / 2147483647 != 1) fail_assert(419);
	if (-2147483648 / -2147483648 != 1) fail_assert(420);
	if (-2147483648 % -2147483648 != 0) fail_assert(421);
	if (-2147483648 / 2147483647 != -1) fail_assert(422);
	if (-2147483648 % 2147483647 != -1) fail_assert(423);
	if (2147483647 / -2147483648 != 0) fail_assert(424);
	if (2147483647 % -2147483648 != 2147483647) fail_assert(425);
	// boundary quotients
	if (-2147483648 / 2 != -1073741824) fail_assert(426);
	if (-2147483648 / -2 != 1073741824) fail_assert(427);
	if (-2147483648 / 3 != -715827882) fail_assert(428);
	if (-2147483648 % 3 != -2) fail_assert(429);
	if (2147483647 / 2 != 1073741823) fail_assert(430);
	if (2147483647 % 2 != 1) fail_assert(431);
}

//======================================================================
// Section 5: int.min / -1, the one signed division that overflows
//======================================================================
var minv: int;
var negone: int;
def divOverflow() {
	// Reset the globals this section writes.
	minv = 0;
	negone = 0;
	// Drive the values through globals and an array so the operands are not
	// compile-time constants: this is the runtime path, not the folded one.
	minv = EDGE[0];			// int.min
	negone = DIV[1];		// -1
	var q = minv / negone;		// must WRAP to int.min, not trap
	var r = minv % negone;		// must be 0, not trap
	acci(mix(mix(0, q), r));
	if (q != -2147483648) fail_assert(501);
	if (r != 0) fail_assert(502);

	var qs = Array<int>.new(EDGE.length);
	var rs = Array<int>.new(EDGE.length);
	for (i < EDGE.length) {
		qs[i] = EDGE[i] / negone;
		rs[i] = EDGE[i] % negone;
	}
	var h = 0;
	for (i < EDGE.length) {
		h = mix(h, qs[i]);
		h = mix(h, rs[i]);
		// x / -1 == -x for every x, including int.min (where -x is x)
		h = mixb(h, qs[i] == 0 - EDGE[i]);
		h = mixb(h, rs[i] == 0);
	}
	acci(h);

	// the constant-folded forms must agree with the runtime ones
	if (-2147483648 / -1 != -2147483648) fail_assert(503);
	if (-2147483648 % -1 != 0) fail_assert(504);
	if (2147483647 / -1 != -2147483647) fail_assert(505);
	if (2147483647 % -1 != 0) fail_assert(506);
	if (0 / -1 != 0) fail_assert(507);
	if (1 / -1 != -1) fail_assert(508);
	if (-1 / -1 != 1) fail_assert(509);
	if (-1 % -1 != 0) fail_assert(510);
	// the same overflow through the multiplication side
	if (-2147483648 / -1 * -1 != -2147483648) fail_assert(511);
}

//======================================================================
// Section 6: narrow integer types and promotion
//======================================================================
def promote() {
	var bs = Array<byte>.new(SMALL.length);
	var s8 = Array<i8>.new(SMALL.length);
	var s16 = Array<i16>.new(SMALL.length);
	var u16s = Array<u16>.new(SMALL.length);
	for (i < SMALL.length) {
		bs[i] = byte.view(SMALL[i]);
		s8[i] = i8.view(byte.view(SMALL[i]));
		s16[i] = i16.view(u16.view(SMALL[i]));
		u16s[i] = u16.view(SMALL[i]);
	}
	var h = 0;
	for (i < SMALL.length) {
		h = mix(h, bs[i]);		// each widens to int on read
		h = mix(h, s8[i]);
		h = mix(h, s16[i]);
		h = mix(h, u16s[i]);
		h = mix(h, bs[i] + 1);		// arithmetic happens at int width
		h = mix(h, s8[i] * 2);
		h = mix(h, s16[i] - 1);
		h = mixb(h, byte.?(SMALL[i]));
		h = mixb(h, i8.?(SMALL[i]));
		h = mixb(h, u16.?(SMALL[i]));
	}
	acci(h);

	// truncating views drop the high bits
	if (byte.view(256) != 0) fail_assert(601);
	if (byte.view(255) != 255) fail_assert(602);
	if (byte.view(-1) != 255) fail_assert(603);
	if (byte.view(-256) != 0) fail_assert(604);
	if (byte.view(0x1234) != 0x34) fail_assert(605);
	if (u16.view(0x12345678) != 0x5678) fail_assert(606);
	if (i16.view(0xABCD) != -21555) fail_assert(607);
	if (u16.view(0xABCD) != 43981) fail_assert(608);
	if (i8.view(byte.view(200)) != -56) fail_assert(609);
	// byte is unsigned, i8 is signed; both widen to int
	if (byte.max != 255) fail_assert(610);
	if (i8.min != -128) fail_assert(611);
	if (i8.max != 127) fail_assert(612);
	if (u16.max != 65535) fail_assert(613);
	if (i16.min != -32768) fail_assert(614);
	// promotion happens before the arithmetic, so no wraparound at byte width
	var b: byte = 255;
	if (b + 1 != 256) fail_assert(615);
	if (b * 2 != 510) fail_assert(616);
	var n: i8 = -128;
	if (n - 1 != -129) fail_assert(617);
	if (0 - n != 128) fail_assert(618);
	// but an explicit narrowing view does wrap
	if (byte.view(b + 1) != 0) fail_assert(619);
	if (i8.view(byte.view(n - 1)) != 127) fail_assert(620);
	// range queries
	if (!byte.?(255)) fail_assert(621);
	if (byte.?(256)) fail_assert(622);
	if (byte.?(-1)) fail_assert(623);
	if (!i8.?(127)) fail_assert(624);
	if (i8.?(128)) fail_assert(625);
	if (!i8.?(-128)) fail_assert(626);
	if (i8.?(-129)) fail_assert(627);
	// exact casts that must succeed
	if (byte.!(255) != 255) fail_assert(628);
	if (i8.!(-128) != -128) fail_assert(629);
	if (u16.!(65535) != 65535) fail_assert(630);
}

//======================================================================
// Section 7: int.view / int.! / int.? conversions
//======================================================================
def convert() {
	var h = 0;
	for (i < LONGS.length) {
		var l = LONGS[i];
		h = mix(h, int.view(l));		// always defined: low 32 bits
		h = mixb(h, int.?(l));
		h = mixl(h, l);
		// int.! is only safe when the query says so
		if (int.?(l)) h = mix(h, int.!(l));
	}
	acci(h);
	var g = 0;
	for (i < EDGE.length) {
		var a = EDGE[i];
		g = mixl(g, long.!(a));			// sign-extends
		g = mixl(g, long.view(a));		// also sign-extends: int is signed
		g = mixl(g, long.view(u32.view(a)));	// zero-extends: u32 is unsigned
		g = mix(g, int.view(u32.view(a)));	// round trip
		g = mixb(g, int.view(u32.view(a)) == a);
	}
	acci(g);

	// int.view of a long keeps the low 32 bits
	if (int.view(0x100000001L) != 1) fail_assert(701);
	if (int.view(-1L) != -1) fail_assert(702);
	if (int.view(4294967296L) != 0) fail_assert(703);
	if (int.view(4294967295L) != -1) fail_assert(704);
	if (int.view(2147483648L) != -2147483648) fail_assert(705);
	if (int.view(0x1234567890ABCDEFL) != -1867788817) fail_assert(706);
	// int.view of a u32 reinterprets the top bit as a sign
	if (int.view(3000000000u) != -1294967296) fail_assert(707);
	if (int.view(2147483648u) != -2147483648) fail_assert(708);
	if (int.view(4294967295u) != -1) fail_assert(709);
	// int.? is exact-representability, not truncation
	if (!int.?(2147483647L)) fail_assert(710);
	if (int.?(2147483648L)) fail_assert(711);
	if (!int.?(-2147483648L)) fail_assert(712);
	if (int.?(-2147483649L)) fail_assert(713);
	if (int.?(4294967295u)) fail_assert(714);
	if (!int.?(2147483647u)) fail_assert(715);
	if (!int.?(0L)) fail_assert(716);
	// int.! on values the query accepts
	if (int.!(2147483647L) != 2147483647) fail_assert(717);
	if (int.!(-2147483648L) != -2147483648) fail_assert(718);
	if (int.!(2147483647u) != 2147483647) fail_assert(719);
	// widening: int -> long sign-extends, u32 -> long zero-extends
	if (long.!(-1) != -1L) fail_assert(720);
	if (long.view(-1) != -1L) fail_assert(721);
	if (long.view(u32.view(-1)) != 4294967295L) fail_assert(722);
	if (long.!(u32.view(-1)) != 4294967295L) fail_assert(723);
	if (long.view(int.min) != -2147483648L) fail_assert(724);
	if (long.view(u32.view(int.min)) != 2147483648L) fail_assert(725);
	// round trip through u32 is the identity on int
	if (int.view(u32.view(int.min)) != int.min) fail_assert(726);
	if (int.view(u32.view(-12345)) != -12345) fail_assert(727);
	// a long round trip is only the identity when the value fits
	if (int.view(long.view(int.min)) != int.min) fail_assert(728);
	if (int.view(long.view(int.min) - 1L) != int.max) fail_assert(729);
}

//======================================================================
// Section 8: edge values routed through the storage forms
//======================================================================
var ge: int;
var gp: (int, int);
var garr: Array<int>;

component Edges {
	var lo: int = int.min;
	var hi: int = int.max;
	var acc: int;
	var n: int;
	def step(x: int) -> int {
		acc = acc * 1103515245 + x;	// deliberately overflows every step
		if (x < lo) lo = x;
		if (x > hi) hi = x;
		n++;
		return acc;
	}
}
class ECell {
	var v: int;
	def tag: int;
	new(v, tag) { }
	def wrapped() -> int { return v * v + v; }
}
class EPair extends ECell {
	var other: ECell;
	new(v: int, tag: int, other) super(v, tag) { }
	def wrapped() -> int { return if(other == null, v, v * other.v); }
}
type EVal {
	case Plain(v: int);
	case Span(lo: int, hi: int);
	case None;
}
def spanOf(e: EVal) -> int {
	match (e) {
		Plain(v) => return v;
		Span(lo, hi) => return hi - lo;		// wraps for the full range
		None => return 0;
	}
}
def route() {
	// Reset all mutable global state.
	ge = 0;
	gp = (0, 0);
	Edges.lo = int.max;
	Edges.hi = int.min;
	Edges.acc = 0;
	Edges.n = 0;

	garr = Array<int>.new(EDGE.length);
	var h = 0;
	for (i < EDGE.length) {
		ge = EDGE[i];
		gp = (ge, ge + 1);		// wraps at int.max
		garr[i] = ge - 1;		// wraps at int.min
		h = mix(h, ge);
		h = mix(h, gp.0);
		h = mix(h, gp.1);
		h = mix(h, garr[i]);
	}
	acci(h);
	if (garr[0] != int.max) fail_assert(801);		// int.min - 1 wrapped
	if (gp.1 != int.min) fail_assert(802);			// int.max + 1 wrapped

	var g = 0;
	for (i < EDGE.length) g = mix(g, Edges.step(EDGE[i]));
	g = mix(g, Edges.lo);
	g = mix(g, Edges.hi);
	g = mix(g, Edges.n);
	acci(g);
	if (Edges.lo != int.min) fail_assert(803);
	if (Edges.hi != int.max) fail_assert(804);
	if (Edges.n != EDGE.length) fail_assert(805);

	var cells = Array<ECell>.new(2 * EDGE.length);
	for (i < EDGE.length) {
		cells[2 * i + 0] = ECell.new(EDGE[i], i);
		cells[2 * i + 1] = EPair.new(EDGE[i], i, cells[2 * i + 0]);
	}
	var k = 0;
	for (i < cells.length) {
		k = mix(k, cells[i].v);
		k = mix(k, cells[i].wrapped());
		k = mix(k, cells[i].tag);
		k = mixb(k, EPair.?(cells[i]));
	}
	acci(k);
	if (ECell.new(65536, 0).wrapped() != 65536) fail_assert(806);	// 65536^2 wraps to 0
	if (ECell.new(int.min, 0).wrapped() != int.min) fail_assert(807);
	if (EPair.new(3, 0, null).wrapped() != 3) fail_assert(808);
	if (EPair.new(65536, 0, ECell.new(65536, 0)).wrapped() != 0) fail_assert(809);

	var vs = Array<EVal>.new(EDGE.length + 1);
	for (i < EDGE.length) {
		vs[i] = if(i % 2 == 0, EVal.Plain(EDGE[i]), EVal.Span(EDGE[i], EDGE[EDGE.length - 1 - i]));
	}
	vs[EDGE.length] = EVal.None;
	var m = 0;
	for (i < vs.length) {
		m = mix(m, spanOf(vs[i]));
		m = mix(m, vs[i].tag);
	}
	acci(m);
	if (spanOf(EVal.Span(int.min, int.max)) != -1) fail_assert(810);	// wraps
	if (spanOf(EVal.Plain(int.min)) != int.min) fail_assert(811);
	if (spanOf(EVal.None) != 0) fail_assert(812);
	if (EVal.None.tag != 2) fail_assert(813);

	// tuples of boundary values compare componentwise
	var t1 = (int.min, int.max);
	var t2 = (int.min, int.max);
	var t3 = (int.max, int.min);
	if (!(t1 == t2)) fail_assert(814);
	if (t1 == t3) fail_assert(815);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) overflowAdd();
	if (a == 0 || a == 2) overflowMul();
	if (a == 0 || a == 3) boundaries();
	if (a == 0 || a == 4) divmod();
	if (a == 0 || a == 5) divOverflow();
	if (a == 0 || a == 6) promote();
	if (a == 0 || a == 7) convert();
	if (a == 0 || a == 8) route();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
