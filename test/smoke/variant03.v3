//@execute 0=-389881014; 1=-1899284816; 2=-1008371463; 3=-537100638; 4=150162960; 5=-1584399249
//@heap-size=4000000
// Smoke test: recursive algebraic data types under allocation pressure.
// Builds, traverses, rewrites and compares trees, association lists and
// expression graphs, mixing boxed and unboxed variants with class references,
// tuples, arrays and ranges. Results are mixed into a running CRC that main()
// returns, so no traversal can be optimized away. Interleaved are assert()s over
// compile-time constants, which the optimizer is expected to fold away; a
// folding bug sets the failure flag instead. Input selects the section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

// Deterministic pseudo-random source; reset by every section that uses it.
var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

//======================================================================
// Types
//======================================================================
type Tree {
	case Leaf;
	case Node(left: Tree, key: int, val: string, right: Tree);
}
type List<T> {
	case Nil;
	case Cons(head: T, tail: List<T>);
}
type Expr {
	case Lit(v: long);
	case Neg(e: Expr);
	case Add(l: Expr, r: Expr);
	case Mul(l: Expr, r: Expr);
	case Div(l: Expr, r: Expr);
	case Var(idx: int);
}
type Small #unboxed {
	case A(x: int);
	case B(x: int, y: byte);
	case C;
}
class Cell(id: int) {
	var next: Cell;
	var payload: Tree;
}
type Holder {
	case Ref(c: Cell);
	case Val(s: Small);
	case Empty;
}

def NAMES: Array<string> = [
	"alpha", "beta", "gamma", "delta", "epsilon", "zeta", "eta", "theta"
];

//======================================================================
// Section 1: binary search tree insert / lookup / delete-by-rebuild
//======================================================================
def insert(t: Tree, k: int, v: string) -> Tree {
	match (t) {
		Leaf => return Tree.Node(Tree.Leaf, k, v, Tree.Leaf);
		Node(l, key, val, r) => {
			if (k < key) return Tree.Node(insert(l, k, v), key, val, r);
			if (k > key) return Tree.Node(l, key, val, insert(r, k, v));
			return Tree.Node(l, key, v, r);		// replace value
		}
	}
}
def lookup(t: Tree, k: int) -> string {
	match (t) {
		Leaf => return null;
		Node(l, key, val, r) => {
			if (k < key) return lookup(l, k);
			if (k > key) return lookup(r, k);
			return val;
		}
	}
}
def size(t: Tree) -> int {
	match (t) {
		Leaf => return 0;
		Node(l, _, _, r) => return 1 + size(l) + size(r);
	}
}
def depth(t: Tree) -> int {
	match (t) {
		Leaf => return 0;
		Node(l, _, _, r) => {
			var a = depth(l), b = depth(r);
			return 1 + if(a > b, a, b);
		}
	}
}
def inorder(h: int, t: Tree) -> int {
	match (t) {
		Leaf => return mix(h, 0x1EAF);
		Node(l, key, val, r) => {
			var g = inorder(h, l);
			g = mix(g, key);
			g = mixs(g, val);
			return inorder(g, r);
		}
	}
}
// Rebuild the tree without any key for which drop() holds.
def filter(t: Tree, m: int) -> Tree {
	match (t) {
		Leaf => return Tree.Leaf;
		Node(l, key, val, r) => {
			var nl = filter(l, m), nr = filter(r, m);
			if ((key % m) == 0) {
				// splice: hang the right subtree's keys onto the left
				var merged = nl;
				merged = graft(merged, nr);
				return merged;
			}
			return Tree.Node(nl, key, val, nr);
		}
	}
}
def graft(dst: Tree, src: Tree) -> Tree {
	match (src) {
		Leaf => return dst;
		Node(l, key, val, r) => return graft(graft(insert(dst, key, val), l), r);
	}
}
def trees() {
	srand(0x5EED01);
	var t: Tree = Tree.Leaf;
	for (i < 400) {
		var k = randn(1000);
		t = insert(t, k, NAMES[k % NAMES.length]);
	}
	var h = mix(0, size(t));
	h = mix(h, depth(t));
	h = inorder(h, t);
	for (i < 200) h = mixs(h, lookup(t, randn(1000)));
	acci(h);

	var f = filter(t, 7);
	var g = mix(0, size(f));
	g = mix(g, depth(f));
	g = inorder(g, f);
	g = mixb(g, t == f);
	g = mixb(g, t == t);
	g = mixb(g, Tree.Leaf == Tree.Leaf);
	g = mixb(g, Tree.Node.?(t));
	g = mix(g, t.tag);
	g = mix(g, Tree.Leaf.tag);
	acci(g);

	// rebuilding from the same key sequence must produce an equal tree
	srand(0x5EED01);
	var t2: Tree = Tree.Leaf;
	for (i < 400) {
		var k = randn(1000);
		t2 = insert(t2, k, NAMES[k % NAMES.length]);
	}
	acci(mixb(mixb(0, t == t2), f == t2));

	// small trees with hand-checkable shape
	var s0: Tree = Tree.Leaf;
	if (size(s0) != 0) fail_assert(101);
	if (depth(s0) != 0) fail_assert(102);
	if (lookup(s0, 1) != null) fail_assert(103);
	var s1 = insert(s0, 5, "five");
	if (size(s1) != 1) fail_assert(104);
	if (depth(s1) != 1) fail_assert(105);
	var s2 = insert(insert(s1, 3, "three"), 7, "seven");
	if (size(s2) != 3) fail_assert(106);
	if (depth(s2) != 2) fail_assert(107);
	if (size(insert(s2, 5, "other")) != 3) fail_assert(108);	// replaces
	if (depth(insert(insert(insert(s0, 1, "a"), 2, "b"), 3, "c")) != 3) fail_assert(109);
	if (!(s0 == Tree.Leaf)) fail_assert(110);
	if (Tree.Leaf.tag != 0) fail_assert(111);
	if (s1.tag != 1) fail_assert(112);
	if (!Tree.Node.?(s1)) fail_assert(113);
	if (Tree.Node.?(s0)) fail_assert(114);
	// Structural equality: independently built trees compare equal, but the
	// string payload is compared by reference (strings are arrays), so the two
	// builds must share the same string objects, not just equal contents.
	var ka = NAMES[0], kb = NAMES[1];
	var a1 = insert(insert(Tree.Leaf, 1, ka), 2, kb);
	var a2 = insert(insert(Tree.Leaf, 1, ka), 2, kb);
	if (!(a1 == a2)) fail_assert(115);
	if (a1 == insert(insert(Tree.Leaf, 2, kb), 1, ka)) fail_assert(116);	// shape differs
	// distinct-but-equal string objects make otherwise identical trees unequal
	var s1a = Array<byte>.new(1), s1b = Array<byte>.new(1);
	s1a[0] = 'z';
	s1b[0] = 'z';
	if (insert(Tree.Leaf, 1, s1a) == insert(Tree.Leaf, 1, s1b)) fail_assert(117);
}

//======================================================================
// Section 2: polymorphic lists
//======================================================================
def len<T>(l: List<T>) -> int {
	var n = 0, p = l;
	while (true) {
		match (p) {
			Nil => return n;
			Cons(_, tail) => { n++; p = tail; }
		}
	}
	return n;
}
def rev<T>(l: List<T>) -> List<T> {
	var acc: List<T> = List<T>.Nil, p = l;
	while (true) {
		match (p) {
			Nil => return acc;
			Cons(head, tail) => { acc = List<T>.Cons(head, acc); p = tail; }
		}
	}
	return acc;
}
def mapl<A, B>(f: A -> B, l: List<A>) -> List<B> {
	match (l) {
		Nil => return List<B>.Nil;
		Cons(head, tail) => return List<B>.Cons(f(head), mapl(f, tail));
	}
}
def sumIntList(l: List<int>) -> int {
	match (l) {
		Nil => return 0;
		Cons(head, tail) => return head + sumIntList(tail);
	}
}
def dbl(x: int) -> int { return x * 2; }
def tostr(x: int) -> string { return NAMES[(x & 0x7FFFFFFF) % NAMES.length]; }
def lists() {
	srand(0x5EED02);
	var li: List<int> = List<int>.Nil;
	for (i < 300) li = List<int>.Cons(randn(10000) - 5000, li);
	var r = rev(li);
	var h = mix(0, len(li));
	h = mix(h, sumIntList(li));
	h = mix(h, len(r));
	h = mix(h, sumIntList(r));
	h = mixb(h, li == r);
	h = mixb(h, rev(r) == li);
	acci(h);

	var d = mapl(dbl, li);
	var hh = mix(0, sumIntList(d));
	var s = mapl(tostr, li);
	hh = mix(hh, len(s));
	var p = s;
	while (true) {
		match (p) {
			Nil => break;
			Cons(head, tail) => { hh = mixs(hh, head); p = tail; }
		}
	}
	acci(hh);
	// lists of tuples and of lists
	var lt: List<(int, string)> = List<(int, string)>.Nil;
	for (i < 100) lt = List<(int, string)>.Cons((i, NAMES[i % NAMES.length]), lt);
	var k = mix(0, len(lt));
	var pp = lt;
	while (true) {
		match (pp) {
			Nil => break;
			Cons(head, tail) => { k = mix(k, head.0); k = mixs(k, head.1); pp = tail; }
		}
	}
	acci(k);
	var ll: List<List<int>> = List<List<int>>.Nil;
	for (i < 20) {
		var inner: List<int> = List<int>.Nil;
		for (j < i) inner = List<int>.Cons(i * j, inner);
		ll = List<List<int>>.Cons(inner, ll);
	}
	var m = mix(0, len(ll));
	var q = ll;
	while (true) {
		match (q) {
			Nil => break;
			Cons(head, tail) => { m = mix(m, len(head)); m = mix(m, sumIntList(head)); q = tail; }
		}
	}
	acci(m);

	var e: List<int> = List<int>.Nil;
	var one = List<int>.Cons(7, e);
	var two = List<int>.Cons(8, one);
	if (len(e) != 0) fail_assert(201);
	if (len(one) != 1) fail_assert(202);
	if (len(two) != 2) fail_assert(203);
	if (sumIntList(two) != 15) fail_assert(204);
	if (len(rev(two)) != 2) fail_assert(205);
	if (sumIntList(rev(two)) != 15) fail_assert(206);
	if (!(rev(rev(two)) == two)) fail_assert(207);
	if (rev(two) == two) fail_assert(208);
	if (sumIntList(mapl(dbl, two)) != 30) fail_assert(209);
	if (len(mapl(tostr, two)) != 2) fail_assert(210);
	if (!(e == List<int>.Nil)) fail_assert(211);
	if (one == two) fail_assert(212);
	if (!(one == List<int>.Cons(7, e))) fail_assert(213);
}

//======================================================================
// Section 3: expression trees -- build, evaluate, rewrite
//======================================================================
def VARS: Array<long> = [3, -7, 11, 0, 1000000007, -2, 5, 1];

def build(d: int) -> Expr {
	if (d <= 0) {
		if ((rand() & 1) == 0) return Expr.Lit(randn(100) - 50);
		return Expr.Var(randn(VARS.length));
	}
	match (randn(5)) {
		0 => return Expr.Neg(build(d - 1));
		1 => return Expr.Add(build(d - 1), build(d - 1));
		2 => return Expr.Mul(build(d - 1), build(d - 1));
		3 => return Expr.Div(build(d - 1), build(d - 1));
		_ => return Expr.Add(build(d - 1), Expr.Lit(randn(10)));
	}
}
def eval(e: Expr) -> long {
	match (e) {
		Lit(v) => return v;
		Neg(x) => return 0 - eval(x);
		Add(l, r) => return eval(l) + eval(r);
		Mul(l, r) => return eval(l) * eval(r);
		Div(l, r) => {
			var d = eval(r);
			if (d == 0) return 0;			// avoid DivideByZeroException
			if (d == -1) return 0 - eval(l);	// avoid long.min / -1 overflow
			return eval(l) / d;
		}
		Var(i) => return VARS[i];
	}
}
// Constant-fold the expression; eval() of the result must be unchanged.
def fold(e: Expr) -> Expr {
	match (e) {
		Lit(_) => return e;
		Var(_) => return e;
		Neg(x) => {
			var f = fold(x);
			if (Expr.Lit.?(f)) return Expr.Lit(0 - Expr.Lit.!(f).v);
			return Expr.Neg(f);
		}
		Add(l, r) => {
			var a = fold(l), b = fold(r);
			if (Expr.Lit.?(a) && Expr.Lit.?(b)) return Expr.Lit(Expr.Lit.!(a).v + Expr.Lit.!(b).v);
			return Expr.Add(a, b);
		}
		Mul(l, r) => {
			var a = fold(l), b = fold(r);
			if (Expr.Lit.?(a) && Expr.Lit.?(b)) return Expr.Lit(Expr.Lit.!(a).v * Expr.Lit.!(b).v);
			return Expr.Mul(a, b);
		}
		Div(l, r) => {
			var a = fold(l), b = fold(r);
			if (Expr.Lit.?(a) && Expr.Lit.?(b)) {
				var d = Expr.Lit.!(b).v;
				if (d != 0 && d != -1) return Expr.Lit(Expr.Lit.!(a).v / d);
			}
			return Expr.Div(a, b);
		}
	}
}
def nodes(e: Expr) -> int {
	match (e) {
		Lit(_) => return 1;
		Var(_) => return 1;
		Neg(x) => return 1 + nodes(x);
		Add(l, r) => return 1 + nodes(l) + nodes(r);
		Mul(l, r) => return 1 + nodes(l) + nodes(r);
		Div(l, r) => return 1 + nodes(l) + nodes(r);
	}
}
def exprs() {
	srand(0x5EED03);
	var h = 0;
	for (i < 60) {
		var e = build(6);
		var f = fold(e);
		h = mixl(h, eval(e));
		h = mixl(h, eval(f));
		h = mixb(h, eval(e) == eval(f));	// folding must preserve meaning
		h = mix(h, nodes(e));
		h = mix(h, nodes(f));
		h = mixb(h, nodes(f) <= nodes(e));
		h = mix(h, e.tag);
		h = mixb(h, e == f);
		h = mixb(h, e == e);
	}
	acci(h);
	// arrays of expressions, and expressions reachable only through a range
	var arr = Array<Expr>.new(40);
	for (i < arr.length) arr[i] = build(4);
	var rg: Range<Expr> = arr;
	var sub = rg[10 ... 30];
	var g = mix(0, sub.length);
	for (i < sub.length) g = mixl(g, eval(sub[i]));
	for (i < arr.length) g = mixl(g, eval(fold(arr[i])));
	acci(g);

	var two = Expr.Lit(2), three = Expr.Lit(3);
	if (eval(two) != 2) fail_assert(301);
	if (eval(Expr.Neg(two)) != -2) fail_assert(302);
	if (eval(Expr.Add(two, three)) != 5) fail_assert(303);
	if (eval(Expr.Mul(two, three)) != 6) fail_assert(304);
	if (eval(Expr.Div(Expr.Lit(7), two)) != 3) fail_assert(305);
	if (eval(Expr.Div(two, Expr.Lit(0))) != 0) fail_assert(306);	// guarded
	if (eval(Expr.Var(0)) != 3) fail_assert(307);			// VARS[0]
	if (nodes(two) != 1) fail_assert(308);
	if (nodes(Expr.Add(two, three)) != 3) fail_assert(309);
	if (nodes(Expr.Neg(Expr.Add(two, three))) != 4) fail_assert(310);
	// folding collapses a constant subtree but preserves meaning
	var big = Expr.Add(Expr.Mul(two, three), Expr.Var(1));
	if (nodes(big) != 5) fail_assert(311);
	if (nodes(fold(big)) != 3) fail_assert(312);
	if (eval(fold(big)) != eval(big)) fail_assert(313);
	if (!(fold(Expr.Add(two, three)) == Expr.Lit(5))) fail_assert(314);
	if (!(fold(Expr.Neg(two)) == Expr.Lit(-2))) fail_assert(315);
	if (Expr.Lit(2).tag != 0) fail_assert(316);
	var el: Expr = Expr.Lit(2), ev: Expr = Expr.Var(2);
	if (!(el == Expr.Lit(2))) fail_assert(317);
	if (el == Expr.Lit(3)) fail_assert(318);
	if (el == ev) fail_assert(319);					// different cases
}

//======================================================================
// Section 4: unboxed variants mixed with class references
//======================================================================
def sm(s: Small) -> int {
	match (s) {
		A(x) => return x;
		B(x, y) => return x + int.!(y);
		C => return -1;
	}
}
def hv(h: Holder) -> int {
	match (h) {
		Ref(c) => return if(c == null, -2, c.id + size(c.payload));
		Val(s) => return sm(s);
		Empty => return -3;
	}
}
def unboxed() {
	srand(0x5EED04);
	var smalls = Array<Small>.new(64);
	for (i < smalls.length) {
		match (i % 3) {
			0 => smalls[i] = Small.A(randn(1000));
			1 => smalls[i] = Small.B(randn(1000), byte.view(randn(256)));
			_ => smalls[i] = Small.C;
		}
	}
	var h = 0;
	for (i < smalls.length) {
		h = mix(h, sm(smalls[i]));
		h = mix(h, smalls[i].tag);
		h = mixb(h, Small.B.?(smalls[i]));
		h = mixb(h, smalls[i] == smalls[(i + 1) % smalls.length]);
		h = mixb(h, smalls[i] == smalls[i]);
	}
	acci(h);
	// unboxed variants inside a boxed variant, alongside class references
	var cells = Array<Cell>.new(32);
	for (i < cells.length) {
		var c = Cell.new(i);
		var t: Tree = Tree.Leaf;
		for (j < i) t = insert(t, randn(100), NAMES[j % NAMES.length]);
		c.payload = t;
		if (i > 0) c.next = cells[i - 1];
		cells[i] = c;
	}
	var hs = Array<Holder>.new(96);
	for (i < hs.length) {
		match (i % 3) {
			0 => hs[i] = Holder.Ref(cells[i % cells.length]);
			1 => hs[i] = Holder.Val(smalls[i % smalls.length]);
			_ => hs[i] = Holder.Empty;
		}
	}
	var g = 0;
	for (i < hs.length) {
		g = mix(g, hv(hs[i]));
		g = mix(g, hs[i].tag);
		g = mixb(g, Holder.Ref.?(hs[i]));
	}
	g = mix(g, hv(Holder.Ref(null)));
	// walk the class chain hanging off the last cell
	var p = cells[cells.length - 1];
	var n = 0;
	while (p != null) {
		g = mix(g, p.id);
		g = mix(g, size(p.payload));
		p = p.next;
		n++;
	}
	g = mix(g, n);
	acci(g);

	if (sm(Small.A(5)) != 5) fail_assert(401);
	if (sm(Small.B(5, byte.view(3))) != 8) fail_assert(402);
	if (sm(Small.C) != -1) fail_assert(403);
	if (Small.A(1).tag != 0) fail_assert(404);
	if (Small.C.tag != 2) fail_assert(405);
	// cross-case queries and comparisons need the parent type, not a case type
	var sa: Small = Small.A(5), sb: Small = Small.B(1, byte.view(2)), sc: Small = Small.C;
	if (!Small.B.?(sb)) fail_assert(406);
	if (Small.B.?(sa)) fail_assert(407);
	if (!(sa == Small.A(5))) fail_assert(408);
	if (sa == Small.A(6)) fail_assert(409);
	if (sa == sc) fail_assert(410);
	if (hv(Holder.Empty) != -3) fail_assert(411);
	if (hv(Holder.Ref(null)) != -2) fail_assert(412);
	if (hv(Holder.Val(Small.A(9))) != 9) fail_assert(413);
	var c = Cell.new(4);
	c.payload = insert(Tree.Leaf, 1, "a");
	if (hv(Holder.Ref(c)) != 5) fail_assert(414);		// id 4 + size 1
}

//======================================================================
// Section 5: allocation churn -- most trees become garbage immediately
//======================================================================
def churn() {
	srand(0x5EED05);
	var keep = Array<Tree>.new(8);
	for (i < keep.length) keep[i] = Tree.Leaf;
	var live: List<int> = List<int>.Nil;
	var h = 0;
	for (i < 600) {
		// build a tree that is dropped on the floor except every 37th
		var t: Tree = Tree.Leaf;
		for (j < 20) t = insert(t, randn(500), NAMES[j % NAMES.length]);
		if ((i % 37) == 0) {
			keep[(i / 37) % keep.length] = t;
			live = List<int>.Cons(size(t), live);
		}
		if ((i % 11) == 0) h = mix(h, size(t));
	}
	acci(h);
	var g = 0;
	for (i < keep.length) {
		g = mix(g, size(keep[i]));
		g = mix(g, depth(keep[i]));
		g = inorder(g, keep[i]);
	}
	g = mix(g, len(live));
	g = mix(g, sumIntList(live));
	acci(g);
	// long-lived expression graph interleaved with short-lived trees
	var graph = Array<Expr>.new(16);
	for (i < graph.length) graph[i] = build(5);
	var k = 0;
	for (i < 300) {
		var junk: Tree = Tree.Leaf;
		for (j < 8) junk = insert(junk, randn(100), "x");
		if ((i % 50) == 0) k = mix(k, size(junk));
	}
	for (i < graph.length) {
		k = mixl(k, eval(graph[i]));
		k = mix(k, nodes(graph[i]));
	}
	acci(k);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) trees();
	if (a == 0 || a == 2) lists();
	if (a == 0 || a == 3) exprs();
	if (a == 0 || a == 4) unboxed();
	if (a == 0 || a == 5) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
