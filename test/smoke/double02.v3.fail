//@execute 0=279633694; 1=483762830; 2=-1392306030; 3=-1782087263; 4=596908843; 5=2019562570; 6=-118198414; 7=518734303; 8=2025180180; 9=-1052750642; 10=-1450811743
//@heap-size=300000
// Smoke test: conversions between double and every other numeric type.
// Section by section this walks int/long/u32/u64 -> double, double -> the
// integer types, double <-> float, and the exact-representability queries,
// pushing the same values through arrays, tuples, variants and generic methods
// so the conversions get exercised in more than one calling context. Observed
// values are folded into a running CRC that main() returns, so nothing can be
// deleted as dead; interleaved assert()s over compile-time constants encode the
// answers the compiler is supposed to produce.
// Input selects the section; input 0 runs every section in one method body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
// NaN bit patterns are not guaranteed identical across backends, so all NaNs
// mix in one canonical marker; every other value mixes exact bits (which
// distinguishes 0.0 from -0.0).
def mixd(h: int, d: double) -> int {
	if (d != d) return mix(h, 0x4E614E01);
	return mixl(h, long.view(d));
}
def mixf(h: int, f: float) -> int {
	return mix(h, if(f != f, 0x4E614E00, int.view(f)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def INTS: Array<int> = [
	0, 1, -1, 2, -2, 127, -128, 255, 65535, -65536,
	16777216, 16777217, -16777217, 1073741824,
	2147483647, -2147483648, 1000000, -999999
];
def LONGS: Array<long> = [
	0, 1, -1, 1024, -1024, 16777217, 4294967296, -4294967296,
	9007199254740991, 9007199254740992, 9007199254740993, 9007199254740995,
	-9007199254740993, 1234567890123456789,
	9223372036854775807, -9223372036854775808
];
def U32S: Array<u32> = [0, 1, 255, 65535, 16777217, 1073741824u, 2147483648u, 4294967295u];
def U64S: Array<u64> = [
	0, 1, 65535, 16777217, 4294967296uL, 9007199254740993uL,
	9223372036854775808uL, 18446744073709551615uL
];
// Doubles whose truncation fits in an int, so int.truncd never leaves range.
def DINT: Array<double> = [
	0d, -0.0d, 1d, -1d, 0.5d, -0.5d, 3.9d, -3.9d, 0.999d, -0.999d,
	127d, -128d, 65535d, 2147483647d, -2147483648d, 1e9d, -1e9d, 0.1d
];
// Doubles whose truncation fits in a long.
def DLONG: Array<double> = [
	0d, -0.0d, 1d, -1d, 3.9d, -3.9d, 1e9d, -1e9d, 1e15d, -1e15d,
	9007199254740992d, -9007199254740992d, 1e18d, -1e18d
];
// Non-negative doubles below 2^32, so u32.truncd stays in range.
def DU32: Array<double> = [0d, 1d, 0.5d, 3.9d, 127d, 65535d, 2147483647d, 4294967295d, 1e9d];
// Non-negative doubles below 2^64, so u64.truncd stays in range.
def DU64: Array<double> = [0d, 1d, 0.5d, 3.9d, 65535d, 4294967295d, 1e18d, 9007199254740992d];
def FLTS: Array<float> = [
	0f, -0.0f, 1f, -1f, 0.1f, 0.5f, -0.5f, 3.5f, -7.25f,
	16777216f, 16777217f, 1e10f, 1e-10f,
	float.infinity, -float.infinity, float.nan
];
def DFLT: Array<double> = [
	0d, -0.0d, 1d, -1d, 0.1d, 1.25d, -7.25d, 16777216d, 16777217d,
	1e-300d, 1e300d, -1e300d, 1e-45d, 3.4028234663852886e38d,
	double.infinity, -double.infinity, double.nan
];

//======================================================================
// Section 1: signed integers into double
//======================================================================
def fromInt() {
	var h = 0;
	for (i < INTS.length) {
		var v = INTS[i];
		h = mixd(h, double.roundi(v));
		h = mixd(h, double.roundi(v) * 0.5d);
		h = mixd(h, double.roundi(long.!(v)));
		h = mixb(h, double.roundi(v) == double.roundi(long.!(v)));
	}
	acci(h);
	var g = 0;
	for (i < LONGS.length) {
		var v = LONGS[i];
		g = mixd(g, double.roundi(v));
		g = mixb(g, double.?(v));
		g = mixl(g, v);
	}
	acci(g);
	// a running conversion chain: int -> double -> arithmetic -> back
	var k = 0;
	var acc = 0d;
	for (i < 500) {
		acc += double.roundi(i * i - 250) / 3d;
		if ((i % 50) == 0) k = mixd(k, acc);
	}
	acci(k);

	// every int converts exactly (32 bits fit in a 53-bit mantissa)
	if (double.roundi(2147483647) != 2147483647d) fail_assert(101);
	if (double.roundi(-2147483648) != -2147483648d) fail_assert(102);
	if (double.roundi(16777217) != 16777217d) fail_assert(103);
	if (double.roundi(0) != 0d) fail_assert(104);
	if (long.view(double.roundi(0)) != 0L) fail_assert(105);	// yields +0, not -0
	// longs only convert exactly below 2^53
	if (double.roundi(9007199254740992L) != 9007199254740992d) fail_assert(106);
	if (double.roundi(9007199254740993L) != 9007199254740992d) fail_assert(107);
	if (double.roundi(9007199254740995L) != 9007199254740996d) fail_assert(108);	// ties to even
	if (double.roundi(-9007199254740993L) != -9007199254740992d) fail_assert(109);
	if (double.roundi(9223372036854775807L) != 9223372036854775808d) fail_assert(110);
	if (double.roundi(-9223372036854775808L) != -9223372036854775808d) fail_assert(111);
	if (double.roundi(4294967296L) != 4294967296d) fail_assert(112);
}

//======================================================================
// Section 2: unsigned integers into double
//======================================================================
def fromUnsigned() {
	var h = 0;
	for (i < U32S.length) {
		var v = U32S[i];
		h = mixd(h, double.roundi(v));
		h = mixb(h, double.?(v));
		h = mixf(h, float.roundi(v));
		h = mixb(h, double.roundi(v) == double.roundi(u64.!(v)));
	}
	acci(h);
	var g = 0;
	for (i < U64S.length) {
		var v = U64S[i];
		g = mixd(g, double.roundi(v));
		g = mixb(g, double.?(v));
		g = mixl(g, long.view(v));
	}
	acci(g);

	// the whole u32 range is exact
	if (double.roundi(4294967295u) != 4294967295d) fail_assert(201);
	if (double.roundi(2147483648u) != 2147483648d) fail_assert(202);
	if (!double.?(4294967295u)) fail_assert(203);
	// u64 above 2^53 is not
	if (double.?(18446744073709551615uL)) fail_assert(204);
	if (double.roundi(18446744073709551615uL) != 18446744073709551616d) fail_assert(205);
	if (double.roundi(9223372036854775808uL) != 9223372036854775808d) fail_assert(206);
	if (double.roundi(9007199254740993uL) != 9007199254740992d) fail_assert(207);
	if (!double.?(9007199254740992uL)) fail_assert(208);
	// the unsigned value must not be sign-extended on the way in
	if (double.roundi(18446744073709551615uL) == double.roundi(-1L)) fail_assert(209);
	if (double.roundi(-1L) != -1d) fail_assert(210);
}

//======================================================================
// Section 3: double into signed integers
//======================================================================
def toSigned() {
	var h = 0;
	for (i < DINT.length) {
		var d = DINT[i];
		h = mix(h, int.truncd(d));
		h = mixl(h, long.truncd(d));
		h = mixb(h, int.?(d));
		h = mixb(h, long.?(d));
		h = mixd(h, double.roundi(int.truncd(d)));	// round trip
	}
	acci(h);
	var g = 0;
	for (i < DLONG.length) {
		var d = DLONG[i];
		g = mixl(g, long.truncd(d));
		g = mixb(g, long.?(d));
		g = mixd(g, double.roundi(long.truncd(d)) - d);
	}
	acci(g);

	// truncation is toward zero, in both directions
	if (int.truncd(3.9d) != 3) fail_assert(301);
	if (int.truncd(-3.9d) != -3) fail_assert(302);
	if (int.truncd(0.999d) != 0) fail_assert(303);
	if (int.truncd(-0.999d) != 0) fail_assert(304);
	if (int.truncd(-0.0d) != 0) fail_assert(305);
	if (int.truncd(2147483647d) != 2147483647) fail_assert(306);
	if (int.truncd(-2147483648d) != -2147483648) fail_assert(307);
	if (long.truncd(1e18d) != 1000000000000000000L) fail_assert(308);
	if (long.truncd(-1e18d) != -1000000000000000000L) fail_assert(309);
	if (long.truncd(9007199254740992d) != 9007199254740992L) fail_assert(310);
	if (long.truncd(9007199254740993d) != 9007199254740992L) fail_assert(311);	// the literal already rounded
	// exact casts that must succeed
	if (int.!(3d) != 3) fail_assert(312);
	if (int.!(-4d) != -4) fail_assert(313);
	if (long.!(1e18d) != 1000000000000000000L) fail_assert(314);
	if (int.!(-2147483648d) != -2147483648) fail_assert(315);
}

//======================================================================
// Section 4: double into unsigned integers
//======================================================================
def toUnsigned() {
	var h = 0;
	for (i < DU32.length) {
		var d = DU32[i];
		h = mix(h, int.view(u32.truncd(d)));
		h = mixb(h, u32.?(d));
		h = mixd(h, double.roundi(u32.truncd(d)));
	}
	acci(h);
	var g = 0;
	for (i < DU64.length) {
		var d = DU64[i];
		g = mixl(g, long.view(u64.truncd(d)));
		g = mixb(g, u64.?(d));
		g = mixd(g, double.roundi(u64.truncd(d)) - d);
	}
	acci(g);
	// negative doubles answer the query without ever being truncated
	var k = 0;
	for (i < DINT.length) {
		k = mixb(k, u32.?(DINT[i]));
		k = mixb(k, u64.?(DINT[i]));
	}
	acci(k);

	if (u32.truncd(3.9d) != 3) fail_assert(401);
	if (u32.truncd(4294967295d) != 4294967295u) fail_assert(402);
	if (u64.truncd(1e18d) != 1000000000000000000uL) fail_assert(403);
	if (u64.truncd(9007199254740992d) != 9007199254740992uL) fail_assert(404);
	if (!u32.?(0d)) fail_assert(405);
	if (!u32.?(4294967295d)) fail_assert(406);
	if (u32.?(4294967296d)) fail_assert(407);
	if (u32.?(-1d)) fail_assert(408);
	if (u32.?(3.5d)) fail_assert(409);
	// -0.0 is NOT accepted as a u32 even though it compares equal to 0
	if (u32.?(-0.0d)) fail_assert(410);
	if (u64.?(-0.5d)) fail_assert(411);
	if (!u64.?(9007199254740992d)) fail_assert(412);
	if (u64.?(18446744073709551616d)) fail_assert(413);	// 2^64 is out of range
	if (u32.!(65535d) != 65535u) fail_assert(414);
}

//======================================================================
// Section 5: double and float
//======================================================================
def toFloat() {
	var h = 0;
	for (i < DFLT.length) {
		var d = DFLT[i];
		var f = float.roundd(d);
		h = mixf(h, f);
		h = mixb(h, float.?(d));
		var back: double = f;			// implicit widening back
		h = mixd(h, back);
		h = mixb(h, back == d);			// true exactly when d was representable
	}
	acci(h);
	var g = 0;
	for (i < FLTS.length) {
		var f = FLTS[i];
		var d: double = f;			// implicit promotion is exact
		g = mixd(g, d);
		g = mixf(g, float.roundd(d));
		g = mixb(g, float.roundd(d) == f || f != f);
		g = mixd(g, d * 2d);
	}
	acci(g);
	// arithmetic that mixes the precisions promotes to double
	var k = 0;
	for (i < FLTS.length) {
		var f = FLTS[i];
		k = mixd(k, f + 0.1d);
		k = mixd(k, f * 3d);
		k = mixb(k, f == 0.1d);
	}
	acci(k);

	// promotion float -> double is exact and never changes the value
	var pd: double = 0.1f;
	if (pd == 0.1d) fail_assert(501);		// 0.1f and 0.1d are different numbers
	if (pd != 0.10000000149011612d) fail_assert(502);
	var p2: double = 3.5f;
	if (p2 != 3.5d) fail_assert(503);
	// narrowing double -> float rounds
	if (float.roundd(1.25d) != 1.25f) fail_assert(504);
	if (float.roundd(0.1d) != 0.1f) fail_assert(505);
	if (float.roundd(16777217d) != 16777216f) fail_assert(506);
	if (float.roundd(1e300d) != float.infinity) fail_assert(507);
	if (float.roundd(-1e300d) != -float.infinity) fail_assert(508);
	if (float.roundd(1e-300d) != 0f) fail_assert(509);
	if (int.view(float.roundd(-1e-300d)) != int.view(-0.0f)) fail_assert(510);	// sign survives underflow
	if (int.view(float.roundd(-0.0d)) != int.view(-0.0f)) fail_assert(511);
	if (float.roundd(double.nan) == float.roundd(double.nan)) fail_assert(512);
	if (float.roundd(double.infinity) != float.infinity) fail_assert(513);
	// representability of a double as a float
	if (!float.?(1.25d)) fail_assert(514);
	if (float.?(0.1d)) fail_assert(515);
	if (!float.?(-0.0d)) fail_assert(516);
	if (float.?(1e-320d)) fail_assert(517);		// subnormal double, no float form
	if (!float.?(double.nan)) fail_assert(518);	// NaN and infinity are representable
	if (!float.?(double.infinity)) fail_assert(519);
	if (float.?(1e300d)) fail_assert(520);
}

//======================================================================
// Section 6: exact-representability queries
//======================================================================
def queries() {
	var h = 0;
	for (i < INTS.length) {
		h = mixb(h, double.?(INTS[i]));
		h = mixb(h, float.?(INTS[i]));
	}
	for (i < LONGS.length) {
		h = mixb(h, double.?(LONGS[i]));
		h = mixb(h, float.?(LONGS[i]));
	}
	acci(h);
	var g = 0;
	for (i < DINT.length) {
		var d = DINT[i];
		g = mixb(g, int.?(d));
		g = mixb(g, long.?(d));
		g = mixb(g, float.?(d));
		g = mixb(g, u32.?(d));
	}
	acci(g);
	// a query and the matching cast must agree: only cast where the query says yes
	var k = 0;
	for (i < DINT.length) {
		var d = DINT[i];
		if (int.?(d)) k = mix(k, int.!(d));
		else k = mix(k, -1);
		if (long.?(d)) k = mixl(k, long.!(d));
		else k = mixl(k, -1);
	}
	acci(k);

	// every int is an exact double; only small ones are exact floats
	if (!double.?(2147483647)) fail_assert(601);
	if (!double.?(-2147483648)) fail_assert(602);
	if (!double.?(16777217)) fail_assert(603);
	if (float.?(16777217)) fail_assert(604);
	if (!float.?(16777216)) fail_assert(605);
	// longs
	if (!double.?(9007199254740992L)) fail_assert(606);
	if (double.?(9007199254740993L)) fail_assert(607);
	if (double.?(9223372036854775807L)) fail_assert(608);
	if (!double.?(-9223372036854775808L)) fail_assert(609);	// exactly -2^63
	// doubles back to integers
	if (!int.?(3d)) fail_assert(610);
	if (int.?(3.5d)) fail_assert(611);
	if (int.?(double.nan)) fail_assert(612);
	if (int.?(double.infinity)) fail_assert(613);
	if (int.?(2147483648d)) fail_assert(614);
	if (!int.?(-2147483648d)) fail_assert(615);
	if (!long.?(1e18d)) fail_assert(616);
	if (long.?(1e300d)) fail_assert(617);
	if (!long.?(-9223372036854775808d)) fail_assert(618);
	if (long.?(9223372036854775808d)) fail_assert(619);
	if (long.?(double.nan)) fail_assert(620);
}

//======================================================================
// Section 7: the 53-bit mantissa boundary
//======================================================================
def boundary() {
	// 2^53 is the last integer with a successor; from there doubles step by 2
	var h = 0;
	var base = 9007199254740992L;
	for (i < 12) {
		var v = base + i;
		h = mixd(h, double.roundi(v));
		h = mixb(h, double.?(v));
		h = mixl(h, long.truncd(double.roundi(v)));
		h = mixb(h, double.roundi(v) == double.roundi(v + 1));
	}
	acci(h);
	// and the boundary is symmetric about zero
	var g = 0;
	for (i < 12) {
		var v = -base - i;
		g = mixd(g, double.roundi(v));
		g = mixb(g, double.?(v));
		g = mixl(g, long.truncd(double.roundi(v)));
	}
	acci(g);
	// float's 24-bit boundary, for contrast
	var k = 0;
	for (i < 12) {
		var v = 16777216 + i;
		k = mixf(k, float.roundi(v));
		k = mixb(k, float.?(v));
		k = mixd(k, double.roundi(v));
		k = mixb(k, double.?(v));
	}
	acci(k);

	// 9007199254740993 == 2^53+1 is the canonical non-representable integer
	if (double.?(9007199254740993L)) fail_assert(701);
	if (double.roundi(9007199254740993L) != 9007199254740992d) fail_assert(702);
	if (long.truncd(double.roundi(9007199254740993L)) != 9007199254740992L) fail_assert(703);
	if (9007199254740993d != 9007199254740992d) fail_assert(704);		// the literal itself rounds
	// its neighbours behave differently
	if (!double.?(9007199254740992L)) fail_assert(705);
	if (!double.?(9007199254740994L)) fail_assert(706);
	if (double.?(9007199254740995L)) fail_assert(707);
	if (!double.?(9007199254740996L)) fail_assert(708);
	// ties round to even at the boundary
	if (double.roundi(9007199254740995L) != 9007199254740996d) fail_assert(709);
	if (double.roundi(9007199254740997L) != 9007199254740996d) fail_assert(710);
	if (double.roundi(9007199254740999L) != 9007199254741000d) fail_assert(711);
	// below the boundary every integer is representable
	if (!double.?(9007199254740991L)) fail_assert(712);
	if (!double.?(4503599627370497L)) fail_assert(713);
	// float's boundary, for contrast
	if (!float.?(16777216)) fail_assert(714);
	if (float.?(16777217)) fail_assert(715);
	if (!double.?(16777217)) fail_assert(716);
}

//======================================================================
// Section 8: conversions inside aggregates
//======================================================================
type Num {
	case I(v: int);
	case L(v: long);
	case F(v: float);
	case D(v: double);
}
def asDouble(n: Num) -> double {
	match (n) {
		I(v) => return double.roundi(v);
		L(v) => return double.roundi(v);
		F(v) => return v;		// implicit promotion
		D(v) => return v;
	}
}
def isExactFloat(n: Num) -> bool {
	match (n) {
		I(v) => return float.?(v);
		L(v) => return float.?(v);
		F(v) => return true;
		D(v) => return float.?(v);
	}
}
def aggregates() {
	var nums = Array<Num>.new(INTS.length + LONGS.length + FLTS.length + DFLT.length);
	var p = 0;
	for (i < INTS.length) nums[p++] = Num.I(INTS[i]);
	for (i < LONGS.length) nums[p++] = Num.L(LONGS[i]);
	for (i < FLTS.length) nums[p++] = Num.F(FLTS[i]);
	for (i < DFLT.length) nums[p++] = Num.D(DFLT[i]);
	var h = 0;
	for (i < nums.length) {
		h = mixd(h, asDouble(nums[i]));
		h = mixb(h, isExactFloat(nums[i]));
		h = mix(h, nums[i].tag);
	}
	acci(h);

	// tuples carrying the two precisions side by side
	var ts = Array<(int, float, double)>.new(INTS.length);
	for (i < INTS.length) ts[i] = (INTS[i], float.roundi(INTS[i]), double.roundi(INTS[i]));
	var g = 0;
	for (i < ts.length) {
		var t = ts[i];
		g = mix(g, t.0);
		g = mixf(g, t.1);
		g = mixd(g, t.2);
		g = mixb(g, t.1 == t.2);		// float widened for the compare
		g = mixd(g, t.2 - t.1);
	}
	acci(g);

	// a conversion table stored as parallel arrays
	var src = Array<long>.new(64);
	var asD = Array<double>.new(64);
	var asF = Array<float>.new(64);
	var back = Array<long>.new(64);
	for (i < src.length) {
		src[i] = 9007199254740980L + i;
		asD[i] = double.roundi(src[i]);
		asF[i] = float.roundd(asD[i]);
		back[i] = long.truncd(asD[i]);
	}
	var k = 0;
	for (i < src.length) {
		k = mixl(k, src[i]);
		k = mixd(k, asD[i]);
		k = mixf(k, asF[i]);
		k = mixl(k, back[i] - src[i]);
	}
	acci(k);

	if (asDouble(Num.I(5)) != 5d) fail_assert(801);
	if (asDouble(Num.L(9007199254740993L)) != 9007199254740992d) fail_assert(802);
	if (asDouble(Num.F(0.5f)) != 0.5d) fail_assert(803);
	if (asDouble(Num.D(0.1d)) != 0.1d) fail_assert(804);
	if (!isExactFloat(Num.I(1024))) fail_assert(805);
	if (isExactFloat(Num.I(16777217))) fail_assert(806);
	if (isExactFloat(Num.D(0.1d))) fail_assert(807);
	if (Num.D(1d).tag != 3) fail_assert(808);
}

//======================================================================
// Section 9: conversions through generic and higher-order code
//======================================================================
def widen<T>(x: T) -> double {
	if (double.?(x)) return double.!(x);
	return -1d;
}
def query<T>(x: T) -> bool {
	return double.?(x);
}
def applyd(f: double -> double, d: double) -> double { return f(d); }
def generics() {
	var h = 0;
	for (i < INTS.length) {
		h = mixd(h, widen(INTS[i]));
		h = mixb(h, query(INTS[i]));
	}
	for (i < LONGS.length) {
		h = mixd(h, widen(LONGS[i]));
		h = mixb(h, query(LONGS[i]));
	}
	for (i < FLTS.length) {
		h = mixd(h, widen(FLTS[i]));
		h = mixb(h, query(FLTS[i]));
	}
	acci(h);

	def CONV: Array<double -> double> = [
		double.abs, double.floor, double.ceil, double.round, double.sqrt,
		fun (d: double) => double.roundi(long.truncd(d)),
		fun (d: double) => float.roundd(d)		// narrow then widen back
	];
	var g = 0;
	for (c < CONV.length) {
		for (i < DLONG.length) g = mixd(g, applyd(CONV[c], DLONG[i]));
	}
	acci(g);

	var toD: int -> double = double.roundi<int>;
	var toI: double -> int = int.truncd;
	var k = 0;
	for (i < INTS.length) {
		var d = toD(INTS[i]);
		k = mixd(k, d);
		k = mix(k, toI(d));
	}
	acci(k);

	if (widen(3) != 3d) fail_assert(901);
	if (widen(9007199254740993L) != -1d) fail_assert(902);	// not representable
	if (widen(0.5f) != 0.5d) fail_assert(903);
	if (!query(16777217)) fail_assert(904);
	if (query(9007199254740993L)) fail_assert(905);
	if (applyd(double.floor, -3.5d) != -4d) fail_assert(906);
	if (toD(7) != 7d) fail_assert(907);
	if (toI(-7.9d) != -7) fail_assert(908);
}

//======================================================================
// Section 10: conversion churn under allocation
//======================================================================
class Cell(i: long, d: double, f: float, next: Cell) { }
def churn() {
	var head: Cell;
	var live = Array<Cell>.new(20);
	for (i < 2500) {
		var v = 9007199254740000L + i * 7;
		var d = double.roundi(v);
		head = Cell.new(v, d, float.roundd(d), head);
		if ((i % 73) == 0) live[(i / 73) % live.length] = head;
		if ((i % 9) == 0) head = null;
	}
	var h = 0;
	var n = 0;
	for (i < live.length) {
		var p = live[i];
		while (p != null) {
			h = mixl(h, p.i);
			h = mixd(h, p.d);
			h = mixf(h, p.f);
			h = mixl(h, long.truncd(p.d) - p.i);
			p = p.next;
			n++;
			if (n > 200000) { acci(h); return; }
		}
	}
	acci(mix(h, n));
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) fromInt();
	if (a == 0 || a == 2) fromUnsigned();
	if (a == 0 || a == 3) toSigned();
	if (a == 0 || a == 4) toUnsigned();
	if (a == 0 || a == 5) toFloat();
	if (a == 0 || a == 6) queries();
	if (a == 0 || a == 7) boundary();
	if (a == 0 || a == 8) aggregates();
	if (a == 0 || a == 9) generics();
	if (a == 0 || a == 10) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
