//@execute 0=1053804033; 1=-354883570; 2=-1793559561; 3=-635400453; 4=1655208972; 5=878760048; 6=605579680; 7=-1698459898; 8=1086131208; 9=297514419
//@heap-size=200000
// Smoke test: 64-bit signed integer arithmetic, comparison and bit operations.
// The 64-bit mirror of int01.v3. Each section drives a group of operations from
// `def` arrays (so no section can be folded away wholesale) and mixes every
// 64-bit result into a running CRC through mixl(), keeping the computation live.
// Interleaved are assert()s whose operands are compile-time constants: the
// optimizer is expected to fold them away entirely, so a folding bug shows up as
// a set failure flag rather than a wrong CRC. On 32-bit targets every one of
// these operations is a multi-word sequence, which is exactly the point.
// Input selects the section; input 0 runs every section in one body.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

//======================================================================
// Shared data
//======================================================================
def VALS: Array<long> = [
	0, 1, -1, 2, -2, 3, -3, 7, -7, 255, -256,
	65535, 65536, 1000000, -1000000,
	2147483647, -2147483648, 4294967296L, -4294967296L,
	0x123456789ABCDEF0L, -0x123456789ABCDEF0L,
	9223372036854775807L, -9223372036854775808L,
	6148914691236517205L, -6148914691236517206L
];
// Divisors: never zero, so division and remainder never trap. long.min / -1 IS
// included on purpose -- Virgil defines it to wrap to long.min rather than trap.
def NZ: Array<long> = [
	1, -1, 2, -2, 3, -3, 7, 255, -256, 65536,
	4294967296L, 1000000007L, -1000000007L,
	9223372036854775807L, -9223372036854775808L
];
// Shift amounts, including several at and beyond the 64-bit width. Virgil does
// NOT mask the shift amount: a shift of 64 or more shifts everything out.
def SHIFTS: Array<byte> = [
	0, 1, 2, 3, 7, 8, 15, 16, 23, 31, 32, 33, 39, 47,
	55, 62, 63, 64, 65, 66, 69, 70
];

//======================================================================
// Section 1: arithmetic
//======================================================================
def arith() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = mixl(0, -a);
		for (j < NZ.length) {
			var b = NZ[j];
			h = mixl(h, a + b);
			h = mixl(h, a - b);
			h = mixl(h, a * b);
			h = mixl(h, a / b);
			h = mixl(h, a % b);
		}
		acci(h);
	}
	// compound assignment forms
	var x = 10L;
	x += 5;		// 15
	x -= 3;		// 12
	x *= 4;		// 48
	x /= 5;		// 9
	x %= 4;		// 1
	acci(mixl(0, x));
	if (x != 1L) fail_assert(101);

	// truncating division and a remainder that takes the sign of the dividend
	if (7L / 2L != 3L) fail_assert(102);
	if (-7L / 2L != -3L) fail_assert(103);
	if (7L / -2L != -3L) fail_assert(104);
	if (-7L / -2L != 3L) fail_assert(105);
	if (7L % 2L != 1L) fail_assert(106);
	if (-7L % 2L != -1L) fail_assert(107);
	if (7L % -2L != 1L) fail_assert(108);
	if (-7L % -2L != -1L) fail_assert(109);
	if (-7L / 2L * 2L + -7L % 2L != -7L) fail_assert(110);
	if (6L * 7L != 42L) fail_assert(111);
	if (-(-5L) != 5L) fail_assert(112);
	if (0L - 5L != -5L) fail_assert(113);
	// products that need all 64 bits
	if (4294967296L * 2L != 8589934592L) fail_assert(114);
	if (2147483647L * 2147483647L != 4611686014132420609L) fail_assert(115);
	if (1000000000000L * 1000000L != 1000000000000000000L) fail_assert(116);
	if (1000000000000000000L / 1000000L != 1000000000000L) fail_assert(117);
	if (9223372036854775807L / 1000000007L != 9223371972L) fail_assert(118);
	if (9223372036854775807L % 1000000007L != 291172003L) fail_assert(119);
	if (0L / 17L != 0L) fail_assert(120);
	if (0L % 17L != 0L) fail_assert(121);
}

//======================================================================
// Section 2: comparisons
//======================================================================
def compare() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = 0;
		for (j < VALS.length) {
			var b = VALS[j];
			h = mixb(h, a == b);
			h = mixb(h, a != b);
			h = mixb(h, a < b);
			h = mixb(h, a <= b);
			h = mixb(h, a > b);
			h = mixb(h, a >= b);
			// the unsigned view of the same bits orders differently
			h = mixb(h, u64.view(a) < u64.view(b));
		}
		acci(h);
	}
	if (!(-1L < 0L)) fail_assert(201);
	if (!(long.min < long.max)) fail_assert(202);
	if (long.min > 0L) fail_assert(203);
	if (!(long.max > -1L)) fail_assert(204);
	if (!(-1L <= -1L)) fail_assert(205);
	if (!(-1L >= -1L)) fail_assert(206);
	if (-1L < -1L) fail_assert(207);
	// a comparison that is only correct if all 64 bits participate
	if (!(4294967296L > 4294967295L)) fail_assert(208);
	if (!(-4294967296L < -4294967295L)) fail_assert(209);
	if (!(0x100000000L > 0xFFFFFFFFL)) fail_assert(210);
	// low words equal, high words differ
	if (!(0x200000001L > 0x100000001L)) fail_assert(211);
	// high words equal, low words differ
	if (!(0x100000002L > 0x100000001L)) fail_assert(212);
	// unsigned view reverses the ordering of negatives
	if (!(u64.view(-1L) > u64.view(1L))) fail_assert(213);
	if (!(u64.view(long.min) > u64.view(long.max))) fail_assert(214);
	// an int operand is widened before comparison, not truncated
	var i32 = -1;
	if (!(i32 < 1L)) fail_assert(215);
	if (i32 != -1L) fail_assert(216);
}

//======================================================================
// Section 3: bitwise and, or, xor, complement
//======================================================================
def bitwise() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = mixl(0, ~a);
		for (j < VALS.length) {
			var b = VALS[j];
			h = mixl(h, a & b);
			h = mixl(h, a | b);
			h = mixl(h, a ^ b);
			h = mixl(h, a & ~b);
			h = mixl(h, ~(a | b));
		}
		acci(h);
	}
	// compound bitwise assignment
	var x = 0xF0F0F0F0F0F0L;
	x &= 0x0FF00FF00FF0L;	// 0x00F000F000F0
	x |= 0x000000000003L;	// 0x00F000F000F3
	x ^= 0x0000000000FFL;	// 0x00F000F0000C
	acci(mixl(0, x));
	if (x != 0x00F000F0000CL) fail_assert(301);

	if ((0xF0F0L & 0x0FF0L) != 0x00F0L) fail_assert(302);
	if ((0xF0F0L | 0x0FF0L) != 0xFFF0L) fail_assert(303);
	if ((0xF0F0L ^ 0x0FF0L) != 0xFF00L) fail_assert(304);
	if (~0L != -1L) fail_assert(305);
	if (~5L != -6L) fail_assert(306);
	if (~(-1L) != 0L) fail_assert(307);
	if (~long.max != long.min) fail_assert(308);
	if (~long.min != long.max) fail_assert(309);
	if (~1234L != -1234L - 1L) fail_assert(310);
	// identities across the word boundary
	if ((0x123456789ABCDEF0L & ~0x123456789ABCDEF0L) != 0L) fail_assert(311);
	if ((0x123456789ABCDEF0L | ~0x123456789ABCDEF0L) != -1L) fail_assert(312);
	if ((0x123456789ABCDEF0L ^ 0x123456789ABCDEF0L) != 0L) fail_assert(313);
	if ((0x123456789ABCDEF0L ^ -1L) != ~0x123456789ABCDEF0L) fail_assert(314);
	if ((0x123456789ABCDEF0L & -1L) != 0x123456789ABCDEF0L) fail_assert(315);
	// masks that touch only one half
	if ((0x123456789ABCDEF0L & 0xFFFFFFFFL) != 0x9ABCDEF0L) fail_assert(316);
	if ((0x123456789ABCDEF0L & -4294967296L) != 0x1234567800000000L) fail_assert(317);
	// de Morgan
	if (~(0x0F0F0F0F0F0FL & 0x333333333333L) != (~0x0F0F0F0F0F0FL | ~0x333333333333L)) fail_assert(318);
}

//======================================================================
// Section 4: shifts, including counts at and past the width
//======================================================================
def shifts() {
	for (i < VALS.length) {
		var a = VALS[i];
		var h = 0;
		for (j < SHIFTS.length) {
			var s = SHIFTS[j];
			h = mixl(h, a << s);
			h = mixl(h, a >> s);
			h = mixl(h, a >>> s);
		}
		acci(h);
	}
	// every shift amount 0..70 against a fixed pattern
	var h = 0;
	for (s < 71) {
		var b = byte.view(s);
		h = mixl(h, 0x123456789ABCDEF0L << b);
		h = mixl(h, 0x123456789ABCDEF0L >> b);
		h = mixl(h, 0x123456789ABCDEF0L >>> b);
		h = mixl(h, -1L << b);
		h = mixl(h, -1L >> b);
		h = mixl(h, -1L >>> b);
		h = mixl(h, long.min << b);
		h = mixl(h, long.min >> b);
		h = mixl(h, long.min >>> b);
	}
	acci(h);
	// compound shift assignment
	var x = 1L;
	x <<= 40;	// 2^40
	x >>= 8;	// 2^32
	x >>>= 16;	// 2^16
	acci(mixl(0, x));
	if (x != 65536L) fail_assert(401);

	// shift by zero is the identity
	if (5L << 0 != 5L) fail_assert(402);
	if (-5L >> 0 != -5L) fail_assert(403);
	if (-5L >>> 0 != -5L) fail_assert(404);
	// shifts that cross the 32-bit boundary
	if (1L << 31 != 2147483648L) fail_assert(405);
	if (1L << 32 != 4294967296L) fail_assert(406);
	if (1L << 62 != 4611686018427387904L) fail_assert(407);
	if (1L << 63 != long.min) fail_assert(408);
	if (0x123456789ABCDEF0L >>> 4 != 0x0123456789ABCDEFL) fail_assert(409);
	if (0x123456789ABCDEF0L << 4 != 0x23456789ABCDEF00L) fail_assert(410);
	if (0x123456789ABCDEF0L >>> 32 != 0x12345678L) fail_assert(411);
	if (0x123456789ABCDEF0L << 32 != -7296712173873528832L) fail_assert(412);
	if (255L << 56 != -72057594037927936L) fail_assert(413);
	if ((255L << 56) >> 56 != -1L) fail_assert(414);	// sign fill
	if ((255L << 56) >>> 56 != 255L) fail_assert(415);	// zero fill
	if (-1L >> 1 != -1L) fail_assert(416);
	if (-1L >>> 1 != long.max) fail_assert(417);
	if (long.min >> 63 != -1L) fail_assert(418);
	if (long.min >>> 63 != 1L) fail_assert(419);
	// shift counts at and beyond the width are NOT masked
	if (1L << 64 != 0L) fail_assert(420);
	if (1L << 65 != 0L) fail_assert(421);
	if (1L << 70 != 0L) fail_assert(422);
	if (-1L >>> 64 != 0L) fail_assert(423);
	if (-1L >>> 70 != 0L) fail_assert(424);
	if (0x123456789ABCDEF0L >> 64 != 0L) fail_assert(425);
	if (-1L >> 64 != -1L) fail_assert(426);
	if (-1L >> 70 != -1L) fail_assert(427);
	if (long.min >> 70 != -1L) fail_assert(428);
	if (long.min >>> 70 != 0L) fail_assert(429);
	// a 32-bit shift count is still valid for a 64-bit value
	if (1L << 33 != 8589934592L) fail_assert(430);
	// a left shift is a multiply by a power of two
	if (3L << 5 != 3L * 32L) fail_assert(431);
	// an arithmetic right shift floors, division truncates
	if (-7L >> 1 != -4L) fail_assert(432);
	if (-7L / 2L != -3L) fail_assert(433);
}

//======================================================================
// Section 5: longs in arrays and ranges
//======================================================================
def arrays() {
	var a = Array<long>.new(96);
	for (i < a.length) a[i] = VALS[i % VALS.length] ^ (long.!(i) * 0x9E3779B97F4A7C15L);
	var h = 0;
	for (i < a.length) h = mixl(h, a[i]);
	acci(h);

	var r: Range<long> = a;
	var mid = r[24 ... 72];
	var tail = r[72 ...];
	var g = mix(0, mid.length);
	for (i < mid.length) g = mixl(g, mid[i]);
	for (i < tail.length) g = mixl(g, tail[i]);
	acci(g);
	if (mid.length != 48) fail_assert(501);
	if (tail.length != 24) fail_assert(502);

	// range writes alias the backing array
	for (i < mid.length) mid[i] = mid[i] & 0xFFFFFFFFL;
	var k = 0;
	for (i < a.length) k = mixl(k, a[i]);
	acci(k);
	if ((a[30] & -4294967296L) != 0L) fail_assert(503);
	if (a[30] < 0L) fail_assert(504);		// masked to 32 bits, so nonnegative

	// two-dimensional, with a sum that spans both halves of the word
	var m = Array<Array<long>>.new(12);
	for (i < m.length) {
		m[i] = Array<long>.new(12);
		for (j < 12) m[i][j] = long.!(i * 12 + j) * 0x0100000193L;
	}
	var sum = 0L;
	for (i < m.length) for (j < 12) sum = sum + m[i][j];
	acci(mixl(0, sum));
	if (sum != 143L * 144L / 2L * 0x0100000193L) fail_assert(505);

	// int arrays widen on read into a long accumulator
	var is = Array<int>.new(32);
	for (i < is.length) is[i] = -1;
	var acc = 0L;
	for (i < is.length) acc = acc + is[i];		// each -1 sign-extends
	acci(mixl(0, acc));
	if (acc != -32L) fail_assert(506);
}

//======================================================================
// Section 6: longs in tuples
//======================================================================
def swapl(t: (long, long)) -> (long, long) {
	return (t.1, t.0);
}
def divmodl(a: long, b: long) -> (long, long) {
	return (a / b, a % b);
}
def splitl(x: long) -> (int, int) {
	return (int.view(x >> 32), int.view(u32.view(x)));
}
def tuples() {
	var h = 0;
	for (i < VALS.length) {
		var t = (VALS[i], NZ[i % NZ.length]);
		var s = swapl(t);
		var q = divmodl(t.0, t.1);
		var p = splitl(t.0);
		h = mixl(h, t.0);
		h = mixl(h, t.1);
		h = mixl(h, s.0);
		h = mixl(h, s.1);
		h = mixl(h, q.0);
		h = mixl(h, q.1);
		h = mix(h, p.0);
		h = mix(h, p.1);
		h = mixb(h, t == s);
	}
	acci(h);

	var ts = Array<(long, int, long)>.new(32);
	for (i < ts.length) ts[i] = (VALS[i % VALS.length], i, long.!(i) * 0x100000001L);
	var g = 0;
	for (i < ts.length) {
		var t = ts[i];
		g = mixl(g, t.0);
		g = mix(g, t.1);
		g = mixl(g, t.2);
	}
	acci(g);

	var n = ((1L, 2L), (3L, (4L, 5L)));	// nested tuples
	var k = mixl(0, n.0.0);
	k = mixl(k, n.0.1);
	k = mixl(k, n.1.0);
	k = mixl(k, n.1.1.0);
	k = mixl(k, n.1.1.1);
	acci(k);

	if (divmodl(-7L, 2L).0 != -3L) fail_assert(601);
	if (divmodl(-7L, 2L).1 != -1L) fail_assert(602);
	if (swapl((1L, 2L)).0 != 2L) fail_assert(603);
	if (n.1.1.1 != 5L) fail_assert(604);
	if ((1L, 2L) == (2L, 1L)) fail_assert(605);
	if (!((1L, 2L) == (1L, 2L))) fail_assert(606);
	if (splitl(0x123456789ABCDEF0L).0 != 0x12345678) fail_assert(607);
	if (splitl(0x123456789ABCDEF0L).1 != -1698898192) fail_assert(608);	// 0x9ABCDEF0
	if (splitl(long.min).0 != int.min) fail_assert(609);
	if (splitl(long.min).1 != 0) fail_assert(610);
}

//======================================================================
// Section 7: longs in globals and a component
//======================================================================
var gl: long;
var gt: (long, long);
var ga: Array<long>;

component Counter {
	var cur: long = 1;
	def base: long = 0x0100000193L;
	var hist: Array<long> = Array<long>.new(8);
	var n: int;

	def step(x: long) -> long {
		cur = cur * 6364136223846793005L + x;
		hist[n % hist.length] = cur;
		n++;
		return cur;
	}
}
def globals() {
	// Reset all mutable global state; the harness may run several inputs in one
	// process, so a section must never depend on what ran before it.
	gl = 0;
	gt = (0, 0);
	Counter.cur = 1;
	Counter.n = 0;
	Counter.hist = Array<long>.new(8);

	ga = Array<long>.new(VALS.length);
	var h = 0;
	for (i < VALS.length) {
		gl = VALS[i];
		gt = (gl, gl ^ -1L);
		ga[i] = gl - 1;
		h = mixl(h, gl);
		h = mixl(h, gt.0);
		h = mixl(h, gt.1);
		h = mixl(h, ga[i]);
	}
	acci(h);

	var g = mixl(0, Counter.base);
	for (i < 40) g = mixl(g, Counter.step(VALS[i % VALS.length]));
	for (i < Counter.hist.length) g = mixl(g, Counter.hist[i]);
	g = mix(g, Counter.n);
	g = mixl(g, Counter.cur);
	acci(g);

	if (Counter.base != 0x0100000193L) fail_assert(701);
	if (Counter.n != 40) fail_assert(702);
	if (gl != VALS[VALS.length - 1]) fail_assert(703);
	if (gt.1 != ~gl) fail_assert(704);
}

//======================================================================
// Section 8: longs in class fields
//======================================================================
class LBox {
	var v: long;
	def tag: int;
	new(v, tag) { }
	def value() -> long { return v; }
	def combine() -> long { return v; }
}
class LScale extends LBox {
	def k: long;
	new(v: long, tag: int, k) super(v, tag) { }
	def combine() -> long { return v * k; }
}
class LPair extends LScale {
	var other: LBox;
	new(v: long, k: long, other) super(v, 2, k) { }
	def combine() -> long { return if(other == null, v, v * k + other.value()); }
}
def classes() {
	var objs = Array<LBox>.new(3 * VALS.length);
	for (i < VALS.length) {
		var v = VALS[i];
		objs[3 * i + 0] = LBox.new(v, i);
		objs[3 * i + 1] = LScale.new(v, i, 0x100000001L);
		objs[3 * i + 2] = LPair.new(v, -2, objs[3 * i + 0]);
	}
	var h = 0;
	for (i < objs.length) {
		var o = objs[i];
		h = mixl(h, o.value());
		h = mixl(h, o.combine());	// virtual dispatch over 3 implementations
		h = mix(h, o.tag);
		h = mixb(h, LScale.?(o));
		h = mixb(h, LPair.?(o));
	}
	acci(h);
	// mutate through the array and re-read
	for (i < objs.length) objs[i].v = objs[i].v ^ 0x5A5A5A5A5A5A5A5AL;
	var g = 0;
	for (i < objs.length) g = mixl(g, objs[i].combine());
	acci(g);

	var b = LBox.new(5L, 7);
	var s = LScale.new(5L, 7, 0x100000001L);
	var p = LPair.new(5L, 4L, null);
	if (b.combine() != 5L) fail_assert(801);
	if (s.combine() != 21474836485L) fail_assert(802);	// 5 * 0x100000001
	if (p.combine() != 5L) fail_assert(803);		// null other
	if (LPair.new(5L, 4L, b).combine() != 25L) fail_assert(804);
	if (!LScale.?(p)) fail_assert(805);
	if (LPair.?(s)) fail_assert(806);
	if (b.tag != 7) fail_assert(807);
}

//======================================================================
// Section 9: longs in variant cases
//======================================================================
type LVal {
	case Plain(v: long);
	case Span(lo: long, hi: long);
	case Boxed(o: LBox);
	case None;
}
type LFlat #unboxed {
	case One(v: long);
	case Two(a: long, b: long);
	case Zero;
}
def evall(v: LVal) -> long {
	match (v) {
		Plain(x) => return x;
		Span(lo, hi) => return hi - lo;
		Boxed(o) => return if(o == null, -1L, o.v);
		None => return 0L;
	}
}
def evalf(v: LFlat) -> long {
	match (v) {
		One(x) => return x;
		Two(a, b) => return a ^ b;
		Zero => return 0L;
	}
}
def variants() {
	var h = 0;
	for (i < VALS.length) {
		var v = VALS[i];
		var p: LVal = LVal.Plain(v);
		var s: LVal = LVal.Span(v, v + 1000000007L);
		var o: LVal = LVal.Boxed(LBox.new(v, i));
		var n: LVal = LVal.None;
		h = mixl(h, evall(p));
		h = mixl(h, evall(s));
		h = mixl(h, evall(o));
		h = mixl(h, evall(n));
		h = mix(h, p.tag);
		h = mix(h, s.tag);
		h = mix(h, o.tag);
		h = mix(h, n.tag);
		h = mixb(h, p == s);

		var f1: LFlat = LFlat.One(v);
		var f2: LFlat = LFlat.Two(v, 0x123456789ABCDEF0L);
		var f3: LFlat = LFlat.Zero;
		h = mixl(h, evalf(f1));
		h = mixl(h, evalf(f2));
		h = mixl(h, evalf(f3));
		h = mixb(h, f1 == f2);
		h = mixb(h, LFlat.One(v) == LFlat.One(v));
		h = mixb(h, LFlat.One(v) == LFlat.One(v + 1));
		h = mixb(h, LFlat.One(v) == LFlat.Zero);
		h = mix(h, f2.tag);
	}
	acci(h);

	var arr = Array<LFlat>.new(VALS.length);
	var barr = Array<LVal>.new(VALS.length);
	for (i < arr.length) {
		arr[i] = LFlat.Two(VALS[i], long.!(i));
		barr[i] = LVal.Span(VALS[i], long.!(i));
	}
	var g = 0;
	for (i < arr.length) {
		g = mixl(g, evalf(arr[i]));
		g = mixl(g, evall(barr[i]));
	}
	acci(g);

	if (evall(LVal.Plain(0x123456789ABCDEF0L)) != 0x123456789ABCDEF0L) fail_assert(901);
	if (evall(LVal.Span(2L, 9L)) != 7L) fail_assert(902);
	if (evall(LVal.Span(long.min, long.max)) != -1L) fail_assert(903);	// wraps
	if (evall(LVal.None) != 0L) fail_assert(904);
	if (evalf(LFlat.Two(-1L, 0L)) != -1L) fail_assert(905);
	if (evalf(LFlat.Two(-1L, -1L)) != 0L) fail_assert(906);
	if (LVal.Plain(1L).tag != 0) fail_assert(907);
	if (LVal.None.tag != 3) fail_assert(908);
	if (!(LFlat.One(long.min) == LFlat.One(long.min))) fail_assert(909);
	if (LFlat.One(long.min) == LFlat.One(long.max)) fail_assert(910);
	// two values whose low words agree but whose high words differ
	if (LFlat.One(0x100000001L) == LFlat.One(0x200000001L)) fail_assert(911);
	if (LFlat.Two(1L, 2L) == LFlat.Two(2L, 1L)) fail_assert(912);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) arith();
	if (a == 0 || a == 2) compare();
	if (a == 0 || a == 3) bitwise();
	if (a == 0 || a == 4) shifts();
	if (a == 0 || a == 5) arrays();
	if (a == 0 || a == 6) tuples();
	if (a == 0 || a == 7) globals();
	if (a == 0 || a == 8) classes();
	if (a == 0 || a == 9) variants();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
