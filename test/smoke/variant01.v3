//@execute 0=-992309894; 1=-479156532; 2=-792216097; 3=-1338619369; 4=-492540758; 5=1347659100; 6=1762122488; 7=-990398200; 8=878075536; 9=1825103259
//@heap-size=1000000
// Smoke test: variant (ADT) surface area other than recursion.
// Every match form (destructuring, wildcard, typed binding, nested match, match
// on the tag), `.tag` and `.name`, case queries and casts, a variant with many
// cases, tuple and array payloads, variants stored in arrays, globals, tuples
// and class fields, and variant methods declared on the parent type and
// overridden per case. Recursive ADTs are covered by variant03.v3 and are
// deliberately not repeated here.
// Results are mixed into a running CRC that main() returns, so no computation
// can be deleted as dead. Interleaved are assert()s over compile-time
// constants, which the optimizer is expected to fold away; a folding bug sets
// the failure flag instead. Input selects the section.

//======================================================================
// Accumulator and assertions
//======================================================================
var crc: int;
var failed: int;

def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def mixl(h: int, x: long) -> int {
	return mix(mix(h, int.view(u32.view(x))), int.view(u32.view(x >> 32)));
}
def mixb(h: int, b: bool) -> int {
	return mix(h, if(b, 0x5A5A5A5A, 0x0F0F0F0F));
}
def mixs(h: int, s: string) -> int {
	if (s == null) return mix(h, -1);
	var t = mix(h, s.length);
	for (i < s.length) t = mix(t, s[i]);
	return t;
}
def acci(x: int) { crc = mix(crc, x); }

// Records the first failing assertion; main() returns the id instead of the CRC.
def fail_assert(id: int) { if (failed == 0) failed = id; }

var seed: int;
def srand(s: int) { seed = s; }
def rand() -> int {
	seed = seed * 1664525 + 1013904223;
	seed = seed ^ (seed >>> 16);
	return seed;
}
def randn(n: int) -> int { return (rand() & 0x7FFFFFFF) % n; }

def WORDS: Array<string> = ["ay", "bee", "cee", "dee", "ee", "ef", "gee"];
def NUMS: Array<int> = [7, 2, 9, 4, 1, 8, 3, 6, 5, 0, 11, 12];

//======================================================================
// Types
//======================================================================
class Obj {
	def id: int;
	var w: int;
	new(id) { }
	def score() -> int { return id * 10 + w; }
}

// Method declared on the parent type, overridden by some cases.
type Shape {
	def area() -> int { return 0; }
	def sides() -> int { return 0; }
	// a parent method that calls the overridable ones
	def summary() -> int { return area() * 100 + sides() * 10 + tag; }

	case Nothing;
	case Circle(r: int) { def area() -> int { return r * r * 3; } }
	case Sq(s: int) {
		def area() -> int { return s * s; }
		def sides() -> int { return 4; }
	}
	case Rect(w: int, h: int) {
		def area() -> int { return w * h; }
		def sides() -> int { return 4; }
	}
	case Tri(b: int, h: int) {
		def area() -> int { return b * h / 2; }
		def sides() -> int { return 3; }
	}
}

// Payload variety: tuples, arrays, strings, classes, other variants.
type Pay {
	case Empty;
	case Ints(a: int, b: int);
	case Tup(t: (int, string));
	case Tup3(t: (int, int, int));
	case Arr(a: Array<int>);
	case Str(s: string);
	case Ref(o: Obj);
	case Nested(s: Shape, k: int);
}

// A variant with many cases, to exercise dense tag dispatch.
type Op {
	case C0;
	case C1(x: int);
	case C2(x: int);
	case C3(x: int, y: int);
	case C4;
	case C5(s: string);
	case C6(x: int);
	case C7(x: int, y: int);
	case C8;
	case C9(x: int);
	case C10(x: int);
	case C11(s: string);
	case C12(x: int, y: int);
	case C13;
	case C14(x: int);
	case C15(x: int);
	case C16(t: (int, int));
	case C17;
	case C18(x: int);
	case C19(x: int, y: int, z: int);
}

//======================================================================
// Section 1: every match form
//======================================================================
def destructure(p: Pay) -> int {
	match (p) {
		Empty => return -1;
		Ints(a, b) => return a + b;
		Tup(t) => return t.0 + t.1.length;
		Tup3(t) => return t.0 * t.1 - t.2;
		Arr(a) => {
			if (a == null) return -2;
			var s = 0;
			for (i < a.length) s += a[i];
			return s;
		}
		Str(s) => return if(s == null, -3, s.length);
		Ref(o) => return if(o == null, -4, o.score());
		Nested(s, k) => return s.area() + k;
	}
}
// wildcards in pattern positions and a catch-all arm
def partial(p: Pay) -> int {
	match (p) {
		Ints(a, _) => return a;
		Tup3(_) => return 100;
		Nested(_, k) => return k;
		_ => return -9;
	}
}
// typed binding form: the arm names the whole case value
def bound(p: Pay) -> int {
	match (p) {
		x: Pay.Ints => return x.a * x.b;
		x: Pay.Str => return if(x.s == null, 0, x.s.length * 2);
		x: Pay.Nested => return x.s.sides();
		_ => return -1;
	}
}
// nested match
def nested(p: Pay) -> int {
	match (p) {
		Nested(s, k) => {
			match (s) {
				Nothing => return k;
				Circle(r) => return r + k;
				Sq(t) => return t * k;
				Rect(w, h) => return w * h + k;
				Tri(b, h) => return b - h + k;
			}
		}
		Ints(a, b) => {
			match (a) {
				0 => return b;
				1 => return b * 2;
				_ => return b * 3;
			}
		}
		_ => return -5;
	}
}
// match on the tag rather than the value
def bytag(p: Pay) -> int {
	match (p.tag) {
		0 => return 1000;
		1 => return 1001;
		2 => return 1002;
		7 => return 1007;
		_ => return 1099;
	}
}
def makePay(i: int) -> Pay {
	var a = NUMS[i % NUMS.length];
	var b = NUMS[(i + 5) % NUMS.length];
	match (i % 8) {
		0 => return Pay.Empty;
		1 => return Pay.Ints(a, b);
		2 => return Pay.Tup((a, WORDS[i % WORDS.length]));
		3 => return Pay.Tup3((a, b, i));
		4 => return Pay.Arr(NUMS);
		5 => return Pay.Str(WORDS[i % WORDS.length]);
		6 => {
			var o = Obj.new(a);
			o.w = b;
			return Pay.Ref(o);
		}
		_ => return Pay.Nested(Shape.Rect(a, b), i);
	}
}
def matchforms() {
	var h = 0;
	for (i < 160) {
		var p = makePay(i);
		h = mix(h, destructure(p));
		h = mix(h, partial(p));
		h = mix(h, bound(p));
		h = mix(h, nested(p));
		h = mix(h, bytag(p));
	}
	acci(h);

	var e: Pay = Pay.Empty;
	var ints: Pay = Pay.Ints(3, 4);
	var tup: Pay = Pay.Tup((5, WORDS[1]));
	var tup3: Pay = Pay.Tup3((2, 3, 4));
	var arr: Pay = Pay.Arr(NUMS);
	var str: Pay = Pay.Str(WORDS[2]);
	var nul: Pay = Pay.Str(null);
	var nst: Pay = Pay.Nested(Shape.Sq(5), 7);
	if (destructure(e) != -1) fail_assert(101);
	if (destructure(ints) != 7) fail_assert(102);
	if (destructure(tup) != 8) fail_assert(103);		// 5 + 3
	if (destructure(tup3) != 2) fail_assert(104);		// 2*3 - 4
	if (destructure(arr) != 68) fail_assert(105);		// NUMS sums to 68
	if (destructure(str) != 3) fail_assert(106);
	if (destructure(nul) != -3) fail_assert(107);
	if (destructure(Pay.Arr(null)) != -2) fail_assert(108);
	if (destructure(Pay.Ref(null)) != -4) fail_assert(109);
	if (destructure(nst) != 32) fail_assert(110);		// 25 + 7
	if (partial(ints) != 3) fail_assert(111);
	if (partial(tup3) != 100) fail_assert(112);
	if (partial(nst) != 7) fail_assert(113);
	if (partial(e) != -9) fail_assert(114);
	if (partial(str) != -9) fail_assert(115);
	if (bound(ints) != 12) fail_assert(116);
	if (bound(str) != 6) fail_assert(117);
	if (bound(nst) != 4) fail_assert(118);
	if (bound(e) != -1) fail_assert(119);
	if (nested(nst) != 35) fail_assert(120);		// Sq(5) * 7
	if (nested(Pay.Nested(Shape.Nothing, 9)) != 9) fail_assert(121);
	if (nested(Pay.Nested(Shape.Circle(2), 9)) != 11) fail_assert(122);
	if (nested(Pay.Nested(Shape.Tri(9, 4), 1)) != 6) fail_assert(123);
	if (nested(Pay.Ints(0, 5)) != 5) fail_assert(124);
	if (nested(Pay.Ints(1, 5)) != 10) fail_assert(125);
	if (nested(Pay.Ints(2, 5)) != 15) fail_assert(126);
	if (nested(e) != -5) fail_assert(127);
	if (bytag(e) != 1000) fail_assert(128);
	if (bytag(ints) != 1001) fail_assert(129);
	if (bytag(tup) != 1002) fail_assert(130);
	if (bytag(nst) != 1007) fail_assert(131);
	if (bytag(arr) != 1099) fail_assert(132);
}

//======================================================================
// Section 2: .tag and .name
//======================================================================
def tagname() {
	var h = 0;
	for (i < 64) {
		var p = makePay(i);
		h = mix(h, p.tag);
		h = mixs(h, p.name);
		h = mix(h, p.name.length);
	}
	acci(h);
	// a table indexed by tag: the tag is a dense 0-based index
	var counts = Array<int>.new(8);
	var names = Array<string>.new(8);
	for (i < 160) {
		var p = makePay(i);
		counts[p.tag]++;
		names[p.tag] = p.name;
	}
	var g = 0;
	for (i < counts.length) {
		g = mix(g, counts[i]);
		g = mixs(g, names[i]);
	}
	acci(g);
	for (i < counts.length) if (counts[i] != 20) fail_assert(201);

	if (Pay.Empty.tag != 0) fail_assert(202);
	if (Pay.Ints(0, 0).tag != 1) fail_assert(203);
	if (Pay.Tup((0, null)).tag != 2) fail_assert(204);
	if (Pay.Tup3((0, 0, 0)).tag != 3) fail_assert(205);
	if (Pay.Arr(null).tag != 4) fail_assert(206);
	if (Pay.Str(null).tag != 5) fail_assert(207);
	if (Pay.Ref(null).tag != 6) fail_assert(208);
	if (Pay.Nested(Shape.Nothing, 0).tag != 7) fail_assert(209);
	if (Pay.Empty.name.length != 5) fail_assert(210);
	if (Pay.Ints(0, 0).name.length != 4) fail_assert(211);
	if (Pay.Nested(Shape.Nothing, 0).name.length != 6) fail_assert(212);
	if (Pay.Empty.name[0] != 'E') fail_assert(213);
	if (Pay.Str(null).name[0] != 'S') fail_assert(214);
	if (Shape.Nothing.tag != 0) fail_assert(215);
	if (Shape.Circle(1).tag != 1) fail_assert(216);
	if (Shape.Tri(1, 1).tag != 4) fail_assert(217);
	if (Op.C0.tag != 0) fail_assert(218);
	if (Op.C19(0, 0, 0).tag != 19) fail_assert(219);
	if (Op.C13.name.length != 3) fail_assert(220);
	// two constructions of the same case share the same name string object
	var n1 = Pay.Ints(1, 2).name;
	var n2 = Pay.Ints(3, 4).name;
	if (n1 != n2) fail_assert(221);
}

//======================================================================
// Section 3: case queries and casts
//======================================================================
def queryAll(h: int, p: Pay) -> int {
	var g = mixb(h, Pay.Empty.?(p));
	g = mixb(g, Pay.Ints.?(p));
	g = mixb(g, Pay.Tup.?(p));
	g = mixb(g, Pay.Tup3.?(p));
	g = mixb(g, Pay.Arr.?(p));
	g = mixb(g, Pay.Str.?(p));
	g = mixb(g, Pay.Ref.?(p));
	g = mixb(g, Pay.Nested.?(p));
	return g;
}
def querycast() {
	var h = 0;
	for (i < 160) {
		var p = makePay(i);
		h = queryAll(h, p);
		if (Pay.Ints.?(p)) h = mix(h, Pay.Ints.!(p).a * Pay.Ints.!(p).b);
		if (Pay.Str.?(p)) h = mixs(h, Pay.Str.!(p).s);
		if (Pay.Nested.?(p)) h = mix(h, Pay.Nested.!(p).k);
		if (Pay.Tup.?(p)) h = mix(h, Pay.Tup.!(p).t.0);
	}
	acci(h);

	// queries and casts as first-class functions
	def QUERIES: Array<Pay -> bool> = [
		Pay.Empty.?, Pay.Ints.?, Pay.Tup.?, Pay.Tup3.?,
		Pay.Arr.?, Pay.Str.?, Pay.Ref.?, Pay.Nested.?
	];
	var g = 0;
	for (k < QUERIES.length) {
		var n = 0;
		for (i < 160) if (QUERIES[k](makePay(i))) n++;
		g = mix(g, n);
	}
	acci(g);
	var toInts: Pay -> Pay.Ints = Pay.Ints.!;
	var k = 0;
	for (i < 160) {
		var p = makePay(i);
		if (Pay.Ints.?(p)) k = mix(k, toInts(p).a);
	}
	acci(k);

	var ints: Pay = Pay.Ints(3, 4);
	var str: Pay = Pay.Str(WORDS[0]);
	if (!Pay.Ints.?(ints)) fail_assert(301);
	if (Pay.Str.?(ints)) fail_assert(302);
	if (Pay.Ints.!(ints).a != 3) fail_assert(303);
	if (Pay.Ints.!(ints).b != 4) fail_assert(304);
	if (Pay.Str.!(str).s.length != 2) fail_assert(305);
	if (toInts(ints).b != 4) fail_assert(306);
	// a query function value agrees with the query operator
	var q: Pay -> bool = Pay.Str.?;
	if (q(ints)) fail_assert(307);
	if (!q(str)) fail_assert(308);
	// the parent type query holds for every case
	if (!Pay.?<Pay>(ints)) fail_assert(309);
	if (!Pay.?<Pay>(str)) fail_assert(310);
	// queries on the Shape hierarchy
	var sh: Shape = Shape.Rect(2, 3);
	if (!Shape.Rect.?(sh)) fail_assert(311);
	if (Shape.Sq.?(sh)) fail_assert(312);
	if (Shape.Rect.!(sh).w != 2) fail_assert(313);
	if (Shape.Rect.!(sh).h != 3) fail_assert(314);
}

//======================================================================
// Section 4: a variant with many cases
//======================================================================
def evalOp(o: Op) -> int {
	match (o) {
		C0 => return 0;
		C1(x) => return x;
		C2(x) => return x * 2;
		C3(x, y) => return x + y;
		C4 => return 4;
		C5(s) => return if(s == null, -5, s.length);
		C6(x) => return x - 6;
		C7(x, y) => return x * y;
		C8 => return 8;
		C9(x) => return x / 3;
		C10(x) => return x % 7;
		C11(s) => return if(s == null, -11, s.length * 11);
		C12(x, y) => return x - y;
		C13 => return 13;
		C14(x) => return x ^ 14;
		C15(x) => return x & 15;
		C16(t) => return t.0 * t.1;
		C17 => return 17;
		C18(x) => return x << 2;
		C19(x, y, z) => return x + y * z;
	}
}
def makeOp(i: int) -> Op {
	var a = NUMS[i % NUMS.length];
	var b = NUMS[(i + 3) % NUMS.length];
	match (i % 20) {
		0 => return Op.C0;
		1 => return Op.C1(a);
		2 => return Op.C2(a);
		3 => return Op.C3(a, b);
		4 => return Op.C4;
		5 => return Op.C5(WORDS[i % WORDS.length]);
		6 => return Op.C6(a);
		7 => return Op.C7(a, b);
		8 => return Op.C8;
		9 => return Op.C9(a);
		10 => return Op.C10(a);
		11 => return Op.C11(WORDS[i % WORDS.length]);
		12 => return Op.C12(a, b);
		13 => return Op.C13;
		14 => return Op.C14(a);
		15 => return Op.C15(a);
		16 => return Op.C16((a, b));
		17 => return Op.C17;
		18 => return Op.C18(a);
		_ => return Op.C19(a, b, i % 5);
	}
}
def manycases() {
	var h = 0;
	var seen = Array<int>.new(20);
	for (i < 400) {
		var o = makeOp(i);
		h = mix(h, evalOp(o));
		h = mix(h, o.tag);
		h = mixs(h, o.name);
		seen[o.tag]++;
	}
	for (i < seen.length) h = mix(h, seen[i]);
	acci(h);
	for (i < seen.length) if (seen[i] != 20) fail_assert(401);

	// tag-driven dispatch table over all 20 cases
	var g = 0;
	for (i < 400) {
		var o = makeOp(i);
		match (o.tag) {
			0 => g = mix(g, 100);
			5 => g = mix(g, 105);
			11 => g = mix(g, 111);
			19 => g = mix(g, 119);
			_ => g = mix(g, o.tag);
		}
	}
	acci(g);

	if (evalOp(Op.C0) != 0) fail_assert(402);
	if (evalOp(Op.C1(5)) != 5) fail_assert(403);
	if (evalOp(Op.C2(5)) != 10) fail_assert(404);
	if (evalOp(Op.C3(5, 6)) != 11) fail_assert(405);
	if (evalOp(Op.C5(null)) != -5) fail_assert(406);
	if (evalOp(Op.C5(WORDS[1])) != 3) fail_assert(407);
	if (evalOp(Op.C7(5, 6)) != 30) fail_assert(408);
	if (evalOp(Op.C9(10)) != 3) fail_assert(409);
	if (evalOp(Op.C10(10)) != 3) fail_assert(410);
	if (evalOp(Op.C11(WORDS[1])) != 33) fail_assert(411);
	if (evalOp(Op.C14(1)) != 15) fail_assert(412);
	if (evalOp(Op.C15(255)) != 15) fail_assert(413);
	if (evalOp(Op.C16((3, 4))) != 12) fail_assert(414);
	if (evalOp(Op.C18(3)) != 12) fail_assert(415);
	if (evalOp(Op.C19(1, 2, 3)) != 7) fail_assert(416);
	if (Op.C17.tag != 17) fail_assert(417);
	var o13: Op = Op.C13;
	if (!Op.C13.?(o13)) fail_assert(418);
	if (Op.C17.?(o13)) fail_assert(419);
}

//======================================================================
// Section 5: tuple and array payloads
//======================================================================
def payloads() {
	var tups = Array<Pay>.new(64);
	var arrs = Array<Pay>.new(64);
	for (i < tups.length) {
		tups[i] = Pay.Tup3((i, i * i, i - 5));
		var a = Array<int>.new(4);
		for (j < 4) a[j] = i * 4 + j;
		arrs[i] = Pay.Arr(a);
	}
	var h = 0;
	for (i < tups.length) {
		h = mix(h, destructure(tups[i]));
		h = mix(h, destructure(arrs[i]));
		h = mix(h, Pay.Tup3.!(tups[i]).t.1);
		var a = Pay.Arr.!(arrs[i]).a;
		for (j < a.length) h = mix(h, a[j]);
	}
	acci(h);

	// tuple payloads compare componentwise; array payloads compare by reference
	var g = 0;
	for (i < tups.length) {
		g = mixb(g, tups[i] == Pay.Tup3((i, i * i, i - 5)));
		g = mixb(g, arrs[i] == Pay.Arr(Pay.Arr.!(arrs[i]).a));
		g = mixb(g, tups[i] == tups[(i + 1) % tups.length]);
	}
	acci(g);

	var t1: Pay = Pay.Tup3((1, 2, 3));
	var t2: Pay = Pay.Tup3((1, 2, 3));
	var t3: Pay = Pay.Tup3((1, 2, 4));
	if (!(t1 == t2)) fail_assert(501);
	if (t1 == t3) fail_assert(502);
	if (Pay.Tup3.!(t1).t.2 != 3) fail_assert(503);
	var s1: Pay = Pay.Tup((7, WORDS[0]));
	var s2: Pay = Pay.Tup((7, WORDS[0]));
	if (!(s1 == s2)) fail_assert(504);
	if (s1 == Pay.Tup((7, WORDS[1]))) fail_assert(505);
	// arrays are compared by reference, so equal contents are not enough
	var a1 = Array<int>.new(2);
	var a2 = Array<int>.new(2);
	a1[0] = 5;
	a2[0] = 5;
	var p1: Pay = Pay.Arr(a1);
	var p2: Pay = Pay.Arr(a2);
	if (!(p1 == Pay.Arr(a1))) fail_assert(506);
	if (p1 == p2) fail_assert(507);
	// mutating the payload array is visible through the variant
	a1[1] = 9;
	if (Pay.Arr.!(p1).a[1] != 9) fail_assert(508);
	if (destructure(p1) != 14) fail_assert(509);
	// class payloads compare by reference too
	var o1 = Obj.new(3), o2 = Obj.new(3);
	var r1: Pay = Pay.Ref(o1);
	if (!(r1 == Pay.Ref(o1))) fail_assert(510);
	if (r1 == Pay.Ref(o2)) fail_assert(511);
	o1.w = 4;
	if (destructure(r1) != 34) fail_assert(512);
}

//======================================================================
// Section 6: variant methods
//======================================================================
def shapes() {
	var ss = Array<Shape>.new(80);
	for (i < ss.length) {
		var a = NUMS[i % NUMS.length];
		var b = NUMS[(i + 4) % NUMS.length];
		match (i % 5) {
			0 => ss[i] = Shape.Nothing;
			1 => ss[i] = Shape.Circle(a);
			2 => ss[i] = Shape.Sq(a);
			3 => ss[i] = Shape.Rect(a, b);
			_ => ss[i] = Shape.Tri(a, b);
		}
	}
	var h = 0;
	for (i < ss.length) {
		var s = ss[i];
		h = mix(h, s.area());
		h = mix(h, s.sides());
		h = mix(h, s.summary());
		h = mix(h, s.tag);
		h = mixs(h, s.name);
	}
	acci(h);

	// methods reached through a first-class function value
	def METHODS: Array<Shape -> int> = [Shape.area, Shape.sides, Shape.summary];
	var g = 0;
	for (k < METHODS.length) for (i < ss.length) g = mix(g, METHODS[k](ss[i]));
	acci(g);

	// the parent method is inherited where a case does not override it
	if (Shape.Nothing.area() != 0) fail_assert(601);
	if (Shape.Nothing.sides() != 0) fail_assert(602);
	if (Shape.Circle(2).area() != 12) fail_assert(603);
	if (Shape.Circle(2).sides() != 0) fail_assert(604);	// not overridden
	if (Shape.Sq(5).area() != 25) fail_assert(605);
	if (Shape.Sq(5).sides() != 4) fail_assert(606);
	if (Shape.Rect(3, 4).area() != 12) fail_assert(607);
	if (Shape.Tri(6, 4).area() != 12) fail_assert(608);
	if (Shape.Tri(6, 4).sides() != 3) fail_assert(609);
	// summary() is declared on the parent and sees the overrides
	if (Shape.Nothing.summary() != 0) fail_assert(610);
	if (Shape.Circle(2).summary() != 1201) fail_assert(611);	// 12*100 + 0 + 1
	if (Shape.Sq(5).summary() != 2542) fail_assert(612);		// 25*100 + 40 + 2
	if (Shape.Rect(3, 4).summary() != 1243) fail_assert(613);
	if (Shape.Tri(6, 4).summary() != 1234) fail_assert(614);
	// dispatch through a parent-typed variable
	var v: Shape = Shape.Sq(5);
	if (v.area() != 25) fail_assert(615);
	if (v.summary() != 2542) fail_assert(616);
	var f: Shape -> int = Shape.area;
	if (f(Shape.Rect(3, 4)) != 12) fail_assert(617);
	if (f(Shape.Nothing) != 0) fail_assert(618);
}

//======================================================================
// Section 7: variants in arrays, globals, tuples and class fields
//======================================================================
class Holder {
	var p: Pay;
	def s: Shape;
	var pair: (Pay, Shape);
	var many: Array<Pay>;
	new(s) {
		p = Pay.Empty;
		pair = (Pay.Empty, s);
		many = Array<Pay>.new(4);
		for (i < many.length) many[i] = Pay.Ints(i, i * 2);
	}
	def total() -> int {
		var t = destructure(p) + s.area() + destructure(pair.0) + pair.1.sides();
		for (i < many.length) t += destructure(many[i]);
		return t;
	}
}
var gPay: Pay;
var gShape: Shape;
var gTup: (Pay, Shape, int);
var gArr: Array<Pay>;

def storage() {
	gPay = Pay.Empty;
	gShape = Shape.Nothing;
	gTup = (Pay.Empty, Shape.Nothing, 0);
	gArr = null;

	var h = mix(0, destructure(gPay));
	h = mix(h, gShape.area());
	h = mix(h, gTup.2);
	h = mixb(h, gArr == null);
	acci(h);
	if (destructure(gPay) != -1) fail_assert(701);
	if (gShape.tag != 0) fail_assert(702);
	if (gArr != null) fail_assert(703);

	gArr = Array<Pay>.new(96);
	for (i < gArr.length) gArr[i] = makePay(i);
	var g = 0;
	for (i < gArr.length) {
		gPay = gArr[i];
		gShape = Shape.Rect(i, i + 1);
		gTup = (gPay, gShape, i);
		g = mix(g, destructure(gPay));
		g = mix(g, gShape.area());
		g = mix(g, destructure(gTup.0));
		g = mix(g, gTup.1.summary());
		g = mix(g, gTup.2);
		g = mix(g, gArr[i].tag);
	}
	acci(g);
	if (gTup.2 != 95) fail_assert(704);
	if (gShape.area() != 95 * 96) fail_assert(705);
	if (gArr[7].tag != 7) fail_assert(706);

	// variants inside class fields
	var hs = Array<Holder>.new(40);
	for (i < hs.length) {
		var x = Holder.new(Shape.Sq(i));
		x.p = makePay(i);
		x.pair = (makePay(i + 1), Shape.Rect(i, 2));
		hs[i] = x;
	}
	var k = 0;
	for (i < hs.length) {
		k = mix(k, hs[i].total());
		k = mix(k, hs[i].s.area());
		k = mix(k, hs[i].p.tag);
		k = mix(k, hs[i].pair.1.sides());
	}
	acci(k);

	var one = Holder.new(Shape.Sq(3));
	// p = Empty (-1), s.area = 9, pair.0 = Empty (-1), pair.1.sides = 4,
	// many = Ints(0,0), Ints(1,2), Ints(2,4), Ints(3,6) summing to 0+3+6+9
	if (one.total() != -1 + 9 - 1 + 4 + 18) fail_assert(707);
	one.p = Pay.Ints(10, 20);
	if (one.total() != 30 + 9 - 1 + 4 + 18) fail_assert(708);
	if (one.s.area() != 9) fail_assert(709);
	if (one.many[3].tag != 1) fail_assert(710);
	if (destructure(one.many[3]) != 9) fail_assert(711);

	gPay = Pay.Empty;
	gShape = Shape.Nothing;
	gTup = (Pay.Empty, Shape.Nothing, 0);
	gArr = null;
}

//======================================================================
// Section 8: equality
//======================================================================
def equality() {
	var h = 0;
	for (i < 64) {
		var a = makePay(i);
		var b = makePay(i);
		var c = makePay(i + 1);
		h = mixb(h, a == b);
		h = mixb(h, a == c);
		h = mixb(h, a != c);
		h = mixb(h, a == a);
	}
	acci(h);
	var g = 0;
	for (i < 40) {
		var s = makeOp(i);
		for (j < 40) g = mixb(g, s == makeOp(j));
	}
	acci(g);

	// same case, same payload
	if (!(Pay.Empty == Pay.Empty)) fail_assert(801);
	if (!(Pay.Ints(1, 2) == Pay.Ints(1, 2))) fail_assert(802);
	if (Pay.Ints(1, 2) == Pay.Ints(1, 3)) fail_assert(803);
	// different cases are never equal, even with the same field values
	var e: Pay = Pay.Empty;
	var i1: Pay = Pay.Ints(1, 2);
	var s1: Pay = Pay.Str(WORDS[0]);
	if (e == i1) fail_assert(804);
	if (i1 == s1) fail_assert(805);
	if (!(i1 != s1)) fail_assert(806);
	// nested variants compare structurally
	var n1: Pay = Pay.Nested(Shape.Rect(2, 3), 4);
	var n2: Pay = Pay.Nested(Shape.Rect(2, 3), 4);
	var n3: Pay = Pay.Nested(Shape.Rect(2, 4), 4);
	var n4: Pay = Pay.Nested(Shape.Sq(2), 4);
	if (!(n1 == n2)) fail_assert(807);
	if (n1 == n3) fail_assert(808);
	if (n1 == n4) fail_assert(809);
	// string payloads compare by reference: equal contents are not enough
	var w1 = Array<byte>.new(2);
	var w2 = Array<byte>.new(2);
	w1[0] = 'a';
	w1[1] = 'y';
	w2[0] = 'a';
	w2[1] = 'y';
	if (Pay.Str(w1) == Pay.Str(w2)) fail_assert(810);
	if (!(Pay.Str(w1) == Pay.Str(w1))) fail_assert(811);
	// Shape cases
	if (!(Shape.Nothing == Shape.Nothing)) fail_assert(812);
	var sh: Shape = Shape.Sq(3);
	if (!(sh == Shape.Sq(3))) fail_assert(813);
	if (sh == Shape.Circle(3)) fail_assert(814);
	if (sh == Shape.Rect(3, 3)) fail_assert(815);
	// Op with many cases
	var o: Op = Op.C12(5, 6);
	if (!(o == Op.C12(5, 6))) fail_assert(816);
	if (o == Op.C7(5, 6)) fail_assert(817);
	if (o == Op.C12(6, 5)) fail_assert(818);
	if (!(Op.C0 == Op.C0)) fail_assert(819);
	var z: Op = Op.C0;
	if (z == Op.C4) fail_assert(820);
}

//======================================================================
// Section 9: allocation churn with boxed variants
//======================================================================
def churn() {
	srand(0x5EED91);
	var keep = Array<Pay>.new(24);
	var ops = Array<Op>.new(24);
	for (i < keep.length) {
		keep[i] = Pay.Empty;
		ops[i] = Op.C0;
	}
	var h = 0;
	for (i < 6000) {
		var p = makePay(randn(160));
		var o = makeOp(randn(400));
		if ((i % 211) == 0) {
			keep[(i / 211) % keep.length] = p;
			ops[(i / 211) % ops.length] = o;
		}
		if ((i % 401) == 0) h = mix(h, destructure(p) + evalOp(o));
	}
	acci(h);
	var g = 0;
	for (i < keep.length) {
		g = mix(g, destructure(keep[i]));
		g = mix(g, keep[i].tag);
		g = mix(g, evalOp(ops[i]));
		g = mix(g, ops[i].tag);
		g = mixs(g, ops[i].name);
	}
	acci(g);

	// arrays of variants that are mostly garbage
	var live: Array<Pay>;
	for (i < 400) {
		var a = Array<Pay>.new(32);
		for (j < 32) a[j] = makePay(randn(160));
		if (i == 399) live = a;
	}
	var k = 0;
	for (i < live.length) {
		k = mix(k, destructure(live[i]));
		k = mix(k, live[i].tag);
	}
	acci(k);
}

//======================================================================
def run(a: int) {
	crc = a;
	failed = 0;
	if (a == 0 || a == 1) matchforms();
	if (a == 0 || a == 2) tagname();
	if (a == 0 || a == 3) querycast();
	if (a == 0 || a == 4) manycases();
	if (a == 0 || a == 5) payloads();
	if (a == 0 || a == 6) shapes();
	if (a == 0 || a == 7) storage();
	if (a == 0 || a == 8) equality();
	if (a == 0 || a == 9) churn();
}
def main(a: int) -> int {
	run(a);
	if (failed != 0) return failed;
	return crc;
}
