//@execute 0=-1468365431; 1=243044166; 2=-1367719481; 3=-2041069865; 4=-226289718; 5=-2008115333; 6=1653946201; 7=-1493167431; 8=-202046528
// Smoke test: first-class functions.
// Operator references, bound method delegates, partial application, closures,
// and function values stored in arrays, tuples, globals, class fields and
// variant cases -- then composed and applied in bulk. Every result folds into
// a running CRC. Input selects the section.

//======================================================================
// CRC accumulator
//======================================================================
var crc: int;

def acci(x: int) {
	var h = crc ^ x;
	h = h * 0x01000193;
	crc = h ^ (h >>> 15);
}
def accl(x: long) {
	acci(int.view(u32.view(x)));
	acci(int.view(u32.view(x >> 32)));
}
def accb(x: bool) {
	acci(if(x, 0x5A5A5A5A, 0x0F0F0F0F));
}
def accs(s: string) {
	if (s == null) { acci(-1); return; }
	acci(s.length);
	for (i < s.length) acci(s[i]);
}

def ARGS: Array<int> = [
	0, 1, -1, 2, -2, 7, -7, 31, -31, 255, -256,
	65535, -65536, 1000000, -1000000, 2147483647, -2147483648
];
def NAMES: Array<string> = ["add", "sub", "mul", "and", "or", "xor"];

//======================================================================
// Section 1: operator references and plain function values
//======================================================================
def add(a: int, b: int) -> int { return a + b; }
def sub(a: int, b: int) -> int { return a - b; }
def safediv(a: int, b: int) -> int {
	if (b == 0) return 0;
	if (b == -1) return 0 - a;	// avoid int.min / -1 overflow
	return a / b;
}
def opsrefs() {
	def OPS: Array<(int, int) -> int> = [
		int.+, int.-, int.*, int.&, int.|, int.^, add, sub, safediv
	];
	// shift operators take a byte amount, not an int
	def SHIFTS: Array<(int, byte) -> int> = [int.<<, int.>>, int.>>>];
	for (k < SHIFTS.length) {
		var f = SHIFTS[k];
		for (i < ARGS.length) for (b < 40) acci(f(ARGS[i], byte.view(b)));
	}
	for (k < OPS.length) {
		var f = OPS[k];
		for (i < ARGS.length) {
			for (j < ARGS.length) {
				// shifts by huge amounts are well defined in Virgil, but keep
				// the divisor of safediv away from the overflow case above
				acci(f(ARGS[i], ARGS[j]));
			}
		}
	}
	// comparison operator references
	def CMPS: Array<(int, int) -> bool> = [int.<, int.<=, int.>, int.>=, int.==, int.!=];
	for (k < CMPS.length) {
		var f = CMPS[k];
		for (i < ARGS.length) for (j < ARGS.length) accb(f(ARGS[i], ARGS[j]));
	}
	// function values compared and selected at runtime
	var g: (int, int) -> int = if(ARGS.length > 0, int.+, int.-);
	acci(g(3, 4));
	acci(g(-7, 31));
	// NOTE: comparing a function value against an operator reference (g == int.+)
	// is deliberately not checked here -- the interpreter and the compiled
	// backends disagree on it. Equality of ordinary function values is portable.
	accb(add == add);
	accb(add == sub);
	var p: (int, int) -> int = add, q: (int, int) -> int = sub;
	accb(p == add);
	accb(p == q);
	// unary and conversion operators as values
	def U: Array<int -> long> = [long.!, long.view];
	for (k < U.length) for (i < ARGS.length) accl(U[k](ARGS[i]));
	var tb: int -> byte = byte.view;
	for (i < ARGS.length) acci(int.!(tb(ARGS[i])));
}

//======================================================================
// Section 2: bound method delegates and virtual dispatch
//======================================================================
class Acc {
	var total: int;
	def name: string;
	new(name) { }
	def step(x: int) -> int { total = total + x; return total; }
	def kind() -> string { return "acc"; }
	def combine(a: int, b: int) -> int { return a + b; }
}
class MulAcc extends Acc {
	new(name: string) super(name) { }
	def step(x: int) -> int { total = total * 2 + x; return total; }
	def kind() -> string { return "mul"; }
	def combine(a: int, b: int) -> int { return a * b; }
}
class XorAcc extends Acc {
	new(name: string) super(name) { }
	def step(x: int) -> int { total = total ^ (x * 3); return total; }
	def kind() -> string { return "xor"; }
	def combine(a: int, b: int) -> int { return a ^ b; }
}
def delegates() {
	var objs: Array<Acc> = [
		Acc.new("a"), MulAcc.new("m"), XorAcc.new("x"),
		Acc.new("a2"), MulAcc.new("m2"), XorAcc.new("x2")
	];
	// delegates bound to each receiver; dispatch is fixed at bind time
	var steps = Array<int -> int>.new(objs.length);
	var kinds = Array<void -> string>.new(objs.length);
	var combines = Array<(int, int) -> int>.new(objs.length);
	for (i < objs.length) {
		steps[i] = objs[i].step;
		kinds[i] = objs[i].kind;
		combines[i] = objs[i].combine;
	}
	for (r < 4) {
		for (i < steps.length) {
			for (j < ARGS.length) acci(steps[i](ARGS[j]));
			accs(kinds[i]());
		}
	}
	for (i < objs.length) {
		acci(objs[i].total);
		accs(objs[i].name);
		accb(MulAcc.?(objs[i]));
		accb(XorAcc.?(objs[i]));
	}
	for (i < combines.length) {
		for (j < ARGS.length) acci(combines[i](ARGS[j], ARGS[(j + 1) % ARGS.length]));
	}
	// unbound method references applied to an explicit receiver
	var um: (Acc, int) -> int = Acc.step;
	for (i < objs.length) acci(um(objs[i], 5));
	// delegate identity
	var d1 = objs[0].step, d2 = objs[0].step, d3 = objs[1].step;
	accb(d1 == d2);
	accb(d1 == d3);
	// an unassigned function value is null and compares equal to null
	var nf: int -> int;
	accb(nf == null);
	accb(d1 == null);
}

//======================================================================
// Section 3: partial application
//======================================================================
def four(a: int, b: int, c: int, d: int) -> int {
	return a * 1000 + b * 100 + c * 10 + d;
}
def mixed(a: int, s: string, b: bool) -> int {
	return a + s.length + if(b, 1, 0);
}
def partial() {
	var f1 = four(1, _, _, _);
	var f2 = four(_, 2, _, _);
	var f3 = four(_, _, 3, _);
	var f4 = four(_, _, _, 4);
	var g1 = four(1, 2, _, _);
	var g2 = four(_, _, 3, 4);
	var g3 = four(1, _, 3, _);
	var h1 = four(1, 2, 3, _);
	var h2 = four(_, 2, 3, 4);
	for (i < ARGS.length) {
		var v = ARGS[i] % 10;
		acci(f1(v, v, v));
		acci(f2(v, v, v));
		acci(f3(v, v, v));
		acci(f4(v, v, v));
		acci(g1(v, v));
		acci(g2(v, v));
		acci(g3(v, v));
		acci(h1(v));
		acci(h2(v));
	}
	// partial application over operators and mixed types
	var inc = int.+(1, _);
	var dec = int.-(_, 1);
	var neg = int.-(0, _);
	for (i < ARGS.length) {
		acci(inc(ARGS[i]));
		acci(dec(ARGS[i]));
		acci(neg(ARGS[i]));
	}
	var m1 = mixed(_, "hello", true);
	var m2 = mixed(10, _, false);
	var m3 = mixed(10, "xy", _);
	for (i < ARGS.length) acci(m1(ARGS[i] % 100));
	for (i < NAMES.length) acci(m2(NAMES[i]));
	acci(m3(true));
	acci(m3(false));
	// partially applied bound method
	var acc = Acc.new("p");
	var st = acc.step;
	var pa = acc.combine(7, _);
	for (i < ARGS.length) { acci(st(ARGS[i] % 50)); acci(pa(ARGS[i] % 50)); }
	acci(acc.total);
	// partial application of a constructor
	var mk = Pair.new(3, _);
	for (i < ARGS.length) acci(mk(ARGS[i]).sum());
}
class Pair(a: int, b: int) {
	def sum() -> int { return a + b; }
}

//======================================================================
// Section 4: closures
//======================================================================
def makeAdder(n: int) -> int -> int {
	return fun (x: int) => x + n;
}
// Closures capture locals by value, so mutable counter state has to live on the
// heap; each call to makeCounter() must produce an independent counter.
class Counter { var n: int; }
def makeCounter() -> void -> int {
	var c = Counter.new();
	return fun () -> int {
		c.n++;
		return c.n;
	};
}
def makeChain(n: int) -> int -> int {
	var f: int -> int = fun (x: int) => x;
	for (i < n) {
		var k = i + 1;			// fresh capture each iteration
		var prev = f;
		f = fun (x: int) => prev(x) + k;
	}
	return f;
}
def closures() {
	var adders = Array<int -> int>.new(16);
	for (i < adders.length) adders[i] = makeAdder(i * 7 - 40);
	for (i < adders.length) for (j < ARGS.length) acci(adders[i](ARGS[j]));

	// each counter must own its captured state
	var c1 = makeCounter(), c2 = makeCounter();
	for (i < 20) { acci(c1()); if ((i % 3) == 0) acci(c2()); }
	acci(c1());
	acci(c2());

	// capture of a loop variable: each closure keeps its own copy
	var chain = makeChain(12);
	for (i < ARGS.length) acci(chain(ARGS[i] % 1000));

	// closure capturing a mutable object rather than a value
	var acc = Acc.new("c");
	var bump = fun (x: int) -> int { return acc.step(x); };
	for (i < ARGS.length) acci(bump(ARGS[i] % 30));
	acci(acc.total);

	// closure capturing an array and a tuple
	var data = Array<int>.new(32);
	for (i < data.length) data[i] = i * i - 100;
	var t = (3, 5);
	var probe = fun (i: int) -> int { return data[(i & 0x7FFFFFFF) % data.length] + t.0 * t.1; };
	for (i < ARGS.length) acci(probe(ARGS[i]));
	// mutating the captured array is visible through the closure
	for (i < data.length) data[i] = data[i] * -1;
	for (i < ARGS.length) acci(probe(ARGS[i]));
}

//======================================================================
// Section 5: functions inside data structures
//======================================================================
type Op {
	case Bin(label: string, f: (int, int) -> int);
	case Un(f: int -> int);
	case None;
}
class Handler {
	var fn: int -> int;
	def tag: int;
	new(tag, fn) { }
}
component Registry {
	var table: Array<(int, int) -> int> = [int.+, int.-, int.*];
	var fallback: (int, int) -> int = int.^;
	def pick(i: int) -> (int, int) -> int {
		if (i < 0 || i >= table.length) return fallback;
		return table[i];
	}
}
var gfun: int -> int;
var gtup: (int -> int, (int, int) -> int);

def applyOp(o: Op, a: int, b: int) -> int {
	match (o) {
		Bin(_, f) => return f(a, b);
		Un(f) => return f(a);
		None => return -1;
	}
}
def stored() {
	// reset globals: the harness may run several inputs in one process
	gfun = null;
	gtup = (null, null);

	var ops: Array<Op> = [
		Op.Bin("add", int.+), Op.Bin("sub", int.-), Op.Bin("mul", int.*),
		Op.Bin("and", int.&), Op.Un(makeAdder(5)), Op.Un(int.-(0, _)),
		Op.None
	];
	for (k < ops.length) {
		acci(ops[k].tag);
		for (i < ARGS.length) acci(applyOp(ops[k], ARGS[i], ARGS[(i + 2) % ARGS.length]));
	}
	match (ops[0]) {
		Bin(label, _) => accs(label);
		_ => acci(-2);
	}

	// functions in class fields, dispatched through an array of handlers
	var hs = Array<Handler>.new(8);
	for (i < hs.length) hs[i] = Handler.new(i, makeAdder(i * 3));
	for (i < hs.length) {
		acci(hs[i].tag);
		for (j < ARGS.length) acci(hs[i].fn(ARGS[j]));
	}
	for (i < hs.length) hs[i].fn = int.-(_, i);	// overwrite the field
	for (i < hs.length) for (j < ARGS.length) acci(hs[i].fn(ARGS[j]));

	// functions in a component and in globals
	for (i = -1; i < 4; i++) {
		var f = Registry.pick(i);
		for (j < ARGS.length) acci(f(ARGS[j], 3));
	}
	gfun = makeAdder(100);
	gtup = (gfun, int.*);
	for (i < ARGS.length) {
		acci(gfun(ARGS[i]));
		acci(gtup.0(ARGS[i]));
		acci(gtup.1(ARGS[i], 2));
	}
	// functions in tuples inside arrays
	var pairs = Array<(int -> int, int)>.new(8);
	for (i < pairs.length) pairs[i] = (makeAdder(i), i * i);
	for (i < pairs.length) for (j < ARGS.length) acci(pairs[i].0(ARGS[j]) + pairs[i].1);
}

//======================================================================
// Section 6: higher-order combinators
//======================================================================
def mapa(f: int -> int, a: Array<int>) -> Array<int> {
	var r = Array<int>.new(a.length);
	for (i < a.length) r[i] = f(a[i]);
	return r;
}
def folda(f: (int, int) -> int, init: int, a: Array<int>) -> int {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def filtera(p: int -> bool, a: Array<int>) -> Array<int> {
	var n = 0;
	for (i < a.length) if (p(a[i])) n++;
	var r = Array<int>.new(n);
	var k = 0;
	for (i < a.length) if (p(a[i])) { r[k] = a[i]; k++; }
	return r;
}
def compose(f: int -> int, g: int -> int) -> int -> int {
	return fun (x: int) => g(f(x));
}
def curry(f: (int, int) -> int) -> int -> (int -> int) {
	return fun (a: int) => f(a, _);
}
def twice(f: int -> int) -> int -> int {
	return fun (x: int) => f(f(x));
}
def higher() {
	var data = Array<int>.new(48);
	for (i < data.length) data[i] = (i * 37) % 101 - 50;

	def FS: Array<int -> int> = [makeAdder(3), int.*(_, 2), int.-(0, _), makeAdder(-9)];
	for (k < FS.length) {
		var m = mapa(FS[k], data);
		for (i < m.length) acci(m[i]);
		acci(folda(int.+, 0, m));
		acci(folda(int.^, -1, m));
	}
	def PS: Array<int -> bool> = [int.<(_, 0), int.>(_, 0), int.==(_, 0)];
	for (k < PS.length) {
		var f = filtera(PS[k], data);
		acci(f.length);
		for (i < f.length) acci(f[i]);
	}
	// composition, currying, repeated application
	var c1 = compose(makeAdder(5), int.*(_, 3));
	var c2 = compose(c1, makeAdder(-2));
	var c3 = compose(c2, c2);
	for (i < ARGS.length) {
		acci(c1(ARGS[i] % 1000));
		acci(c2(ARGS[i] % 1000));
		acci(c3(ARGS[i] % 1000));
	}
	var cur = curry(int.+);
	var add10 = cur(10);
	for (i < ARGS.length) acci(add10(ARGS[i]));
	var t2 = twice(makeAdder(7));
	var t4 = twice(t2);
	for (i < ARGS.length) { acci(t2(ARGS[i])); acci(t4(ARGS[i])); }
	// build a pipeline of composed closures and run the whole array through it
	var pipe: int -> int = fun (x: int) => x;
	for (i < 8) pipe = compose(pipe, makeAdder(i * i));
	var out = mapa(pipe, data);
	for (i < out.length) acci(out[i]);
	acci(folda(int.+, 0, out));
}

//======================================================================
// Section 7: polymorphic functions
//======================================================================
def ident<T>(x: T) -> T { return x; }
def applyp<A, B>(f: A -> B, a: A) -> B { return f(a); }
def mapp<A, B>(f: A -> B, a: Array<A>) -> Array<B> {
	var r = Array<B>.new(a.length);
	for (i < a.length) r[i] = f(a[i]);
	return r;
}
def foldp<A, B>(f: (B, A) -> B, init: B, a: Array<A>) -> B {
	var acc = init;
	for (i < a.length) acc = f(acc, a[i]);
	return acc;
}
def swap<A, B>(t: (A, B)) -> (B, A) { return (t.1, t.0); }
def strlen(s: string) -> int { return s.length; }
def polymorphic() {
	for (i < ARGS.length) {
		acci(ident(ARGS[i]));
		accl(ident(long.!(ARGS[i])));
		accb(ident(ARGS[i] > 0));
	}
	for (i < NAMES.length) accs(ident(NAMES[i]));

	acci(applyp(strlen, "hello"));
	acci(applyp(makeAdder(4), 38));
	accb(applyp(int.<(_, 0), -5));

	var lens = mapp(strlen, NAMES);
	for (i < lens.length) acci(lens[i]);
	acci(foldp(int.+, 0, lens));

	var data = Array<int>.new(24);
	for (i < data.length) data[i] = i * 13 - 100;
	var strs = mapp(fun (x: int) => NAMES[(x & 0x7FFFFFFF) % NAMES.length], data);
	for (i < strs.length) accs(strs[i]);
	acci(foldp(fun (b: int, s: string) => b + s.length, 0, strs));

	var t = swap((3, "abc"));
	accs(t.0);
	acci(t.1);
	var u = swap(swap((7, true)));
	acci(u.0);
	accb(u.1);
	// polymorphic function stored as a value at two instantiations
	var fi: int -> int = ident<int>;
	var fs: string -> string = ident<string>;
	for (i < ARGS.length) acci(fi(ARGS[i]));
	for (i < NAMES.length) accs(fs(NAMES[i]));
}

//======================================================================
// Section 8: closure allocation churn
//======================================================================
def churn() {
	var keep = Array<int -> int>.new(12);
	for (i < keep.length) keep[i] = int.+(0, _);
	var live: int -> int = int.+(0, _);
	for (i < 1500) {
		// most of these closures are immediately garbage
		var k = i % 251;
		var f = fun (x: int) => x + k;
		if ((i % 61) == 0) {
			keep[(i / 61) % keep.length] = f;
			live = compose(live, f);
		}
		if ((i % 17) == 0) acci(f(i));
	}
	for (i < keep.length) for (j < ARGS.length) acci(keep[i](ARGS[j]));
	for (i < ARGS.length) acci(live(ARGS[i] % 10000));
	// closures capturing freshly allocated objects
	var objs = Array<void -> int>.new(64);
	for (i < objs.length) {
		var a = Acc.new("n");
		a.total = i * 3;
		var n = i;
		objs[i] = fun () -> int { return a.step(n); };
	}
	for (r < 3) for (i < objs.length) acci(objs[i]());
}

//======================================================================
def run(a: int) {
	crc = a * 0x9E3779B9;
	if (a == 0 || a == 1) opsrefs();
	if (a == 0 || a == 2) delegates();
	if (a == 0 || a == 3) partial();
	if (a == 0 || a == 4) closures();
	if (a == 0 || a == 5) stored();
	if (a == 0 || a == 6) higher();
	if (a == 0 || a == 7) polymorphic();
	if (a == 0 || a == 8) churn();
}
def main(a: int) -> int {
	run(a);
	return crc;
}
