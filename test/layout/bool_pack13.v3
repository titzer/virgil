//@execute 0=-1307540252; 1=1971861624; 2=-1241904384
// Packing a bool into a byte uses only the low bit of the bool's register, but
// on x86-64 setcc writes a whole byte and leaves the rest of the register alone.
// The mask applied afterwards was one bit too wide, so a bit left in the
// register by an unrelated value leaked into the packed byte, and input 1 --
// which accumulates the packed bytes on their own -- returned 1623939448.
//
// The second pack, the calls, and accumulating x and y separately are all
// load-bearing: any of them removed and the register allocator happens to leave
// a zero in that bit.
def mix(h: int, x: int) -> int {
	var t = h ^ x;
	t = t * 0x01000193;
	return t ^ (t >>> 15);
}
def main(n: int) -> int {
	var g = 0, p = 0, q = 0;
	for (i < 16) {
		var a = u4.view(i);
		var x = u8.pack((a, 0b000u3, (i % 2) == 0));
		var y = u32.pack((0x12u8, a, 0x345u12, 0xABu8));
		g = mix(g, x);
		g = mix(g, int.view(y));
		p = p * 31 + x;
		q = q * 31 + int.view(y);
	}
	if (n == 0) return g;
	if (n == 1) return p;
	return q;
}
