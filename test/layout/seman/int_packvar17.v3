//@seman
// a phantom type parameter is packable no matter what the type argument is
type T { case A(x: u4); case B(y: u4); }
type X<P>(f: u8) { }
def a = u8.pack<X<bool>>;
def b = u8.pack<X<string>>;
def c = u8.pack<X<T>>;
def d = u8.pack<X<T.A>>;
def e = u8.pack<X<int -> int>>;
def f = u8.unpack<X<Array<int>>>;
