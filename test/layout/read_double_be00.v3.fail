//@execute = true
// Reading a `double #big-endian` layout field is not byte-swapped on compiled
// backends. Writes are correct -- big_endian15..18/32/34 already pin the byte
// image a big-endian double write produces, and those pass everywhere -- but
// nothing covered the read direction until now.
//
//	v3i : r.g == double.view(0x3FF8000000000000)   (correct)
//	jar : r.g == double.view(0x000000000000F83F)   (the BE image read as LE)
//
// `float #big-endian` reads are correct; only `double` is affected.
layout D {
	+0	g:	double	#big-endian;
	=8;
}
// big-endian image of 1.5d
def bytes: Array<byte> = [ 0x3F, 0xF8, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 ];
def main() -> bool {
	var r = Ref<D>.at(bytes, 0);
	return r.g == 1.5d;
}
