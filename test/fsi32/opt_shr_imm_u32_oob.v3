//@execute 0=0; 1=0; -1=0; 77777=0; -99999=0
// Logical-shifting a u32 right by exactly its bit width yields 0 (mirrors
// the i64 oob case in opt_shr_imm_i64_oob.v3 for u64, which shifts by 64).
def shr_oob(a: u32) -> u32 { return a >>> 32; }
def main(a: int) -> int {
	return int.view(shr_oob(u32.view(a)));
}
