//@execute 0=true; 1=true; 2=true; 3=true
// long.min / -1L overflows 64 bits and wraps back to long.min (two's-
// complement identity), rather than trapping; every other value divides
// normally. (Compared against precomputed constants since long.min cannot
// be written directly as a negative literal in the @execute directive.)
def values   = [0L, 1L, 77777L, -9223372036854775808L];
def expected = [0L, -1L, -77777L, -9223372036854775808L];
def main(a: int) -> bool {
	return (values[a] / -1L) == expected[a];
}
