//@execute 33=1; 34=1; 35=1; 36=1; 37=1; 38=1; 39=1; 40=1; 41=1; 42=1; 43=1; 44=1; 45=1; 46=1; 47=1; 48=1; 49=1; 50=1; 51=1; 52=1; 53=1; 54=1; 55=1; 56=1; 57=1; 58=1; 59=1; 60=1; 61=1; 62=1; 63=1; 64=1

def num() -> long {
    // 33 bits
    return 0xFFFFFFFF00000000L;
}
def main(a: int) -> int {
    def shift: byte = byte.view(a - 1);
    match (a) {
        33 => return int.view(u33.view(num()) >>> shift);
        34 => return int.view(u34.view(num()) >>> shift);
        35 => return int.view(u35.view(num()) >>> shift);
        36 => return int.view(u36.view(num()) >>> shift);
        37 => return int.view(u37.view(num()) >>> shift);
        38 => return int.view(u38.view(num()) >>> shift);
        39 => return int.view(u39.view(num()) >>> shift);
        40 => return int.view(u40.view(num()) >>> shift);
        41 => return int.view(u41.view(num()) >>> shift);
        42 => return int.view(u42.view(num()) >>> shift);
        43 => return int.view(u43.view(num()) >>> shift);
        44 => return int.view(u44.view(num()) >>> shift);
        45 => return int.view(u45.view(num()) >>> shift);
        46 => return int.view(u46.view(num()) >>> shift);
        47 => return int.view(u47.view(num()) >>> shift);
        48 => return int.view(u48.view(num()) >>> shift);
        49 => return int.view(u49.view(num()) >>> shift);
        50 => return int.view(u50.view(num()) >>> shift);
        51 => return int.view(u51.view(num()) >>> shift);
        52 => return int.view(u52.view(num()) >>> shift);
        53 => return int.view(u53.view(num()) >>> shift);
        54 => return int.view(u54.view(num()) >>> shift);
        55 => return int.view(u55.view(num()) >>> shift);
        56 => return int.view(u56.view(num()) >>> shift);
        57 => return int.view(u57.view(num()) >>> shift);
        58 => return int.view(u58.view(num()) >>> shift);
        59 => return int.view(u59.view(num()) >>> shift);
        60 => return int.view(u60.view(num()) >>> shift);
        61 => return int.view(u61.view(num()) >>> shift);
        62 => return int.view(u62.view(num()) >>> shift);
        63 => return int.view(u63.view(num()) >>> shift);
        64 => return int.view(u64.view(num()) >>> shift);
        _ => return 42;
    }
    
}