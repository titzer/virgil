//@execute =true
layout L {
    +0  f1: byte;
    +1  f2: u33; //approx 5 bytes
    +9  f3: byte; 
    =10;
}

def getArr() -> Array<byte> {
    def arr = Array<byte>.new(10);
    for (i=1; i < 9; i++) {
        arr[i] = 0xFF;
    }
    return arr;
}

def main() -> bool {
    def r = Ref<L>.of(getArr());
    return r.f2 == u33.view(-1);
}