//@execute 0=false; 1=true; 2=true; 3=true; 4=true; 5=true; 6=true; 7=true; 8=true; 9=true; 10=true; 11=true; 12=true; 14=false
def main(arg: int) -> bool {
	if (arg == 1) return long.+ == long.+;
	if (arg == 2) return long.- == long.-;
	if (arg == 3) return long.* == long.*;
	if (arg == 4) return long./ == long./;
	if (arg == 5) return long.% == long.%;
	if (arg == 6) return long.& == long.&;
	if (arg == 7) return long.| == long.|;
	if (arg == 8) return long.^ == long.^;
	if (arg == 9) return long.< == long.<;
	if (arg == 10) return long.<= == long.<=;
	if (arg == 11) return long.> == long.>;
	if (arg == 12) return long.>= == long.>=;
	return false;
}
