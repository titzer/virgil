//@execute 0=0; 1=0
// Widening a negative value into an unsigned type wider than 32 bits must mask
// the result down to that type's width. On 32-bit targets the value is carried
// in a pair of words and the sign extension filled the whole upper word, which
// left the bits above the type's width set.
//
// The converse also has to hold: a type whose big end IS a full word (u64, or
// long reached through u32.view) must NOT be re-masked, because re-viewing an
// already-extended full word turns the extend value into an instruction, and on
// x86-32 the second phi input below then lands in the wrong register. Input 1
// exercises that path -- it miscompiled Aeneas itself, so test/gc went red while
// this suite stayed green.
var A17: Array<i17> = [i17.view(-1)];
var A23: Array<i23> = [i23.view(-1)];
var A32: Array<int> = [-1];

def hi(x: long) -> int { return int.view(x >>> 32); }
def lo(x: long) -> int { return int.view(x); }

// {v} reaches long two ways -- signed and unsigned widening -- merged in a phi,
// exactly the shape of Long.unboxSU that the compiler runs on itself.
def su(v: int, signed: bool) -> long { return if(signed, v, u32.view(v)); }

def fullWord(a: int) -> int {
	var v = A32[a];			// runtime -1, not a constant
	if (lo(su(v, true)) != v) return 101;
	if (hi(su(v, true)) != -1) return 102;		// signed: high word all ones
	if (lo(su(v, false)) != v) return 103;
	if (hi(su(v, false)) != 0) return 104;		// unsigned: high word zero
	if (u64.view(v) != 18446744073709551615uL) return 105;
	if (long.view(u32.view(v)) != 4294967295L) return 106;
	return 0;
}

def main(a: int) -> int {
	if (a == 1) return fullWord(0);
	var x17 = A17[a], x23 = A23[a], x32 = A32[a];

	if (u33.view(x17) != 8589934591L) return 1;
	if (u47.view(x17) != 140737488355327L) return 2;
	if (u63.view(x17) != 9223372036854775807L) return 3;

	if (u33.view(x23) != 8589934591L) return 4;
	if (u47.view(x23) != 140737488355327L) return 5;
	if (u63.view(x23) != 9223372036854775807L) return 6;

	if (u33.view(x32) != 8589934591L) return 7;
	if (u47.view(x32) != 140737488355327L) return 8;
	if (u63.view(x32) != 9223372036854775807L) return 9;

	// the high word alone, in case the comparison itself is what masks
	if (hi(long.view(u33.view(x23))) != 1) return 10;
	if (hi(long.view(u47.view(x23))) != 32767) return 11;
	if (hi(long.view(u63.view(x23))) != 2147483647) return 12;
	if (lo(long.view(u47.view(x23))) != -1) return 13;

	// the signed targets sign-extend all the way, and must keep doing so
	if (i33.view(x23) != -1L) return 14;
	if (i47.view(x23) != -1L) return 15;
	if (i63.view(x23) != -1L) return 16;
	if (u64.view(x23) != 18446744073709551615uL) return 17;

	return 0;
}
