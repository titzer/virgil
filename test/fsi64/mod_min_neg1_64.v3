//@execute 0=true; 1=true; 2=true; 3=true
// Modulo by -1L is always 0, including for long.min where the corresponding
// division overflows (see div_min_neg1_64.v3). Returns bool rather than long
// directly, matching the convention used elsewhere for long-valued results.
def values = [0L, 1L, 77777L, -9223372036854775808L];
def main(a: int) -> bool {
	return (values[a] % -1L) == 0;
}
