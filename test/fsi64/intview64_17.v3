def getArr() -> Array<byte> {
    def arr = Array<byte>.new(10);
    for (i=1; i < 9; i++) {
        arr[i] = 0xFF;
    }
    return arr;
}

def main(a: int) -> bool {
    match (a) {
        33 => { def r = Ref<L33>.of(getArr()); return r.f2 == i33.view(-1); }
        34 => { def r = Ref<L34>.of(getArr()); return r.f2 == i34.view(-1); }
