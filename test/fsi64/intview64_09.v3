//@execute 33=-1; 34=-1; 35=-1; 36=-1; 37=-1; 38=-1; 39=-1; 40=-1; 41=-1; 42=-1; 43=-1; 44=-1; 45=-1; 46=-1; 47=-1; 48=-1; 49=-1; 50=-1; 51=-1; 52=-1; 53=-1; 54=-1; 55=-1; 56=-1; 57=-1; 58=-1; 59=-1; 60=-1; 61=-1; 62=-1; 63=-1; 64=-1

def num() -> long {
    // 33 bits
    return 0xFFFFFFFF00000000L;
}
def main(a: int) -> int {
    def shift: byte = byte.view(32);
    match (a) {
        33 => return int.view(i33.view(num()) >> shift);
        34 => return int.view(i34.view(num()) >> shift);
        35 => return int.view(i35.view(num()) >> shift);
        36 => return int.view(i36.view(num()) >> shift);
        37 => return int.view(i37.view(num()) >> shift);
        38 => return int.view(i38.view(num()) >> shift);
        39 => return int.view(i39.view(num()) >> shift);
        40 => return int.view(i40.view(num()) >> shift);
        41 => return int.view(i41.view(num()) >> shift);
        42 => return int.view(i42.view(num()) >> shift);
        43 => return int.view(i43.view(num()) >> shift);
        44 => return int.view(i44.view(num()) >> shift);
        45 => return int.view(i45.view(num()) >> shift);
        46 => return int.view(i46.view(num()) >> shift);
        47 => return int.view(i47.view(num()) >> shift);
        48 => return int.view(i48.view(num()) >> shift);
        49 => return int.view(i49.view(num()) >> shift);
        50 => return int.view(i50.view(num()) >> shift);
        51 => return int.view(i51.view(num()) >> shift);
        52 => return int.view(i52.view(num()) >> shift);
        53 => return int.view(i53.view(num()) >> shift);
        54 => return int.view(i54.view(num()) >> shift);
        55 => return int.view(i55.view(num()) >> shift);
        56 => return int.view(i56.view(num()) >> shift);
        57 => return int.view(i57.view(num()) >> shift);
        58 => return int.view(i58.view(num()) >> shift);
        59 => return int.view(i59.view(num()) >> shift);
        60 => return int.view(i60.view(num()) >> shift);
        61 => return int.view(i61.view(num()) >> shift);
        62 => return int.view(i62.view(num()) >> shift);
        63 => return int.view(i63.view(num()) >> shift);
        64 => return int.view(i64.view(num()) >> shift);
        _ => return 42;
    }
    
}