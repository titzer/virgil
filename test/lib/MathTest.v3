def T = LibTests.register("Math", _, _);
def X = [
	T("exp:simple", test_exp_simple),
	T("exp:nan", test_exp_nan),
	T("exp:infinities", test_exp_infinities),
	T("log:simple", test_log_simple),
	T("log:nan", test_log_nan),
	T("log:infinities", test_log_infinities),
	T("sqrt:simple", test_sqrt_simple),
	T("sqrt:special", test_sqrt_special),
	T("expm1:simple", test_expm1_simple),
	T("expm1:special", test_expm1_special),
	T("sin:simple", test_sin_simple),
	T("sin:special", test_sin_special),
	T("cos:simple", test_cos_simple),
	T("cos:special", test_cos_special),
	T("tan:simple", test_tan_simple),
	T("tan:special", test_tan_special),
	T("asin:simple", test_asin_simple),
	T("asin:special", test_asin_special),
	T("acos:simple", test_acos_simple),
	T("acos:special", test_acos_special),
	T("atan:simple", test_atan_simple),
	T("atan:special", test_atan_special),
	T("atan2:simple", test_atan2_simple),
	T("atan2:special", test_atan2_special),
	T("sinh:simple", test_sinh_simple),
	T("sinh:special", test_sinh_special),
	T("cosh:simple", test_cosh_simple),
	T("cosh:special", test_cosh_special),
	T("tanh:simple", test_tanh_simple),
	T("tanh:special", test_tanh_special),
	()
];

def assertOk<T>(t: LibTest, f: (StringBuilder, T) -> StringBuilder, val: T, expected: string) {
	var b = StringBuilder.new();
	f(b, val);
	t.assert_string(expected, b.extract());
}

// Assert that {e == g}.
def assertDoubleEq(t: LibTest, e: double, g: double) {
	if (e != g) t.fail(Strings.format2("expected double 0x%x, got 0x%x", u64.view(e), u64.view(g)));
}

def assertDoubleNan(t: LibTest, g: double) {
	if (g != g) return;
	t.fail(Strings.format1("expected double.nan, got 0x%x", u64.view(g)));
}

// Assert that {g} is within one unit of least precision of {e}.
def assertDouble1ulp(t: LibTest, e: double, g: double) {
	if (e.sign == g.sign && e.exponent == g.exponent) {
		var e_frac = e.fraction;
		var g_frac = g.fraction;
		if (e_frac == g_frac) return;
		if (e_frac == (g_frac + 1)) return;
		if (e_frac == (g_frac - 1)) return;
	}
	// Adjacent doubles across a power-of-2 boundary (e.g. 0.5 and 0x3FDFFFFFFFFFFFFF):
	// the larger has fraction=0 and the smaller has fraction=u52.max (wraps to 0 on +1).
	if (e.sign == g.sign) {
		if (e.exponent == g.exponent + 1 && e.fraction == 0 && (g.fraction + 1) == 0) return;
		if (g.exponent == e.exponent + 1 && g.fraction == 0 && (e.fraction + 1) == 0) return;
	}
	t.fail(Strings.format2("expected double close to 0x%x, got 0x%x", u64.view(e), u64.view(g)));
}

def assertDoubleConst(d: double, bits: u64) -> double { // primarily checks Virgil parsing of double constants
	if (u64.view(d) != bits) System.error("DoubleConstantError", "compile-time double constant differed from expected bits");
	return d;
}

def CONSTANT_E = assertDoubleConst(2.718281828459045d, 0x4005BF0A8B145769);
def CONSTANT_1_OVER_E = 0.3678794411714423534480749d;
def CONSTANT_SQRT_E = 1.6487212707001280754720355d;

def test_exp_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assert(CONSTANT_E, Math.exp(1));
	assert(CONSTANT_E * CONSTANT_E, Math.exp(2));
	assert(CONSTANT_1_OVER_E, Math.exp(-1));
	assert(CONSTANT_SQRT_E, Math.exp(0.5));
}

def test_exp_nan(t: LibTest) {
	assertDoubleNan(t, Math.exp(double.nan));
	assertDoubleNan(t, Math.exp(0d / 0d));
	assertDoubleNan(t, Math.exp(double.nan + 1));
}

def test_exp_infinities(t: LibTest) {
	assertDoubleEq(t, double.infinity, Math.exp(double.infinity));
	assertDoubleEq(t, double.infinity, Math.exp(10000000d));
	assertDoubleEq(t, double.infinity, Math.exp(1000000d));
	assertDoubleEq(t, double.infinity, Math.exp(100000d));
	assertDoubleEq(t, double.infinity, Math.exp(10000d));
	assertDoubleEq(t, double.infinity, Math.exp(1000d));
	// TODO: find threshold for infinity
	assertDoubleEq(t, 0, Math.exp(0d - double.infinity));
}

def test_log_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assert(1, Math.log(CONSTANT_E));
	assert(-1, Math.log(CONSTANT_1_OVER_E));
//TODO: 2ulp	assert(0.5, Math.log(CONSTANT_SQRT_E));
}

def test_log_nan(t: LibTest) {
	assertDoubleNan(t, Math.log(double.nan));
	assertDoubleNan(t, Math.log(0d / 0d));
	assertDoubleNan(t, Math.log(double.nan + 1));
	assertDoubleNan(t, Math.log(-1));
}

def test_log_infinities(t: LibTest) {
	assertDoubleEq(t, double.infinity, Math.log(double.infinity));
	assertDoubleEq(t, 0d - double.infinity, Math.log(0));
}

// Known-good values for common mathematical constants and function outputs.
def SQRT_2    = 1.4142135623730951d;
def SQRT_3    = 1.7320508075688772d;
def SQRT_HALF = 0.7071067811865476d;
def SIN_1     = 0.8414709848078965d;
def COS_1     = 0.5403023058681398d;
def TAN_1     = 1.5574077246549023d;
def SINH_1    = 1.1752011936438014d;
def COSH_1    = 1.5430806348152437d;
def TANH_1    = 0.7615941559557649d;
def EXPM1_1   = 1.718281828459045d;   // e - 1

def test_sqrt_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.sqrt(0));
	assertDoubleEq(t, 1, Math.sqrt(1));
	assertDoubleEq(t, 2, Math.sqrt(4));
	assertDoubleEq(t, 3, Math.sqrt(9));
	assertDoubleEq(t, 0.5, Math.sqrt(0.25));
	assert(SQRT_2, Math.sqrt(2));
	assert(SQRT_3, Math.sqrt(3));
	assert(SQRT_HALF, Math.sqrt(0.5));
}

def test_sqrt_special(t: LibTest) {
	assertDoubleNan(t, Math.sqrt(double.nan));
	assertDoubleNan(t, Math.sqrt(-1));
	assertDoubleNan(t, Math.sqrt(-0.001));
	assertDoubleEq(t, double.infinity, Math.sqrt(double.infinity));
}

def test_expm1_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.expm1(0));
	assert(EXPM1_1, Math.expm1(1));
	// For |x| < 2^-54, expm1 returns x exactly (correction is below double precision)
	assertDoubleEq(t, 1.0e-17, Math.expm1(1.0e-17));
	assertDoubleEq(t, -1.0e-17, Math.expm1(-1.0e-17));
}

def test_expm1_special(t: LibTest) {
	assertDoubleNan(t, Math.expm1(double.nan));
	assertDoubleEq(t, double.infinity, Math.expm1(double.infinity));
	assertDoubleEq(t, -1, Math.expm1(0d - double.infinity));
}

def test_sin_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.sin(0));
	assert(SIN_1, Math.sin(1));
	assert(-SIN_1, Math.sin(-1));
	assert(0.5, Math.sin(Math.PI / 6));
	assert(SQRT_HALF, Math.sin(Math.PI / 4));
	assert(1, Math.sin(Math.PI / 2));
	assert(-1, Math.sin(3 * Math.PI / 2));
}

def test_sin_special(t: LibTest) {
	assertDoubleNan(t, Math.sin(double.nan));
	assertDoubleNan(t, Math.sin(double.infinity));
	assertDoubleNan(t, Math.sin(0d - double.infinity));
}

def test_cos_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 1, Math.cos(0));
	assert(COS_1, Math.cos(1));
	assert(COS_1, Math.cos(-1));
	assert(0.5, Math.cos(Math.PI / 3));
	assert(SQRT_HALF, Math.cos(Math.PI / 4));
	assert(-1, Math.cos(Math.PI));
}

def test_cos_special(t: LibTest) {
	assertDoubleNan(t, Math.cos(double.nan));
	assertDoubleNan(t, Math.cos(double.infinity));
	assertDoubleNan(t, Math.cos(0d - double.infinity));
}

def test_tan_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.tan(0));
	assert(TAN_1, Math.tan(1));
	assert(-TAN_1, Math.tan(-1));
	assert(1, Math.tan(Math.PI / 4));
	assert(-1, Math.tan(-Math.PI / 4));
}

def test_tan_special(t: LibTest) {
	assertDoubleNan(t, Math.tan(double.nan));
	assertDoubleNan(t, Math.tan(double.infinity));
	assertDoubleNan(t, Math.tan(0d - double.infinity));
}

def test_asin_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.asin(0));
	assert(Math.PI / 2, Math.asin(1));
	assert(-Math.PI / 2, Math.asin(-1));
	assert(Math.PI / 6, Math.asin(0.5));
	assert(Math.PI / 4, Math.asin(SQRT_HALF));
}

def test_asin_special(t: LibTest) {
	assertDoubleNan(t, Math.asin(double.nan));
	assertDoubleNan(t, Math.asin(2));
	assertDoubleNan(t, Math.asin(-2));
	assertDoubleNan(t, Math.asin(double.infinity));
}

def test_acos_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.acos(1));
	assert(Math.PI, Math.acos(-1));
	assert(Math.PI / 2, Math.acos(0));
	assert(Math.PI / 3, Math.acos(0.5));
	assert(Math.PI / 4, Math.acos(SQRT_HALF));
}

def test_acos_special(t: LibTest) {
	assertDoubleNan(t, Math.acos(double.nan));
	assertDoubleNan(t, Math.acos(2));
	assertDoubleNan(t, Math.acos(-2));
	assertDoubleNan(t, Math.acos(double.infinity));
}

def test_atan_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.atan(0));
	assert(Math.PI / 4, Math.atan(1));
	assert(-Math.PI / 4, Math.atan(-1));
	assert(Math.PI / 3, Math.atan(SQRT_3));
	assert(Math.PI / 6, Math.atan(1 / SQRT_3));
}

def test_atan_special(t: LibTest) {
	assertDoubleNan(t, Math.atan(double.nan));
	assertDouble1ulp(t, Math.PI / 2, Math.atan(double.infinity));
	assertDouble1ulp(t, -Math.PI / 2, Math.atan(0d - double.infinity));
}

def test_atan2_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.atan2(0, 1));
	assertDoubleEq(t, 0, Math.atan2(0, 0));
	assert(Math.PI / 4, Math.atan2(1, 1));
	assert(Math.PI / 2, Math.atan2(1, 0));
	assert(Math.PI, Math.atan2(0, -1));
	assert(-Math.PI / 4, Math.atan2(-1, 1));
	assert(-Math.PI / 2, Math.atan2(-1, 0));
}

def test_atan2_special(t: LibTest) {
	assertDoubleNan(t, Math.atan2(double.nan, 1));
	assertDoubleNan(t, Math.atan2(1, double.nan));
	assertDouble1ulp(t, Math.PI / 4, Math.atan2(double.infinity, double.infinity));
	assertDouble1ulp(t, Math.PI / 2, Math.atan2(double.infinity, 1));
	assertDouble1ulp(t, -Math.PI / 2, Math.atan2(0d - double.infinity, 1));
}

def test_sinh_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.sinh(0));
	assert(SINH_1, Math.sinh(1));
	assert(-SINH_1, Math.sinh(-1));
	assert(1.0e-10, Math.sinh(1.0e-10));
}

def test_sinh_special(t: LibTest) {
	assertDoubleNan(t, Math.sinh(double.nan));
	assertDoubleEq(t, double.infinity, Math.sinh(double.infinity));
	assertDoubleEq(t, 0d - double.infinity, Math.sinh(0d - double.infinity));
}

def test_cosh_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 1, Math.cosh(0));
	assert(COSH_1, Math.cosh(1));
	assert(COSH_1, Math.cosh(-1));
}

def test_cosh_special(t: LibTest) {
	assertDoubleNan(t, Math.cosh(double.nan));
	assertDoubleEq(t, double.infinity, Math.cosh(double.infinity));
	assertDoubleEq(t, double.infinity, Math.cosh(0d - double.infinity));
}

def test_tanh_simple(t: LibTest) {
	var assert = assertDouble1ulp(t, _, _);
	assertDoubleEq(t, 0, Math.tanh(0));
	assert(TANH_1, Math.tanh(1));
	assert(-TANH_1, Math.tanh(-1));
	assert(1.0e-10, Math.tanh(1.0e-10));
}

def test_tanh_special(t: LibTest) {
	assertDoubleNan(t, Math.tanh(double.nan));
	assertDoubleEq(t, 1, Math.tanh(double.infinity));
	assertDoubleEq(t, -1, Math.tanh(0d - double.infinity));
	assertDoubleEq(t, 1, Math.tanh(100));
	assertDoubleEq(t, -1, Math.tanh(-100));
}
