def T = LibTests.register("Sha1", _, _);
def X = (
	T("rfc3174", test_rfc3174),
	T("boundaries", test_boundaries),
	T("aReps", test_aReps),
	T("zeros", test_zeros),
	T("ones", test_ones),
	T("binary", test_binary),
	T("ranges", test_ranges),
	T("reuse", test_reuse),
	T("render", test_render),
	()
);

// Compare the hex digest of {data} against the expected `sha1sum` output.
def check(t: LibTest, expected: string, data: Range<byte>) {
	var got = Sha1.hash(data).toString();
	t.assert_string(expected, got);
}

// Build an array of {n} copies of byte {b}.
def rep(b: byte, n: int) -> Array<byte> {
	var a = Array<byte>.new(n);
	for (i < n) a[i] = b;
	return a;
}

// Standard RFC 3174 / well-known test vectors (matches `sha1sum` output).
def test_rfc3174(t: LibTest) {
	var P = check(t, _, _);
	P("da39a3ee5e6b4b0d3255bfef95601890afd80709", "");
	P("86f7e437faa5a7fce15d1ddcb9eaeaea377667b8", "a");
	P("a9993e364706816aba3e25717850c26c9cd0d89d", "abc");
	P("c12252ceda8be8994d5fa0290a47231c1d16aae3", "message digest");
	P("32d10c7b8cf96570ca04ce37f2a19d84240d3a89", "abcdefghijklmnopqrstuvwxyz");
	P("761c457bf73b14d27e9e9265c46f4b4dda11f940", "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789");
	P("50abf5706a150990a08b2c5ea40fa0e585554732", "12345678901234567890123456789012345678901234567890123456789012345678901234567890");
	P("2fd4e1c67a2d28fced849ee1bb76e7391b93eb12", "The quick brown fox jumps over the lazy dog");
	P("408d94384216f890ff7a0c3528e8bed1e0b01621", "The quick brown fox jumps over the lazy dog.");
}

// SHA-1 digests of "a" repeated n times, for n = 0..73. This exhaustively exercises
// every possible padding residue class (mod 64), including the critical 55/56/57
// and 63/64/65 block boundaries.
def aVectors = [
	"da39a3ee5e6b4b0d3255bfef95601890afd80709", // 0
	"86f7e437faa5a7fce15d1ddcb9eaeaea377667b8", // 1
	"e0c9035898dd52fc65c41454cec9c4d2611bfb37", // 2
	"7e240de74fb1ed08fa08d38063f6a6a91462a815", // 3
	"70c881d4a26984ddce795f6f71817c9cf4480e79", // 4
	"df51e37c269aa94d38f93e537bf6e2020b21406c", // 5
	"f7a9e24777ec23212c54d7a350bc5bea5477fdbb", // 6
	"e93b4e3c464ffd51732fbd6ded717e9efda28aad", // 7
	"b480c074d6b75947c02681f31c90c668c46bf6b8", // 8
	"2882f38e575101ba615f725af5e59bf2333a9a68", // 9
	"3495ff69d34671d1e15b33a63c1379fdedd3a32a", // 10
	"755c001f4ae3c8843e5a50dd6aa2fa23893dd3ad", // 11
	"384fcd160ab3b33174ea279ad26052eee191508a", // 12
	"897b99631295d204db13e863b296a09e70ab1d65", // 13
	"128c484ff69fcdc1f82cd3781595cac5185e688f", // 14
	"7e13c003a8256cd421055563c5da6571d50713c9", // 15
	"3499c60eea227453c779de50fc84e217e9a53a18", // 16
	"321a618ba6830de900738b0814d0c9f28ff2fece", // 17
	"0478095c8ece0bbc11f94663ac2c4f10b29666de", // 18
	"1335bfa62671b0015c6e20766c07035868edb8f4", // 19
	"38666b8ba500faa5c2406f4575d42a92379844c2", // 20
	"035a4ee5d60816878caec161d6cb8e00e9cc539b", // 21
	"8c2a4e5c8f210b6aaa6c95e1c8e21351959f4541", // 22
	"85e3737bb8ab36e2866501e517c46fffc085313e", // 23
	"b1c76aec7674865d5346b3b0d1cb2c223c53e73e", // 24
	"44f4647e1542a79d7d68ceb7f75d1dbf77fdebfc", // 25
	"de8280c3a1c7db377f1ec7107c7fb62d374cc09c", // 26
	"52a00b8461593ce33409d7c5d0411699cbf9cda3", // 27
	"06587751ce11a8703abc64cab55b0b96d88341aa", // 28
	"498a75f314a645671bc79a118df385d0d9948484", // 29
	"cd762363c1c11ecb48611583520bba111f0034d4", // 30
	"65cf771ad2cc0b1e8f89361e3b7bec2365b3ad24", // 31
	"68f84a59a3ca2d0e5cb1646fbb164da409b5d8f2", // 32
	"2368a1ac71c68c4b47b4fb2806508e0eb447aa64", // 33
	"82d5343f4b2f0fcf6e28672d1f1a10c434f213d5", // 34
	"f4d3e057abac5109b7e953578fa97968ea34f43a", // 35
	"6c783ce5cc13ea5ce572eddfaba02f9d1bb90905", // 36
	"9e55bf6ab8f14b37cc6f69eb7374be6c5cbd2d07", // 37
	"1290c28910a6c12c9a131f0ecb523114f20f14c2", // 38
	"4f5fc75bd3c93bccc09fc2de9c95442456053faf", // 39
	"a56559418dc7908ce5f0b24b05c78e055cb863dc", // 40
	"52cedd6b110e4330b5186478736afa5203c4f9ea", // 41
	"32e067e0414932c3edd95fc4176a54bff1ddfe29", // 42
	"7bd258f2f4cc4b02fca4ea157f55f6d88d26d954", // 43
	"df51a19b291586bf46450aec1d775f3e02799b55", // 44
	"4642fe68c57cd01fc68fc11b7f22b940328a7cc4", // 45
	"03a4de84c189a836eaee643041b34ad2386db70d", // 46
	"25883f7a0e732e9ab10e594ea59425dfe4d90359", // 47
	"3e3d6e12b933133de2caa248ea12bd193a67f206", // 48
	"1e666934c5a35f509aa31bbd9af8a37a1ed13ba6", // 49
	"6c177354157989a2c6cd7bac80465b13bea25832", // 50
	"aca32b501c231ef8e2d8703e71415bfbe4ccbc64", // 51
	"e6479c70bbac662e4cc134cb8bdaade59ff55b66", // 52
	"d9b66a0801459c8094398ef8f04700a8569c9906", // 53
	"b05d71c64979cb95fa74a33cdb31a40d258ae02e", // 54
	"c1c8bbdc22796e28c0e15163d20899b65621d65a", // 55  (fits in one block: 0x80 at 55, len at 56..63)
	"c2db330f6083854c99d4b5bfb6e8f29f201be699", // 56  (needs a second block)
	"f08f24908d682555111be7ff6f004e78283d989a", // 57
	"5ee0f8895f4e1aae6a6661de5c432e34188a5a2d", // 58
