	"13d956033d9af449bfe2c4ef78c17c20469c4bf1", // 60
	"aeab141db28af3353283b5ccb2a322df0b9b5f56", // 61
	"67b4b3923fa178d788a9611b76446c96431071f2", // 62
	"03f09f5b158a7a8cdad920bddc29b81c18a551f5", // 63
	"0098ba824b5c16427bd7a1122a5a442a25ec644d", // 64  (exactly one full block + a padding block)
	"11655326c708d70319be2610e8a57d9a5b959d3b", // 65
	"a4e77d9c0c9344921a0ac998b442ad572afdc5fb", // 66
	"c70cc62a2ecb15f4bf1b70904dd621373d79f311", // 67
	"dca1c821b7970a33a9a0524892ce7e49581591fd", // 68
	"165f932eb7f82c26d8169abfe3b665d92ea8cf4a", // 69
	"ed6c69d9e8b4373af86303dfaa3528dfbc129902", // 70
	"0dfc17ce9eaca1570de957219f0c65c0c1f13654", // 71
	"227c150957bf386497eb4f8eeabbaf9fe5ff5b96", // 72
	"39c1b19d6b81461cf01a28952cc1e19c70a93851"  // 73
];

def test_aReps(t: LibTest) {
	for (n < aVectors.length) {
		check(t, aVectors[n], rep('a', n));
	}
}

// A handful of larger inputs spanning multiple full blocks and their boundaries.
def test_boundaries(t: LibTest) {
	var P = check(t, _, _);
	P("ee971065aaa017e0632a8ca6c77bb3bf8b1dfc56", rep('a', 119));
	P("f34c1488385346a55709ba056ddd08280dd4c6d6", rep('a', 120));
	P("89d95fa32ed44a7c610b7ee38517ddf57e0bb975", rep('a', 127));
	P("ad5b3fdbcb526778c2839d2f151ea753995e26a0", rep('a', 128));
	P("d96debf1bdcbc896e6c134ea76e8141f40d78536", rep('a', 129));
	P("f0d0429532d8c279879349ef6d15ec39a1f337c7", rep('a', 191));
	P("9b1a580cb91c62712ce65498ebad252a1d83051d", rep('a', 192));
	P("e61cfffe0d9195a525fc6cf06ca2d77119c24a40", rep('a', 200));
}

// All-zero inputs of various lengths (exercises padding with zero content).
def test_zeros(t: LibTest) {
	var P = check(t, _, _);
	P("5ba93c9db0cff93f52b521d7420e43f6eda2784f", rep(0, 1));
	P("8e8832c642a6a38c74c17fc92ccedc266c108e6c", rep(0, 55));
	P("9438e360f578e12c0e0e8ed28e2c125c1cefee16", rep(0, 56));
	P("c8d7d0ef0eedfa82d2ea1aa592845b9a6d4b02b7", rep(0, 64));
	P("0ae4f711ef5d6e9d26c611fd2c8c8ac45ecbf9e7", rep(0, 128));
}

// All-0xff inputs (exercises high bit patterns).
def test_ones(t: LibTest) {
	var P = check(t, _, _);
	P("85e53271e14006f0265921d02d4d736cdc580b0b", rep(0xff, 1));
	P("ffc6261e487efa8c7442069f71acfc4aa826993d", rep(0xff, 64));
}

// Binary input containing every byte value 0..255.
def test_binary(t: LibTest) {
	var a = Array<byte>.new(256);
	for (i < 256) a[i] = byte.view(i);
	check(t, "4916d6bdb7f78e6803698cab32d1586ea457dfc8", a);
}

// Hashing a sub-range of a larger array must match hashing that content directly.
def test_ranges(t: LibTest) {
	// Slice "abc" out of the middle of a larger array.
	var buf = "XXabcYY";
	check(t, "a9993e364706816aba3e25717850c26c9cd0d89d", buf[2 ..+ 3]);

	// Empty sub-range.
	check(t, "da39a3ee5e6b4b0d3255bfef95601890afd80709", buf[3 ..+ 0]);

	// Slice a 55-byte window out of a 64-byte 'a' buffer (boundary case via range).
	var big = rep('a', 64);
	check(t, "c1c8bbdc22796e28c0e15163d20899b65621d65a", big[0 ..+ 55]);
	// And a 64-byte window from a larger buffer starting at a non-zero offset.
	var bigger = rep('a', 100);
	check(t, "0098ba824b5c16427bd7a1122a5a442a25ec644d", bigger[10 ..+ 64]);
}

// The component holds mutable state across calls; verify back-to-back hashes
// don't leak state into each other, including the empty case in between.
def test_reuse(t: LibTest) {
	var P = check(t, _, _);
	P("a9993e364706816aba3e25717850c26c9cd0d89d", "abc");
	P("da39a3ee5e6b4b0d3255bfef95601890afd80709", "");
	P("a9993e364706816aba3e25717850c26c9cd0d89d", "abc");
	P("86f7e437faa5a7fce15d1ddcb9eaeaea377667b8", "a");
	P("0098ba824b5c16427bd7a1122a5a442a25ec644d", rep('a', 64));
	P("a9993e364706816aba3e25717850c26c9cd0d89d", "abc");
}

// render() must append the same digest that toString() produces, and append
// (not overwrite) any existing content in the builder.
def test_render(t: LibTest) {
	var R = check_render(t, _, _);
	R("da39a3ee5e6b4b0d3255bfef95601890afd80709", "");
	R("86f7e437faa5a7fce15d1ddcb9eaeaea377667b8", "a");
	R("a9993e364706816aba3e25717850c26c9cd0d89d", "abc");
	R("ad5b3fdbcb526778c2839d2f151ea753995e26a0", rep('a', 128));

	// Appending twice accumulates in the same builder.
	var buf = StringBuilder.new();
	Sha1.hash("abc").render(buf.puts("sha1="));
	buf.putc(' ');
	Sha1.hash("a").render(buf);
	t.assert_string("sha1=a9993e364706816aba3e25717850c26c9cd0d89d 86f7e437faa5a7fce15d1ddcb9eaeaea377667b8", buf.toString());
}

def check_render(t: LibTest, expected: string, data: Range<byte>) {
	var hash = Sha1.hash(data);
	var got = hash.render(StringBuilder.new()).toString();
	t.assert_string(expected, got);
	// render() and toString() must agree.
	t.assert_string(hash.toString(), got);
}
