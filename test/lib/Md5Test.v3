def T = LibTests.register("Md5", _, _);
def X = (
	T("rfc1321", test_rfc1321),
	T("boundaries", test_boundaries),
	T("aReps", test_aReps),
	T("zeros", test_zeros),
	T("ones", test_ones),
	T("binary", test_binary),
	T("ranges", test_ranges),
	T("reuse", test_reuse),
	T("render", test_render),
	()
);

// Compare the hex digest of {data} against the expected {md5} unix-tool output.
def check(t: LibTest, expected: string, data: Range<byte>) {
	var got = Md5.hash(data).toString();
	t.assert_string(expected, got);
}

// Build an array of {n} copies of byte {b}.
def rep(b: byte, n: int) -> Array<byte> {
	var a = Array<byte>.new(n);
	for (i < n) a[i] = b;
	return a;
}

// Standard RFC 1321 test vectors (matches `md5` unix tool output).
def test_rfc1321(t: LibTest) {
	var P = check(t, _, _);
	P("d41d8cd98f00b204e9800998ecf8427e", "");
	P("0cc175b9c0f1b6a831c399e269772661", "a");
	P("900150983cd24fb0d6963f7d28e17f72", "abc");
	P("f96b697d7cb7938d525a2f31aaf161d0", "message digest");
	P("c3fcd3d76192e4007dfb496cca67e13b", "abcdefghijklmnopqrstuvwxyz");
	P("d174ab98d277d9f5a5611c2c9f419d9f", "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789");
	P("57edf4a22be3c955ac49da2e2107b67a", "12345678901234567890123456789012345678901234567890123456789012345678901234567890");
	P("9e107d9d372bb6826bd81d3542a419d6", "The quick brown fox jumps over the lazy dog");
	P("e4d909c290d0fb1ca068ffaddf22cbd0", "The quick brown fox jumps over the lazy dog.");
}

// MD5 digests of "a" repeated n times, for n = 0..73. This exhaustively exercises
// every possible padding residue class (mod 64), including the critical 55/56/57
// and 63/64/65 block boundaries.
def aVectors = [
	"d41d8cd98f00b204e9800998ecf8427e", // 0
	"0cc175b9c0f1b6a831c399e269772661", // 1
	"4124bc0a9335c27f086f24ba207a4912", // 2
	"47bce5c74f589f4867dbd57e9ca9f808", // 3
	"74b87337454200d4d33f80c4663dc5e5", // 4
	"594f803b380a41396ed63dca39503542", // 5
	"0b4e7a0e5fe84ad35fb5f95b9ceeac79", // 6
	"5d793fc5b00a2348c3fb9ab59e5ca98a", // 7
	"3dbe00a167653a1aaee01d93e77e730e", // 8
	"552e6a97297c53e592208cf97fbb3b60", // 9
	"e09c80c42fda55f9d992e59ca6b3307d", // 10
	"d57f21e6a273781dbf8b7657940f3b03", // 11
	"45e4812014d83dde5666ebdf5a8ed1ed", // 12
	"c162de19c4c3731ca3428769d0cd593d", // 13
	"451599a5f9afa91a0f2097040a796f3d", // 14
	"12f9cf6998d52dbe773b06f848bb3608", // 15
	"23ca472302f49b3ea5592b146a312da0", // 16
	"88e42e96cc71151b6e1938a1699b0a27", // 17
	"2c60c24e7087e18e45055a33f9a5be91", // 18
	"639d76897485360b3147e66e0a8a3d6c", // 19
	"22d42eb002cefa81e9ad604ea57bc01d", // 20
	"bd049f221af82804c5a2826809337c9b", // 21
	"ff49cfac3968dbce26ebe7d4823e58bd", // 22
	"d95dbfee231e34cccb8c04444412ed7d", // 23
	"40edae4bad0e5bf6d6c2dc5615a86afb", // 24
	"a5a8bfa3962f49330227955e24a2e67c", // 25
	"ae791f19bdf77357ff10bb6b0e97e121", // 26
	"aaab9c59a88bf0bdfcb170546c5459d6", // 27
	"b0f0545856af1a340acdedce23c54b97", // 28
	"f7ce3d7d44f3342107d884bfa90c966a", // 29
	"59e794d45697b360e18ba972bada0123", // 30
	"3b0845db57c200be6052466f87b2198a", // 31
	"5eca9bd3eb07c006cd43ae48dfde7fd3", // 32
	"b4f13cb081e412f44e99742cb128a1a5", // 33
	"4c660346451b8cf91ef50f4634458d41", // 34
	"11db24dc3f6c2145701db08625dd6d76", // 35
	"80dad3aad8584778352c68ab06250327", // 36
	"1227fe415e79db47285cb2689c93963f", // 37
	"8e084f489f1bdf08c39f98ff6447ce6d", // 38
	"08b2f2b0864bac1ba1585043362cbec9", // 39
	"4697843037d962f62a5a429e611e0f5f", // 40
	"10c4da18575c092b486f8ab96c01c02f", // 41
	"af205d729450b663f48b11d839a1c8df", // 42
	"0d3f91798fac6ee279ec2485b25f1124", // 43
	"4c3c7c067634daec9716a80ea886d123", // 44
	"d1e358e6e3b707282cdd06e919f7e08c", // 45
	"8c6ded4f0af86e0a7e301f8a716c4363", // 46
	"4c2d8bcb02d982d7cb77f649c0a2dea8", // 47
	"bdb662f765cd310f2a547cab1cfecef6", // 48
	"08ff5f7301d30200ab89169f6afdb7af", // 49
	"6eb6a030bcce166534b95bc2ab45d9cf", // 50
	"1bb77918e5695c944be02c16ae29b25e", // 51
	"b6fe77c19f0f0f4946c761d62585bfea", // 52
	"e9e7e260dce84ffa6e0e7eb5fd9d37fc", // 53
	"eced9e0b81ef2bba605cbc5e2e76a1d0", // 54
	"ef1772b6dff9a122358552954ad0df65", // 55  (fits in one block: 0x80 at 55, len at 56..63)
	"3b0c8ac703f828b04c6c197006d17218", // 56  (needs a second block)
	"652b906d60af96844ebd21b674f35e93", // 57
	"dc2f2f2462a0d72358b2f99389458606", // 58
	"762fc2665994b217c52c3c2eb7d9f406", // 59
	"cc7ed669cf88f201c3297c6a91e1d18d", // 60
	"cced11f7bbbffea2f718903216643648", // 61
	"24612f0ce2c9d2cf2b022ef1e027a54f", // 62
	"b06521f39153d618550606be297466d5", // 63
	"014842d480b571495a4a0363793f7367", // 64  (exactly one full block + a padding block)
	"c743a45e0d2e6a95cb859adae0248435", // 65
	"def5d97e01e1219fb2fc8da6c4d6ba2f", // 66
	"92cb737f8687ccb93022fdb411a77cca", // 67
	"a0d1395c7fb36247bfe2d49376d9d133", // 68
	"ab75504250558b788f99d1ebd219abf2", // 69
	"0f5c6c4e740bfcc08c3c26ccb2673d46", // 70
	"cddd19bec7f310d8c87149ef47a1828f", // 71
	"96b39b8b95e016c79d104d83395b8133", // 72
	"f1fc0b14ff8fa674b02344577e23eeb1"  // 73
];

def test_aReps(t: LibTest) {
	for (n < aVectors.length) {
		check(t, aVectors[n], rep('a', n));
	}
}

// A handful of larger inputs spanning multiple full blocks and their boundaries.
def test_boundaries(t: LibTest) {
	var P = check(t, _, _);
	P("8a7bd0732ed6a28ce75f6dabc90e1613", rep('a', 119));
	P("5f61c0ccad4cac44c75ff505e1f1e537", rep('a', 120));
	P("020406e1d05cdc2aa287641f7ae2cc39", rep('a', 127));
	P("e510683b3f5ffe4093d021808bc6ff70", rep('a', 128));
	P("b325dc1c6f5e7a2b7cf465b9feab7948", rep('a', 129));
	P("16e2824f7a3f00ef0028994182071953", rep('a', 191));
	P("234c07907df5019d5f40f03936939bce", rep('a', 192));
	P("887f30b43b2867f4a9accceee7d16e6c", rep('a', 200));
}

// All-zero inputs of various lengths (exercises padding with zero content).
def test_zeros(t: LibTest) {
	var P = check(t, _, _);
	P("93b885adfe0da089cdf634904fd59f71", rep(0, 1));
	P("c9ea3314b91c9fd4e38f9432064fd1f2", rep(0, 55));
	P("e3c4dd21a9171fd39d208efa09bf7883", rep(0, 56));
	P("3b5d3c7d207e37dceeedd301e35e2e58", rep(0, 64));
	P("f09f35a5637839458e462e6350ecbce4", rep(0, 128));
}

// All-0xff inputs (exercises high bit patterns).
def test_ones(t: LibTest) {
	var P = check(t, _, _);
	P("00594fd4f42ba43fc1ca0427a0576295", rep(0xff, 1));
	P("aabd2b2a451504e119a243d8e775fdad", rep(0xff, 64));
}

// Binary input containing every byte value 0..255.
def test_binary(t: LibTest) {
	var a = Array<byte>.new(256);
	for (i < 256) a[i] = byte.view(i);
	check(t, "e2c865db4162bed963bfaa9ef6ac18f0", a);
}

// Hashing a sub-range of a larger array must match hashing that content directly.
def test_ranges(t: LibTest) {
	// Slice "abc" out of the middle of a padded array.
	var buf = "XXabcYY";
	check(t, "900150983cd24fb0d6963f7d28e17f72", buf[2 ..+ 3]);

	// Empty sub-range.
	check(t, "d41d8cd98f00b204e9800998ecf8427e", buf[3 ..+ 0]);

	// Slice a 55-byte window out of a 64-byte 'a' buffer (boundary case via range).
	var big = rep('a', 64);
	check(t, "ef1772b6dff9a122358552954ad0df65", big[0 ..+ 55]);
	// And a 64-byte window from a larger buffer starting at a non-zero offset.
	var bigger = rep('a', 100);
	check(t, "014842d480b571495a4a0363793f7367", bigger[10 ..+ 64]);
}

// The component holds mutable state across calls; verify back-to-back hashes
// don't leak state into each other, including the empty case in between.
def test_reuse(t: LibTest) {
	var P = check(t, _, _);
	P("900150983cd24fb0d6963f7d28e17f72", "abc");
	P("d41d8cd98f00b204e9800998ecf8427e", "");
	P("900150983cd24fb0d6963f7d28e17f72", "abc");
	P("0cc175b9c0f1b6a831c399e269772661", "a");
	P("014842d480b571495a4a0363793f7367", rep('a', 64));
	P("900150983cd24fb0d6963f7d28e17f72", "abc");
}

// render() must append the same digest that toString() produces, and append
// (not overwrite) any existing content in the builder.
def test_render(t: LibTest) {
	var R = check_render(t, _, _);
	R("d41d8cd98f00b204e9800998ecf8427e", "");
	R("0cc175b9c0f1b6a831c399e269772661", "a");
	R("900150983cd24fb0d6963f7d28e17f72", "abc");
	R("e510683b3f5ffe4093d021808bc6ff70", rep('a', 128));

	// Appending twice accumulates in the same builder.
	var buf = StringBuilder.new();
	Md5.hash("abc").render(buf.puts("md5="));
	buf.putc(' ');
	Md5.hash("a").render(buf);
	t.assert_string("md5=900150983cd24fb0d6963f7d28e17f72 0cc175b9c0f1b6a831c399e269772661", buf.toString());
}

def check_render(t: LibTest, expected: string, data: Range<byte>) {
	var hash = Md5.hash(data);
	var got = hash.render(StringBuilder.new()).toString();
	t.assert_string(expected, got);
	// render() and toString() must agree.
	t.assert_string(hash.toString(), got);
}
