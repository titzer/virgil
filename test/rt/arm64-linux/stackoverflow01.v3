// Stack overflow via mutual recursion must be caught as StackOverflow.
def main(a: Array<string>) -> int {
	System.puts(">1\n");
	tryOverflow();
	System.puts("##-fail: did not catch signal\n");
	return -1;
}
def tryOverflow() {
	System.puts("##+try-overflow\n");
	ping(0);
}
def ping(n: int) { pong(n + 1); }
def pong(n: int) { ping(n + 1); }
