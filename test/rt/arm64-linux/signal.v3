def main(a: Array<string>) -> int {
	System.puts(">1\n");
	tryNullAccess();
	System.puts("##-fail: did not catch signal\n");
	return -1;
}

def tryNullAccess() {
	System.puts("##+try-null-access\n");
	RiRuntime.userSignalHandler = handleSignal;

	// ARM64 does not raise SIGFPE for integer division by zero.
	// Instead, test signal handling with SIGSEGV from null pointer load.
	var p = Pointer.NULL;
	var x = p.load<int>();
	if (x == 0) return; // should not reach here
}

def SIGSEGV = 11;
def SYS_exit = 93;
def ucontext_pc_offset = 440;

def handleSignal(signum: int, siginfo: Pointer, ucontext: Pointer) -> bool {
	System.puts("  handleSignal ");
	System.puti(signum);
	System.ln();
	if (signum != SIGSEGV) return false;
	var t: (Pointer, void) = CiRuntime.unpackClosure(ok);
	// adjust IP to point to {ok} function
	System.puts("    bump IP\n");
	(ucontext + ucontext_pc_offset).store<Pointer>(t.0);
	return true;
}

def ok() -> int {
	System.puts("##-ok\n");
	Linux.syscall(SYS_exit, 0);
	return 0;
}
