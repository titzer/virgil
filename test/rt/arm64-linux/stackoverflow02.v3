// Stack overflow with a larger per-call frame must still land in the red zone.
def main(a: Array<string>) -> int {
	System.puts(">1\n");
	tryOverflow();
	System.puts("##-fail: did not catch signal\n");
	return -1;
}
def tryOverflow() {
	System.puts("##+try-overflow\n");
	deep(0);
}
def deep(n: int) -> long {
	var a = long.view(n), b = a+1, c = a+2, d = a+3, e = a+4, f = a+5, g = a+6, h = a+7;
	var r = deep(n + 1);
	return r ^ a ^ b ^ c ^ d ^ e ^ f ^ g ^ h;
}
