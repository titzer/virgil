//@execute 0=1
// Regression test for a Wasm-target shadow-stack codegen bug: a value
// live across two CONSECUTIVE GC-triggering calls with no intervening
// control flow is correctly saved to the shadow stack before the first
// call, but never reloaded after the second one before its next use. If
// a GC relocates the object during either call, that next use (the
// implicit return of {r} below) silently reads through the stale,
// pre-relocation pointer instead of the real (moved) object.
//
// RiGc.forceGC() deterministically forces a real collection -- Virgil's
// GC is a copying collector, so every live object is relocated on every
// single cycle. This means no calibrated heap/array padding is needed to
// coincidentally trigger a GC at the right moment, unlike a natural-
// allocation-pressure-based repro of the same bug.
def TARGET_wasm_wave: bool = false;
def TARGET_x86_linux: bool = false;
def TARGET_x86_64_linux: bool = false;
def TARGET_x86_darwin: bool = false;
def TARGET_x86_64_darwin: bool = false;

class GBox {
	def val: int;
	new(val) { }
}

def add(t: GBox, a: GBox) -> GBox {
	var r = GBox.new(t.val + a.val);
	RiGc.forceGC();
	RiGc.forceGC();
	return r;
}

def main() -> int {
	if (!TARGET_wasm_wave) return 1;
	return add(GBox.new(0), GBox.new(1)).val;
}
