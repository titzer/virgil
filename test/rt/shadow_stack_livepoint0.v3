//@execute 0=1
// Tests that a value live across two consecutive GC-triggering calls with
// no intervening control flow is correctly reloaded from the shadow stack
// after both calls, even if a collection relocates it during either call.
class GBox {
	def val: int;
	new(val) { }
}

def add(t: GBox, a: GBox) -> GBox {
	var r = GBox.new(t.val + a.val);
	RiGc.forceGC();
	RiGc.forceGC();
	return r;
}

def main() -> int {
	return add(GBox.new(0), GBox.new(1)).val;
}
