//@execute 0=42
// Regression test for a Wasm-target shadow-stack codegen bug: a value
// (here, "this" inside GFrame.eval()) that is live across two CONSECUTIVE
// GC-triggering calls with no intervening control flow is correctly saved
// to the shadow stack before the first allocation, but never reloaded
// after the second one before its next use. If a GC relocates the object
// during either allocation, that next use (the "result = ..." field store)
// silently writes through the stale, pre-relocation pointer instead of
// the real (moved) object -- so the write is lost.
//
// The heap/array sizes below are calibrated to force exactly one GC cycle
// during GFrame.eval()'s two allocations, specifically on the wasm-wave
// target (see .flags). Other targets don't share this bug and don't need
// (or reliably tolerate, given wider native pointers) the same tight
// heap pressure, so they skip straight to the trivial expected result.
def TARGET_wasm_wave: bool = false;
def TARGET_x86_linux: bool = false;
def TARGET_x86_64_linux: bool = false;
def TARGET_x86_darwin: bool = false;
def TARGET_x86_64_darwin: bool = false;

class GObject { }
class GBox extends GObject {
	def val: int;
	new(val) { }
}

type GResult {
	case OK(v: GObject);
}

class GFrame {
	var result: GResult;
	var pendingArgs: Array<GObject>;
	def eval() {
		var t = GBox.!(pendingArgs[0]);
		var a = GBox.!(pendingArgs[1]);
		result = GResult.OK(GBox.new(t.val + a.val));
	}
}

def main() -> int {
	if (!TARGET_wasm_wave) return 42;

	var i: GObject = GBox.new(41);
	var one: GObject = GBox.new(1);

	// Pad the heap so that GFrame.eval()'s own two allocations (GBox.new,
	// GResult.OK) trigger exactly one GC cycle, relocating the still-live
	// GFrame.
	var padlen = Array<GObject>.new(4078).length;

	var callee = GFrame.new();
	callee.pendingArgs = [i, one];
	callee.eval();
	match (callee.result) {
		OK(v) => i = v;
	}

	return GBox.!(i).val;
}
