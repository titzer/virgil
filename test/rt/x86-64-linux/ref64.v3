layout LInfo {
         +0      info : u64;
         =8;
}

var ignored: int;

def forceSpill(a: int) { ignored = a; }

def getRef(p: Pointer) -> Ref<LInfo> {
         return Ref<LInfo>.of(CiRuntime.forgeRange<byte>(p, 4096));
}

def getData(r: Ref<LInfo>) -> u64 {
         var p = Pointer.atField(r.info);
         var value = p.load<u64>();
         return value;
}

def getArg() -> int {
         return 100;
}

def main(args: Array<int>) -> int {
         var a = getArg();
         var flags = LinuxConst.MAP_PRIVATE | LinuxConst.MAP_FIXED | LinuxConst.MAP_ANONYMOUS;
         var prot = LinuxConst.PROT_READ | LinuxConst.PROT_WRITE;
         var res = Linux.syscall(LinuxConst.SYS_mmap, (Pointer.NULL + 0x1_0000_0000, 4096, prot, flags, 0, 0));
         var start = Pointer.NULL + res.0;
         start.store<u64>(u64.view(a));
         var r = getRef(start);
         forceSpill(a);
         var u = getData(r);
	 Linux.syscall(LinuxConst.SYS_write, (1, Pointer.atContents("ok\n"), 3));
         return 0;
}
