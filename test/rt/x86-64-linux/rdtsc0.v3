def CALLS = 1_000_000;

def test_nonzero() -> int {
	if (CiRuntime.readTsc() == 0) return -1;
	return 42;
}

def test_monotonic() -> int {
	var a = CiRuntime.readTsc();
	var b = CiRuntime.readTsc();
	if (b < a) return -1;
	return 42;
}

def test_advances() -> int {
	var a = CiRuntime.readTsc();
	var sum = 0u;
	for (i < 10_000_000) sum = sum + u32.!(i);
	var b = CiRuntime.readTsc();
	if (b <= a) return -1;
	if (sum == 0) return -2; // keep the loop live
	return 42;
}

var acc: long;

def test_not_elided() -> int {
	var a = CiRuntime.readTsc();
	for (i < CALLS) acc = acc ^ CiRuntime.readTsc();
	var b = CiRuntime.readTsc();
	var delta = b - a;
	if (delta <= 0) return -1;
	var cyclesPerCall = delta / long.!(CALLS);
	if (cyclesPerCall < 1) return -2;
	if (cyclesPerCall > 100_000) return -3;
	return 42;
}

def main() -> int {
	var result = 0;
	for (t in [("nonzero", test_nonzero), ("monotonic", test_monotonic),
		("advances", test_advances), ("not_elided", test_not_elided)]) {
		System.puts("##+");
		System.puts(t.0);
		System.ln();
		var r = t.1();
		if (r == 42) {
			System.puts("##-ok\n");
		} else {
			System.puts("##-fail: ");
			System.puti(r);
			System.ln();
			result--;
		}
	}
	return result;
}
