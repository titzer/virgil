// Extension emulation.
def EMULATE = true;
class Cell(next: Cell) { }
class CellOf<T> extends Cell {
	var x: T;
	new(x, next: Cell) super(next) { }
}

class D(id: byte, var dx: int) describes C {
	def inc() { dx += id; }
}
class C(var cx: int) descriptor D {
	var cells: Cell;

	def inc() { cx += (this.descriptor.id + this.descriptor.dx); }
	def unsafe_get<T>() -> T {
		if (EMULATE) return find<T>().x;
		var p = Pointer.atEnd(this);
		return p.load<T>();
	}
	def unsafe_set<T>(val: T) -> this {
		if (EMULATE) {
			var c = find<T>();
			if (c != null) c.x = val;
			else cells = CellOf<T>.new(val, cells);
			return;
		}
		var p = Pointer.atEnd(this);
		p.store(val);
	}
	def find<T>() -> CellOf<T> {
		for (l = cells; l != null; l = l.next) {
			if (CellOf<T>.?(l)) return CellOf<T>.!(l);
		}
		return null;
	}
}

def brand<T>(d: T, words: Range<bool>) -> T {
	//TODO CiRuntime.brandDescriptor(d, words); // instances of C that point to dK will have one additional non-ref word
	return d;
}
def test(name: string, f: void -> bool) {
	System.puts("##+");
	System.puts(name);
	System.ln();
	var result = f();
	System.puts(if(result, "##-ok", "##-fail"));
	System.ln();
}

def main() {
	var dK = brand(D.new('K', 12), [false]);

	// Check basic allocation functionality.
	test("alloc", fun -> bool {
		var ck1 = C.new(dK, 111);
		var ck2 = C.new(dK, 222);
		return ck1 != ck2 && ck1.descriptor == ck2.descriptor;
	});

	// Check basic read/write access to an integer extension field.
	test("set_get1", fun -> bool {
		var ck1 = C.new(dK, 111);
		var ck2 = C.new(dK, 222);

		for (i = -5; i < 5; i++) {
			var c = ck1.unsafe_set(i);
			if (c != ck1) return false;
			if (i != c.unsafe_get<int>()) return false;
		}

		return true;
	});

	// Check read/write access to an integer extension field of two different objects.
	test("set_get2", fun -> bool {
		var ck1 = C.new(dK, 111);
		var ck2 = C.new(dK, 222);

		for (i = -5; i < 5; i++) {
			var ck11 = ck1.unsafe_set(i);
			var ck22 = ck2.unsafe_set(i + 10);
			if (ck11 != ck1) return false;
			if (ck22 != ck2) return false;
			if (i != ck11.unsafe_get<int>()) return false;
			if ((i + 10) != ck22.unsafe_get<int>()) return false;
		}

		return true;
	});
}
