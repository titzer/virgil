//@execute 0=0
// Regression test for the loop-liveness fix in WasmCodeGen, isolated from
// the separate ShadowStackSpiller restore-placement bug: the extra
// alloc(999) call after "keep.val" pushes the shadow-stack deallocation
// past that use, so this only exercises finishLoopLiveness().
class GBox {
	def val: int;
	new(val) { }
}

def alloc(n: int) -> GBox {
	var b = GBox.new(n);
	RiGc.forceGC();
	return b;
}

def loopy(keep: GBox, iters: int) -> int {
	var acc = 0;
	for (i < iters) {
		var tmp = alloc(i);
		acc += tmp.val;
	}
	var v = keep.val;
	var extra = alloc(999); // pushes dealloc past the use of "keep" above
	return v + acc + extra.val;
}

def main() -> int {
	var k = GBox.new(42);
	var r = loopy(k, 100);
	return if(r == 5991, 0, 1);
}
