//@execute 0=0
// Tests that a value live into a loop containing a GC-triggering call, but
// never read or written inside the loop body, is still correctly saved and
// reloaded across a collection, rather than omitted from the GC root set.
class GBox {
	def val: int;
	new(val) { }
}

def alloc(n: int) -> GBox {
	var b = GBox.new(n);
	RiGc.forceGC();
	return b;
}

def loopy(keep: GBox, iters: int) -> int {
	var acc = 0;
	for (i < iters) {
		var tmp = alloc(i);
		acc += tmp.val;
	}
	return keep.val + acc; // first use of "keep" is after the loop
}

def main() -> int {
	var k = GBox.new(42);
	var r = loopy(k, 100);
	return if(r == 4992, 0, 1);
}
