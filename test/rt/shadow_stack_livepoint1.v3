//@execute 0=0
// Regression test for a second, distinct Wasm-target shadow-stack codegen
// bug (see shadow_stack_livepoint0.v3 for the first): a value that is live
// across a GC-triggering call *inside a loop*, but never actually used
// inside the loop body (only used after the loop exits), is omitted from
// that call's GC root set entirely -- no shadow-stack slot is ever
// allocated for it, so it isn't saved before the call at all. If a GC
// relocates the object during any loop iteration, the code falls out of
// the loop still holding the stale, pre-relocation pointer.
//
// This is a loop/back-edge-specific variant of the first bug: that one was
// about a value live across two *consecutive, straight-line* GC-triggering
// calls; this one is about a value that's live-in to a loop containing a
// GC-triggering call, with its only use *after* the loop. If the value is
// also used somewhere inside the loop body, it gets spilled correctly --
// it's specifically "loop-carried but loop-body-dead" values that are
// dropped from the root set.
def TARGET_wasm_wave: bool = false;
def TARGET_x86_linux: bool = false;
def TARGET_x86_64_linux: bool = false;
def TARGET_x86_darwin: bool = false;
def TARGET_x86_64_darwin: bool = false;

class GBox {
	def val: int;
	new(val) { }
}

def alloc(n: int) -> GBox {
	var b = GBox.new(n);
	RiGc.forceGC();
	return b;
}

def loopy(keep: GBox, iters: int) -> int {
	var acc = 0;
	for (i < iters) {
		var tmp = alloc(i);
		acc += tmp.val;
	}
	return keep.val + acc; // first use of "keep" is after the loop
}

def main() -> int {
	if (!TARGET_wasm_wave) return 0;
	var k = GBox.new(42);
	var r = loopy(k, 100);
	return if(r == 4992, 0, 1);
}
