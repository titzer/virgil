//@execute 0=12; 1=25; 2=37
type T {
	case A(x: int); // dead
	case B(x: int); 
	case C(x: int); // dead
	case D(x: int);
	case E(x: int);
}

var vs = [T.B(11), T.D(22), T.E(33)];

def main(a: int) -> int {
	var v = vs[a];
	match (v) {
		A(x) => return v.tag + x;
		B(x) => return v.tag + x;
		C(x) => return v.tag + x;
		D(x) => return v.tag + x;
		E(x) => return v.tag + x;
	}
}
