//@execute 0=333; 1=444; 2=-333; 3=-444
type T {
	case A(x: int);
	case B(x: int);
}

var ga1: T = T.A(333);
var ga2: T = T.A(444);

var gb1: T = T.B(-333);
var gb2: T = T.B(-444);

def swap() { // defeat constant-folding before reachability.
	var ta = ga1;
	ga1 = ga2;
	ga2 = ga1;

	var tb = gb1;
	gb1 = gb2;
	gb2 = gb1;
}

def main(a: int) -> int {
	match (a) {
		0 => match (ga1) { // folds after reachability
			A(x) => return x;
			B(x) => return x;
		}
		1 => match (ga2) { // folds after reachability
			A(x) => return x;
			B(x) => return x;
		}
		2 => match (gb1) { // folds after reachability
			A(x) => return x;
			B(x) => return x;
		}
		3 => match (gb2) { // folds after reachability
			A(x) => return x;
			B(x) => return x;
		}
	}
	return -42;
}
