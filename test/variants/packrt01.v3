//@execute 0=171; 1=255; 2=10
// packlayout01 at runtime: wider container zero-pads the high bits
def w16(a: u4, b: u4) -> u16 { return u16.pack<(u4,u4)>((a,b)); }
def w32(a: u4, b: u4) -> u32 { return u32.pack<(u4,u4)>((a,b)); }
def w1(a: u4) -> u32 { return u32.pack<u4>(a); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(w16(u4.view(0xA), u4.view(0xB)));
		1 => return int.view(w32(u4.view(0xF), u4.view(0xF)));
		2 => return int.view(w1(u4.view(0xA)));
		_ => return -1;
	}
}
