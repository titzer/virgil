//@execute 0=true;1=false;2=true;3=false;4=true;5=false
type A {
	case X(b: u20);
	case Y(y: int) #unboxed;
}

def arr1 = [A.X(12), A.X(12), A.X(34), A.X(56), A.Y(99), A.Y(99)];
def arr2 = [A.X(12), A.X(34), A.X(34), A.Y(99), A.Y(99), A.X(7)];

def main(a: int) -> bool {
	return arr1[a] == arr2[a];
}