//@execute 0=1; 1=1
// a 2-bit payload round-trips through every container width from 2 to 64
def w2(a: u1, b: u1) -> bool { def p = u2.pack<(u1,u1)>((a,b)); def u = u2.unpack<(u1,u1)>(p); return u.0 == a && u.1 == b; }
