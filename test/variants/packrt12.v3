//@execute 0=213; 1=-3; 2=5; 3=21
// packlayout23 at runtime: signed fields inside a case type
type T { case A(x: i4, y: i4); case B(z: u8); }
def pk(x: i4, y: i4) -> u8 { return u8.pack<T.A>(T.A(x,y)); }
def up(v: u8) -> T.A { return u8.unpack<T.A>(v); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(pk(i4.view(-3), i4.view(5)));
		1 => return up(u8.view(0xD5)).x;
		2 => return up(u8.view(0xD5)).y;
		3 => {
			var t: T = up(u8.view(0xAB));   // usable where a T is expected
			match (t) {
				A(x, y) => return int.view(u4.view(x)) + int.view(u4.view(y));
				B(z) => return -1;
			}
		}
		_ => return -99;
	}
}
