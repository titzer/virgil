//@execute = 39

type V<T> #unboxed {
	case A(x: int, y: T, z: int /*dead*/);
	case B(x: int/*dead*/, y: T, z: int);
}

var global = 0;

def get<T>(v: V<T>) -> T {
	match (v) {
		x: V<T>.A => {
			global += x.x;
			return x.y;
		}
		x: V<T>.B => {
			global += x.z;
			return x.y;
		}
	}
}

def B1 = V<byte>.B(31, 6, 33);

def main() -> int {
	global = 0;
	var v = get<byte>(B1);
	return v + global;
}
