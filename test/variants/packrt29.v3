//@execute 0=1; 1=1; 2=1
// mixed signed and unsigned fields filling a 64-bit container exactly
type M(a: i16, b: u16, c: i16, d: u16) { }
def pk(a: i16, b: u16, c: i16, d: u16) -> u64 { return u64.pack<M>(M(a,b,c,d)); }
def up(v: u64) -> M { return u64.unpack<M>(v); }
def main(n: int) -> int {
	def v = pk(i16.view(-1), u16.view(0x1234), i16.view(-32768), u16.view(0xFFFF));
	def u = up(v);
	match (n) {
		0 => return if(v == 0xFFFF12348000FFFFuL, 1, 0);
		1 => return if(u.a == -1 && u.c == -32768, 1, 0);
		2 => return if(u.b == 0x1234 && u.d == 0xFFFF, 1, 0);
		_ => return -1;
	}
}
