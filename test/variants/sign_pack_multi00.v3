//@execute 0=-100060
// Regression test: reading a SIGNED sub-word field of a `#packed` variant used
// to corrupt the fields packed above it, after normalization (`-ra`) and on the
// compiled backends:
//
//	v3i          : -100060   (a == -100, b == -60)   correct
//	-ra / backend: -100001   (a == -100, b == -1)    b was all-ones
//
// SsaNormalizer.genSetInterval() sign-extended the field into the shared packed
// word and shifted it into place without masking it back to its own interval,
// so the copies of the sign bit ran over everything above it. Characterization
// at the time:
//
//	(a: i16, b: i8)  reading both		DIVERGED, b read as -1
//	(a: i16, b: i8)  reading only b		agreed -- needs the signed read
//	(a: i16, b: u8)  reading both		DIVERGED, b read as 255
//	(a: u16, b: i8)  reading both		agreed -- unsigned leader is fine
//	(a: i16, b: i8, c: i8)			DIVERGED, both b and c corrupted
//	(a: i16, b: i8) without #packed		agreed
//
// The payload must be runtime-computed; constant payloads folded correctly.
//
// The rest of test/variants/sign_pack*.v3 uses a single signed field per case,
// which is why a signed field FOLLOWED BY another field was missed.
type B2 #unboxed #packed {
	case T(a: i16, b: i8) #unboxed #packed;
	case F #unboxed #packed;
}
def main(k: int) -> int {
	var v: B2 = B2.T(i16.view(k - 100), i8.view(k - 60));
	var t = B2.T.!(v);
	return int.!(t.a) * 1000 + int.!(t.b);
}
