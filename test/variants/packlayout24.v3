//@execute 0=1; 1=1; 2=1; 3=1
// many field kinds inside one case type, round-tripped at RUNTIME (not folded)
// NOTE: enum and E.set fields are deliberately omitted; both have open bugs.
// See test/fail/int_unpack_enum_runtime00.v3 and int_unpack_enumset00.v3.
type Rgb(r: byte, g: byte, b: byte) { }
type T {
	case Big(f: bool, s: i5, c: Rgb, n: u3, w: u16);
	case Small(z: u8);
}
def mk(n: u3) -> T.Big { return T.Big(true, -7, Rgb(0x11, 0x22, 0x33), n, 0xBEEF); }
def main(a: int) -> int {
	def u = u64.unpack<T.Big>(u64.pack<T.Big>(mk(u3.view(a))));
	match (a) {
		0 => return if(u.f == true && u.s == -7, 1, 0);
		1 => return if(u.w == 0xBEEF, 1, 0);
		2 => return if(u.c.r == 0x11 && u.c.g == 0x22 && u.c.b == 0x33, 1, 0);
		3 => return if(u.n == 3 && u == mk(3), 1, 0);
		_ => return -1;
	}
}
