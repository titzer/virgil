//@execute 0=1; 1=1; 2=1; 3=1; 7=1
// every 3-bit pattern maps onto a 5-case enum: valid tags pass through,
// out-of-range patterns map to tag 0 (same rule as an enum layout field)
enum E { A, B, C, D, F }
def f(v: u3) -> E { return u3.unpack<E>(v); }
def main(n: int) -> int {
	def got = f(u3.view(n)).tag;
	def want = if(n < 5, n, 0);
	return if(got == want, 1, 0);
}
