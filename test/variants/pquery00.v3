//@execute 0=-42; 1=-42
type Some<T> {
	case One(x: T);
	case Two(x: T, y: T);
}

def isOneInt<T>(x: Some<T>, val: int) -> bool {
	return Some.One<int>.?(x) && Some<int>.One.!(x).x == val;
}

def main(a: int) -> int {
	var x: Some<int> = Some.Two(a, a);
	if (isOneInt(x, a)) return 11;
	return -42;
}
