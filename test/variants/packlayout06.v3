//@execute 0=1193046; 1=1; 2=18; 3=52; 4=86
// a data type packs exactly like a tuple of its fields, in declaration order
type Rgb(r: byte, g: byte, b: byte) { }
def main(a: int) -> int {
	def c = u24.pack<Rgb>(Rgb(0x12, 0x34, 0x56));
	def t = u24.pack<(byte, byte, byte)>((0x12, 0x34, 0x56));
	def u = u24.unpack<Rgb>(c);
	match (a) {
		0 => return int.view(c);              // 0x123456
		1 => return if(c == t, 1, 0);         // identical to the tuple encoding
		2 => return u.r;                      // 0x12
		3 => return u.g;                      // 0x34
		4 => return u.b;                      // 0x56
		_ => return -1;
	}
}
