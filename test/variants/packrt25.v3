//@execute 0=1; 1=1
// void fields occupy no bits and do not disturb the layout
type P(x: u4, v: void, y: u4) { }
def pk(x: u4, y: u4) -> u8 { return u8.pack<P>(P(x, (), y)); }
def pt(x: u4, y: u4) -> u8 { return u8.pack<(u4, void, u4)>((x, (), y)); }
def main(n: int) -> int {
	def x = u4.view(0xA), y = u4.view(0xB);
	match (n) {
		0 => return if(pk(x, y) == 0xAB, 1, 0);
		1 => return if(pt(x, y) == 0xAB, 1, 0);
		_ => return -1;
	}
}
