//@execute 0=10; 1=11; 2=1; 3=0
// packlayout02 at runtime: unpack ignores bits above the packing width
def hi(v: u16) -> (u4, u4) { return u16.unpack<(u4,u4)>(v); }
def lo(v: u8) -> (bool, u1) { return u8.unpack<(bool,u1)>(v); }
def main(a: int) -> int {
	def t = hi(u16.view(0xFFAB));
	def u = lo(u8.view(0xFE));
	match (a) {
		0 => return int.view(t.0);
		1 => return int.view(t.1);
		2 => return if(u.0, 1, 0);
		3 => return int.view(u.1);
		_ => return -1;
	}
}
