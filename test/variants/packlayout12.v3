//@execute 0=1; 1=1; 2=1
// the full 64-bit container is usable
def main(a: int) -> int {
	def p = u64.pack<(u32, u32)>((0xAAAAAAAAu, 0xBBBBBBBBu));
	def u = u64.unpack<(u32, u32)>(p);
	match (a) {
		0 => return if(p == 0xAAAAAAAABBBBBBBBuL, 1, 0);
		1 => return if(u.0 == 0xAAAAAAAAu, 1, 0);
		2 => return if(u.1 == 0xBBBBBBBBu, 1, 0);
		_ => return -1;
	}
}
