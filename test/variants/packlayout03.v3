//@execute 0=213; 1=-3; 2=5; 3=-1; 4=-8
// signed fields are stored two's complement in their own width and sign-extended by unpack
def main(a: int) -> int {
	def p = u8.pack<(i4, i4)>((-3, 5));
	def u = u8.unpack<(i4, i4)>(0xD5);
	match (a) {
		0 => return int.view(p);                            // 0xD5: -3 is 0b1101, 5 is 0b0101
		1 => return u.0;                                    // sign-extended back to -3
		2 => return u.1;                                    // 5
		3 => return u8.unpack<(i4, i4)>(0xFF).0;            // 0b1111 -> -1
		4 => return u8.unpack<(i4, i4)>(0x8F).0;            // 0b1000 -> -8
		_ => return -99;
	}
}
