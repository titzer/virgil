//@execute 0=true;1=false;2=true;3=false
type A #unboxed {
	case X;
	case Y(x: int);
}

def eq = A.==;

def main(a: int) -> bool {
	var a_x: A = A.X;
	var a_x2: A = A.X;
	var a_y: A = A.Y(12);
	var a_y2: A = A.Y(12);
	var a_y3: A = A.Y(13);

	match (a) {
		0 => return eq(a_x, a_x2);
		1 => return eq(a_x, a_y);
		2 => return eq(a_y, a_y2);
		3 => return eq(a_y, a_y3);
	}
	return false;
}
