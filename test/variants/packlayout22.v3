//@execute 0=11; 1=10; 2=1; 3=11
// generic type arguments of every packable kind
enum E { A, B, C, D }
type P<X>(x: X, y: u4) { }
type T<X> { case A(v: X, w: u4); case B(z: X); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u12.unpack<P<(u4, u4)>>(0xABC).x.1);   // 0xB
		1 => return int.view(u6.unpack<P<E>>(0b101010).y);          // 0b1010
		2 => return int.view(u36.unpack<P<float>>(0x3FC000000u36).x == 1.5f);
		3 => return int.view(u12.unpack<(u4, T<u4>.A)>(0xCAB).1.w); // 0xB
		_ => return -1;
	}
}
