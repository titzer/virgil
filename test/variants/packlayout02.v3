//@execute 0=10; 1=11; 2=1; 3=0
// unpack ignores bits above the packing width rather than rejecting them
def main(a: int) -> int {
	def t = u16.unpack<(u4, u4)>(0xFFAB);
	def u = u8.unpack<(bool, u1)>(0xFE);
	match (a) {
		0 => return int.view(t.0);          // 0xA; the high 0xFF is discarded
		1 => return int.view(t.1);          // 0xB
		2 => return if(u.0, 1, 0);          // bit 1 of 0b10 == 1
		3 => return int.view(u.1);          // bit 0 of 0b10 == 0
		_ => return -1;
	}
}
