//@execute 0=1962; 1=1; 2=-2; 3=1; 4=10
// a heterogeneous layout: bool, signed, enum and unsigned fields side by side
// 1 | 1110 | 10 | 1010  ==  0b11110101010
enum E { A, B, C, D }
def main(a: int) -> int {
	def p = u11.pack<(bool, i4, E, u4)>((true, -2, E.C, 0xA));
	def u = u11.unpack<(bool, i4, E, u4)>(p);
	match (a) {
		0 => return int.view(p);
		1 => return if(u.0, 1, 0);
		2 => return u.1;                     // sign-extended back to -2
		3 => return if(u.2 == E.C, 1, 0);
		4 => return int.view(u.3);
		_ => return -99;
	}
}
