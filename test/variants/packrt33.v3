//@execute 0=1; 1=1; 15=1; 16=1; 128=1; 171=1; 255=1
// a signed container round-trips identically to an unsigned one, at runtime.
// Values are supplied as inputs rather than looped, to avoid the wasm bug in
// test/fail/wasm_unpack_loop00.v3.
type P(a: u4, b: u4) { }
def su(a: u4, b: u4) -> i8 { return i8.pack<P>(P(a,b)); }
def uu(a: u4, b: u4) -> u8 { return u8.pack<P>(P(a,b)); }
def si(v: i8) -> P { return i8.unpack<P>(v); }
def main(n: int) -> int {
	def a = u4.view(n >> 4), b = u4.view(n & 0xF);
	if (u8.view(su(a,b)) != uu(a,b)) return -1;      // same bits either way
	def r = si(su(a,b));
	if (r.a != a || r.b != b) return -2;             // round-trips through i8
	if (i8.unpack<P>(i8.view(n)).a != a) return -3;
	return 1;
}
