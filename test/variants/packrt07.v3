//@execute 0=27966412; 1=1
// packlayout07 at runtime: data types compose inside tuples
type Rgb(r: byte, g: byte, b: byte) { }
def pk(f: bool, r: byte, g: byte, b: byte) -> u32 { return u32.pack<(bool,Rgb)>((f, Rgb(r,g,b))); }
def up(v: u32) -> (bool, Rgb) { return u32.unpack<(bool,Rgb)>(v); }
def main(a: int) -> int {
	def p = pk(true, byte.view(0xAA), byte.view(0xBB), byte.view(0xCC));
	def u = up(p);
	match (a) {
		0 => return int.view(p);
		1 => return if(u.0 && u.1.r == 0xAA && u.1.b == 0xCC, 1, 0);
		_ => return -1;
	}
}
