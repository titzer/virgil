//@execute = 11
// Pins the inconsistency directly: the same comparison must not depend on
// whether the operands reached the optimizer as constants. `folded` is built
// from a compile-time NaN, `live` from an array load, and both hold identical
// bits, so the two comparisons must agree.
type F {
	case M(x: float);
}
def NANS: Array<float> = [float.nan];
def main() -> int {
	var k = float.nan;			// constant
	var v = NANS[0];			// runtime value, same bits
	if (int.view(k) != int.view(v)) return -1;	// precondition: identical bits
	var folded = if(F.M(k) == F.M(k), 1, 0);
	var live = if(F.M(v) == F.M(v), 1, 0);
	return folded * 10 + live;		// 11 or 00, never 10
}
