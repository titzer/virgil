//@execute 0=1069547520; 1=1; 2=1; 3=1
// packlayout08 at runtime: float/double raw IEEE bits
def pf(f: float) -> u32 { return u32.pack<float>(f); }
def uf(v: u32) -> float { return u32.unpack<float>(v); }
def pd(d: double) -> u64 { return u64.pack<double>(d); }
def ud(v: u64) -> double { return u64.unpack<double>(v); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(pf(float.view(u32.view(0x3FC00000))));  // 1.5f
		1 => return if(pd(double.view(0x3FF8000000000000uL)) == 0x3FF8000000000000uL, 1, 0);
		2 => return if(uf(pf(-2.5f)) == -2.5f, 1, 0);
		3 => return if(ud(pd(-2.5d)) == -2.5d, 1, 0);
		_ => return -1;
	}
}
