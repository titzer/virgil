//@execute 0=true; 1=true
// Same as eq_nan00, for an #unboxed variant, which breaks earlier: this one
// already fails under `-ra`, so unboxing lowers the payload to a raw float field
// compared with IEEE `==` during normalization rather than in the backend.
type F #unboxed {
	case M(x: float);
	case N;
}
def NANS: Array<float> = [float.nan, float.nan];
def main(a: int) -> bool {
	var x = NANS[a];			// runtime value, not a constant
	return F.M(x) == F.M(x);
}
