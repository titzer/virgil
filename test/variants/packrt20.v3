//@execute 0=43981; 1=10; 2=11; 3=205
// packlayout15 at runtime: nested data types flatten in declaration order
type Inner(a: u4, b: u4) { }
type Outer(i: Inner, c: u8) { }
def pk(a: u4, b: u4, c: u8) -> u16 { return u16.pack<Outer>(Outer(Inner(a,b), c)); }
def up(v: u16) -> Outer { return u16.unpack<Outer>(v); }
def main(n: int) -> int {
	def p = pk(u4.view(0xA), u4.view(0xB), u8.view(0xCD));
	def u = up(p);
	match (n) {
		0 => return int.view(p);
		1 => return int.view(u.i.a);
		2 => return int.view(u.i.b);
		3 => return u.c;
		_ => return -1;
	}
}
