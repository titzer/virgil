//@execute 0=1; 1=1; 2=1; 3=1
// an E.set round-trips through a container of ANY width, not just its own.
// (regression: unpack used TypeSubsume, which SHIFTS an enum tag into a
// singleton set, so wider containers silently produced the wrong set)
enum E { A, B, C, D }
def w4(s: E.set) -> E.set { return u4.unpack<E.set>(u4.pack<E.set>(s)); }
def w5(s: E.set) -> E.set { return u5.unpack<E.set>(u5.pack<E.set>(s)); }
def w8(s: E.set) -> E.set { return u8.unpack<E.set>(u8.pack<E.set>(s)); }
def w32(s: E.set) -> E.set { return u32.unpack<E.set>(u32.pack<E.set>(s)); }
def bits(s: E.set) -> int { return int.view(u4.pack<E.set>(s)); }
def pick(n: int) -> E.set {
	match (n) {
		0 => return E.A;              // 0b0001
		1 => return E.B;              // 0b0010
		2 => return E.C;              // 0b0100
		_ => return E.A | E.D;        // 0b1001
	}
}
def main(n: int) -> int {
	def s = pick(n), b = bits(s);
	if (bits(w4(s)) != b) return -1;
	if (bits(w5(s)) != b) return -2;
	if (bits(w8(s)) != b) return -3;
	if (bits(w32(s)) != b) return -4;
	return 1;
}
