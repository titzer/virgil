//@execute 0=1; 1=2; 2=13; 3=2; 4=24; 5=1000; 6=!BoundsCheckException
type T {
	case A(x: int);
	case B(x: int);

	def get(ok: bool) -> int {
		if (T.A.?(this) && ok) return T.A.!(this).x;
		if (T.B.?(this) && ok) return T.B.!(this).x;
		return int.max;
	}
}

def vs = [T.A(1), T.A(2), T.A(13), T.B(2), T.B(24), T.B(1000)];

def main(a: int) -> int {
	return vs[a].get(true);
}