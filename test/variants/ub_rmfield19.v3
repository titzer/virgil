//@execute 0=23; 1=43; 2=39; 3=50; 4=0

type V<T> #unboxed {
	case A(x: int, y: T, z: int /*dead*/);
	case B(x: int/*dead*/, y: T, z: int);
}

var global = 0;

def get<T>(v: V<T>) -> T {
	match (v) {
		x: V<T>.A => {
			global += x.x;
			return x.y;
		}
		x: V<T>.B => {
			global += x.z;
			return x.y;
		}
	}
}

def A1 = V<int>.A(11, 12, 13);
def A2 = V<int>.A(21, 22, 23);

def B1 = V<byte>.B(31, 6, 33);
def B2 = V<byte>.B(41, 7, 43);

def main(a: int) -> int {
	global = 0;
	var v: int;
	match (a) {
		0 => v = get(A1);
		1 => v = get(A2);
		2 => v = get<byte>(B1);
		3 => v = get<byte>(B2);
	}
	return v + global;
}
