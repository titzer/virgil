//@execute 0=1; 1=1; 2=1; 3=1
// a phantom type parameter stays packable even when the type argument itself
// is NOT packable, because no field ever mentions it
type T { case A(x: u4); case B(y: u4); }
type X<P>(f: u8) { }
type N<P>(a: X<P>, b: u4) { }
def pv(v: u8) -> u8 { return u8.pack<X<T>>(X<T>(v)); }          // arg is a variant with cases
def pc(v: u8) -> u8 { return u8.pack<X<T.A>>(X<T.A>(v)); }      // arg is a case type
def pf(v: u8) -> u8 { return u8.pack<X<int -> int>>(X<int -> int>(v)); }  // arg is a function
def pn(v: u8, b: u4) -> u12 { return u12.pack<N<T>>(N<T>(X<T>(v), b)); }  // nested phantom
def main(n: int) -> int {
	def v = u8.view(0xAB);
	match (n) {
		0 => return if(pv(v) == 0xAB, 1, 0);
		1 => return if(pc(v) == 0xAB, 1, 0);
		2 => return if(pf(v) == 0xAB, 1, 0);
		3 => return if(pn(v, u4.view(0xC)) == 0xABC, 1, 0);
		_ => return -1;
	}
}
