//@execute 0=9; 1=1; 2=1; 3=1
// packlayout11 at runtime: u1 fields and minimum widths
def pk(a: u1, b: u1, c: u1, d: u1) -> u4 { return u4.pack<(u1,u1,u1,u1)>((a,b,c,d)); }
def up(v: u4) -> (u1,u1,u1,u1) { return u4.unpack<(u1,u1,u1,u1)>(v); }
def main(x: int) -> int {
	def one = u1.view(1), zero = u1.view(0);
	def u = up(u4.view(0b1001));
	match (x) {
		0 => return int.view(pk(one, zero, zero, one));
		1 => return int.view(u.0);
		2 => return int.view(u.3);
		3 => return if(u.1 == 0 && u.2 == 0, 1, 0);
		_ => return -1;
	}
}
