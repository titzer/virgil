//@execute 0=10; 1=15; 2=0; 3=1
// NOTE: constant inputs, so these fold via Eval. Runtime E.set unpack is broken
// unless the container is exactly the set width; see test/fail/int_unpack_enumset00.v3.
// an enum set packs to its bitset: one bit per case, first case in the LOW bit
enum E { A, B, C, D }
def empty: E.set;
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u4.pack<E.set>(E.B | E.D));        // 0b1010
		1 => return int.view(u4.pack<E.set>(E.set.all));        // 0b1111
		2 => return int.view(u4.pack<E.set>(empty));            // 0b0000
		3 => return if(u4.unpack<E.set>(0b0101) == (E.A | E.C), 1, 0);
		_ => return -1;
	}
}
