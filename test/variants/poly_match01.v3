//@execute 0=11; 1=12; 2=-13
type E<T> {
	case A;
	case B;
}

def m<T>(e: E<T>.B) -> int {
	match (e) {
		x: E<int>.B => return 11;
		x: E<bool>.B => return 12;
		_ => return -13;
	}
}

def main(a: int) -> int {
	match (a) {
		0 => return m(E<int>.B);
		1 => return m(E<bool>.B);
		2 => return m(E<string>.B);
	}
	return -42;
}
