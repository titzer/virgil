//@execute 0=1; 1=1; 2=1
// every bit pattern of a 4-case enum set round-trips through a wider container
enum E { A, B, C, D }
def w8(s: E.set) -> E.set { return u8.unpack<E.set>(u8.pack<E.set>(s)); }
def bits(s: E.set) -> int { return int.view(u4.pack<E.set>(s)); }
def mk(i: int) -> E.set { return u4.unpack<E.set>(u4.view(i)); }
def main(k: int) -> int {
	for (i < 16) {
		def s = mk(i);
		match (k) {
			0 => if (bits(s) != i) return -i-1;          // construction is exact
			1 => if (bits(w8(s)) != i) return -i-1;      // and survives a wide container
			2 => if (bits(w8(w8(s))) != i) return -i-1;  // repeatedly
			_ => return -1;
		}
	}
	return 1;
}
