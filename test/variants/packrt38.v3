//@execute 0=1; 1=1; 2=1; 3=1
// enum fields inside tuples, data types and case types, at runtime
enum E { A, B, C, D }
type P(e: E, x: u4) { }
type T { case A(e: E, y: u4); case B(z: u8); }
def ft(v: u6) -> (E, u4) { return u6.unpack<(E, u4)>(v); }
def fp(v: u6) -> P { return u6.unpack<P>(v); }
def fc(v: u6) -> T.A { return u6.unpack<T.A>(v); }
def main(a: int) -> int {
	def v = u6.view(0b10_1010);   // tag 2 == E.C, then 0b1010
	match (a) {
		0 => return if(ft(v).0 == E.C && ft(v).1 == 0xA, 1, 0);
		1 => return if(fp(v).e == E.C && fp(v).x == 0xA, 1, 0);
		2 => return if(fc(v).e == E.C && fc(v).y == 0xA, 1, 0);
		3 => return if(u6.pack<P>(P(E.C, u4.view(0xA))) == 0b10_1010, 1, 0);
		_ => return -1;
	}
}
