//@execute 0=2748; 1=2748; 2=1
// packlayout05 at runtime: nested tuples flatten identically
def nest(a: u4, b: u4, c: u4) -> u12 { return u12.pack<(u4,(u4,u4))>((a,(b,c))); }
def flat(a: u4, b: u4, c: u4) -> u12 { return u12.pack<(u4,u4,u4)>((a,b,c)); }
def right(a: u4, b: u4, c: u4) -> u12 { return u12.pack<((u4,u4),u4)>(((a,b),c)); }
def main(x: int) -> int {
	def a = u4.view(0xA), b = u4.view(0xB), c = u4.view(0xC);
	match (x) {
		0 => return int.view(nest(a,b,c));
		1 => return int.view(flat(a,b,c));
		2 => return if(nest(a,b,c) == flat(a,b,c) && flat(a,b,c) == right(a,b,c), 1, 0);
		_ => return -1;
	}
}
