//@execute 0=true;1=true;2=true
// Packed unboxed variant whose cases mix a 64-bit double payload with an
// integer payload. Reading the double back goes through the dispatched
// accessor, which returns a double across a call boundary.
type P19 #unboxed #packed {
	case D(a: double) { def f() -> double { return a; } }
	case L(b: long) { def f() -> double { return double.view(b); } }
	def f() -> double;
}
def arr = [ P19.D(5.0d), P19.L(long.view(9.0d)), P19.D(0.0d) ];
def ans = [ 5.0d, 9.0d, 0.0d ];
def main(a: int) -> bool {
	return arr[a].f() == ans[a];
}
