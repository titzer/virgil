//@execute 0=2; 1=1; 2=0; 3=-88
type T {
	case A;
	case B;
	case C;
}

var ka: T = T.A;
var kb: T = T.B;
var kc: T = T.C;

def kill() { // unreachable, defeats early const-prop
	ka = T.B;
	kb = T.A;
	kc = T.B;
}

def main(a: int) -> int {
	match (a) {
		0 => return kc.tag;
		1 => return kb.tag;
		2 => return ka.tag;
	}
	return -88;
}
