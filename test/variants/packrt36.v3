//@execute 0=0; 1=1; 2=2; 3=3
// enum fields unpack correctly at RUNTIME (not constant-folded)
// (regression: this used to fail with "InternalError: subsume should never fail")
enum E { A, B, C, D }
def f(v: u2) -> E { return u2.unpack<E>(v); }
def main(a: int) -> int { return f(u2.view(a)).tag; }
