//@execute 0=1; 1=1
// case types of a GENERIC variant, at runtime
type T<X> { case A(v: X, w: u4); case B(z: X); }
def pa(v: u4, w: u4) -> u8 { return u8.pack<T<u4>.A>(T<u4>.A(v, w)); }
def ua(p: u8) -> T<u4>.A { return u8.unpack<T<u4>.A>(p); }
def pb(z: u8) -> u8 { return u8.pack<T<u8>.B>(T<u8>.B(z)); }
def main(n: int) -> int {
	match (n) {
		0 => return if(pa(u4.view(0xA), u4.view(0xB)) == 0xAB && ua(u8.view(0xAB)).v == 0xA, 1, 0);
		1 => return if(pb(u8.view(0xCD)) == 0xCD, 1, 0);
		_ => return -1;
	}
}
