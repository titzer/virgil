//@execute 0=43981; 1=4660; 2=2748; 3=2748
// the first field occupies the HIGH bits; fields are contiguous and in declaration order
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u16.pack<(u4, u4, u4, u4)>((0xA, 0xB, 0xC, 0xD))); // 0xABCD
		1 => return int.view(u16.pack<(u8, u8)>((0x12, 0x34)));                 // 0x1234
		2 => return int.view(u12.pack<(u4, u8)>((0xA, 0xBC)));                  // 0xABC
		3 => return int.view(u12.pack<(u8, u4)>((0xAB, 0xC)));                  // 0xABC
		_ => return -1;
	}
}
