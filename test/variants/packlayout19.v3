//@execute 0=3243; 1=11; 2=3243; 3=10; 4=21
// case types compose inside tuples and data types, and unpack to real values
type T { case A(x: u4, y: u4); case B(z: u8); }
type W(a: u4, c: T.A) { }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u12.pack<(u4, T.A)>((0xC, T.A(0xA, 0xB))));  // 0xCAB
		1 => return int.view(u12.unpack<(u4, T.A)>(0xCAB).1.y);
		2 => return int.view(u12.pack<W>(W(0xC, T.A(0xA, 0xB))));         // 0xCAB
		3 => return int.view(u12.unpack<W>(0xCAB).c.x);
		4 => {
			var t: T = u8.unpack<T.A>(0xAB);   // usable where a T is expected
			match (t) {
				A(x, y) => return int.view(x) + int.view(y);
				B(z) => return -1;
			}
		}
		_ => return -1;
	}
}
