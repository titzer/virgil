//@execute 0=171; 1=205; 2=10; 3=11; 4=0
// a case type denotes exactly one case, so it packs its fields with no tag
type T { case A(x: u4, y: u4); case B(z: u8); case C; }
def main(a: int) -> int {
	def p = u8.pack<T.A>(T.A(0xA, 0xB));
	def u = u8.unpack<T.A>(0xAB);
	match (a) {
		0 => return int.view(p);                          // 0xAB
		1 => return int.view(u8.pack<T.B>(T.B(0xCD)));    // 0xCD
		2 => return int.view(u.x);
		3 => return int.view(u.y);
		4 => return int.view(u8.pack<T.C>(T.C));          // no fields, no tag
		_ => return -1;
	}
}
