//@execute 0=1; 3=1; 7=1
// an enum reached through a tuple, a data type and a case type all agree
enum E { A, B, C, D, F }
type P(e: E) { }
type T { case A(e: E); case B(x: u3); }
def viaBare(v: u3) -> E { return u3.unpack<E>(v); }
def viaTuple(v: u3) -> E { return u3.unpack<(E)>(v); }
def viaData(v: u3) -> E { return u3.unpack<P>(v).e; }
def viaCase(v: u3) -> E { return u3.unpack<T.A>(v).e; }
def main(n: int) -> int {
	def v = u3.view(n);
	def want = if(n < 5, n, 0);
	if (viaBare(v).tag != want) return -1;
	if (viaTuple(v).tag != want) return -2;
	if (viaData(v).tag != want) return -3;
	if (viaCase(v).tag != want) return -4;
	return 1;
}
