//@execute 0=1; 1=2; 2=13; 3=!BoundsCheckException
type T {
	case A(x: int);
	case B(x: int);

	def get(ok: bool) -> int {
		if (T.A.?(this) && ok) return T.A.!(this).x;
		if (T.B.?(this) && ok) return T.B.!(this).x;
		return int.max;
	}
}

def vs = [T.A(1), T.A(2), T.A(13)];

def main(a: int) -> int {
	return vs[a].get(true);
}