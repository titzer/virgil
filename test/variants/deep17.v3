//@execute 0=24; 1=24; 2=26; 3=88
type List {
	case Cons(cdr: int, car: List);
	case Nil;
}

def d: List;

def x = List.Cons(1, List.Cons(2, List.Nil));
def y = List.Cons(1, List.Cons(2, List.Nil));
def z = List.Cons(1, List.Cons(2, d));

def sumTags(l: List) -> int {
	if (l == d) return 3;
	match (l) {
		Nil => return 1;
		Cons(cdr, car) => return cdr + 10 + sumTags(car);
	}
}

def main(a: int) -> int {
	match (a) {
		0 => return sumTags(x);
		1 => return sumTags(y);
		2 => return sumTags(z);
	}
	return 88;
}
