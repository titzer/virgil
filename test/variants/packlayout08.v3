//@execute 0=1069547520; 1=1; 2=1
// float and double pack to their raw IEEE 754 bit patterns
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u32.pack<float>(1.5f));                       // 0x3FC00000
		1 => return if(u64.pack<double>(1.5d) == 0x3FF8000000000000uL, 1, 0);
		2 => return if(u32.unpack<float>(u32.pack<float>(-2.5f)) == -2.5f, 1, 0);
		_ => return -1;
	}
}
