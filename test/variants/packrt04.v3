//@execute 0=-1; 1=127; 2=-128
// packlayout04 at runtime: container signedness only affects how bits are read
def pk(x: u4, y: u4) -> i8 { return i8.pack<(u4,u4)>((x,y)); }
def main(a: int) -> int {
	match (a) {
		0 => return pk(u4.view(0xF), u4.view(0xF));
		1 => return pk(u4.view(0x7), u4.view(0xF));
		2 => return pk(u4.view(0x8), u4.view(0x0));
		_ => return -99;
	}
}
