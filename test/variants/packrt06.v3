//@execute 0=1193046; 1=1; 2=18; 3=52; 4=86
// packlayout06 at runtime: data type == tuple of its fields
type Rgb(r: byte, g: byte, b: byte) { }
def pk(r: byte, g: byte, b: byte) -> u24 { return u24.pack<Rgb>(Rgb(r,g,b)); }
def pt(r: byte, g: byte, b: byte) -> u24 { return u24.pack<(byte,byte,byte)>((r,g,b)); }
def up(v: u24) -> Rgb { return u24.unpack<Rgb>(v); }
def main(a: int) -> int {
	def r = byte.view(0x12), g = byte.view(0x34), b = byte.view(0x56);
	match (a) {
		0 => return int.view(pk(r,g,b));
		1 => return if(pk(r,g,b) == pt(r,g,b), 1, 0);
		2 => return up(pk(r,g,b)).r;
		3 => return up(pk(r,g,b)).g;
		4 => return up(pk(r,g,b)).b;
		_ => return -1;
	}
}
