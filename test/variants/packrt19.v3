//@execute 0=3243; 1=11; 2=3243; 3=10
// packlayout19 at runtime: case types compose in tuples and data types
type T { case A(x: u4, y: u4); case B(z: u8); }
type W(a: u4, c: T.A) { }
def pt(c: u4, x: u4, y: u4) -> u12 { return u12.pack<(u4, T.A)>((c, T.A(x,y))); }
def ut(v: u12) -> (u4, T.A) { return u12.unpack<(u4, T.A)>(v); }
def pw(c: u4, x: u4, y: u4) -> u12 { return u12.pack<W>(W(c, T.A(x,y))); }
def uw(v: u12) -> W { return u12.unpack<W>(v); }
def main(n: int) -> int {
	def c = u4.view(0xC), x = u4.view(0xA), y = u4.view(0xB);
	match (n) {
		0 => return int.view(pt(c,x,y));
		1 => return int.view(ut(u12.view(0xCAB)).1.y);
		2 => return int.view(pw(c,x,y));
		3 => return int.view(uw(u12.view(0xCAB)).c.x);
		_ => return -1;
	}
}
