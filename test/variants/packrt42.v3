//@execute 0=1; 1=1; 2=1; 3=1; 4=1; 5=1; 200=1; 255=1
// reading an enum layout field and unpacking an integer to an enum use the same
// operator, so they must agree on every bit pattern, including invalid tags
enum E { A, B, C, D, F }
layout L {
	+0	e: E;
	=1;
}
def viaLayout(b: byte) -> E {
	var data = [b];
	return Ref<L>.at(data, 0).e;
}
def viaUnpack(b: byte) -> E { return u8.unpack<E>(b); }
def main(n: int) -> int {
	def b = byte.view(n);
	def want = if(n < 5, n, 0);
	if (viaLayout(b).tag != want) return -1;
	if (viaUnpack(b).tag != want) return -2;
	if (viaLayout(b) != viaUnpack(b)) return -3;
	return 1;
}
