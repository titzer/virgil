//@execute 0=true;1=true;2=true;3=true
// Packed unboxed variant passed BY VALUE to a function, which then invokes the
// double-returning accessor. Exercises the packed value as a call argument.
type Q23 #unboxed #packed {
	case D(a: double) { def f() -> double { return a; } }
	case P(x: float, y: float) { def f() -> double { return double.!(x) * double.!(y); } }
	def f() -> double;
}
def call(v: Q23) -> double { return v.f(); }
def arr = [ Q23.D(1.5d), Q23.P(2f, 3f), Q23.D(4.0d), Q23.P(0.5f, 8f) ];
def ans = [ 1.5d, 6.0d, 4.0d, 4.0d ];
def main(a: int) -> bool { return call(arr[a]) == ans[a]; }
