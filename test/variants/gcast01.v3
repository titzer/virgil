//@execute 0=3; 1=3; 2=4; 3=!BoundsCheckException
type T {
	case A(x: int);
	case B(x: int);

	def close(that: T) -> bool {
		if (T.A.?(this) && T.A.?(that)) {
			var a = T.A.!(this), b = T.A.!(that);
			var dist = a.x - b.x;
			return dist < 10 && dist > -10;
		}
		if (T.B.?(this) && T.B.?(that)) {
			var a = T.B.!(this), b = T.B.!(that);
			var dist = a.x - b.x;
			return dist < 100 && dist > -100;
		}
		return false;
	}
}

def vs = [T.A(1), T.A(2), T.A(13)];

def main(a: int) -> int {
	var x = vs[a];
	var result = 0;
	for (i < vs.length) {
		if (x.close(vs[i])) result |= 1 << u5.view(i);
	}
	return result;
}