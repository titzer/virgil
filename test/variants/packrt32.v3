//@execute 0=1; 1=1
// pack/unpack used as higher-order function values
type Rgb(r: byte, g: byte, b: byte) { }
def apply<A, B>(f: A -> B, a: A) -> B { return f(a); }
def main(n: int) -> int {
	def r = byte.view(1), g = byte.view(2), b = byte.view(3);
	match (n) {
		0 => return if(apply(u24.pack<Rgb>, Rgb(r,g,b)) == 0x010203, 1, 0);
		1 => return if(apply(u24.unpack<Rgb>, u24.view(0x010203)).g == 2, 1, 0);
		_ => return -1;
	}
}
