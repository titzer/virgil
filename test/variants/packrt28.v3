//@execute 0=1; 1=1; 2=1; 3=1
// the same generic data type instantiated at several widths in one program
type P<X>(x: X, y: X) { }
def a4(x: u4, y: u4) -> u8 { return u8.pack<P<u4>>(P<u4>(x,y)); }
def a8(x: u8, y: u8) -> u16 { return u16.pack<P<u8>>(P<u8>(x,y)); }
def a16(x: u16, y: u16) -> u32 { return u32.pack<P<u16>>(P<u16>(x,y)); }
def a32(x: u32, y: u32) -> u64 { return u64.pack<P<u32>>(P<u32>(x,y)); }
def main(n: int) -> int {
	match (n) {
		0 => return if(a4(u4.view(0xA), u4.view(0xB)) == 0xAB, 1, 0);
		1 => return if(a8(u8.view(0xAB), u8.view(0xCD)) == 0xABCD, 1, 0);
		2 => return if(a16(u16.view(0xABCD), u16.view(0xEF01)) == 0xABCDEF01u, 1, 0);
		3 => return if(a32(u32.view(0xAAAAAAAAu), u32.view(0xBBBBBBBBu)) == 0xAAAAAAAABBBBBBBBuL, 1, 0);
		_ => return -1;
	}
}
