//@execute 0=171; 1=10; 2=11; 3=2747; 4=3277
// iN.unpack of a generic data type instantiates its field types
// (regression: this used to crash the compiler in SsaUnpacker.unpack0)
type P<X>(x: X, y: X) { }
def main(a: int) -> int {
	def u = u8.unpack<P<u4>>(0xAB);
	def v = u24.unpack<P<u12>>(0xABBCCD);
	match (a) {
		0 => return int.view(u8.pack<P<u4>>(P<u4>(0xA, 0xB)));
		1 => return int.view(u.x);
		2 => return int.view(u.y);
		3 => return int.view(v.x);   // 0xABB
		4 => return int.view(v.y);   // 0xCCD
		_ => return -1;
	}
}
