//@execute 0=true; 1=true
// Variant equality is structural/bitwise -- F.M(0f) == F.M(-0.0f) is false, and
// string payloads compare by reference -- so two cases built from the same NaN
// bits must be equal. The interpreter and the constant folder agree on true.
// A boxed variant currently answers false only once compiled: v3i and -ra pass,
// the backends fail, so the fault is in equality lowering. See eq_nan01 for the
// unboxed case, which breaks earlier, and eq_nan02 for the sharpest statement.
type F {
	case M(x: float);
}
def NANS: Array<float> = [float.nan, float.nan];
def main(a: int) -> bool {
	var x = NANS[a];			// runtime value, not a constant
	return F.M(x) == F.M(x);
}
