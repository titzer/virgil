//@execute 0=75; 1=1; 2=1; 3=1
// enum, enum set and bool fields inside a data type
// 10 | 0101 | 1  ==  0b1001011
enum E { A, B, C, D }
type P(e: E, s: E.set, b: bool) { }
def main(a: int) -> int {
	def p = u7.pack<P>(P(E.C, E.A | E.C, true));
	def u = u7.unpack<P>(p);
	match (a) {
		0 => return int.view(p);
		1 => return if(u.e == E.C, 1, 0);
		2 => return if(u.s == (E.A | E.C), 1, 0);
		3 => return if(u.b, 1, 0);
		_ => return -1;
	}
}
