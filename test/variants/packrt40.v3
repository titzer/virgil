//@execute 0=1; 5=1; 6=1; 7=1
// an out-of-range tag inside a composite maps to 0 without disturbing siblings
enum E { A, B, C, D, F }
type P(e: E, x: u4) { }
def f(v: u7) -> P { return u7.unpack<P>(v); }
def main(n: int) -> int {
	def v = u7.view((n << 4) | 0xA);
	def p = f(v);
	def wantTag = if(n < 5, n, 0);
	return if(p.e.tag == wantTag && p.x == 0xA, 1, 0);
}
