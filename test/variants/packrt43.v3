//@execute 0=1; 1=1; 2=1; 3=1
// an enum tag packed into containers much wider than the tag type
enum E { A, B, C, D }
def w8(v: u8) -> E { return u8.unpack<E>(v); }
def w16(v: u16) -> E { return u16.unpack<E>(v); }
def w32(v: u32) -> E { return u32.unpack<E>(v); }
def w64(v: u64) -> E { return u64.unpack<E>(v); }
def main(n: int) -> int {
	def t = u2.view(n);
	if (w8(u8.pack<E>(u2.unpack<E>(t))) != u2.unpack<E>(t)) return -1;
	if (w16(u16.pack<E>(u2.unpack<E>(t))) != u2.unpack<E>(t)) return -2;
	if (w32(u32.pack<E>(u2.unpack<E>(t))) != u2.unpack<E>(t)) return -3;
	if (w64(u64.pack<E>(u2.unpack<E>(t))) != u2.unpack<E>(t)) return -4;
	return 1;
}
