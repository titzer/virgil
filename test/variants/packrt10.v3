//@execute 0=1; 1=1; 2=1
// packlayout12 at runtime: full 64-bit container
def pk(a: u32, b: u32) -> u64 { return u64.pack<(u32,u32)>((a,b)); }
def up(v: u64) -> (u32, u32) { return u64.unpack<(u32,u32)>(v); }
def main(x: int) -> int {
	def a = u32.view(0xAAAAAAAAu), b = u32.view(0xBBBBBBBBu);
	def p = pk(a, b);
	def u = up(p);
	match (x) {
		0 => return if(p == 0xAAAAAAAABBBBBBBBuL, 1, 0);
		1 => return if(u.0 == a, 1, 0);
		2 => return if(u.1 == b, 1, 0);
		_ => return -1;
	}
}
