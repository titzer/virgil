//@execute 0=43981; 1=10; 2=11; 3=205
// nested data types flatten in declaration order, just like nested tuples
type Inner(a: u4, b: u4) { }
type Outer(i: Inner, c: u8) { }
def main(a: int) -> int {
	def p = u16.pack<Outer>(Outer(Inner(0xA, 0xB), 0xCD));
	def u = u16.unpack<Outer>(p);
	match (a) {
		0 => return int.view(p);          // 0xABCD
		1 => return int.view(u.i.a);      // 0xA
		2 => return int.view(u.i.b);      // 0xB
		3 => return u.c;                  // 0xCD
		_ => return -1;
	}
}
