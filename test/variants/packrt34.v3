//@execute 0=1; 1=1; 128=1; 200=1; 255=1
// unpacking a value with garbage above the packing width ignores those bits.
// Values are supplied as inputs rather than looped; see
// test/fail/wasm_unpack_loop00.v3.
type P(a: u4, b: u4) { }
def up(v: u16) -> P { return u16.unpack<P>(v); }
def main(n: int) -> int {
	def garbage = u16.view(n << 8);
	def g = up(u16.view(0xAB) | garbage);
	if (g.a != 0xA || g.b != 0xB) return -1;
	if (g.a != up(u16.view(0xAB)).a) return -2;
	return 1;
}
