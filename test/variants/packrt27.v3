//@execute 0=1; 1=1
// deeply nested data types and tuples, 5 levels, round-tripped at runtime
type L1(a: u4) { }
type L2(x: L1, b: u4) { }
type L3(x: L2, c: u4) { }
type L4(x: L3, d: u4) { }
type L5(x: L4, e: u4) { }
def mk(a: u4, b: u4, c: u4, d: u4, e: u4) -> L5 { return L5(L4(L3(L2(L1(a), b), c), d), e); }
def pk(v: L5) -> u20 { return u20.pack<L5>(v); }
def up(v: u20) -> L5 { return u20.unpack<L5>(v); }
def main(n: int) -> int {
	def v = mk(u4.view(1), u4.view(2), u4.view(3), u4.view(4), u4.view(5));
	match (n) {
		0 => return if(pk(v) == 0x12345, 1, 0);           // outermost field last
		1 => return if(up(pk(v)) == v && up(pk(v)).x.x.x.x.a == 1, 1, 0);
		_ => return -1;
	}
}
