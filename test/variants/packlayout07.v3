//@execute 0=27966412; 1=1
// data types compose with tuples
type Rgb(r: byte, g: byte, b: byte) { }
def main(a: int) -> int {
	def p = u32.pack<(bool, Rgb)>((true, Rgb(0xAA, 0xBB, 0xCC)));
	def u = u32.unpack<(bool, Rgb)>(p);
	match (a) {
		0 => return int.view(p);                                    // 0x1AABBCC
		1 => return if(u.0 && u.1.r == 0xAA && u.1.b == 0xCC, 1, 0);
		_ => return -1;
	}
}
