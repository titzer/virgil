//@execute 0=true;1=false;2=true;3=false;4=true;5=false
type A {
	case X(b: string);
	case Y(y: int) #unboxed;
}

def x7 = "x7";
def x12 = "x12";
def x32 = "x32";
def y32 = "y32";
def x34 = "x34";
def y34 = "y34";
def x56 = "x56";
def y56 = "y56";

def arr1 = [A.X(x12), A.X(x12), A.X(y34), A.X(x56), A.Y(99), A.Y(99)];
def arr2 = [A.X(x12), A.X(x34), A.X(y34),  A.Y(99), A.Y(99), A.X(x7)];

def main(a: int) -> bool {
	return arr1[a] == arr2[a];
}