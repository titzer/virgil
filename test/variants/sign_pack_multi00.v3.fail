//@execute 0=-100060
// Reading a SIGNED sub-word field of a `#packed` variant corrupts the fields
// that follow it, after normalization (`-ra`) and on compiled backends.
//
//	v3i          : -100060   (a == -100, b == -60)   correct
//	-ra / backend: -100001   (a == -100, b == -1)    b is all-ones
//
// The sign-extension of the leading field appears to run over the bits the
// following fields occupy in the shared packed word. Characterization:
//
//	(a: i16, b: i8)  reading both		DIVERGES, b reads as -1
//	(a: i16, b: i8)  reading only b		agrees -- needs the signed read
//	(a: i16, b: u8)  reading both		DIVERGES, b reads as 255
//	(a: u16, b: i8)  reading both		agrees -- unsigned leader is fine
//	(a: i16, b: i8, c: i8)			DIVERGES, both b and c corrupted
//	(a: i16, b: i8) without #packed		agrees
//
// The payload must be runtime-computed; constant payloads fold correctly.
//
// Existing coverage in test/variants/sign_pack*.v3 uses a single signed field
// per case, which is why a signed field FOLLOWED BY another field was missed.
type B2 #unboxed #packed {
	case T(a: i16, b: i8) #unboxed #packed;
	case F #unboxed #packed;
}
def main(k: int) -> int {
	var v: B2 = B2.T(i16.view(k - 100), i8.view(k - 60));
	var t = B2.T.!(v);
	return int.!(t.a) * 1000 + int.!(t.b);
}
