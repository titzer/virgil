//@execute 0=11; 1=24; 2=37
type T #unboxed {
	case A(x: int);
	case B(x: int); // dead
	case C(x: int);
	case D(x: int); // dead
	case E(x: int);
}

var vs = [T.A(11), T.C(22), T.E(33)];

def main(a: int) -> int {
	var v = vs[a];
	match (v) {
		A(x) => return v.tag + x;
		B(x) => return v.tag + x;
		C(x) => return v.tag + x;
		D(x) => return v.tag + x;
		E(x) => return v.tag + x;
	}
}
