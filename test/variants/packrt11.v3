//@execute 0=171; 1=205; 2=10; 3=11; 4=0
// packlayout18 at runtime: case types pack their fields with no tag
type T { case A(x: u4, y: u4); case B(z: u8); case C; }
def pa(x: u4, y: u4) -> u8 { return u8.pack<T.A>(T.A(x,y)); }
def pb(z: u8) -> u8 { return u8.pack<T.B>(T.B(z)); }
def pc(c: T.C) -> u8 { return u8.pack<T.C>(c); }
def ua(v: u8) -> T.A { return u8.unpack<T.A>(v); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(pa(u4.view(0xA), u4.view(0xB)));
		1 => return int.view(pb(u8.view(0xCD)));
		2 => return int.view(ua(u8.view(0xAB)).x);
		3 => return int.view(ua(u8.view(0xAB)).y);
		4 => return int.view(pc(T.C));
		_ => return -1;
	}
}
