//@execute 0=2748; 1=2748; 2=1
// nesting tuples is purely notational; fields flatten in order
def main(a: int) -> int {
	def nested = u12.pack<(u4, (u4, u4))>((0xA, (0xB, 0xC)));
	def flat = u12.pack<(u4, u4, u4)>((0xA, 0xB, 0xC));
	def right = u12.pack<((u4, u4), u4)>(((0xA, 0xB), 0xC));
	match (a) {
		0 => return int.view(nested);                       // 0xABC
		1 => return int.view(flat);                         // 0xABC
		2 => return if(nested == flat && flat == right, 1, 0);
		_ => return -1;
	}
}
