//@execute 0=true;1=true;2=true;3=true
// Packed unboxed variant with int, double, and long payloads; each accessor
// returns a double (some via reinterpret, some via conversion).
type Q21 #unboxed #packed {
	case I(a: int) { def f() -> double { return double.!(a); } }
	case D(b: double) { def f() -> double { return b; } }
	case L(c: long) { def f() -> double { return double.view(c); } }
	def f() -> double;
}
def arr = [ Q21.I(42), Q21.D(3.5d), Q21.L(long.view(-2.5d)), Q21.D(0.0d) ];
def ans = [ double.!(42), 3.5d, -2.5d, 0.0d ];
def main(a: int) -> bool { return arr[a].f() == ans[a]; }
