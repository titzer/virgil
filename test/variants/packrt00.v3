//@execute 0=43981; 1=4660; 2=2748; 3=2748
// packlayout00 at runtime: field order cannot be constant-folded away
def p4(a: u4, b: u4, c: u4, d: u4) -> u16 { return u16.pack<(u4,u4,u4,u4)>((a,b,c,d)); }
def p2_8(a: u8, b: u8) -> u16 { return u16.pack<(u8,u8)>((a,b)); }
def p48(a: u4, b: u8) -> u12 { return u12.pack<(u4,u8)>((a,b)); }
def p84(a: u8, b: u4) -> u12 { return u12.pack<(u8,u4)>((a,b)); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(p4(u4.view(0xA), u4.view(0xB), u4.view(0xC), u4.view(0xD)));
		1 => return int.view(p2_8(u8.view(0x12), u8.view(0x34)));
		2 => return int.view(p48(u4.view(0xA), u8.view(0xBC)));
		3 => return int.view(p84(u8.view(0xAB), u4.view(0xC)));
		_ => return -1;
	}
}
