//@execute 0=1; 1=1; 2=1; 3=1; 4=1
// unpacking an enum through a chain that defeats folding at each step
enum E { A, B, C, D, F }
def id(v: u3) -> u3 { return v; }
def step1(v: u3) -> E { return u3.unpack<E>(id(v)); }
def step2(v: u3) -> u3 { return u3.pack<E>(step1(v)); }
def main(n: int) -> int {
	def v = u3.view(n);
	def want = if(n < 5, n, 0);
	if (step1(v).tag != want) return -1;
	if (step2(v) != u3.view(want)) return -2;
	if (step1(step2(v)).tag != want) return -3;
	return 1;
}
