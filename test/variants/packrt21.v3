//@execute 0=10; 1=188; 2=13; 3=11; 4=10
// packlayout21 at runtime: multi-param, nested and composed generics
type P<X>(x: X, y: X) { }
type Inner<X>(a: X) { }
type Outer<X>(i: Inner<X>, b: u4) { }
type Q<X, Y>(a: X, b: Y, c: u4) { }
def uq(v: u16) -> Q<u4, byte> { return u16.unpack<Q<u4, byte>>(v); }
def upp(v: u16) -> P<P<u4>> { return u16.unpack<P<P<u4>>>(v); }
def uo(v: u8) -> Outer<u4> { return u8.unpack<Outer<u4>>(v); }
def main(n: int) -> int {
	def w = uq(u16.view(0xABCD));
	match (n) {
		0 => return int.view(w.a);
		1 => return w.b;
		2 => return int.view(w.c);
		3 => return int.view(upp(u16.view(0xABCD)).x.y);
		4 => return int.view(uo(u8.view(0xAB)).i.a);
		_ => return -1;
	}
}
