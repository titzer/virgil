//@execute 0=171; 1=10; 2=11
// pack and unpack are first-class values; unpack infers its type argument from context
def encode = u16.pack<(u4, u4)>;
def decode = u16.unpack<(u4, u4)>;
def main(a: int) -> int {
	def t: (u4, u4) = u16.unpack(0xAB);   // type argument inferred
	match (a) {
		0 => return int.view(encode((0xA, 0xB)));
		1 => return int.view(decode(0xAB).0);
		2 => return int.view(t.1);
		_ => return -1;
	}
}
