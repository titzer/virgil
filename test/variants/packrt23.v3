//@execute 0=1; 1=1; 2=1
// first-class pack/unpack values applied to runtime arguments
type Rgb(r: byte, g: byte, b: byte) { }
def encode = u16.pack<(u4, u4)>;
def decode = u16.unpack<(u4, u4)>;
def encRgb = u24.pack<Rgb>;
def main(n: int) -> int {
	def a = u4.view(0xA), b = u4.view(0xB);
	match (n) {
		0 => return if(encode((a, b)) == 0x00AB, 1, 0);
		1 => return if(decode(encode((a, b))) == (a, b), 1, 0);
		2 => return if(encRgb(Rgb(byte.view(1), byte.view(2), byte.view(3))) == 0x010203, 1, 0);
		_ => return -1;
	}
}
