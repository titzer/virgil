//@execute 0=213; 1=-3; 2=5; 3=-1; 4=-8
// signed fields inside a case type are two's complement and sign-extended
type T { case A(x: i4, y: i4); case B(z: u8); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u8.pack<T.A>(T.A(-3, 5)));   // 0xD5
		1 => return u8.unpack<T.A>(0xD5).x;
		2 => return u8.unpack<T.A>(0xD5).y;
		3 => return u8.unpack<T.A>(0xFF).x;
		4 => return u8.unpack<T.A>(0x8F).x;
		_ => return -99;
	}
}
