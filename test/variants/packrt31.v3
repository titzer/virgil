//@execute 0=1; 1=1
// a data type with 16 fields fills a 64-bit container exactly
type Wide(f0: u4, f1: u4, f2: u4, f3: u4, f4: u4, f5: u4, f6: u4, f7: u4, f8: u4, f9: u4, f10: u4, f11: u4, f12: u4, f13: u4, f14: u4, f15: u4) { }
def pk(f0: u4, f1: u4, f2: u4, f3: u4, f4: u4, f5: u4, f6: u4, f7: u4, f8: u4, f9: u4, f10: u4, f11: u4, f12: u4, f13: u4, f14: u4, f15: u4) -> u64 { return u64.pack<Wide>(Wide(f0, f1, f2, f3, f4, f5, f6, f7, f8, f9, f10, f11, f12, f13, f14, f15)); }
def up(v: u64) -> Wide { return u64.unpack<Wide>(v); }
def main(n: int) -> int {
	def p = pk(u4.view(0), u4.view(1), u4.view(2), u4.view(3), u4.view(4), u4.view(5), u4.view(6), u4.view(7), u4.view(8), u4.view(9), u4.view(10), u4.view(11), u4.view(12), u4.view(13), u4.view(14), u4.view(15));
	def u = up(p);
	match (n) {
		0 => return if(p == 0x0123456789ABCDEFuL, 1, 0);
		1 => return if(u.f0 == 0 && u.f1 == 1 && u.f2 == 2 && u.f3 == 3 && u.f4 == 4 && u.f5 == 5 && u.f6 == 6 && u.f7 == 7 && u.f8 == 8 && u.f9 == 9 && u.f10 == 10 && u.f11 == 11 && u.f12 == 12 && u.f13 == 13 && u.f14 == 14 && u.f15 == 15, 1, 0);
		_ => return -1;
	}
}
