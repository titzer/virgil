//@execute 0=true;1=true;2=true;3=true;4=true
// Packed unboxed variant exercising double, float-pair, and mixed float/int
// payloads through the dispatched accessor (which returns a double).
type P20 #unboxed #packed {
	case A(x: double) { def f() -> double { return x; } }
	case B(c: float, d: float) { def f() -> double { return double.!(c) + double.!(d); } }
	case C(n: int, e: float) { def f() -> double { return double.!(n) + double.!(e); } }
	def f() -> double;
}
def arr = [
	P20.A(3.5d),
	P20.B(1.0f, 2.0f),
	P20.C(10, 0.5f),
	P20.A(0.0d),
	P20.C(-4, 4.0f)
];
def ans = [
	3.5d,
	double.!(1.0f) + double.!(2.0f),
	double.!(10) + double.!(0.5f),
	0.0d,
	double.!(-4) + double.!(4.0f)
];
def main(a: int) -> bool {
	return arr[a].f() == ans[a];
}
