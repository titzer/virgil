//@execute 0=9; 1=15; 2=9; 3=9
type V {
	case X(i: int);
	case Y(i: int);
}
def compare(x: V, y: V) -> int {
	return comb(
		x == x,
		x == y,
		y == x,
		y == y
	);
}
def comb(a: bool, b: bool, c: bool, d: bool) -> int {
	var r = 0;
	if (a) r |= 1;
	if (b) r |= 2;
	if (c) r |= 4;
	if (d) r |= 8;
	return r;
}

def xx = [V.X(11), V.Y(11), V.X(12), V.Y(12)];

def main(a: int) -> int {
	return compare(xx[a], V.Y(11));
}
