//@execute 0=4; 1=0; 2=35; 3=1
// an enum packs to its tag, using only as many bits as the largest tag needs
enum E { A, B, C, D, F }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u3.pack<E>(E.F));                  // tag 4
		1 => return int.view(u3.pack<E>(E.A));                  // tag 0
		2 => return int.view(u6.pack<(E, E)>((E.F, E.D)));      // 0b100_011
		3 => return if(u3.unpack<E>(u3.pack<E>(E.C)) == E.C, 1, 0);
		_ => return -1;
	}
}
