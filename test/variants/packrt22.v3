//@execute 0=1; 1=1
// sign extension is exact for every i4 bit pattern, and i4/u4 agree on bits
def si(v: u8) -> i4 { return u8.unpack<(i4,i4)>(v).0; }
def ui(v: u8) -> u4 { return u8.unpack<(u4,u4)>(v).0; }
def main(n: int) -> int {
	for (i < 256) {
		def v = u8.view(i);
		def s = si(v), u = ui(v);
		match (n) {
			0 => if (s != i4.view(u)) return -i;              // same bits
			1 => if ((int.view(u) >= 8) != (s < 0)) return -i; // high bit == negative
			_ => return -1;
		}
	}
	return 1;
}
