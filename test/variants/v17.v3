//@execute 0=9; 1=15; 2=9; 3=9
type V {
	case X(i: int);
	case Y(i: int);
}
def compare(x: V, y: V) -> int {
	return
		if(x == x, 0b0001) |
		if(x == y, 0b0010) |
		if(y == x, 0b0100) |
		if(y == y, 0b1000);
}

def xx = [V.X(11), V.Y(11), V.X(12), V.Y(12)];

def main(a: int) -> int {
	return compare(xx[a], V.Y(11));
}
