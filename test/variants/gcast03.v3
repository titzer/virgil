//@execute 0=3; 1=3; 2=4; 3=!BoundsCheckException
type T {
	case A(x: int);
	case B(x: int);

	def diff(that: T) -> int {
		if (T.A.?(this) && T.A.?(that)) {
			var a = T.A.!(this), b = T.A.!(that);
			return a.x - b.x;
		}
		if (T.B.?(this) && T.B.?(that)) {
			var a = T.B.!(this), b = T.B.!(that);
			return a.x - b.x;
		}
		return int.max;
	}
}

def vs: Array<T> = [T.A(1), T.A(2), T.A(13)];

def main(a: int) -> int {
	var x = vs[a];
	var result = 0;
	for (i < vs.length) {
		var diff = x.diff(vs[i]);
		var dist = if(diff < 0, 0 - diff, diff);
		var close = if(T.A.?(x), dist < 10, dist < 100);
		if (close) result |= 1 << u5.view(i);
	}
	return result;
}