//@execute 0=1; 1=1; 2=1; 3=1
// a single-case enum and a two-case enum, at runtime
enum One { X }
enum Two { X, Y }
def f1(v: u1) -> One { return u1.unpack<One>(v); }
def f2(v: u1) -> Two { return u1.unpack<Two>(v); }
def main(n: int) -> int {
	match (n) {
		0 => return if(f1(u1.view(0)).tag == 0, 1, 0);
		1 => return if(f1(u1.view(1)).tag == 0, 1, 0);   // out of range -> 0
		2 => return if(f2(u1.view(0)) == Two.X, 1, 0);
		3 => return if(f2(u1.view(1)) == Two.Y, 1, 0);
		_ => return -1;
	}
}
