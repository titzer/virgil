//@execute 0=171; 1=255; 2=10
// a container wider than the packing width zero-pads the HIGH bits
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u16.pack<(u4, u4)>((0xA, 0xB)));  // 0x00AB, not 0xAB00
		1 => return int.view(u32.pack<(u4, u4)>((0xF, 0xF)));  // 0x000000FF
		2 => return int.view(u32.pack<u4>(0xA));               // 0x0000000A
		_ => return -1;
	}
}
