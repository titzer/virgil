//@execute 0=-1; 1=127; 2=-128
// the container's signedness affects only how the resulting bits are read
def main(a: int) -> int {
	match (a) {
		0 => return i8.pack<(u4, u4)>((0xF, 0xF));  // 0xFF viewed as i8 == -1
		1 => return i8.pack<(u4, u4)>((0x7, 0xF));  // 0x7F == 127
		2 => return i8.pack<(u4, u4)>((0x8, 0x0));  // 0x80 viewed as i8 == -128
		_ => return -99;
	}
}
