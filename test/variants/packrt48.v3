//@execute 0=1; 1=1; 2=1; 3=1
// an E.set beside other fields, in tuples, data types and case types --
// the container is necessarily wider than the set here
enum E { A, B, C, D }
type P(st: E.set, n: u3) { }
type T { case A(st: E.set, n: u3); case B(z: u8); }
def bits(s: E.set) -> int { return int.view(u4.pack<E.set>(s)); }
def rtT(s: E.set, n: u3) -> (E.set, u3) { return u8.unpack<(E.set,u3)>(u8.pack<(E.set,u3)>((s,n))); }
def rtP(s: E.set, n: u3) -> P { return u8.unpack<P>(u8.pack<P>(P(s,n))); }
def rtC(s: E.set, n: u3) -> T.A { return u8.unpack<T.A>(u8.pack<T.A>(T.A(s,n))); }
def main(k: int) -> int {
	def s = E.A | E.D, n = u3.view(k);
	match (k) {
		0 => { def r = rtT(s, n); return if(bits(r.0) == 9 && r.1 == n, 1, 0); }
		1 => { def r = rtP(s, n); return if(bits(r.st) == 9 && r.n == n, 1, 0); }
		2 => { def r = rtC(s, n); return if(bits(r.st) == 9 && r.n == n, 1, 0); }
		3 => { def r = rtT(s, n); return if(u8.pack<(E.set,u3)>(r) == u8.pack<(E.set,u3)>((s,n)), 1, 0); }
		_ => return -1;
	}
}
