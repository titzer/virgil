//@execute 0=1; 1=1; 2=1; 3=1
// bool fields at runtime: every position in a 4-bool pack
def pk(a: bool, b: bool, c: bool, d: bool) -> u4 { return u4.pack<(bool,bool,bool,bool)>((a,b,c,d)); }
def up(v: u4) -> (bool,bool,bool,bool) { return u4.unpack<(bool,bool,bool,bool)>(v); }
def bit(i: int, n: int) -> bool { return ((i >> byte.view(n)) & 1) == 1; }
def main(n: int) -> int {
	for (i < 16) {
		def t = (bit(i,3), bit(i,2), bit(i,1), bit(i,0));
		if (pk(t.0,t.1,t.2,t.3) != u4.view(i)) return -i-1;
		if (up(u4.view(i)) != t) return -i-100;
	}
	return 1;
}
