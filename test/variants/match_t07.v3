//@execute 0=11; 1=23; 2=22
type X {
	case M;
	case N;
}
class C {
	def m() -> int;
}
class Cof<T>(x: T) extends C {
	def m() -> int {
		match (this.x) {
			x: int	=> return 11;
			x: X.N	=> return 22;
			x: X	=> return 23;
		}
		return 300 - 55;
	}
}
def cs: Array<C> = [Cof.new(33), Cof.new(X.M), Cof.new(X.N)];

def main(a: int) -> int {
	return cs[a].m();
}
