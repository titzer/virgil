//@execute 0=1; 1=1; 2=1; 3=1
// several enum fields side by side, and an enum beside other field kinds
// Mix is E(2) + F(3) + bool(1) + u4(4) == 10 bits
enum E { A, B, C, D }
enum F { P, Q, R, S, T }
type Mix(e: E, f: F, b: bool, x: u4) { }
def mk(v: u10) -> Mix { return u10.unpack<Mix>(v); }
def main(n: int) -> int {
	def v = u10.view((n << 8) | (2 << 5) | (1 << 4) | 0xA);
	def m = mk(v);
	if (m.e.tag != n) return -1;
	if (m.f.tag != 2) return -2;
	if (!m.b) return -3;
	if (m.x != 0xA) return -4;
	if (u10.pack<Mix>(m) != v) return -5;
	return 1;
}
