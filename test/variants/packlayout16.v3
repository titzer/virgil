//@execute 0=171; 1=43964
// a generic data type packs at its instantiated field widths
// NOTE: only pack is exercised here; u8.unpack<P<u4>> currently crashes the
// compiler in SsaUnpacker.unpack0(). See test/fail/int_unpack_generic00.v3.
type P<X>(x: X, y: X) { }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(u8.pack<P<u4>>(P<u4>(0xA, 0xB)));      // 0xAB
		1 => return int.view(u24.pack<P<u12>>(P<u12>(0x00A, 0xBBC))); // 0x00ABBC
		_ => return -1;
	}
}
