//@execute 0=107
//@heap-size=100000
// An unboxed variant whose cases mix float and double payloads gets a `double`
// slot that some cases leave at its default value. A zero double constant
// reaches the x86-32 store path as a null of size 8, which no 32-bit immediate
// store can express: it failed with "invalid size for store". Constant stores
// wider than a word now fall through to the register paths.
type Vec #unboxed {
	case Two(x: float, y: float);
	case Four(x: float, y: float, z: float, w: float);
	case Wide(x: double, y: double);
	case Empty;
}
def norm(v: Vec) -> double {
	match (v) {
		Two(x, y) => return double.sqrt(x * x + y * y);
		Four(x, y, z, w) => return double.sqrt(x * x + y * y + z * z + w * w);
		Wide(x, y) => return double.sqrt(x * x + y * y);
		Empty => return 0d;
	}
}
def SEED: Array<float> = [0.5f, -1.25f, 2f, -0.75f];
def DSEED: Array<double> = [0.5d, -1.25d, 2d, -0.75d];
def main(a: int) -> int {
	var vs = Array<Vec>.new(64);
	for (i < vs.length) {
		var f = SEED[i % SEED.length];
		match (i % 4) {
			0 => vs[i] = Vec.Two(f, f + 1f);
			1 => vs[i] = Vec.Four(f, f + 1f, f + 2f, f + 3f);
			2 => vs[i] = Vec.Wide(DSEED[i % DSEED.length], f);
			_ => vs[i] = Vec.Empty;
		}
	}
	var s = 0d;
	for (i < vs.length) s += norm(vs[i]);
	return int.truncd(s);
}
