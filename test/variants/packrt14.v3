//@execute 0=171; 1=171; 2=1; 3=2748
// a polymorphic data type that does not use its type parameter is packable,
// because every field is packable regardless of the type argument
type X<T>(f: u8) { }
type Y<T>(a: u4, b: u8) { }
def pkb(v: u8) -> u8 { return u8.pack<X<bool>>(X<bool>(v)); }
def pks(v: u8) -> u8 { return u8.pack<X<string>>(X<string>(v)); }
def upb(v: u8) -> X<bool> { return u8.unpack<X<bool>>(v); }
def pky(a: u4, b: u8) -> u12 { return u12.pack<Y<Array<int>>>(Y<Array<int>>(a, b)); }
def main(n: int) -> int {
	match (n) {
		0 => return int.view(pkb(u8.view(0xAB)));
		1 => return int.view(pks(u8.view(0xAB)));           // type arg is irrelevant
		2 => return if(upb(u8.view(0xAB)).f == 0xAB, 1, 0);
		3 => return int.view(pky(u4.view(0xA), u8.view(0xBC)));  // 0xABC
		_ => return -1;
	}
}
