//@execute 0=9; 1=1; 2=1; 3=0
// minimum widths: u1 fields and bool fields each occupy exactly one bit
def main(a: int) -> int {
	def p = u4.pack<(u1, u1, u1, u1)>((1, 0, 0, 1));
	def u = u4.unpack<(u1, u1, u1, u1)>(0b1001);
	match (a) {
		0 => return int.view(p);            // 0b1001
		1 => return int.view(u.0);          // high bit
		2 => return int.view(u.3);          // low bit
		3 => return int.view(u.1);
		_ => return -1;
	}
}
