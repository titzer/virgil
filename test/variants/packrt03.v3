//@execute 0=213; 1=-3; 2=5; 3=-1; 4=-8
// packlayout03 at runtime: signed fields two's complement + sign extension
def pk(x: i4, y: i4) -> u8 { return u8.pack<(i4,i4)>((x,y)); }
def up(v: u8) -> (i4, i4) { return u8.unpack<(i4,i4)>(v); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(pk(i4.view(-3), i4.view(5)));
		1 => return up(u8.view(0xD5)).0;
		2 => return up(u8.view(0xD5)).1;
		3 => return up(u8.view(0xFF)).0;
		4 => return up(u8.view(0x8F)).0;
		_ => return -99;
	}
}
