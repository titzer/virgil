//@execute 0=171; 1=10; 2=11; 3=2747; 4=3277
// packlayout20 at runtime: generic data type instantiates its field types
type P<X>(x: X, y: X) { }
def pk(x: u4, y: u4) -> u8 { return u8.pack<P<u4>>(P<u4>(x,y)); }
def up(v: u8) -> P<u4> { return u8.unpack<P<u4>>(v); }
def up12(v: u24) -> P<u12> { return u24.unpack<P<u12>>(v); }
def main(a: int) -> int {
	match (a) {
		0 => return int.view(pk(u4.view(0xA), u4.view(0xB)));
		1 => return int.view(up(u8.view(0xAB)).x);
		2 => return int.view(up(u8.view(0xAB)).y);
		3 => return int.view(up12(u24.view(0xABBCCD)).x);
		4 => return int.view(up12(u24.view(0xABBCCD)).y);
		_ => return -1;
	}
}
