//@execute 0=10; 1=188; 2=13; 3=11; 4=10
// generic data types with several type parameters, nested, and inside tuples
type P<X>(x: X, y: X) { }
type Q<X, Y>(a: X, b: Y, c: u4) { }
type Inner<X>(a: X) { }
type Outer<X>(i: Inner<X>, b: u4) { }
def main(a: int) -> int {
	def w = u16.unpack<Q<u4, byte>>(0xABCD);
	match (a) {
		0 => return int.view(w.a);                                  // 0xA
		1 => return w.b;                                            // 0xBC
		2 => return int.view(w.c);                                  // 0xD
		3 => return int.view(u16.unpack<P<P<u4>>>(0xABCD).x.y);     // 0xB
		4 => return int.view(u8.unpack<Outer<u4>>(0xAB).i.a);       // 0xA
		_ => return -1;
	}
}
