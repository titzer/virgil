//@execute 0=true;1=true;2=true;3=true;4=true
// Packed unboxed variant with a double case and a three-field (int,float,float)
// case; the accessor combines the packed fields into a double result.
type Q22 #unboxed #packed {
	case A(x: double) { def f() -> double { return x; } }
	case B(n: int, c: float, d: float) { def f() -> double { return double.!(n) + double.!(c) + double.!(d); } }
	def f() -> double;
}
def arr = [ Q22.A(7.25d), Q22.B(3, 1.5f, 2.5f), Q22.A(0.0d), Q22.B(-1, 0.5f, 0.25f), Q22.B(10, 0f, 0f) ];
def ans = [ 7.25d, double.!(3)+double.!(1.5f)+double.!(2.5f), 0.0d, double.!(-1)+double.!(0.5f)+double.!(0.25f), double.!(10) ];
def main(a: int) -> bool { return arr[a].f() == ans[a]; }
