//@execute 0=1; 1=1
// for every 8-bit value, (u4,u4) splits into exactly the high and low nibble
def hi(v: u8) -> u4 { return u8.unpack<(u4,u4)>(v).0; }
def lo(v: u8) -> u4 { return u8.unpack<(u4,u4)>(v).1; }
def main(n: int) -> int {
	for (i < 256) {
		def v = u8.view(i);
		match (n) {
			0 => if (hi(v) != u4.view(i >> 4)) return -i;
			1 => if (lo(v) != u4.view(i & 0xF)) return -i;
			_ => return -1;
		}
	}
	return 1;
}
