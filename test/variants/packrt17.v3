//@execute 0=1; 1=1; 2=1
// every 8-bit value round-trips through (u4,u4), (i4,i4) and (bool,u3,u4)
def ru(v: u8) -> bool { def u = u8.unpack<(u4,u4)>(v); return u8.pack<(u4,u4)>(u) == v; }
def ri(v: u8) -> bool { def u = u8.unpack<(i4,i4)>(v); return u8.pack<(i4,i4)>(u) == v; }
def rm(v: u8) -> bool { def u = u8.unpack<(bool,u3,u4)>(v); return u8.pack<(bool,u3,u4)>(u) == v; }
def main(n: int) -> int {
	for (i < 256) {
		def v = u8.view(i);
		match (n) {
			0 => if (!ru(v)) return -i;
			1 => if (!ri(v)) return -i;
			2 => if (!rm(v)) return -i;
			_ => return -1;
		}
	}
	return 1;
}
