//@execute 0=333; 1=444; 2=2; 44=44
type T {
	case A(x: int);
	case B(x: int);
}

var ga1: T = T.A(333);
var ga2: T = T.A(444);

def swap() { // defeat constant-folding before reachability.
	var ta = ga1;
	ga1 = ga2;
	ga2 = ga1;
}

def main(a: int) -> int {
	match (a) {
		0 => match (ga1) { // folds after reachability
			A(x) => return x;
			B(x) => return x;
		}
		1 => match (ga2) { // folds after reachability
			A(x) => return x;
			B(x) => return x;
		}
	}
	return T.B(a).x;
}
