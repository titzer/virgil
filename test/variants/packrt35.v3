//@execute 0=1; 1=1; 2=1
// chained: unpack a value, repack it, and unpack again
// NOTE: fields compared individually; see test/fail/wasm_variant_eq_loop00.v3.
type Rgb(r: byte, g: byte, b: byte) { }
def cycle(v: u24) -> u24 { return u24.pack<Rgb>(u24.unpack<Rgb>(v)); }
def main(n: int) -> int {
	for (i < 64) {
		def v = u24.view(i * 0x010101);
		match (n) {
			0 => if (cycle(v) != v) return -i-1;
			1 => if (cycle(cycle(v)) != v) return -i-1;
			2 => { def x = u24.unpack<Rgb>(cycle(v)), y = u24.unpack<Rgb>(v);
			       if (x.r != y.r || x.g != y.g || x.b != y.b) return -i-1; }
			_ => return -1;
		}
	}
	return 1;
}
