//@execute =24
type List {
	case Cons(cdr: int, car: List);
	case Nil;
}

def d: List;
def x = List.Cons(1, List.Cons(2, List.Nil));

def sumTags(l: List) -> int {
	if (l == d) return 3;
	match (l) {
		Nil => return 1;
		Cons(cdr, car) => return cdr + 10 + sumTags(car);
	}
}

def main() -> int {
	return sumTags(x);
}
