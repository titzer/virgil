//@execute 0=5; 1=3; 2=3
// A Range<T> slice over an array of a variant/ADT type, summed via a foreach
// loop with a match inside.
type Item {
	case Num(v: int);
	case Nothing;
}
def all = [Item.Num(2), Item.Nothing, Item.Num(3)];
def sumFrom(r: Range<Item>) -> int {
	var s = 0;
	for (it in r) {
		match (it) {
			Num(v) => s = s + v;
			Nothing => ;
		}
	}
	return s;
}
def main(a: int) -> int {
	return sumFrom(all[a ... all.length]);
}
