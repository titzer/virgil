//@execute 0=true; 1=true; 2=true; 3=true
// Edge cases around zero-length arrays and zero-length range slices: an
// empty array has length 0, an empty range slice iterates zero times, and
// slicing an array down to zero length does not throw.
def main(a: int) -> bool {
	match (a) {
		0 => return Array<int>.new(0).length == 0;
		1 => {
			var arr = Array<int>.new(5);
			var r = arr[2 ..+ 0];
			return r.length == 0;
		}
		2 => {
			var arr = Array<int>.new(5);
			var count = 0;
			for (x in arr[2 ..+ 0]) count++;
			return count == 0;
		}
		_ => {
			var arr = Array<int>.new(0);
			var count = 0;
			for (x in arr) count++;
			return count == 0;
		}
	}
}
