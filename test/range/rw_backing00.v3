//@execute (5,1,3,77)=77; (5,0,4,9)=9; (5,3,1,55)=55
// A write through a range slice must be visible through the backing array
// itself, not just through the range view (contrast with rw*.v3, which only
// check the range's own read-back).
def main(len: int, start: int, offset: int, value: int) -> int {
	var a = Array<int>.new(len);
	var r = a[start ..+ (len - start)];
	r[offset] = value;
	return a[start + offset];
}
