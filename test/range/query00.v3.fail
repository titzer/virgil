//@execute = true
// `Range<T>.?` disagrees with `Range<T>.!` on an `Array<T>`.
//
// Array -> Range is an intended conversion: cast00.v3 pins `Range<int>.!(arr)`
// succeeding, and promote00.v3 pins the implicit promotion `var y: Range<int> = x`.
// The type query should therefore also be true, but it returns false:
//
//   Range<int>.?(arr)  =>  false      <-- this test
//   Range<int>.!(arr)  =>  succeeds, yields a valid range of the right length
//
// Same answer on v3i, `-ra -ma=true`, and the jar backend, so this is a type
// system inconsistency rather than a backend divergence.
//
// The query has to be written behind a type parameter: spelled directly,
// `Range<int>.?(arr)` is rejected at compile time as a structurally impossible
// query, which is itself inconsistent with the cast being allowed.
def q<F, T>(x: F) -> bool { return T.?(x); }
def main() -> bool {
	var arr = Array<int>.new(4);
	return q<Array<int>, Range<int>>(arr);
}
