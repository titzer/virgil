//@execute 0=300102; 1=4000103; 2=!BoundsCheckException
var a: Range<int> = [100, 20101, 300102, 4000103];
def copy(src: Range<int>, dst: Range<int>) {
	for (i < src.length) dst[i] = src[i];
}
def main(i: int) -> int {
	def r = CiRuntime.forgeRange<int>(Pointer.NULL + 1024, a.length);
	copy(a, r);
	var x = r[2 ...];
	var p = Pointer.atElement(x, i);
	return p.load<int>();
}
