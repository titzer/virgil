//@execute 0=2; 1=3; 2=4; 3=5; 4=2; 5=3; 6=4; 7=5; 8=1; 9=1

// Test depends on TagUtils.v3

def main(a: int) -> int {
	def c1 = GCRefTestC.new(1, 2); 		// ref
	def c1NonRef = TagUtils.setRefTag<GCRefTestC>(c1, 1); // nonref

	def c2 = GCRefTestC.new(2, 3); 		// ref
	def c2Ref = TagUtils.setRefTag<GCRefTestC>(c2, 0); 	// ref

	def c3 = GCRefTestC.new(3, 4); 		// ref 
	def c3NonRef = TagUtils.setRefTag<GCRefTestC>(c3, 1); // nonref

	def c4 = GCRefTestC.new(4, 5); 		// ref 
	def c4Ref = TagUtils.setRefTag<GCRefTestC>(c4, 0); 	// ref 

	// Induce GC through allocation and rt.test-gc
	def stuff = GCRefTestC.new(99, 99);

	match (a) {
		// Check nonrefs were ignored
		0 => return c2.a;
		1 => return c2.b;
		2 => return c4.a;
		3 => return c4.b;
		4 => return c2Ref.a;
		5 => return c2Ref.b;
		6 => return c4Ref.a;
		7 => return c4Ref.b;
		8 => return int.view(CiRuntime.isOop(Pointer.atObject(c2Ref)));
		9 => return int.view(CiRuntime.isOop(Pointer.atObject(c4Ref)));
		_ => return 42;
	}
}
