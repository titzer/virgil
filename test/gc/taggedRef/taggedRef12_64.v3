//@execute 4=true; 5=true; 262143=true; 262142=true; 131070=true

// Test depends on TagUtils.v3

// Testing the upper tag and isOop
// 262143 is 2^18 - 1 (17 lower bits are filled)
// 131070 is 2^17 - 2 (16 tag bits are filled, leftmost and rightmost empty)
def main(a: int) -> bool {
	def c1 = GCRefTestC.new(1, 2);
	def c1Tagged = TagUtils.setAuxTag<GCRefTestC>(c1, a);
	
	// induce GC
	def stuff = GCRefTestC.new(99, 99);

	// Test isOop is correct after GC updates ref
	return CiRuntime.isOop(Pointer.atObject(c1Tagged));
}

