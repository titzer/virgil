//@execute 0=0; 1=1; 2=2; 3=1

// Test depends on TagUtils.v3

def main(a: int) -> int {
	def c = GCRefTestC.new(1, 2);
	def cWithRefTag = TagUtils.setRefTag<GCRefTestC>(c, 1); 
	def ptrBeforeGC = Pointer.atObject(cWithRefTag);
	// convert reference to nonref; isOop(p1)=false
	// p1 should be ignored by the GC => ref address not updated 

	// Induce GC through allocation and rt.test-gc
	def stuff = GCRefTestC.new(99, 99);
	def ptrAfterGC = Pointer.atObject(cWithRefTag);


	match (a) {
		// Testing the nonreference is recognized as not an oop
		0 => return int.view(CiRuntime.isOop(ptrAfterGC));
		// Testing the object still accessible
		1 => return c.a;
		2 => return c.b;
		// Testing that the nonref was not touched by GC
		3 => return int.view(ptrBeforeGC == ptrAfterGC);
		_ => return 42;
	}
}
