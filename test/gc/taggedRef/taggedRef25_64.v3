//@execute (4,0)=3; (4,1)=4; (4,2)=4; (5,0)=3; (5,1)=4; (5,2)=5; (262143,0)=3; (262143,1)=4; (262143,2)=262143; (131070,0)=3; (131070,1)=4; (131070,2)=131070

// Test depends on TagUtils.v3

/**
(4,0)=3; (4,1)=4; (4,2)=4;
(5,0)=3; (5,1)=4; (5,2)=5;
(262143,0)=3; (262143,1)=4; (262143,2)=262143;
(131070,0)=3; (131070,1)=4; (131070,2)=131070
*/

// Simpler test checking only one nested reference (upper tag set)
def main(t: (int, int)) -> int {
	def a = t.0;
	def cbig = GCRefTestBigC.new();
	def taggedCbig = TagUtils.setAuxTag<GCRefTestBigC>(cbig, a);

	// Induce GC (rt.test-gc flag on)
	RiGc.forceGC();

	def untaggedCbig = TagUtils.removeAuxTag<GCRefTestBigC>(taggedCbig);

	// Testing references are properly garbage collected when tagged
	def tagIdx = t.1;
	match (tagIdx) {
		0 => return untaggedCbig.c2.a;
		1 => return untaggedCbig.c2.b;
		2 => return TagUtils.getAuxTag(taggedCbig);
		_ => return 42;
	}
}
