//@execute (4,0)=1; (4,1)=2; (5,0)=1; (5,1)=2; (262143,0)=1; (262143,1)=2; (131070,0)=1;  (131070,1)=2

// Test depends on TagUtils.v3

// Testing the upper tag getAuxTag after setAuxTag
// 262143 is 2^18 - 1 (17 lower bits are filled)
// 131070 is 2^17 - 2 (16 tag bits are filled, leftmost and rightmost empty)
def main(t: (int, int)) -> int {
	def a = t.0;
	def c1 = GCRefTestC.new(1, 2);
	def c1Tagged = TagUtils.setAuxTag<GCRefTestC>(c1, a);
	
	// induce GC
	def stuff = GCRefTestC.new(99, 99);

	def c1Untagged = TagUtils.removeAuxTag<GCRefTestC>(c1Tagged);

	def elemIdx = t.1;
	match (elemIdx) {
		0 => return c1Untagged.a;
		1 => return c1Untagged.b;
		_ => return 42;
	}
}

