//@execute 0=1; 1=2; 2=4; 3=5; 4=1; 5=1

// Test depends on TagUtils.v3

// Testing reference and nonrefernece recognition
def main(a: int) -> int {
	def c1 = GCRefTestC.new(1, 2);			// ref

	def c2 = GCRefTestC.new(2, 3);			// ref
	def c2NonRef = TagUtils.setRefTag(c2, 1);	// nonref

	def c3 = GCRefTestC.new(3, 4);			// ref
	def c3NonRef = TagUtils.setRefTag(c3, 1);	// nonref
	
	def c4 = GCRefTestC.new(4, 5);			// ref

	// Induce GC through allocation and rt.test-gc
	def stuff = GCRefTestC.new(99, 99);

	match (a) {
		// Check reference fields are accessible and correct
		0 => return c1.a;
		1 => return c1.b;
		2 => return c4.a;
		3 => return c4.b;
		// Test isOop
		4 => return int.view(CiRuntime.isOop(Pointer.atObject(c1)));
		5 => return int.view(CiRuntime.isOop(Pointer.atObject(c3)));
		_ => return 42;
	}
}
