//@execute (0,0)=1; (0,1)=2; (0,2)=3; (0,3)=4; (0,4)=5; (0,5)=6; (0,6)=7; (0,7)=8; (0,8)=0; (1,0)=1; (1,1)=2; (1,2)=3; (1,3)=4; (1,4)=5; (1,5)=6; (1,6)=7; (1,7)=8; (1,8)=1; (2,0)=1; (2,1)=2; (2,2)=3; (2,3)=4; (2,4)=5; (2,5)=6; (2,6)=7; (2,7)=8; (2,8)=2; (3,0)=1; (3,1)=2; (3,2)=3; (3,3)=4; (3,4)=5; (3,5)=6; (3,6)=7; (3,7)=8; (3,8)=3

// Test depends on TagUtils.v3

/**
This is a coverage test case; for a simpler test case, see taggedRef24_64.v3

  (0,0)=1; (0,1)=2; (0,2)=3; (0,3)=4; (0,4)=5; (0,5)=6; (0,6)=7; (0,7)=8; field tests
  (0,8)=0; tag test
  (1,0)=1; (1,1)=2; (1,2)=3; (1,3)=4; (1,4)=5; (1,5)=6; (1,6)=7; (1,7)=8; field tests 
  (1,8)=1; tag test
  (2,0)=1; (2,1)=2; (2,2)=3; (2,3)=4; (2,4)=5; (2,5)=6; (2,6)=7; (2,7)=8; field tests
  (2,8)=2; tag test 
  (3,0)=1; (3,1)=2; (3,2)=3; (3,3)=4; (3,4)=5; (3,5)=6; (3,6)=7; (3,7)=8; field tests
  (3,8)=3 tag test
*/

// Tests tagged container ref and data consistency of nested refs
def main(t: (int, int)) -> int {
	def a = t.0;
	def cbig = GCRefTestBigC.new();
	def taggedCbig = TagUtils.setAuxTag<GCRefTestBigC>(cbig, a);

	// Induce GC (rt.test-gc flag on)
	RiGc.forceGC();

	def untaggedCbig = TagUtils.clearAuxTag<GCRefTestBigC>(taggedCbig);

	// Testing references are properly garbage collected when tagged
	def tagIdx = t.1;
	match (tagIdx) {
		0 => return untaggedCbig.c1.a;
		1 => return untaggedCbig.c1.b;
		2 => return untaggedCbig.c2.a;
		3 => return untaggedCbig.c2.b;
		4 => return untaggedCbig.c3.a;
		5 => return untaggedCbig.c3.b;
		6 => return untaggedCbig.c4.a;
		7 => return untaggedCbig.c4.b;
		8 => return TagUtils.getAuxTag(taggedCbig);
		_ => return 42;
	}
}
