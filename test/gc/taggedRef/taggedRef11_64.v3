//@execute 0=9; 1=9; 2=9; 3=9

// Test depends on TagUtils.v3

def main(a: int) ->  int {
	def c1 = GCRefTestC.new(1, 2);
	def c1Tagged = TagUtils.setAuxTag(c1, a);
	
	// induce GC
	def stuff = GCRefTestC.new(99, 99);

	def c1Untagged = TagUtils.removeAuxTag(c1Tagged);

	// Test isOop is correct after GC updates ref
	// `a` field represented in rightmost bit 
	// `b` field represented in bits at indices 2 and 3
	// expected 0b1001
	return c1Untagged.a | (c1Untagged.b << 2);
}

