//@execute (0,0)=1; (0,1)=2; (1,0)=1; (1,1)=2; (2,0)=1; (2,1)=2; (3,0)=1; (3,1)=2

// Test depends on TagUtils.v3

// Test ref fields after setAuxTag
def main(t: (int, int)) ->  int {
	def a = t.0;
	def c1 = GCRefTestC.new(1, 2);
	def c1Tagged = TagUtils.setAuxTag<GCRefTestC>(c1, a);
	
	// induce GC
	RiGc.forceGC();

	def c1Untagged = TagUtils.removeAuxTag<GCRefTestC>(c1Tagged);

	def elemIdx = t.1;
	match (elemIdx) {
		0 => return c1Untagged.a;
		1 => return c1Untagged.b;
		_ => return 42;
	}
}

