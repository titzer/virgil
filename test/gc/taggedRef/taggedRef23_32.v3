//@execute (0,0)=1; (0,1)=2; (0,2)=3; (0,3)=4; (0,4)=5; (0,5)=6; (0,6)=7; (0,7)=8; (0,8)=0; (1,0)=1; (1,1)=2; (1,2)=3; (1,3)=4; (1,4)=5; (1,5)=6; (1,6)=7; (1,7)=8; (1,8)=1

// Test depends on TagUtils.v3

// Tests tagged container ref and data consistency of nested refs
def main(t: (int, int)) -> int {
	def a = t.0;
	def cbig = GCRefTestBigC.new();
	def taggedCbig = TagUtils.setAuxTag<GCRefTestBigC>(cbig, a);

	// Induce GC (rt.test-gc flag on)
	RiGc.forceGC();

	def untaggedCbig = TagUtils.removeAuxTag<GCRefTestBigC>(taggedCbig);

	// Testing references are properly garbage collected when tagged
	def tagIdx = t.1;
	match (tagIdx) {
		0 => return untaggedCbig.c1.a;
		1 => return untaggedCbig.c1.b;
		2 => return untaggedCbig.c2.a;
		3 => return untaggedCbig.c2.b;
		4 => return untaggedCbig.c3.a;
		5 => return untaggedCbig.c3.b;
		6 => return untaggedCbig.c4.a;
		7 => return untaggedCbig.c4.b;
		8 => return TagUtils.getAuxTag(taggedCbig);
		_ => return 42;
	}
}
