//@execute (4,0)=4; (4,1)=4; (4,2)=4; (4,3)=4; (5,0)=5; (5,1)=5; (5,2)=5; (5,3)=5; (262143,0)=262143; (262143,1)=262143; (262143,2)=262143; (262143,3)=262143; (131070,0)=131070; (131070,1)=131070; (131070,2)=131070; (131070,3)=131070

// Test depends on TagUtils.v3

// Tests tagged nested refs and tag retrieval (upper tag for 64-bit targets)
def main(t: (int, int)) -> int {
	def a = t.0;
	def cbig = GCRefTestBigC.new();
	cbig.c1 = TagUtils.setAuxTag<GCRefTestC>(cbig.c1, a);
	cbig.c2 = TagUtils.setAuxTag<GCRefTestC>(cbig.c2, a);
	cbig.c3 = TagUtils.setAuxTag<GCRefTestC>(cbig.c3, a);
	cbig.c4 = TagUtils.setAuxTag<GCRefTestC>(cbig.c4, a);

	// Induce GC (rt.test-gc flag on)
	def stuff = GCRefTestC.new(99, 99);

	def c1Tag = TagUtils.getAuxTag(cbig.c1);
	def c2Tag = TagUtils.getAuxTag(cbig.c2);
	def c3Tag = TagUtils.getAuxTag(cbig.c3);
	def c4Tag = TagUtils.getAuxTag(cbig.c4);
	
	def tagIdx = t.1;
	match (tagIdx) {
		0 => return c1Tag;
		1 => return c2Tag;
		2 => return c3Tag;
		3 => return c4Tag;
		_ => return 42;
	}
}
