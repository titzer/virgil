//@execute 0=1; 1=1; 2=2; 3=3; 4=3; 5=4; 6=0; 7=0

// Test depends on TagUtils.v3

// Testing refs are correct and nonrefs untouched
def main(a: int) -> int {
	def c1 = GCRefTestC.new(1, 2);			// ref

	def c2 = GCRefTestC.new(2, 3);			// ref
	def c2NonRef = TagUtils.setRefTag<GCRefTestC>(c2, 1);	// nonref

	def c3 = GCRefTestC.new(3, 4);			// ref
	def c3NonRef = TagUtils.setRefTag<GCRefTestC>(c3, 1);	// nonref

	def c4 = GCRefTestC.new(4, 5);			// ref

	// Pointers to nonreferences
	def p2BeforeGC = Pointer.atObject(c2NonRef);
	def p3BeforeGC = Pointer.atObject(c3NonRef);

	// Induce GC through allocation and rt.test-gc
	RiGc.forceGC();

	def p2AfterGC = Pointer.atObject(c2NonRef);
	def p3AfterGC = Pointer.atObject(c3NonRef);

	match (a) {
		// Tests nonrefs were ignored by GC
		0 => return int.view<bool>(p2BeforeGC == p2AfterGC);
		1 => return int.view<bool>(p3BeforeGC == p3AfterGC);
		// Check original object is still correct
		2 => return c2.a;
		3 => return c2.b;
		4 => return c3.a;
		5 => return c3.b;
		// Test isOop
		6 => return int.view<bool>(CiRuntime.isOop(p2AfterGC));
		7 => return int.view<bool>(CiRuntime.isOop(p3AfterGC));
		_ => return 42;
	}
}
