//@execute 0=0; 1=1

// Test depends on TagUtils.v3

// Test getAuxTag after setAuxTag
def main(a: int) -> int {
	def c1 = GCRefTestC.new(1, 2);
	def c1Tagged = TagUtils.setAuxTag<GCRefTestC>(c1, a);
	
	// induce GC
	RiGc.forceGC();

	def tag = TagUtils.getAuxTag(c1Tagged);

	// Test tag is correct after GC updates ref
	return tag;
}

