//@execute 0=1; 1=1; 2=1; 3=2; 4=3; 5=4; 6=0; 7=0

// Test depends on TagUtils.v3

// Testing refs are correct and nonrefs untouched
def main(a: int) -> int {
	def c1 = GCRefTestC.new(1, 2);			// ref
	def c1NonRef = TagUtils.setRefTag<GCRefTestC>(c1, 1);	// nonref

	def c2 = GCRefTestC.new(2, 3);			// ref

	def c3 = GCRefTestC.new(3, 4);			// ref
	def c3NonRef = TagUtils.setRefTag<GCRefTestC>(c3, 1);	// nonref

	def c4 = GCRefTestC.new(4, 5);			// ref

	// These should not get GC'd 
	def p1BeforeGC = Pointer.atObject(c1NonRef);
	def p3BeforeGC = Pointer.atObject(c3NonRef);

	// Induce GC through allocation and rt.test-gc
	def stuff = GCRefTestC.new(99, 99);

	def p1AfterGC = Pointer.atObject(c1NonRef);
	def p3AfterGC = Pointer.atObject(c3NonRef);

	match (a) {
		// Check nonrefs were ignored
		0 => return int.view(p1BeforeGC == p1AfterGC);
		1 => return int.view(p3BeforeGC == p3AfterGC);
		// Check original object is still correct  
		2 => return c1.a;
		3 => return c1.b;
		4 => return c3.a;
		5 => return c3.b;
		6 => return int.view(CiRuntime.isOop(p1AfterGC));
		7 => return int.view(CiRuntime.isOop(p3AfterGC));
		_ => return 42;
	}
}
