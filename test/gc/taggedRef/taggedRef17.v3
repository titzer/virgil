//@execute 0=1; 1=1; 2=3; 3=4; 4=5; 5=6

// Test depends on TagUtils.v3

// Tests nested refs with nested nonrefs
def main(a: int) -> int {
	def cbig = GCRefTestBigC.new();
	cbig.c1 = TagUtils.setRefTag<GCRefTestC>(cbig.c1, 1); // nonrefs
	cbig.c4 = TagUtils.setRefTag<GCRefTestC>(cbig.c4, 1); // nonrefs

	def p1BeforeGC = Pointer.atObject(cbig.c1);
	def p4BeforeGC = Pointer.atObject(cbig.c4);

	// Induce GC (rt.test-gc flag on)
	def stuff = GCRefTestC.new(99, 99);

	// Shouldn't have been changed by the GC
	def p1AfterGC = Pointer.atObject(cbig.c1);
	def p4AfterGC = Pointer.atObject(cbig.c4);

	match (a) {
		0 => return int.view(p1BeforeGC == p1AfterGC);
		1 => return int.view(p4BeforeGC == p4AfterGC);
		2 => return cbig.c2.a;
		3 => return cbig.c2.b;
		4 => return cbig.c3.a;
		5 => return cbig.c3.b;
		_ => return 42;
	}
}
