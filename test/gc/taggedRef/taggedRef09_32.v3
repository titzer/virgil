//@execute 0=true; 1=true

// Test depends on TagUtils.v3

def main(a: int) -> bool {
	def c1 = GCRefTestC.new(1, 2);
	def c1Tagged = TagUtils.setAuxTag(c1, a);
	
	// induce GC
	def stuff = GCRefTestC.new(99, 99);

	// Test isOop is correct after GC updates ref
	return CiRuntime.isOop(Pointer.atObject(c1Tagged));
}

