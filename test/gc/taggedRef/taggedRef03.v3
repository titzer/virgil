//@execute 0=1; 1=1; 2=1; 3=2; 4=4; 5=5; 6=0; 7=0

// Test depends on TagUtils.v3

// Testing reference and nonrefernece recognition
def main(a: int) -> int {
	def c1 = GCRefTestC.new(1, 2);			// ref
	def c1NonRef = TagUtils.setRefTag(c1, 1);	// nonref

	def c2 = GCRefTestC.new(2, 3);			// ref
	def c3 = GCRefTestC.new(3, 4);			// ref

	def c4 = GCRefTestC.new(4, 5);			// ref
	def c4NonRef = TagUtils.setRefTag(c4, 1); 	// nonref

	// Pointers to nonreferences
	def p1BeforeGC = Pointer.atObject(c1NonRef);
	def p4BeforeGC = Pointer.atObject(c4NonRef);

	// Induce GC through allocation and rt.test-gc
	def stuff = GCRefTestC.new(99, 99);

	def p1AfterGC = Pointer.atObject(c1NonRef);
	def p4AfterGC = Pointer.atObject(c4NonRef);

	match (a) {
		// Tests nonrefs were ignored by GC
		0 => return int.view(p1BeforeGC == p1AfterGC);
		1 => return int.view(p4BeforeGC == p4AfterGC);
		// Check original object is still correct  
		2 => return c1.a;
		3 => return c1.b;
		4 => return c4.a;
		5 => return c4.b;
		// Test isOop
		6 => return int.view(CiRuntime.isOop(p1AfterGC));
		7 => return int.view(CiRuntime.isOop(p4AfterGC));
		_ => return 42;
	}
}
