//@execute (4,0)=1; (4,1)=2; (4,2)=3; (4,3)=4; (4,4)=5; (4,5)=6; (4,6)=7; (4,7)=8; (4,8)=4; (5,0)=1; (5,1)=2; (5,2)=3; (5,3)=4; (5,4)=5; (5,5)=6; (5,6)=7; (5,7)=8; (5,8)=5; (262143,0)=1; (262143,1)=2; (262143,2)=3; (262143,3)=4; (262143,4)=5; (262143,5)=6; (262143,6)=7; (262143,7)=8; (262143,8)=262143; (131070,0)=1; (131070,1)=2; (131070,2)=3; (131070,3)=4; (131070,4)=5; (131070,5)=6; (131070,6)=7; (131070,7)=8; (131070,8)=131070

// Test depends on TagUtils.v3

/**
	This is a coverage test case; for a simpler test case, see taggedRef25_64.v3

	(4,0)=1; (4,1)=2; (4,2)=3; (4,3)=4; (4,4)=5; (4,5)=6; (4,6)=7; (4,7)=8; (4,8)=4; 
	(5,0)=1; (5,1)=2; (5,2)=3; (5,3)=4; (5,4)=5; (5,5)=6; (5,6)=7; (5,7)=8; (5,8)=5; 
	(262143,0)=1; (262143,1)=2; (262143,2)=3; (262143,3)=4; (262143,4)=5; (262143,5)=6; (262143,6)=7; (262143,7)=8; (262143,8)=262143; 
	(131070,0)=1; (131070,1)=2; (131070,2)=3; (131070,3)=4; (131070,4)=5; (131070,5)=6; (131070,6)=7; (131070,7)=8; (131070,8)=131070
*/

// Simpler test checking only one nested reference (upper tag set)
def main(t: (int, int)) -> int {
	def a = t.0;
	def cbig = GCRefTestBigC.new();
	def taggedCbig = TagUtils.setAuxTag<GCRefTestBigC>(cbig, a);

	// Induce GC (rt.test-gc flag on)
	RiGc.forceGC();

	def untaggedCbig = TagUtils.removeAuxTag<GCRefTestBigC>(taggedCbig);

	// Testing references are properly garbage collected when tagged
	def tagIdx = t.1;
	match (tagIdx) {
		0 => return untaggedCbig.c1.a;
		1 => return untaggedCbig.c1.b;
		2 => return untaggedCbig.c2.a;
		3 => return untaggedCbig.c2.b;
		4 => return untaggedCbig.c3.a;
		5 => return untaggedCbig.c3.b;
		6 => return untaggedCbig.c4.a;
		7 => return untaggedCbig.c4.b;
		8 => return TagUtils.getAuxTag(taggedCbig);
		_ => return 42;
	}
}
