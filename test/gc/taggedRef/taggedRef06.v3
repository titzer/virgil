//@execute 0=2; 1=3; 2=3; 3=4; 4=1; 5=1

// Test depends on TagUtils.v3

// Testing reference and nonrefernece recognition
def main(a: int) -> int {
	def c1 = GCRefTestC.new(1, 2); 			// ref
	def c1NonRef = TagUtils.setRefTag(c1, 1);	// nonref

	def c2 = GCRefTestC.new(2, 3);			// ref
	def c3 = GCRefTestC.new(3, 4);			// ref

	def c4 = GCRefTestC.new(4, 5);			// ref
	def c4NonRef = TagUtils.setRefTag(c4, 1);	// nonref

	// Induce GC through allocation and rt.test-gc
	def stuff = GCRefTestC.new(99, 99);

	match (a) {
		// Tests nonrefs were ignored by GC
		0 => return c2.a;
		1 => return c2.b;
		2 => return c3.a;
		3 => return c3.b;
		// Test isOop
		4 => return int.view(CiRuntime.isOop(Pointer.atObject(c2)));
		5 => return int.view(CiRuntime.isOop(Pointer.atObject(c3)));
		_ => return 42;
	}
}
