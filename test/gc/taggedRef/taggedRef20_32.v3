//@execute (0,0)=1; (0,1)=2; (0,2)=3; (0,3)=4; (0,4)=5; (0,5)=6; (0,6)=7; (0,7)=8; (1,0)=1; (1,1)=2; (1,2)=3; (1,3)=4; (1,4)=5; (1,5)=6; (1,6)=7; (1,7)=8

// Test depends on TagUtils.v3

// Tests tagged nested refs and data consistency
def main(t: (int, int)) -> int {
	def a = t.0;
	def cbig = GCRefTestBigC.new();
	cbig.c1 = TagUtils.setAuxTag<GCRefTestC>(cbig.c1, a);
	cbig.c2 = TagUtils.setAuxTag<GCRefTestC>(cbig.c2, a);
	cbig.c3 = TagUtils.setAuxTag<GCRefTestC>(cbig.c3, a);
	cbig.c4 = TagUtils.setAuxTag<GCRefTestC>(cbig.c4, a);

	// Induce GC (rt.test-gc flag on)
	RiGc.forceGC();

	def c1Untagged = TagUtils.removeAuxTag<GCRefTestC>(cbig.c1);
	def c2Untagged = TagUtils.removeAuxTag<GCRefTestC>(cbig.c2);
	def c3Untagged = TagUtils.removeAuxTag<GCRefTestC>(cbig.c3);
	def c4Untagged = TagUtils.removeAuxTag<GCRefTestC>(cbig.c4);
	

	// Testing references are properly garbage collected when tagged
	def tagIdx = t.1;
	match (tagIdx) {
		0 => return c1Untagged.a;
		1 => return c1Untagged.b;
		2 => return c2Untagged.a;
		3 => return c2Untagged.b;
		4 => return c3Untagged.a;
		5 => return c3Untagged.b;
		6 => return c4Untagged.a;
		7 => return c4Untagged.b;
		_ => return 42;
	}
}
