// Allows TagUtils to be called on either GCRefTestC or GCRefTestBigC
class GCRefTestBase {}
// Used for general ref and nonref tests
class GCRefTestC extends GCRefTestBase {
	def a: int; 
	def b: int;
	new(a, b) {}
}
// Used for testing nested references
class GCRefTestBigC extends GCRefTestBase {
	var c1 = GCRefTestC.new(1, 2);
	var c2 = GCRefTestC.new(3, 4);
	var c3 = GCRefTestC.new(5, 6);
	var c4 = GCRefTestC.new(7, 8);
	new () { }
}

component TagUtils {
	def helperArr64: Array<u64> = Array<u64>.new(1);
	def helperArr32: Array<u32> = Array<u32>.new(1);
	// Sets the auxiliary tag of a reference
	def setAuxTag<T>(oop: GCRefTestBase, tag: int) -> T {
		var ptr = Pointer.atObject(oop);
		ptr = CiRuntime.setAuxTag(ptr, tag);
		return ptrToOop<T>(ptr);
	}
	// Gets the auxiliary tag of a reference
	def getAuxTag(oop: GCRefTestBase) -> int {
		def ptr = Pointer.atObject(oop);
		return int.view(CiRuntime.getAuxTag(ptr));
	}
	// Sets the reference tag. Used for treating a ref type as a nonref
	def setRefTag<T>(oop: GCRefTestBase, tag: int) -> T {
		var ptr = Pointer.atObject(oop);
		ptr = CiRuntime.setRefTag(ptr, tag); 
		return ptrToOop<T>(ptr);	
	}
	// Returns the reference with the auxiliary tag removed
	// Used for properly accessing fields of the reference
	def removeAuxTag<T>(oop: GCRefTestBase) -> T {
		var ptr = Pointer.atObject(oop);
		// Should work for both 32-bit and 64-bit pointers
		var intPtr = u64.view(ptr);
		intPtr = intPtr & u64.view(CiRuntime.AUX_TAG_MASK);
		var untaggedPtr = Pointer.view(intPtr);
		return ptrToOop<T>(untaggedPtr);
	}
	// Views a pointer as a reference type (specified by type param)
	def ptrToOop<T>(ptr: Pointer) -> T {
		if (Pointer.SIZE == 4) {
			def addr = u32.view<Pointer>(ptr);
			helperArr32[0] = addr;
			def ptrAtContents = Pointer.atContents(helperArr32);
			return CiRuntime.forgeRange<T>(ptrAtContents, 1)[0];
		}
		def addr = u64.view<Pointer>(ptr);
		helperArr64[0] = addr; 
		def ptrAtContents = Pointer.atContents(helperArr64);
		return CiRuntime.forgeRange<T>(ptrAtContents, 1)[0];
	}
}
