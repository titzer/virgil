//@execute 1=43; 0=42
def foo() => 42;
def bar() => 43;
def ps = [Pointer.NULL, Pointer.NULL];
def unpack = CiRuntime.unpackClosure<void, void, int>;
def main(a: int) -> int {
	ps[0] = unpack(foo).0;
	ps[1] = unpack(bar).0;
	var ptr = ps[a];
	var f2 = CiRuntime.forgeClosure<void, void, int>(ptr, ());
	return f2();
}
