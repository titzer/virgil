//@execute =true

// For now, 32-bit targets have 32-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 32-bit targets have 4 byte alignment => 2 lower bits available for tagging
// 1 bit for auxiliary tag bit, 1 for ref bit
def getAddressWidth() -> int {
    return 32; 
    // TODO: in the future, should be log2ceil(CiRuntime.HEAP_END)
}
def expected() -> u32 {
    def allOnes = u32.view(-1);
    def numAvailUpperBits = byte.view(32-getAddressWidth());
    var mask = if(numAvailUpperBits==0, allOnes, (allOnes << numAvailUpperBits) >> numAvailUpperBits);
    mask = (mask >> 2) << 2;
    mask += 1;
    return u32.view(mask ^ allOnes);
}
def main() -> bool {
    return CiRuntime.AUX_TAG_MASK==expected();
}