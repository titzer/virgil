//@execute =true

// Creates a mask where the tag bits are 0s
def getMask() -> u32 {
    def allOnes: u32 = u32.view(-1);
    var mask = (allOnes >> 2) << 2;
    def shiftsToRemoveUpperBits = byte.view(32 - getHeapBits() - 2);
    mask = u32.view(mask << shiftsToRemoveUpperBits) >> shiftsToRemoveUpperBits;
    return (mask + 1) ^ u32.view(-1);
}
def getHeapBits() -> int {
    def heap_size = CiRuntime.HEAP_SIZE;
    var numBits = 1, exp = 2;
    while (exp < heap_size) {
        exp = exp << 1;
        numBits++;
    }
    return numBits;
}
def main() -> bool {
    return CiRuntime.AUX_TAG_MASK == getMask();
}