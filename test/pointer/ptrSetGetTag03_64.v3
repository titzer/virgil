//@execute 0=true; 1=true; 2=true; 3=true
def getHeapBits() -> int {
    def heap_size = CiRuntime.HEAP_SIZE;
    var numBits = 1, exp = 2;
    while (exp < heap_size) {
        exp = exp << 1;
        numBits++;
    }
    return numBits;
}
// Creates a mask where the tag bits are 0s
def getMask() -> u64 {
    def allOnes: u64 = u64.view(-1);
    var mask = (allOnes >> 3) << 3;
    def shiftsToRemoveUpperBits = byte.view(64 - getHeapBits() - 3);
    mask = u64.view(mask << shiftsToRemoveUpperBits) >> shiftsToRemoveUpperBits;
    return mask + 1;
}
def expected(tag: u64) -> long {
    def mask = getMask();
    def lower = u2.view(tag);
    var result = mask | (u64.view(lower) << 1);
    def upper = tag >> 2;
    result = result | (upper << byte.view(2 + getHeapBits()));
    return long.view(result);
}
def main(a: int) -> bool {
    // 32 bits
    def mask = -1L;
    var ptr = Pointer.NULL + mask;
    ptr = CiRuntime.setAuxTag(ptr, a);
    return (ptr - Pointer.NULL) == expected(u64.view(a));
}