//@execute 0=true; 1=true; 2=true; 3=true; 4=true; 5=true; 7=true
def getHeapBits() -> int {
    return 48;
}
// Test when setAuxTag when all bits are initially 1

// For now, 64-bit targets have 64-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 64-bit targets have 8 byte alignment => 3 lower bits available for tagging
// 2 bit for auxiliary tag bit, 1 for ref bit
def expected(tag: u64) -> u64 {
    def mask = CiRuntime.AUX_TAG_MASK;
    def lower = u2.view(tag);
    var result: u64 = mask | (u64.view(lower) << 1);
    def upper: u64 = tag >> 2;
    result = result | (upper << byte.view(getHeapBits()));
    return result;
}
def main(a: int) -> bool {
    def mask = -1L;
    var ptr = Pointer.NULL + mask;
    ptr = CiRuntime.setAuxTag(ptr, a);
    return (u64.view(ptr - Pointer.NULL)) == (expected(u64.view(a)));
}