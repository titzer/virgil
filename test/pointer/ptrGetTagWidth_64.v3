//@execute 0=18; 1=1
// Creates a mask where the tag bits are 0s
// For now, 64-bit targets have 48-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 64-bit targets have 8 byte alignment => 8 lower bits available for tagging
// 2 bit for auxiliary tag bit, 1 for ref bit
def getHeapBits() -> int {
    return 48;
}
def getAvailAlignBits() -> int {
    return 3;
}
def main(a: int) -> int {
    def expected = (64 - getHeapBits() + getAvailAlignBits() - 1);
    match (a) {
        0 => return expected;
        1 => return int.view(CiRuntime.AUX_TAG_WIDTH==expected);
        _ => return 42;
    }
}