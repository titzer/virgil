def p() -> Pointer {
    def addend = -1;
    return Pointer.NULL + addend;
}

def main(a: int) -> int {
    // truncation test 
    match (a) {
        1 => return i1.view<Pointer>(p());
        2 => return i2.view<Pointer>(p());
        3 => return i3.view<Pointer>(p());
        4 => return i4.view<Pointer>(p());
