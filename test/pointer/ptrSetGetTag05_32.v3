//@execute 0=true; 1=true
def getHeapBits() -> int {
    def heap_size = CiRuntime.HEAP_SIZE;
    var numBits = 1, exp = 2;
    while (exp < heap_size) {
        exp = exp << 1;
        numBits++;
    }
    return numBits;
}
def expected(tag: u32) -> int {
    def mask = CiRuntime.AUX_TAG_MASK ^ u32.view(-1);
    def lower = u1.view(tag);
    var result = mask | (u32.view(lower) << 1);
    def upper = tag >> 1;
    result = result | (upper << byte.view(2 + getHeapBits()));
    return int.view(result);
}
def main(a: int) -> bool {
    // 32 bits
    def mask = -1;
    var ptr = Pointer.NULL + mask;
    ptr = CiRuntime.setAuxTag(ptr, a);
    return (ptr - Pointer.NULL) == expected(u32.view(a));
}