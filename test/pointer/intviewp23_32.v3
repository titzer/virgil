        43 => return int.view(i43.view<Pointer>(p()) >> 32);
        44 => return int.view(i44.view<Pointer>(p()) >> 32);
        45 => return int.view(i45.view<Pointer>(p()) >> 32);
        46 => return int.view(i46.view<Pointer>(p()) >> 32);
        47 => return int.view(i47.view<Pointer>(p()) >> 32);
