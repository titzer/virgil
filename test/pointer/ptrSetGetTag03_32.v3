//@execute 0=true; 1=true; 2=true; 3=true
def getHeapBits() -> int {
    return 32;
}
// Test when setAuxTag when all bits are initially 1

// For now, 32-bit targets have 32-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 32-bit targets have 4 byte alignment => 2 lower bits available for tagging
// 1 bit for auxiliary tag bit, 1 for ref bit
def expected(tag: u32) -> int {
    var mask = (CiRuntime.AUX_TAG_MASK ^ u32.view(-1));
    def lower = u1.view(tag);
    var result = mask | (u32.view(lower) << 1);
    def upper = tag >> 1;
    result = result | (upper << byte.view(getHeapBits()));
    return int.view(result);
}
def main(a: int) -> bool {
    // 32 bits
    def mask = -1;
    var ptr = Pointer.NULL + mask;
    ptr = CiRuntime.setAuxTag(ptr, a);
    return (ptr - Pointer.NULL) == expected(u32.view(a));
}