//@execute 0=true; 1=true
def getHeapBits() -> int {
    def heap_size = CiRuntime.HEAP_SIZE;
    var numBits = 1, exp = 2;
    while (exp < heap_size) {
        exp = exp << 1;
        numBits++;
    }
    return numBits;
}
// Creates a mask where the tag bits are 0s
def getMask() -> u32 {
    def allOnes: u32 = u32.view(-1);
    var mask = (allOnes >> 2) << 2;
    def shiftsToRemoveUpperBits = byte.view(32 - getHeapBits() - 2);
    mask = u32.view(mask << shiftsToRemoveUpperBits) >> shiftsToRemoveUpperBits;
    return mask + 1;
}
def expected(tag: u32) -> int {
    def mask = getMask();
    def lower = u1.view(tag);
    var result = mask | (u32.view(lower) << 1);
    def upper = tag >> 1;
    result = result | (upper << byte.view(2 + getHeapBits()));
    return int.view(result);
}
def main(a: int) -> bool {
    // 32 bits
    def mask = -1;
    var ptr = Pointer.NULL + mask;
    ptr = CiRuntime.setAuxTag(ptr, a);
    return (ptr - Pointer.NULL) == expected(u32.view(a));
}