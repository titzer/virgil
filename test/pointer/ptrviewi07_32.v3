//@execute 1=1; 2=3; 3=7; 4=15; 5=31; 6=63; 7=127; 8=255; 9=511; 10=1023; 11=2047; 12=4095; 13=8191; 14=16383; 15=32767; 16=65535; 17=131071; 18=262143; 19=524287; 20=1048575; 21=2097151; 22=4194303; 23=8388607; 24=16777215; 25=33554431; 26=67108863; 27=134217727; 28=268435455; 29=536870911; 30=1073741823; 31=2147483647; 32=-1
def main(a: int) -> int {
    match (a) {
        1 => return Pointer.view<u1>(u1.view(1  )) - Pointer.NULL;
        2 => return Pointer.view<u2>(u2.view(3  )) - Pointer.NULL;
        3 => return Pointer.view<u3>(u3.view(7  )) - Pointer.NULL;
        4 => return Pointer.view<u4>(u4.view(15 )) - Pointer.NULL;
        5 => return Pointer.view<u5>(u5.view(31 )) - Pointer.NULL;
        6 => return Pointer.view<u6>(u6.view(63 )) - Pointer.NULL;
        7 => return Pointer.view<u7>(u7.view(127)) - Pointer.NULL;
        8 => return Pointer.view<u8>(u8.view(255)) - Pointer.NULL;
        9 => return Pointer.view<u9>(u9.view(511       )) - Pointer.NULL;
        10 => return Pointer.view<u10>(u10.view(1023      )) - Pointer.NULL;
        11 => return Pointer.view<u11>(u11.view(2047      )) - Pointer.NULL;
        12 => return Pointer.view<u12>(u12.view(4095      )) - Pointer.NULL;
        13 => return Pointer.view<u13>(u13.view(8191      )) - Pointer.NULL;
        14 => return Pointer.view<u14>(u14.view(16383     )) - Pointer.NULL;
        15 => return Pointer.view<u15>(u15.view(32767     )) - Pointer.NULL;
        16 => return Pointer.view<u16>(u16.view(65535     )) - Pointer.NULL;
        17 => return Pointer.view<u17>(u17.view(131071    )) - Pointer.NULL;
        18 => return Pointer.view<u18>(u18.view(262143    )) - Pointer.NULL;
        19 => return Pointer.view<u19>(u19.view(524287    )) - Pointer.NULL;
        20 => return Pointer.view<u20>(u20.view(1048575   )) - Pointer.NULL;
        21 => return Pointer.view<u21>(u21.view(2097151   )) - Pointer.NULL;
        22 => return Pointer.view<u22>(u22.view(4194303   )) - Pointer.NULL;
        23 => return Pointer.view<u23>(u23.view(8388607   )) - Pointer.NULL;
        24 => return Pointer.view<u24>(u24.view(16777215  )) - Pointer.NULL;
        25 => return Pointer.view<u25>(u25.view(33554431  )) - Pointer.NULL;
        26 => return Pointer.view<u26>(u26.view(67108863  )) - Pointer.NULL;
        27 => return Pointer.view<u27>(u27.view(134217727 )) - Pointer.NULL;
        28 => return Pointer.view<u28>(u28.view(268435455 )) - Pointer.NULL;
        29 => return Pointer.view<u29>(u29.view(536870911 )) - Pointer.NULL;
        30 => return Pointer.view<u30>(u30.view(1073741823)) - Pointer.NULL;
        31 => return Pointer.view<u31>(u31.view(2147483647)) - Pointer.NULL;
        32 => return Pointer.view<u32>(u32.view(-1)) - Pointer.NULL;
        _ => return 42;                         
    }

}