//@execute 1=1; 2=3; 3=7; 4=15; 5=31; 6=63; 7=127; 8=255; 9=511; 10=1023; 11=2047; 12=4095; 13=8191; 14=16383; 15=32767; 16=65535; 17=131071; 18=262143; 19=524287; 20=1048575; 21=2097151; 22=4194303; 23=8388607; 24=16777215; 25=33554431; 26=67108863; 27=134217727; 28=268435455; 29=536870911; 30=1073741823; 31=2147483647; 32=-1
def v(i: int) -> long {
    return (1L << byte.view(i)) - 1L;
}
def main(a: int) -> int {
    match (a) {
        1 => return Pointer.view<u1>(u1.view(v(a))) - Pointer.NULL;
        2 => return Pointer.view<u2>(u2.view(v(a))) - Pointer.NULL;
        3 => return Pointer.view<u3>(u3.view(v(a))) - Pointer.NULL;
        4 => return Pointer.view<u4>(u4.view(v(a))) - Pointer.NULL;
        5 => return Pointer.view<u5>(u5.view(v(a))) - Pointer.NULL;
        6 => return Pointer.view<u6>(u6.view(v(a))) - Pointer.NULL;
        7 => return Pointer.view<u7>(u7.view(v(a))) - Pointer.NULL;
        8 => return Pointer.view<u8>(u8.view(v(a))) - Pointer.NULL;
        9 => return Pointer.view<u9>(u9.view(v(a))) - Pointer.NULL;
        10 => return Pointer.view<u10>(u10.view(v(a))) - Pointer.NULL;
        11 => return Pointer.view<u11>(u11.view(v(a))) - Pointer.NULL;
        12 => return Pointer.view<u12>(u12.view(v(a))) - Pointer.NULL;
        13 => return Pointer.view<u13>(u13.view(v(a))) - Pointer.NULL;
        14 => return Pointer.view<u14>(u14.view(v(a))) - Pointer.NULL;
        15 => return Pointer.view<u15>(u15.view(v(a))) - Pointer.NULL;
        16 => return Pointer.view<u16>(u16.view(v(a))) - Pointer.NULL;
        17 => return Pointer.view<u17>(u17.view(v(a))) - Pointer.NULL;
        18 => return Pointer.view<u18>(u18.view(v(a))) - Pointer.NULL;
        19 => return Pointer.view<u19>(u19.view(v(a))) - Pointer.NULL;
        20 => return Pointer.view<u20>(u20.view(v(a))) - Pointer.NULL;
        21 => return Pointer.view<u21>(u21.view(v(a))) - Pointer.NULL;
        22 => return Pointer.view<u22>(u22.view(v(a))) - Pointer.NULL;
        23 => return Pointer.view<u23>(u23.view(v(a))) - Pointer.NULL;
        24 => return Pointer.view<u24>(u24.view(v(a))) - Pointer.NULL;
        25 => return Pointer.view<u25>(u25.view(v(a))) - Pointer.NULL;
        26 => return Pointer.view<u26>(u26.view(v(a))) - Pointer.NULL;
        27 => return Pointer.view<u27>(u27.view(v(a))) - Pointer.NULL;
        28 => return Pointer.view<u28>(u28.view(v(a))) - Pointer.NULL;
        29 => return Pointer.view<u29>(u29.view(v(a))) - Pointer.NULL;
        30 => return Pointer.view<u30>(u30.view(v(a))) - Pointer.NULL;
        31 => return Pointer.view<u31>(u31.view(v(a))) - Pointer.NULL;
        32 => return Pointer.view<u32>(u32.view(-1)) - Pointer.NULL;
        _ => return 42;                         
    }

}