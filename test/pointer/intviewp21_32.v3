def p() -> Pointer {
    return Pointer.NULL + (-1);
}

def main(a: int) -> int {
    // sign extension test
    match (a) {
        33 => return int.view(u33.view<Pointer>(p()) >> 32);
        34 => return int.view(u34.view<Pointer>(p()) >> 32);
        35 => return int.view(u35.view<Pointer>(p()) >> 32);
        36 => return int.view(u36.view<Pointer>(p()) >> 32);
