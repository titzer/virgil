        58 => return int.view(u58.view<Pointer>(p()) >> 32);
        59 => return int.view(u59.view<Pointer>(p()) >> 32);
        60 => return int.view(u60.view<Pointer>(p()) >> 32);
        61 => return int.view(u61.view<Pointer>(p()) >> 32);
        62 => return int.view(u62.view<Pointer>(p()) >> 32);
        63 => return int.view(u63.view<Pointer>(p()) >> 32);
        64 => return int.view(u64.view<Pointer>(p()) >> 32);
        _ => return 42;
