def v(i: int) -> long {
    return (1L << byte.view(i)) - 1L;
}
def main(a: int) -> int {
    match (a) {
        1 => return Pointer.view<i1>(i1.view(v(a-1))) - Pointer.NULL;
        2 => return Pointer.view<i2>(i2.view(v(a-1))) - Pointer.NULL;
