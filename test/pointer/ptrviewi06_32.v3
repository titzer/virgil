//@execute 1=0; 2=1; 3=3; 4=7; 5=15; 6=31; 7=63; 8=127; 9=255; 10=511; 11=1023; 12=2047; 13=4095; 14=8191; 15=16383; 16=32767; 17=65535; 18=131071; 19=262143; 20=524287; 21=1048575; 22=2097151; 23=4194303; 24=8388607; 25=16777215; 26=33554431; 27=67108863; 28=134217727; 29=268435455; 30=536870911; 31=1073741823; 32=2147483647
def main(a: int) -> int {
    match (a) {
        1 => return Pointer.view<i1>(i1.view(0  )) - Pointer.NULL;
        2 => return Pointer.view<i2>(i2.view(1  )) - Pointer.NULL;
        3 => return Pointer.view<i3>(i3.view(3  )) - Pointer.NULL;
        4 => return Pointer.view<i4>(i4.view(7  )) - Pointer.NULL;
        5 => return Pointer.view<i5>(i5.view(15 )) - Pointer.NULL;
        6 => return Pointer.view<i6>(i6.view(31 )) - Pointer.NULL;
        7 => return Pointer.view<i7>(i7.view(63 )) - Pointer.NULL;
        8 => return Pointer.view<i8>(i8.view(127)) - Pointer.NULL;
        9 => return Pointer.view<i9>(i9.view(255)) - Pointer.NULL;
        10 => return Pointer.view<i10>(i10.view(511       )) - Pointer.NULL;
        11 => return Pointer.view<i11>(i11.view(1023      )) - Pointer.NULL;
        12 => return Pointer.view<i12>(i12.view(2047      )) - Pointer.NULL;
        13 => return Pointer.view<i13>(i13.view(4095      )) - Pointer.NULL;
        14 => return Pointer.view<i14>(i14.view(8191      )) - Pointer.NULL;
        15 => return Pointer.view<i15>(i15.view(16383     )) - Pointer.NULL;
        16 => return Pointer.view<i16>(i16.view(32767     )) - Pointer.NULL;
        17 => return Pointer.view<i17>(i17.view(65535     )) - Pointer.NULL;
        18 => return Pointer.view<i18>(i18.view(131071    )) - Pointer.NULL;
        19 => return Pointer.view<i19>(i19.view(262143    )) - Pointer.NULL;
        20 => return Pointer.view<i20>(i20.view(524287    )) - Pointer.NULL;
        21 => return Pointer.view<i21>(i21.view(1048575   )) - Pointer.NULL;
        22 => return Pointer.view<i22>(i22.view(2097151   )) - Pointer.NULL;
        23 => return Pointer.view<i23>(i23.view(4194303   )) - Pointer.NULL;
        24 => return Pointer.view<i24>(i24.view(8388607   )) - Pointer.NULL;
        25 => return Pointer.view<i25>(i25.view(16777215  )) - Pointer.NULL;
        26 => return Pointer.view<i26>(i26.view(33554431  )) - Pointer.NULL;
        27 => return Pointer.view<i27>(i27.view(67108863  )) - Pointer.NULL;
        28 => return Pointer.view<i28>(i28.view(134217727 )) - Pointer.NULL;
        29 => return Pointer.view<i29>(i29.view(268435455 )) - Pointer.NULL;
        30 => return Pointer.view<i30>(i30.view(536870911 )) - Pointer.NULL;
        31 => return Pointer.view<i31>(i31.view(1073741823)) - Pointer.NULL;
        32 => return Pointer.view<i32>(i32.view(2147483647)) - Pointer.NULL;
        _ => return 42;                         
    }

}