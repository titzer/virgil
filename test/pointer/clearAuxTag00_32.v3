//@execute (0,0)=-3; (0,1)=-3; (1,0)=-1; (1,1)=-3
def main(t: (int, int)) -> int {
	def tag = t.0;

	// All bits set to 1
	var p = Pointer.NULL + int.view(CiRuntime.AUX_TAG_MASK);
	p = CiRuntime.setAuxTag(p, tag);

	match (t.1) {
		0 => return int.view(p);
		1 => return int.view(CiRuntime.clearAuxTag(p));
		_ => return 42;
	}
}



