//@execute (5,0)=-5; (5,1)=131071; (5,2)=-7; (5,3)=65535; (131070,0)=-3; (131070,1)=2147483647; (131070,2)=-7; (131070,3)=65535
def main(t: (int, int)) -> int {
	def tag = t.0;

	// All bits set to 1
	var p = Pointer.NULL + int.view(CiRuntime.AUX_TAG_MASK);
	p = CiRuntime.setAuxTag(p, tag);
	def c = CiRuntime.clearAuxTag(p);

	match (t.1) {
		0 => return int.view(p);
		1 => return int.view(long.view(p) >>> 32);
		2 => return int.view(c);
		3 => return int.view(long.view(c) >>> 32);
		_ => return 42;
	}
}



