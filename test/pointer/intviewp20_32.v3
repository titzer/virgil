def p() -> Pointer {
    return Pointer.NULL + (-1);
}

def main(a: int) -> int {
    // sign extension test 
    match (a) {
        33 => return int.view(i33.view<Pointer>(p()) >> 32);
        34 => return int.view(i34.view<Pointer>(p()) >> 32);
        35 => return int.view(i35.view<Pointer>(p()) >> 32);
        36 => return int.view(i36.view<Pointer>(p()) >> 32);
        37 => return int.view(i37.view<Pointer>(p()) >> 32);
        38 => return int.view(i38.view<Pointer>(p()) >> 32);
        39 => return int.view(i39.view<Pointer>(p()) >> 32);
        40 => return int.view(i40.view<Pointer>(p()) >> 32);
        41 => return int.view(i41.view<Pointer>(p()) >> 32);
        42 => return int.view(i42.view<Pointer>(p()) >> 32);
        43 => return int.view(i43.view<Pointer>(p()) >> 32);
        44 => return int.view(i44.view<Pointer>(p()) >> 32);
        45 => return int.view(i45.view<Pointer>(p()) >> 32);
        46 => return int.view(i46.view<Pointer>(p()) >> 32);
        47 => return int.view(i47.view<Pointer>(p()) >> 32);
        48 => return int.view(i48.view<Pointer>(p()) >> 32);
        49 => return int.view(i49.view<Pointer>(p()) >> 32);
        50 => return int.view(i50.view<Pointer>(p()) >> 32);
        51 => return int.view(i51.view<Pointer>(p()) >> 32);
        52 => return int.view(i52.view<Pointer>(p()) >> 32);
        53 => return int.view(i53.view<Pointer>(p()) >> 32);
        54 => return int.view(i54.view<Pointer>(p()) >> 32);
        55 => return int.view(i55.view<Pointer>(p()) >> 32);
        56 => return int.view(i56.view<Pointer>(p()) >> 32);
        57 => return int.view(i57.view<Pointer>(p()) >> 32);
        58 => return int.view(i58.view<Pointer>(p()) >> 32);
        59 => return int.view(i59.view<Pointer>(p()) >> 32);
        60 => return int.view(i60.view<Pointer>(p()) >> 32);
        61 => return int.view(i61.view<Pointer>(p()) >> 32);
        62 => return int.view(i62.view<Pointer>(p()) >> 32);
        63 => return int.view(i63.view<Pointer>(p()) >> 32);
        64 => return int.view(i64.view<Pointer>(p()) >> 32);
        _ => return 42;
    }
