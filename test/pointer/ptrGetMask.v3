//@execute =true

// For now, 64-bit targets have 48-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 64-bit targets have 8 byte alignment => 8 lower bits available for tagging
// 2 bit for auxiliary tag bit, 1 for ref bit

// For now, 32-bit targets have 32-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 32-bit targets have 4 byte alignment => 2 lower bits available for tagging
// 1 bit for auxiliary tag bit, 1 for ref bit
def getAddressWidth() -> int {
    return if(Pointer.SIZE == 4, 32, 48); 
    // TODO: in the future, should be log2ceil(CiRuntime.HEAP_END)
}
// Computes the expected mask
def expected32() -> u32 {
    def allOnes = u32.max;
    def numAvailUpperBits = byte.view(32-getAddressWidth());
    var mask = if(numAvailUpperBits == 0, allOnes, (allOnes << numAvailUpperBits) >> numAvailUpperBits);
    mask = (mask >> 2) << 2;
    mask += 1;
    return u32.view(mask);
}
// Computes the expected mask
def expected64() -> u64 {
    def allOnes= u64.max;
    def numAvailUpperBits = byte.view(64-getAddressWidth());
    var mask = if(numAvailUpperBits == 0, allOnes, (allOnes << numAvailUpperBits) >> numAvailUpperBits);
    mask = (mask >> 3) << 3;
    mask += 1;
    return mask;
}
def main() -> bool {
    if (Pointer.SIZE == 4) {
        return CiRuntime.AUX_TAG_MASK == expected32();
    } 
    return CiRuntime.AUX_TAG_MASK == expected64();
}