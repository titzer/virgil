//@execute =true

// Creates a mask where the tag bits are 0s
// For now, 64-bit targets have 48-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 64-bit targets have 8 byte alignment => 8 lower bits available for tagging
// 2 bit for auxiliary tag bit, 1 for ref bit
def getAddressWidth() -> int {
    return 48; 
    // TODO: in the future, should be log2ceil(CiRuntime.HEAP_END)
}
def expected() -> u64 {
    def allOnes= u64.view(-1L);
    def numAvailUpperBits = byte.view(64-getAddressWidth());
    var mask = (allOnes << numAvailUpperBits) >> numAvailUpperBits;
    mask = (mask >> 3) << 3;
    mask += 1;
    return mask;
}
def main() -> bool {
    return CiRuntime.AUX_TAG_MASK==expected();
}