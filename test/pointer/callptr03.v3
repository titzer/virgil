//@execute 1=43; 0=42
def foo() => 42;
def bar() => 43;
def fs = [foo, bar];
def repack<C, P, R>(f: P -> R) -> (P -> R) {
	var t = CiRuntime.unpackClosure<C, P, R>(f), ptr = t.0, env = t.1;
	var f2 = CiRuntime.forgeClosure<C, P, R>(ptr, env);
	return f2;
}
def main(a: int) -> int {
	var f = fs[a];
	var f2 = repack<void, void, int>(f);
	return f2();
}
