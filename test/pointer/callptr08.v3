//@execute 1=43; 0=42
class C {
	def foo() => 42;
	def bar() => 43;
}
def c = C.new();
def ps = [Pointer.NULL, Pointer.NULL];
def unpack = CiRuntime.unpackClosure<C, void, int>;
def pack = CiRuntime.forgeClosure<C, void, int>;
def main(a: int) -> int {
	ps[0] = unpack(c.foo).0;
	ps[1] = unpack(c.bar).0;
	var ptr = ps[a];
	var f2 = pack(ptr, c);
	return f2();
}
