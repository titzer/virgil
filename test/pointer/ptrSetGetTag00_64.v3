//@execute 0=0; 1=2; 2=4; 3=6; 4=1; 12=3

// Testing setAuxTag on lower bits

// For now, 64-bit targets have 64-bit addresses
// In the future, smaller heaps may result in smaller address widths
// allowing for more tag bits. 
// NOTE: 64-bit targets have 8 byte alignment => 3 lower bits available for tagging
// 2 bit for auxiliary tag bit, 1 for ref bit

// Pointers are 4 byte aligned => 2 lower bits
// RefBit occupies 1 bit => 1 tag bit avaialble
def getAddressWidth() -> byte {
    return 48;
}
def p() -> Pointer {
    var ptr = Pointer.NULL;
    return ptr;
}
def main(a: int) -> int {
    def ptr = CiRuntime.setAuxTag(p(), a);
    // tag should be placed after the ref bit (0th bit)
    def intPtr = ptr - Pointer.NULL;
    return if(a < 4, int.view(intPtr), int.view(intPtr >> getAddressWidth()));
}