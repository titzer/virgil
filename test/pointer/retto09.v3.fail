//@execute = 42
// CiRuntime.returnTo with more return values than there are return registers.
//
// Disabled (.v3.fail): pre-existing, reproduces on master and on both backends.
// Return values beyond the register set go to caller stack slots, and returnTo
// replaces SP before returning, so the slot the callee wrote is not the one the
// caller reads. x86-64 does not get that far and fails during code generation --
//   InternalError: near block #N in retto09.f3: expected XMM, got r15
// -- while arm64-linux miscompiles it: the third value comes back wrong (this
// test returns 3 there). Two float return registers are enough for retto07, so
// three doubles is the smallest case that overflows on both targets.
//
// Re-enable once returnTo can deliver stack-allocated return values, or once it
// is rejected outright when the return types do not fit in registers.
def f3() -> (double, double, double) {
	var sp = CiRuntime.callerSp() + (0 - Pointer.SIZE);
	CiRuntime.returnTo<(double, double, double)>(sp, (1.5d, 2.5d, 4.5d));
	return (-1, -2, -3);
}
def main() -> int {
	var a = f3();
	if (a.0 != 1.5d) return 1;
	if (a.1 != 2.5d) return 2;
	if (a.2 != 4.5d) return 3;
	return 42;
}
