//@execute = 42
// Pointer.cmpswp used twice on the same pointer variable, with reference-typed
// operands.
//
// Disabled (.v3.fail): pre-existing verifier bug, reproduces on bin/stable. The
// first call type-checks; the second cannot infer the type parameter and is
// reported against whatever consumes its result --
//   TypeError: expected bool in boolean not operator, got ?
// Using the pointer again afterwards fails the same way ("expected Pointer in
// call, got ?"), so the variable's type is left unresolved by the first call.
// Native compilation accepts this program and both backends run it correctly;
// only the interpreter path rejects it, which is why ptr_cmpswp10 works around
// it by re-deriving the pointer on every iteration.
//
// Re-enable once type-parameter inference for cmpswp is fixed for reference
// types.
class Cell(n: int) { }
def A = Cell.new(1), B = Cell.new(2), C = Cell.new(3);
def refs: Array<Cell> = [A, B];
def main() -> int {
	var p = Pointer.atContents(refs);
	if (p.cmpswp(C, C)) return 1;   // fails: refs[0] is A
	if (!p.cmpswp(A, C)) return 2;  // succeeds
	if (refs[0] != C) return 3;
	if (refs[1] != B) return 4;
	return 42;
}
