//@execute 0=true; 1=true

// Testing lower tag for 32-bit pointer with getAuxTag
// See that setAuxTag places after the ref bit 

// Pointers are 4 byte aligned => 2 lower bits
// RefBit occupies 1 bit => 1 tag bit avaialble
def p() -> Pointer {
    var ptr = Pointer.NULL;
    return ptr;
}
def main(a: int) -> bool {
    def ptr = CiRuntime.setAuxTag(p(), a);
    // tag is placed after the 0th bit (the Ref tag bit)
    var intPtr = ptr - Pointer.NULL;
    intPtr = intPtr >> 1;
    return CiRuntime.getAuxTag(ptr) == intPtr;
}