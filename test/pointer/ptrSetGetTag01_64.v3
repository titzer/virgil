//@execute 0=0; 1=1; 2=2; 3=3

// Pointers are 4 byte aligned => 2 lower bits
// RefBit occupies 1 bit => 1 tag bit avaialble
def p() -> Pointer {
    var ptr = Pointer.NULL;
    return ptr;
}
def main(a: int) -> long {
    def ptr = CiRuntime.setAuxTag(p(), a);
    return int.view(CiRuntime.getAuxTag(ptr));
}