//@execute =true
def getHeapBits() -> int {
    def heap_size = CiRuntime.HEAP_SIZE;
    var numBits = 1, exp = 2;
    while (exp < heap_size) {
        exp = exp << 1;
        numBits++;
    }
    return numBits;
}
def expected() -> int {
    return 32 - getHeapBits() - 1;
}
def main() -> bool{
    return CiRuntime.AUX_TAG_WIDTH == expected();
}