//@execute 0=true; 1=true; 2=true; 3=true

// Testing lower tag for 64-bit pointer with getAuxTag
// See that setAuxTag places after the ref bit 

// Pointers are 8 byte aligned => 3 lower bits
// RefBit occupies 1 bit => 2 tag bits avaialble
def p() -> Pointer {
    var ptr = Pointer.NULL;
    return ptr;
}
def main(a: int) -> bool {
    def ptr = CiRuntime.setAuxTag(p(), a);
    // tag is placed after the 0th bit (the Ref tag bit)
    var intPtr = ptr - Pointer.NULL;
    intPtr = intPtr >> 1;
    return CiRuntime.getAuxTag(ptr) == intPtr;
}