//@execute 1=53; 0=52
class C(base: int) {
	def foo() => base + 22;
	def bar() => base + 23;
}
def c = C.new(10), d = C.new(30);
def ps = [Pointer.NULL, Pointer.NULL];
def unpack = CiRuntime.unpackClosure<C, void, int>;
def pack = CiRuntime.forgeClosure<C, void, int>;
def main(a: int) -> int {
	ps[0] = unpack(c.foo).0;
	ps[1] = unpack(c.bar).0;
	var ptr = ps[a];
	var f2 = pack(ptr, d);
	return f2();
}
