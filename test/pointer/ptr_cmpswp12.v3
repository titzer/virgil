//@execute 0=42; 1=42; 7=42
// Compare-and-swap whose expected and new values are reference constants that
// appear nowhere else in the program. Nothing forces those records into the
// data region ahead of code generation, so the backend meets them as record
// constants and has to materialize their addresses itself, which it must be
// able to do for any reference constant reaching a register.
//
// The swap itself is behind a condition that never holds at run time but that
// the optimizer cannot fold away, so this covers code generation for the
// operands without depending on how any one target executes a reference CAS.
//
// Listed in failures.x86-64-linux and failures.x86-64-darwin: those targets
// mishandle reference constants reaching a CAS, pre-existing and reproducing on
// master. x86-64-linux miscompiles the data region (the array reads back null,
// so this throws NullCheckException even though the swap never executes), and
// x86-64-darwin fails in the compiler with a checked cast in
// MachDataWriter.patchWithCallback. Drop those entries once that is fixed.
class Cell(n: int) { }
def A = Cell.new(1);
def UNUSED_B = Cell.new(2);
def UNUSED_C = Cell.new(3);
var refs: Array<Cell> = [A];

def main(a: int) -> int {
	if (a == 0x5EED) {
		if (Pointer.atContents(refs).cmpswp(UNUSED_C, UNUSED_B)) return 1;
	}
	if (refs[0] != A) return 2;
	return 42;
}
