//@execute = 42
// A compare-and-swap expands to a multi-instruction sequence with internal
// branches (skip-to-fail, retry, skip-the-failure-tail). This test pins down
// where each of those branches must land: every CAS below is followed by code
// that must run, both results are consumed as values rather than only as
// branch conditions, and successes and failures alternate so that a
// displacement off by one instruction lands somewhere observable.
def words: Array<int> = [5, 5, 5, 5];
def bytes: Array<byte> = "\x05\x05\x05\x05";

def main() -> int {
	var p = Pointer.atContents(words);
	var trail = 0;

	// A failing CAS returns false, leaves memory alone, and falls through.
	var f = p.cmpswp(4, 99);
	trail++;
	if (f) return 1;
	if (words[0] != 5) return 2;

	// A succeeding CAS returns true, stores, and also falls through.
	var s = p.cmpswp(5, 6);
	trail++;
	if (!s) return 3;
	if (words[0] != 6) return 4;

	// The same, one element over, so the failure tail cannot be reached by
	// falling out of the success tail.
	if (!(p + 4).cmpswp(5, 7)) return 5;
	trail++;
	if ((p + 4).cmpswp(5, 8)) return 6; // now 7, so this must fail
	trail++;
	if (words[1] != 7) return 7;

	// Alternating results accumulated as integers rather than branched on:
	// a wrong displacement changes the count even when control flow looks fine.
	var hits = 0;
	for (i < 4) {
		if ((p + 8).cmpswp(5, 5)) hits++;   // succeeds once, then 5 != 5 still holds
	}
	if (hits != 4) return 8;
	var misses = 0;
	for (i < 4) {
		if (!(p + 12).cmpswp(1234, 9)) misses++;
	}
	if (misses != 4) return 9;
	if (words[3] != 5) return 10;

	// Byte-sized CAS: the fail path must clear the exclusive monitor, otherwise
	// a following CAS on the same line can spuriously fail.
	var bp = Pointer.atContents(bytes);
	if (bp.cmpswp('\x04', '\x09')) return 11;
	if (!bp.cmpswp('\x05', '\x09')) return 12;
	if (bytes[0] != '\x09') return 13;
	if (bytes[1] != '\x05') return 14;

	if (trail != 4) return 15;
	return 42;
}
