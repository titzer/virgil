type PosInt = int if (this >= 0) {
	def meth();
}

int? = int U null;
int = int+;

class C;
C = C?;
C = values(C);
C+ = values(C) - null;

values(T?) = values(T) U null;
values(T+) = values(T) - null;

var x: PosInt? = PosInt(0);
var y = PosInt.!(x);

var t: T?;
t.somestuff // <- dynamic null check.

def sum(x: PosInt, y: PosInt) -> PosInt {
	return PosInt.!(x + y);
}

sum(x!, y);

Maybe<Maybe<T>>

type Maybe<T> {
	case None;
	case Some(x: T);
}

def unnull<T>(x: T?, defval: T+) -> T+ {
	match (x) {
		null => return defval;
		y: T+ => return y;
	}
}
