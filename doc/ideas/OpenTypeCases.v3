// Idea: Allow an ADT to be open to extension.  Since open/closed are terms already used in
// the compiler code base, it might be good to find alternative terms for this idea.  Here is
// a suggestion:
// - Current form of ADTs are called *complete*
// - The proposed extension types are called *extended* ADTs
//   -- They are composed from a *base* ADT and any number of *subtype* ADTs
//   -- The subtypes can have subtypes, etc.

// A base ADT is indicated by having an _ case, which must be the last case.
// It may also declare methods that apply to the base cases and any subtypes.

type T {
	case A(x: int);
	case B(x: float);
	case _;			// allows a separate declaration of new cases
	def m() -> int;		// All cases should implement this method.
}

// A base ADT may declare methods that apply only to subtypes:

type T {
	case A(x: int);
	case B(x: float);
	case _ {
		def m1() -> byte;	// subtypes should implement this;
					// it is not defined for A and B
	}
}

// A match on an extended ADT cannot be exhaustive. The Virgil compiler will require a
// a default case.
def m1(z: T) -> int {
	match (z) {
		A(x) => return x;
		B(x) => return int.!(x);
		x: _ => return x.m();	// this is the perfect place to call the method.
		// Note how it is helpful if we can bind a name to the subtype instance
	}
}

// A match added later, and where the user does not wish to change the declaration of
// the base ADT, can use a method added later:

def T.m2(x: int) -> float;  // as if m2() were declared in T

def aMatch(t: T) {
	match (t) {
		A(x) => float.!(x);
		B(x) => x;
		x: _ => x.m2();
	}
}

// An ADT subtype is declared using a qualified name (which must be distinct from the
// names already used in the supertype it extends and from names of sibling types):

type T.Mine {
	case X(x: byte) { def m() -> int { return int.!(x); }
	case Y(x: double) { def m() -> int { return int.roundd(x); }
	case _;
	def m2(a: int) => 1;  // defined for T.Mine and its subtypes, including T.Mine.X and T.Mine.Y
}

def anotherMatch(t: T) -> int {
	match (t) {
		A, B => return 0;
		Mine.X => return 2;
		x: Mine => return x.m2(3);
		x: _ => return x.m();
	}
}

// An ADT *subtype* may be subtyped

type T.Mine.More {
	case Z(x: long) { def m() => int.view(x); def m2(a: int) => int.view(x) + a; }
	// No _ case, so T.Mine.More may *not* be subtyped (similar to a Java final class)
}

// A match can mention any cases it knows about:
def newSum(t: T) -> float {
	match (t) {
		A(x) => return x;
		B(x) => return x;
		T.Mine.X(x) => return 112f;
		x: T.Mine => x.m2(0);
		_ => return t.m();
	}
}

// Together these features allow incremental extension of an ADT, both as new cases
// are added and as new matches are.


// Follow-on idea: Extended enums

enum Flower(color: string) {
	ROSE("red"),
	VIOLET("blue"),
	_
}

enum Flower.D {
	DAFFODIL("yellow")
}

// That much is straightforward.  Note that the fields of the supertype are not
// redeclared, for succinctness.  We *could* require them to be declared again
// (with the same names).  We could also *allow* them to be mentioned again if
// desired, as a reminder and documentation.

// The above is useful, but for reasonable / easy extension of matches, it is
// helpful to have a notion of methods for enums - a bit of a new concept.
// Such methods can be supported with a simple dispatch table on the enum's
// tag.  For uniformity in the implementation, we may want to "cast" the tag
// to a hidden object that has a single field containing the tag value.  These
// objects can be preallocated and obtained by indexing into a preconstructed
// array using the tag, so the run-time overhead is small, and can be avoided
// if no feature is used that requires the objects at run time.

// Redoing the above, adding a print method:

enum Flower(color: string) {
	ROSE("red"),
	VIOLET("blue"),
	_;
	def print() { System.puts(color); }
}

def Flower.height() -> int; // inches

def getHeight(f: Flower) {
	match (f) {
		ROSE => return 12;
		VIOLET => return 3;
		_ => return f.height();
	}
}

// f.height would be legal in getHeight, and would build a closure using the enum object.
// Likewise, Flower.height is a closure expecting a Flower enum argument like a class method.

enum Flower.More {
	DAFFODIL("yellow"),
	MARIGOLD("gold") { def print() { System.puts("yellow or orange"); } } ;
		// We could prohibit { } blocks on enum cases and require them to be
		// written as below if we want to simplify the syntax.
	def DAFFODIL.height() => 12;
}
def Flower.More.MARIGOLD.height() => 6;

// We observe that it might be useful to allow a subtype with no specific new cases:

def Flower.isOther() => false;

enum Flower.Other {
	_;
	def isOther() => true;
}

enum Flower.Other.AGroup {
	PANSY("purple"),
	BLUET("blue")
}

// It seems that without something like these enum methods, it is difficult to extend
// previously written matches when new enum cases are added.  We may be able to rule
// out enum *objects* if we disallow referring to enum methods in ways that would form
// a closure, such as f.height in getHeight.  Such closures are probably useful, though.

// One interesting question is whether .tag and .name, applied to an enum type, give
// a method (closure) that can be passed around as a function.  It does not seem too
// hard to accomplish that - but requires a little additional work in the compiler to
// generate these methods when they are needed.

def flowerMoreGetName = Flower.More.name;
def flowerGetTag = Flower.tag;

// There are no obvious issues with enum sets since Virgil is a whole program compiler
// and can (in essence) concatenate all the enums together in some order.  Presumably,
// an enum subtype has a correspond enumset type, e.g.:

var mySet: Flower.More.set = Flower.More.MARIGOLD;

// Such a set could be assigned to and combined with other enumsets that have the same
// base enum type.  This is most easily accomplished if subtype enumsets are implemented
// as base class enumsets where elements outside the subtype are guaranteed not to be
// in the set.  However, specific enum subtype sets could be implemented with smaller
// bit vectors, and zero-extension + shifting used to upcast, and masking + shifting
// used to downcast.  !, ?, and view all have reasonable definitions for enumsets with
// subtypes (and for enum subtypes themselves).  It might be convenient if operations
// on enumsets derived from the same base type automatically promote to the smallest
// common supertype.

var myOuterSet: Flower.set = mySet | Flower.ROSE;

// An open question is whether it would be useful to add a .object builtin that would
// take an enum value and return the singleton object corresponding to it.  Likewise,
// one might apply .class to an enum type to express its class type.  While both of
// these might need to exist internal to the compiler, their utility for users is
// less immediately evident.


// A further idea: Subtype enums that add more fields

enum Flower.ForSale(price: int) {
	CARNATION("carnation", 35),
	_;
}

// The notion is that fields written in the subtype header *add to* the fields of
// the supertype, and exist only for the subtype and its subtypes.  There is no
// inherent difficult in implementing this.  If we allow supertype fields to be
// mentioned when defining a subtype, we may wish to allow the user to write
// something like this when type do *not* wish to recapitulate the supertype fields.

enum Flower.ForSale(_, price: int) {
	// ...
		X.Z1 => return 112;
		X.Z2 => return 113;
		X => return 112f;
		_ => return -1f;
	}
}


// Below are notes from a recent meeting, illustrating:
// - adding new methods to a class after the fact
//   -- which follows reasonably from the proposals above
// - adding constrained ADTs
//   -- in the context of "maybe" types

def C.get() -> int { }

def int.extraStuff() { }

def T.get() -> int {
	match (this) {
		A(x) => ;
		B(x) => ;
		_ => 
	}
}

type PosInt = int if (this >= 0) {
	def meth();
}

int? = int U null;
int = int+;

class C;
C = C?;
C = values(C);
C+ = values(C) - null;

values(T?) = values(T) U null;
values(T+) = values(T) - null;

var x: PosInt? = PosInt(0);
var y = PosInt.!(x);

var t: T?;
t.somestuff // <- dynamic null check.

def sum(x: PosInt, y: PosInt) -> PosInt {
	return PosInt.!(x + y);
}

sum(x!, y);

def unnull<T>(x: T?, defval: T+) -> T+ {
	match (x) {
		null => return defval;
		y: T+ => return y;
	}
}
