def T = UnitTests.registerT("packing:", _, NewPackingSolverTester.new, _);
def X_ = void(
	T("distinguishable", test_distinguishable),
	T("nonrefs", test_nonrefs),
	T("nonrefs_64", test_nonrefs_64),
	T("nonrefs_assigned", test_nonrefs_assigned),
	T("exact fit", test_exact_fit),
	T("best fit", test_best_fit),
	T("multi case", test_multi_case),
	T("unify32", test_unify32),
	T("unify64", test_unify64),
	T("multi scalar 32", test_multi_scalar32),
	T("multi scalar 64", test_multi_scalar64),
	T("multi scalar multi case 32", test_multi_scalar_multi_case32), 
	T("multi scalar multi case 64", test_multi_scalar_multi_case64), 
	()
);
def F = void(UnitTests.fatal = true);
def VERBOSE = true;
class NewPackingSolverTester(t: Tester) {
	var solver: NewPackingSolver;
	def useSolver(s: NewPackingSolver) { solver = s; }
	private def trySolve(problem: NewPackingProblem) -> NewPackingSolution { return solver.solve(problem); }	
	def printPackingField(f: PackingField) {
		match (f) {
			Nonref(width) => Terminal.put1("Nonref(%d)", width);
			Ref => Terminal.put("Ref");
		}
	}
	def printCases(cases: Array<Array<PackingField>>) {
		for (caseIdx < cases.length) {
			def fields = cases[caseIdx];
			Terminal.put1("\tcase: %d | ", caseIdx);
			for (f in fields) { printPackingField(f); Terminal.put(" | "); }
			Terminal.put("\n");
		}
	}
	def printScalars(scalars: Array<ScalarPattern>) {
		for (i < scalars.length) System.puts(Strings.format2("\tScalar %d: %q\n", i, scalars[i].render));
	}
	def assert_distinguishable(patterns: Array<ScalarPattern>) {
		var elements = Array<bool>.new(patterns.length);
		for (i < elements.length) elements[i] = true;
		t.assert(solver.canDistinguish(patterns, elements), "expected distinguishable");
	}
	def assert_indistinguishable(patterns: Array<ScalarPattern>) {
		var elements = Array<bool>.new(patterns.length);
		for (i < elements.length) elements[i] = true;
		t.assert(!solver.canDistinguish(patterns, elements), "expected indistinguishable");
	}
	def verifyValidity(problem: NewPackingProblem, solution: NewPackingSolution) {
		def cases = problem.cases;
		var solvable = true;
		var invalidCaseIdx = 0;
		// Check problem assignments appear in solution assignments
		for (a in problem.assignments) {
			if (solution.assignments[a.0].interval != a.1){
			       	t.fail(Strings.format1("%q: specified assignment not obeyed", problem.render));
			}
		}
		for (caseIdx < cases.length) {
			def fields = cases[caseIdx];
			def isValid = verifyCaseValidity(caseIdx, fields, solution);
			if (!isValid) { solvable = false; invalidCaseIdx = caseIdx; break; }
			if (VERBOSE && !isValid) System.puts(Strings.format1("\tCase %d unsolvable\n", caseIdx));
		}
		if (!solvable) t.fail(Strings.format1("Invalid assignment | invalidCaseIdx: %d", invalidCaseIdx));
	}
	def verifyCaseValidity(
			caseIdx: int, 
			fields: Array<PackingField>, 
			solution: NewPackingSolution
	) -> bool {
		def assignments = solution.assignments;
		def tagInterval = solution.explicitTag;
		def caseToScalars = solution.patterns;

		def resultScalars = caseToScalars.getScalarCopiesForCase(caseIdx);
		def hasRef = caseHasRef(fields);
		def expectedScalars = initExpectedScalars(caseToScalars, caseToScalars.refPatterns, hasRef);
		
		verifyAssignmentsExist(caseIdx, fields, assignments);
		verifyAssignmentsConsistent(caseIdx, fields, assignments, expectedScalars);
		verifyTagInterval(tagInterval, expectedScalars);
		verifyAssignedScalars(resultScalars, expectedScalars);	
		return true;
	}
	def caseHasRef(fields: Array<PackingField>) -> bool {
		for (f in fields) {
			if (f == PackingField.Ref) return true;
		}
		return false;
	}
	def initExpectedScalars(caseToScalars: CaseToScalars, refPatterns: RefPatterns, hasRef: bool) -> Array<ScalarPattern> {
		def expectedScalars = Array<ScalarPattern>.new(caseToScalars.getNumScalars());
		for (scalarIdx < expectedScalars.length) {
			match(caseToScalars.getScalarType(scalarIdx)) {
				B32, B64 => {
					if (VERBOSE) Terminal.put1("Scalar %d is B32 or B64\n", scalarIdx);
					expectedScalars[scalarIdx] = refPatterns.nonref.copy();
				}
				R32, R64 => {
					if (VERBOSE) Terminal.put1("Scalar %d is R32 or R64\n", scalarIdx);
					def scalar = if(hasRef, refPatterns.ptrref, refPatterns.nonptrref);
					expectedScalars[scalarIdx] = scalar.copy();
					if (hasRef) expectedScalars[scalarIdx].unassignInterval(refPatterns.refInterval);
				}
				Ref => {
					if (VERBOSE) Terminal.put1("Scalar %d is Ref\n", scalarIdx);
					expectedScalars[scalarIdx] = refPatterns.ptrref.copy();
					expectedScalars[scalarIdx].unassignInterval(refPatterns.refInterval);
				}
				_ => t.fail("Float scalar types not supported yet\n");
			}
		}
		return expectedScalars;
	}
	def verifyAssignmentsExist(caseIdx: int, fields: Array<PackingField>, assignments: HashMap<CaseField, AssignedField>) {
		for (fieldIdx < fields.length) {
			def caseField = CaseField(caseIdx, fieldIdx);
			if (!assignments.has(caseField)) {
				t.fail1("\tCase field %q wasn't assigned an interval.\n", caseField.render);
				return;
			}
		}
	}
	def verifyAssignmentsConsistent(
			caseIdx: int, 
			fields: Array<PackingField>, 
			assignments: HashMap<CaseField, AssignedField>, 
			expectedScalars: Array<ScalarPattern>
	) {
		for (fieldIdx < fields.length) {	
			def caseField = CaseField(caseIdx, fieldIdx);
			def assignedField = assignments[caseField];
			def assignedScalarIdx = assignedField.scalarIdx;
			def assignedInterval = assignedField.interval;
			def scalar = expectedScalars[assignedScalarIdx];
			// Check assigned interval size matches field size
			verifyFieldSizeCorrect(caseField, fields[fieldIdx], assignedInterval);
			// Check no interval assignments overlap
			if (VERBOSE) System.puts(Strings.format3("\tScalar %d before assignment: %q | Reassigning interval: %q\n", assignedScalarIdx, scalar.render, assignedInterval.render));
			def fieldIsValid: bool = scalar.tryAssignInterval(assignedInterval);
			if (VERBOSE) System.puts(Strings.format3("\tScalar %d after assignment: %q  | fieldIsValid: %z\n", assignedScalarIdx, scalar.render, fieldIsValid));
			if (!fieldIsValid) {
				t.fail3("Failure assigning %q @ scalar %d interval %q", caseField.render, assignedScalarIdx, assignedInterval.render);
				return;
			}
		}
	}
	def verifyFieldSizeCorrect(caseField: CaseField, field: PackingField, assignedInterval: Interval) {
		match (field) {
			Nonref(w) => {
				if (assignedInterval.size() != w) {
					t.fail3("%q nonref size %d. Assigned @ %q\n", caseField.render, w, assignedInterval.render);
				}
			}
			Ref => {
				def refInterval = solver.refPatterns.refInterval;
				if (assignedInterval != refInterval) {
					t.fail2("%q ref @ wrong interval: %q", caseField.render, assignedInterval.render);
				}
			}
		}
	}
	def verifyAssignedScalars(resultScalars: Array<ScalarPattern>, expectedScalars: Array<ScalarPattern>) {
		for (i < resultScalars.length) {
			def rs = resultScalars[i];
			def es = expectedScalars[i];
			if (!Arrays.equal(rs.bits, es.bits)) {
				t.fail3("Scalar %d mismatch:\n\tResult: %q\n\tExpected: %q", i, rs.render, es.render);
				return;
			}
		}
	}
	def verifyTagInterval(tagInterval: Interval, expectedScalars: Array<ScalarPattern> ) {
		def tagIsValid: bool = if(tagInterval != Interval(0, 0), expectedScalars[0].tryAssignInterval(tagInterval), true);
		if (VERBOSE) System.puts(Strings.format2("Tag interval: %q | tagIsValid: %z\n", tagInterval.render, tagIsValid));
		if (!tagIsValid) t.fail2("Invalid tag interval: %q | Scalar 0: %q\n", tagInterval.render, expectedScalars[0].render);
	}
	def assert_solvableN(scalarLimit: int, cases: Array<Array<PackingField>>,  assignments: Array<(CaseField, Interval)> ) {
		var problem = NewPackingProblem(cases, assignments, V3.getTagType(cases.length).width, scalarLimit);
		def solution: NewPackingSolution = trySolve(problem);

		if (VERBOSE) { printCases(cases); System.ln(); }
		if (solution == null) t.fail1("%q: expected solution, no solution found", problem.render);
		else verifyValidity(problem, solution);
	}
	def assert_unsolvableN(scalarLimit: int, cases: Array<Array<PackingField>>, assignments: Array<(CaseField, Interval)> ) {
		var problem = NewPackingProblem(cases, assignments, V3.getTagType(cases.length).width, scalarLimit);
		def solution: NewPackingSolution = trySolve(problem);

		if (VERBOSE) { printCases(cases); System.ln(); }
		if (solution != null) t.fail1("%q: solution found, expected no solution", problem.render);
	}
	def assert_solvable0(cases: Array<Array<PackingField>>) { return assert_solvableN(1, cases, []); }
	def assert_unsolvable0(cases: Array<Array<PackingField>>) { return assert_unsolvableN(1, cases, []); }
	// Unit test function for best fit and exact fit 
	def assert_fittable(
			fitFunc: (Array<Interval>, HashMap<int, List<CaseField>>, HashMap<CaseField, AssignedField>, CaseToScalars, int) -> Array<Interval>,
			unassignedIntervals: Array<Interval>, 
			fields: Array<PackingField>, 
			preassignmentsArr: Array<(CaseField, Interval)>
	) {
		def preassignmentsMap = solver.makePreassignmentsMap(preassignmentsArr);
		def widthToFieldMaps = solver.makeWidthToFieldMaps(preassignmentsMap, [fields]);
		assertWidthToFieldsCorrect(0, fields, widthToFieldMaps[0], preassignmentsMap);
		def caseToScalars = solver.initScalars(widthToFieldMaps);
		def assignments = HashMap<CaseField, AssignedField>.new(CaseField.hash, CaseField.==);
		def origScalar = caseToScalars.caseToScalars[0][0].copy();
		if (VERBOSE) Terminal.put1("origScalar: %q\n", origScalar.render);
		solver.processPreassignments(preassignmentsArr, caseToScalars, assignments);
		def preassignedCaseFields = Arrays.map(preassignmentsArr, (fun (cfAndInterval: (CaseField, Interval)) => cfAndInterval.0));
		assertFieldsAssigned(preassignedCaseFields, assignments);
		// If there are preassignments, then we cannot trust the unassignedIntervals
		assertTestInputsConsistent(preassignmentsArr, unassignedIntervals, byte.view(origScalar.size));
		unassignedIntervals = if(preassignmentsArr.length == 0, unassignedIntervals, caseToScalars.getUnassignedIntervals(0, 0));
		if (VERBOSE) Terminal.put1("Scalar after preassignments: %q\n", caseToScalars.renderScalar(0, 0, _));
		
		fitFunc(unassignedIntervals, widthToFieldMaps[0], assignments, caseToScalars, 0);
		if (VERBOSE) Terminal.put1("Scalar after fit: %q\n", caseToScalars.renderScalar(0, 0, _));
		def allCaseFields = Array<CaseField>.new(fields.length);
		for (fIdx < fields.length) allCaseFields[fIdx] = CaseField(0, fIdx);
		assertFieldsAssigned(allCaseFields, assignments);

		// Create a copy and "unassign intervals" 
		def problem = NewPackingProblem([fields], preassignmentsArr, 0, 1);
		def solution = NewPackingSolution.new(caseToScalars, assignments, false, problem);
		solution.explicitTag = Interval(0, 0);
		verifyCaseValidity(0, fields, solution);
		Terminal.put("Finished assertion\n");
	}
	def intervalsToString(intervals: Array<Interval>) -> string {
		def buf = StringBuilder.new();
		buf.put1("%q", intervals[0].render);
		for (i=1; i < intervals.length; i++) {
			buf.put1(", %s", intervals[i].render);
		}
		return buf.toString();
	}
	def assertTestInputsConsistent(preassignmentsArr: Array<(CaseField, Interval)>, unassignedIntervals: Array<Interval>, scalarSize: byte) {
		if (unassignedIntervals.length == 1 && unassignedIntervals[0] == Interval(0, scalarSize)) return;
		if (preassignmentsArr.length > 0) {
			def intervalsString = intervalsToString(unassignedIntervals);
			t.fail2("Invalid test inputs. Num preassignments: %d. Unassigned intervals: %s", preassignmentsArr.length, intervalsString);
		}
	}
	def assertWidthToFieldsCorrect(caseIdx: int, expectedFields: Array<PackingField>, widthToFieldMap: HashMap<int, List<CaseField>>, preassignments: HashMap<CaseField, AssignedField>) {
		for (fIdx < expectedFields.length) {
			def caseField = CaseField(caseIdx, fIdx);
			def preassigned = preassignments.has(caseField);
			if (preassigned) continue;
			match (expectedFields[fIdx]) {
				Ref => if (!solver.widthToFieldMapHasRef(widthToFieldMap)) t.fail1("Missing field %d, ref", fIdx);
				Nonref(w) => if (!widthToFieldMap.has(w)) t.fail2("Missing field %d, size %d", fIdx, w);
			}
		}
	}
	def assertFieldsAssigned(
			expectedCaseFields: Array<CaseField>,
			assignments: HashMap<CaseField, AssignedField>
	) {
		if (VERBOSE && expectedCaseFields.length == 0) Terminal.put("No fields to check\n");
		for (cf in expectedCaseFields) {
			if (!assignments.has(cf)) { 
				Terminal.put1("`assignments` does not have CaseField: %q\n", cf.render); 
				t.fail1("`assignments` does not have CaseField: %q", cf.render); 
				return; 
			}
			if (VERBOSE) Terminal.put2("[assertAssignmentsExist] CaseField %q | %q\n", cf.render, assignments[cf].render);
		}
	}
}
def NR = PackingField.Nonref;
def R = PackingField.Ref;
def CF = CaseField;
def I = Interval;

def test_distinguishable(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(6, null));

	t.assert_indistinguishable([
		ScalarPatterns.parse("000000"),
		ScalarPatterns.parse("000000")
	]);
	t.assert_indistinguishable([
		ScalarPatterns.parse(".1.0.1"),
		ScalarPatterns.parse("0.1.0.")
	]);
	t.assert_distinguishable([
		ScalarPatterns.parse("000000"),
		ScalarPatterns.parse("000001")
	]);
	t.assert_distinguishable([
		ScalarPatterns.parse("111111"),
		ScalarPatterns.parse("000000")
	]);
	t.assert_distinguishable([
		ScalarPatterns.parse(".....0"),
		ScalarPatterns.parse(".....1")
	]);
	t.assert_distinguishable([
		ScalarPatterns.parse("....00"),
		ScalarPatterns.parse("....01"),
		ScalarPatterns.parse("....10"),
		ScalarPatterns.parse("....11")
	]);
	t.assert_distinguishable([
		ScalarPatterns.parse(".0...0"),
		ScalarPatterns.parse(".0...1"),
		ScalarPatterns.parse(".1...0"),
		ScalarPatterns.parse(".1...1")
	]);
}
def test_nonrefs(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));

	t.assert_solvable0([[NR(32)]]);
	t.assert_solvable0([[NR(16), NR(16)]]);
	t.assert_solvable0([[NR(16), NR(15)], [NR(16), NR(12)]]);
	t.assert_solvable0([[NR(16), NR(15)], [NR(16), NR(15)]]);
	t.assert_solvable0([[NR(15), NR(16)], [NR(16), NR(15)]]);
	t.assert_solvable0([[NR(15), NR(15)], [NR(7), NR(15), NR(8)], [NR(15), NR(15)]]);

	t.assert_unsolvable0([[NR(16), NR(16)], [NR(16), NR(12)]]);
	t.assert_unsolvable0([[NR(16), NR(8), NR(8)], [NR(16), NR(12)]]);
}

def test_nonrefs_64(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(64, ScalarPatterns.TAGGED_PTR_64));

	t.assert_solvable0([[NR(64)]]);
	t.assert_solvable0([[NR(32), NR(32)]]);
	t.assert_solvable0([[NR(16), NR(15)], [NR(16), NR(12)]]);
	t.assert_solvable0([[NR(16), NR(15)], [NR(16), NR(15)]]);
	t.assert_solvable0([[NR(15), NR(16)], [NR(16), NR(15)]]);
	t.assert_solvable0([[NR(15), NR(15)], [NR(7), NR(15), NR(8)], [NR(15), NR(15)]]);
	t.assert_solvable0([[NR(16), NR(16)], [NR(16), NR(12)]]);
	t.assert_solvable0([[NR(16), NR(8), NR(8)], [NR(16), NR(12)]]);
}

def test_nonrefs_assigned(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));

	t.assert_solvableN(1, 
		[[NR(16), NR(15)], [NR(16), NR(12)]],
		[(CF(0, 0), I(16, 32))]
	);
	// should fail, because we don't support non-contiguous intervals
	t.assert_unsolvableN( 1,
		[[NR(16), NR(15)], [NR(16), NR(12)]],
		[(CF(0, 0), I(12, 27))]
	);
	t.assert_solvableN( 1,
		[[NR(10), NR(15)], [NR(16), NR(12)]],
		[(CF(0, 1), I(12, 27))]
	);
}

def test_exact_fit(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	def assert_exact_fittable = t.assert_fittable(t.solver.findExactFits, _, _, _);
	
	// Base case: 
	assert_exact_fittable(
		[ I(0, 32) ], 
		[ NR(32) ], 
		[]
	);

	// Base case: No intervals to assign
	assert_exact_fittable(
		[ I(0, 32) ], 
		[ NR(32) ], 
		[ (CF(0, 0), I(0, 32)) ]
	);

	// Swap order of fields and order of available intervals
	assert_exact_fittable(
		[ I(0, 32) ],
		[ NR(12), NR(5), NR(15) ], 
		[ (CF(0, 1), I(15, 20)) ]
	);
	assert_exact_fittable(
		[ I(0, 15), I(20, 32) ],
		[ NR(12), NR(15) ], 
		[]
	);
		
	// Hard case of swapping order of fields and order of available intervals
	assert_exact_fittable(
		[ I(0, 32) ], 
		[ NR(1), NR(4), NR(1), NR(5), NR(21) ], 
		[ (CF(0, 0), I(5, 6)), (CF(0, 2), I(27, 28)) ]
	);
	assert_exact_fittable(
		[ I(0, 5), I(6, 27), I(28, 32) ], 
		[ NR(4), NR(5), NR(21) ], 
		[ ]
	);
}

def test_best_fit(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	def assert_best_fittable = t.assert_fittable(t.solver.findBestFits, _, _, _);
	// Simple case no preassigned; Best fit test 
	assert_best_fittable(
		[ I(0,32) ], 
		[ NR(16), NR(16) ], 
		[]
	);

	// Simple case one preassigned; 1 contiguous avail interval;  Best fit test 
	assert_best_fittable(
		[ I(0, 32) ], 
		[ NR(2), NR(15), NR(15) ], 
		[ (CF(0, 0), I(0, 2)) ]
	);
	assert_best_fittable(
		[ I(2, 32) ], 
		[ NR(15), NR(15) ], 
		[]
	);

	// Best fit into exact fit; best fit performed in 3 segments
	assert_best_fittable(
		[ I(0, 32) ], 
		[ NR(6), NR(4), NR(1), NR(5), NR(4), NR(6), NR(3), NR(3) ], 
		[ (CF(0, 2), I(10, 11)), (CF(0, 5), I(20, 26)) ]
	);
	assert_best_fittable(
		[ I(0, 10), I(11, 20), I(26, 32) ], 
		[ NR(6), NR(4), NR(5), NR(4), NR(3), NR(3) ],
		[]
	);

	// Best fit into exact fit; 
	assert_best_fittable(
		[ I(0, 32) ],
		[ NR(1), NR(9), NR(2), NR(1), NR(6), NR(13) ], 
		[ (CF(0, 0), I(11, 12)) ] 
	);
	assert_best_fittable(
		[ I(0, 11), I(12, 32) ], 
		[ NR(9), NR(2), NR(1), NR(6), NR(13) ], 
		[]
	);
}

def test_multi_case(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	def assert_solvable = t.assert_solvableN(1, _,  _);
	// Remember that multi-variant ADTs require tagging

	// 2 cases
	assert_solvable(
		[[ NR(1), NR(15), NR(15) ], 
		 [ NR(16), NR(15) ]], 
		[ ]
	);

	// 2 cases; 1 preassignment
	assert_solvable(
		[[ NR(2), NR(14), NR(15) ], 
		 [ NR(2), NR(29) ]], 
		[ (CF(0, 0), I(0, 2)) ]
	);

	// 2 cases; each with preassignment; exact fit test and best fit test 
	assert_solvable(
		[[ NR(12), NR(5), NR(14) ], 
		 [ NR(2), NR(14), NR(15) ]], 
		[ (CF(0, 1), I(15, 20)), (CF(1, 0), I(1, 3)) ]
	);

	// 3 cases
	assert_solvable(
		[ [NR(2), NR(13), NR(15) ],
		 [ NR(11), NR(5), NR(2), NR(12) ], 
		 [ NR(16), NR(12), NR(2) ]],
		[ (CF(0, 0), I(0, 2)),  (CF(1, 1), I(15, 20)) ]
	);
}


def test_unify32(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	
	// Refs
	t.assert_solvable0([ [R] ]);
	t.assert_solvable0([ [R], [R] ]);

	// 2 cases
	t.assert_solvable0(
		[[ NR(15), NR(15) ], 
		 [ R ]]
	);
	t.assert_solvable0(
		[[ NR(30) ], 
		 [ R ]]
	);
	t.assert_solvable0(
		[[ R ], 
		 [ NR(30) ]]
	);
	// 1 ref per case
	t.assert_solvable0(
		[[ R ], 
		 [ R ]]
	);


	t.assert_unsolvable0([[R], [R], [R]]);
	t.assert_unsolvable0([[R, R]]);
	t.assert_unsolvable0([[R], [NR(32)]]);
	t.assert_unsolvable0([[R], [NR(31)]]);
}

def test_unify64(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(64, ScalarPatterns.TAGGED_PTR_64));

	// Refs
	t.assert_solvable0([ [R] ]);
	t.assert_solvable0([ [R], [R] ]);
	t.assert_solvable0([ [R], [R], [R] ]);
	t.assert_solvable0([ [R], [R], [R], [R] ]);

	t.assert_solvable0([[R], [NR(32)]]);
	t.assert_solvable0([[R], [NR(32)], [NR(32)]]);
	t.assert_solvable0([[R, NR(3)]]);
	t.assert_solvable0([[R, NR(1)], [R, NR(1)]]);


	// 2 cases
	t.assert_solvable0(
		[ [ NR(32), NR(30) ], 
		 [ R, NR(16), NR(1) ]]
	);

	// 3 cases
	t.assert_solvable0(
		[ [ NR(32), NR(29) ], 
		 [ R, NR(16) ],
		 [ R, NR(8), NR(8) ]]
	);

	// 4 cases
	t.assert_solvable0(
		[ [ NR(32), NR(29) ], 
		 [ R, NR(16) ],
		 [ R, NR(8), NR(8) ],
		 [ R, NR(4), NR(5), NR(7) ] ]
	);

	// 3 cases; Upper tag filled
	t.assert_solvable0(
		[ [ NR(32), NR(29) ], 
		 [ R, NR(16) ], 
		 [ NR(8), NR(8), R ]]
	);


	// TODO: Consider the ref bit as a tagging bit
	t.assert_unsolvable0([[R], [NR(63)]]);
}
def test_multi_scalar32(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	def assert_solvable = t.assert_solvableN(2, _, _);

	// Test 2 nonrefs
	assert_solvable([ [ NR(32), NR(32) ] ], []);

	// Test 1 ref and 1 nonref
	assert_solvable([ [ NR(32), R ] ], []);

	// Test 1 ref and 2 nonref
	assert_solvable([ [ NR(32), R, NR(1) ] ], []);

	// Test 2 ref and 2 nonref
	assert_solvable([ [ NR(1), R, NR(1), R ] ], []);

	/** 
	TODO: This test fails; weakness of first fit and best fit
	Problem: first fit greedily assigns the largest

	How to come up with similar tests: 
	Define large width fields meant for various scalars
	First-fit will try to pack a large field meant for 
		another scalar will be packed into wrong scalar.
	 */
	// assert_solvable([ [ NR(7), NR(9), NR(11), NR(5), 
	// 			NR(6), NR(8), NR(18) ] ], []);

	// Test best fit with ref
	assert_solvable([ [ R, NR(6), NR(8), NR(18) ] ], []);

	// Test best fit with ref and exact fit on aux tag slot
	assert_solvable([ [ R, NR(1), NR(6), NR(8), NR(18) ] ], []);
	assert_solvable([ [ R, NR(3), NR(3), NR(1), NR(8), NR(18) ] ], []);
}

def test_multi_scalar64(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(64, ScalarPatterns.TAGGED_PTR_64));
	def assert_solvable = t.assert_solvableN(2, _, _);

	// Test 2 nonrefs
	assert_solvable([ [ NR(64), NR(64) ] ], []);

	// Test 1 nonref and 1 ref
	assert_solvable([ [ NR(64), R ] ], []);

	// 2 refs
	assert_solvable([ [ R, R ] ], []);

	// Test exact fit 
	assert_solvable([ [ R, NR(16), NR(2), NR(64) ] ], []);

	// Test exact fit 
	assert_solvable([ [ R, NR(16), NR(2), 
				R, NR(16), NR(2) ] ], []);
	
	// Test best fit on both scalars
	assert_solvable([ [ R, NR(2), NR(4), NR(10), NR(2),
				R, NR(2), NR(8), NR(8) ] ], []);
}

def test_multi_scalar_multi_case32(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	def assert_solvable = t.assert_solvableN(2, _, _);
	def assert_unsolvable = t.assert_unsolvableN(2, _, _);
	
	assert_solvable([ [ NR(31), NR(32) ], 
				[ NR(32), NR(31) ] ], []);
	assert_solvable([ [ R, NR(32) ], 
				[ NR(30), NR(1) ] ], []);
	assert_solvable([ [ R, NR(32) ], 
				[ NR(32), R ] ], []);
	assert_solvable([ [ R, R ], 
				[ R, R] ], []);

	// Tag bit will be stored at index 1; cannot assign NR(32)
	assert_unsolvable([ [ R, NR(32) ], 
				[ NR(32), NR(31) ] ], []);

	// Tag bit only 1 bit wide; need 2 bit wide tag
	assert_unsolvable([ [ R, R ], 
				[ R, R ], 
      				[ R, R ] ], []);

}

def test_multi_scalar_multi_case64(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(64, ScalarPatterns.TAGGED_PTR_64));
	def assert_solvable = t.assert_solvableN(2, _, _);
	// Multi case (REMEMBER TAG BITS)
	assert_solvable([ [ NR(63), NR(64) ],
       			 	[ NR(64), NR(63) ] ], []);

	// 1 case no refs, 1 case has ref
	assert_solvable([ [ NR(62), NR(64) ],
       			 	[ NR(64), R ] ], []);

	// Both cases have refs 
	assert_solvable([ [ R, NR(64) ],
       			 	[ NR(64), R ] ], []);

	// Both cases test exact fit
	assert_solvable([ [ R, NR(16), NR(2), R, NR(16), NR(1) ], 
				[ R, NR(16), NR(2), R, NR(16), NR(1) ] ], []);

	// Both cases test best fit on both scalars
	assert_solvable([ [ R, NR(2), NR(4), NR(10), NR(1), R, NR(2), NR(8), NR(8) ],
      				[ R, NR(2), NR(8), NR(8), R, NR(2), NR(4), NR(10), NR(1) ] ], []);

	// Testing 3 cases
	assert_solvable([ [ NR(62), NR(64) ],
       			 	[ NR(64), NR(62) ], 
       				[ NR(62), NR(64) ] ], []);

	// (hard) Testing 3 cases and best fit 
	assert_solvable([ [ R, NR(2), NR(4), NR(10), R, NR(2), NR(8), NR(8) ],
				[ R, NR(2), NR(9), NR(7), R, NR(2), NR(4), NR(10) ],
       				[ R, NR(2), NR(8), NR(8), R, NR(2), NR(4), NR(10) ] ], []);

	// Wizard Value ADT
	assert_solvable([ 
			[ R ], // Ref
			[ NR(31) ], // I31
			[ NR(32) ], // I32
			[ NR(64) ], // I64
			[ NR(32) ], // F32
			[ NR(64) ], // I64
			[ R ], // V128
			[ R, NR(64) ] // Continuation is a Ref and u64
	], []);
}
