def T = UnitTests.registerT("packing:", _, NewPackingSolverTester.new, _);
def X_ = void(
	T("exact fit", test_exact_fit),
	T("best fit", test_best_fit),
	T("multi case", test_multi_case),
	T("unify32", test_unify32),
	T("unify64", test_unify64),
	()
);
def F = void(UnitTests.fatal = true);
def VERBOSE = false;
class NewPackingSolverTester(t: Tester) {
	var solver: NewPackingSolver;
	def useSolver(s: NewPackingSolver) { solver = s; }

	private def trySolve(problem: PackingProblem) -> NewPackingSolution { return solver.solve(problem); }
	def printPackingField(f: PackingField) {
		match (f) {
			Nonref(width) => Terminal.put1("Nonref(%d)", width);
			Ref => Terminal.put("Ref");
		}
	}
	def printCases(cases: Array<Array<PackingField>>) {
		for (caseIdx < cases.length) {
			def fields = cases[caseIdx];
			Terminal.put1("\tcase: %d | ", caseIdx);
			for (f in fields) { printPackingField(f); Terminal.put(" | "); }
			Terminal.put("\n");
		}
	}
	def assertCaseAssignmentValid(
			caseIdx: int, 
			fields: Array<PackingField>, 
			assignments: HashMap<CaseField, AssignedField>, 
			tagInterval: Interval,
			numScalars: int
	) -> bool {
		def testScalars = Array<ScalarPattern>.new(numScalars);
		for (scalarIdx < testScalars.length) {
			testScalars[scalarIdx] = ScalarPattern.new(Array<PackingBit>.new(solver.scalarWidth));
		}
		for (fieldIdx < fields.length) {
			def caseField = CaseField(caseIdx, fieldIdx);
			if (!assignments.has(caseField)) {
				if (VERBOSE) System.puts(Strings.format1("\tCase field %q wasn't assigned an interval.\n", caseField.render));
				return false;
			}
			def assignedField = assignments[caseField];
			def assignedScalar = assignedField.scalarIdx;
			def assignedInterval = assignedField.interval;
			def scalar = testScalars[assignedScalar];
			// Check no interval assignments overlap
			if (VERBOSE) System.puts(Strings.format1("\tReassigning interval: %q\n", assignedInterval.render));
			def fieldIsValid: bool = scalar.tryAssignInterval(assignedInterval);
			if (VERBOSE) System.puts(Strings.format1("\tScalar after assignment: %q\n", scalar.render));
			if (!fieldIsValid) return false;
		}
		def tagIsValid: bool = if(tagInterval != Interval(0, 0), testScalars[0].tryAssignInterval(tagInterval), true);
		return tagIsValid;
	}
	def assert_assignable(cases: Array<Array<PackingField>>,  assignments: Array<(CaseField, Interval)> ) {
		var problem = PackingProblem(cases, assignments, V3.getTagType(cases.length).width);
		def solution: NewPackingSolution = trySolve(problem);

		if (VERBOSE) { printCases(cases); System.ln(); }
		if (solution == null) {
			t.fail("Packing failed. No solution found");
			return;
		}
		// Check that all fields were assigned
		def assignments = solution.assignments;
		def tagInterval = solution.explicitTag;
		def caseToScalars = solution.patterns;
		var assignable = true;
		var invalidCaseIdx = 0;
		for (caseIdx < cases.length) {
			def fields = cases[caseIdx];
			def isValid = assertCaseAssignmentValid(caseIdx, fields, assignments, tagInterval, caseToScalars.getNumScalars());
			if (!isValid) { assignable = false; invalidCaseIdx = caseIdx; break; }
			if (VERBOSE && !isValid) System.puts(Strings.format1("\tCase %d unassignable\n", caseIdx));
		}
		if (!assignable) t.fail(Strings.format1("Invalid assignment | invalidCaseIdx: %d", invalidCaseIdx));

	}
	def assert_bit_assigned(b: PackingBit, errorMsg: string) {
		match (b) {
			Assigned(_) => ;
			Fixed(v) => {
				t.fail(Strings.format1("Fixed bit found | %s", errorMsg));
				return;
			}
			Unassigned => {
				t.fail(Strings.format1("Unassigned bit found | %s", errorMsg));
				return;
			}
		}
	}
	// Unit test function for best fit and exact fit 
	def assert_fittable(
			fitFunc: (Array<Interval>, HashMap<int, List<CaseField>>, HashMap<CaseField, AssignedField>, CaseToScalars, int) -> Array<Interval>,
			unassignedIntervals: Array<Interval>, 
			fields: Array<PackingField>, 
			preassignmentsArr: Array<(CaseField, Interval)>
	) {
		def preassignmentsMap = solver.makePreassignmentsMap(preassignmentsArr);
		def widthToFieldMaps = solver.makeWidthToFieldMaps(preassignmentsMap, [fields]);
		assertWidthToFieldsCorrect(0, fields, widthToFieldMaps[0], preassignmentsMap);
		def caseToScalars = solver.initScalars(widthToFieldMaps);
		def assignments = HashMap<CaseField, AssignedField>.new(CaseField.hash, CaseField.==);
		def origScalar = caseToScalars.caseToScalars[0][0].copy();
		if (VERBOSE) Terminal.put1("origScalar: %q\n", origScalar.render);
		solver.processPreassignments(preassignmentsArr, caseToScalars, assignments);
		def preassignedCaseFields = Arrays.map(preassignmentsArr, (fun (cfAndInterval: (CaseField, Interval)) => cfAndInterval.0));
		assertFieldsAssigned(preassignedCaseFields, assignments);
		// If there are preassignments, then we cannot trust the unassignedIntervals
		assertTestInputsConsistent(preassignmentsArr, unassignedIntervals, byte.view(origScalar.size));
		unassignedIntervals = if(preassignmentsArr.length == 0, unassignedIntervals, caseToScalars.getUnassignedIntervals(0, 0));
		if (VERBOSE) Terminal.put1("Scalar after preassignments: %q\n", caseToScalars.renderScalar(0, 0, _));
		
		fitFunc(unassignedIntervals, widthToFieldMaps[0], assignments, caseToScalars, 0);
		if (VERBOSE) Terminal.put1("Scalar after fit: %q\n", caseToScalars.renderScalar(0, 0, _));
		def allCaseFields = Array<CaseField>.new(fields.length);
		for (fIdx < fields.length) allCaseFields[fIdx] = CaseField(0, fIdx);
		assertFieldsAssigned(allCaseFields, assignments);
		// Create a copy and "unassign intervals" 
		assertCaseAssignmentValid(0, fields, assignments, Interval(0, 0), caseToScalars.getNumScalars());
		Terminal.put("Finished assertion\n");
	}
	def intervalsToString(intervals: Array<Interval>) -> string {
		def buf = StringBuilder.new();
		buf.put1("%q", intervals[0].render);
		for (i=1; i < intervals.length; i++) {
			buf.put1(", %s", intervals[i].render);
		}
		return buf.toString();
	}
	def assertTestInputsConsistent(preassignmentsArr: Array<(CaseField, Interval)>, unassignedIntervals: Array<Interval>, scalarSize: byte) {
		if (unassignedIntervals.length == 1 && unassignedIntervals[0] == Interval(0, scalarSize)) return;
		if (preassignmentsArr.length > 0) {
			def intervalsString = intervalsToString(unassignedIntervals);
			t.fail2("Invalid test inputs. Num preassignments: %d. Unassigned intervals: %s", preassignmentsArr.length, intervalsString);
		}
	}
	def assertWidthToFieldsCorrect(caseIdx: int, expectedFields: Array<PackingField>, widthToFieldMap: HashMap<int, List<CaseField>>, preassignments: HashMap<CaseField, AssignedField>) {
		for (fIdx < expectedFields.length) {
			def caseField = CaseField(caseIdx, fIdx);
			def preassigned = preassignments.has(caseField);
			if (preassigned) continue;
			match (expectedFields[fIdx]) {
				Ref => if (!solver.widthToFieldMapHasRef(widthToFieldMap)) t.fail1("Missing field %d, ref", fIdx);
				Nonref(w) => if (!widthToFieldMap.has(w)) t.fail2("Missing field %d, size %d", fIdx, w);
			}
		}
	}
	def assertFieldsAssigned(
			expectedCaseFields: Array<CaseField>,
			assignments: HashMap<CaseField, AssignedField>
	) {
		if (VERBOSE && expectedCaseFields.length == 0) Terminal.put("No fields to check\n");
		for (cf in expectedCaseFields) {
			if (!assignments.has(cf)) { 
				Terminal.put1("`assignments` does not have CaseField: %q\n", cf.render); 
				t.fail1("`assignments` does not have CaseField: %q", cf.render); 
				return; 
			}
			if (VERBOSE) Terminal.put2("[assertAssignmentsExist] CaseField %q | %q\n", cf.render, assignments[cf].render);
		}
	}
	def checkAndUnassign(scalar: ScalarPattern, caseField: CaseField, assignedField: AssignedField) {
		def interval = assignedField.interval;
		for (i=interval.start; i < interval.end; i++) {
			// If overlap occurs, then there exists a bit that's unassigned
			def errorMsg = Strings.format3("Index: %d | Interval: %q | Scalar: %q", i, interval.render, scalar.render);
			assert_bit_assigned(scalar.bits[i], errorMsg);
		}
		scalar.unassignInterval(interval);
		if (VERBOSE) Terminal.put2("Unassigned %q | %q\n", assignedField.render, scalar.render);
	}

}
def NR = PackingField.Nonref;
def R = PackingField.Ref;
def CF = CaseField;
def I = Interval;

def test_exact_fit(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	def assert_exact_fittable = t.assert_fittable(t.solver.findExactFits, _, _, _);
	
	// Base case: 
	assert_exact_fittable(
		[ I(0, 32) ], 
		[ NR(32) ], 
		[]
	);

	// Base case: No intervals to assign
	assert_exact_fittable(
		[ I(0, 32) ], 
		[ NR(32) ], 
		[ (CF(0, 0), I(0, 32)) ]
	);

	// Swap order of fields and order of available intervals
	assert_exact_fittable(
		[ I(0, 32) ],
		[ NR(12), NR(5), NR(15) ], 
		[ (CF(0, 1), I(15, 20)) ]
	);
	assert_exact_fittable(
		[ I(0, 15), I(20, 32) ],
		[ NR(12), NR(15) ], 
		[]
	);
		
	// Hard case of swapping order of fields and order of available intervals
	assert_exact_fittable(
		[ I(0, 32) ], 
		[ NR(1), NR(4), NR(1), NR(5), NR(21) ], 
		[ (CF(0, 0), I(5, 6)), (CF(0, 2), I(27, 28)) ]
	);
	assert_exact_fittable(
		[ I(0, 5), I(6, 27), I(28, 32) ], 
		[ NR(4), NR(5), NR(21) ], 
		[ ]
	);
}

def test_best_fit(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	def assert_best_fittable = t.assert_fittable(t.solver.findBestFits, _, _, _);
	// Simple case no preassigned; Best fit test 
	assert_best_fittable(
		[ I(0,32) ], 
		[ NR(16), NR(16) ], 
		[]
	);

	// Simple case one preassigned; 1 contiguous avail interval;  Best fit test 
	assert_best_fittable(
		[ I(0, 32) ], 
		[ NR(2), NR(15), NR(15) ], 
		[ (CF(0, 0), I(0, 2)) ]
	);
	assert_best_fittable(
		[ I(2, 32) ], 
		[ NR(15), NR(15) ], 
		[]
	);

	// Best fit into exact fit; best fit performed in 3 segments
	assert_best_fittable(
		[ I(0, 32) ], 
		[ NR(6), NR(4), NR(1), NR(5), NR(4), NR(6), NR(3), NR(3) ], 
		[ (CF(0, 2), I(10, 11)), (CF(0, 5), I(20, 26)) ]
	);
	assert_best_fittable(
		[ I(0, 10), I(11, 20), I(26, 32) ], 
		[ NR(6), NR(4), NR(5), NR(4), NR(3), NR(3) ],
		[]
	);

	// Best fit into exact fit; 
	assert_best_fittable(
		[ I(0, 32) ],
		[ NR(1), NR(9), NR(2), NR(1), NR(6), NR(13) ], 
		[ (CF(0, 0), I(11, 12)) ] 
	);
	assert_best_fittable(
		[ I(0, 11), I(12, 32) ], 
		[ NR(9), NR(2), NR(1), NR(6), NR(13) ], 
		[]
	);
}

def test_multi_case(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	// Remember that multi-variant ADTs require tagging

	// 2 cases
	t.assert_assignable(
		[[ NR(1), NR(15), NR(15) ], 
		 [ NR(16), NR(15) ]], 
		[ ]
	);

	// 2 cases; 1 preassignment
	t.assert_assignable(
		[[ NR(2), NR(14), NR(15) ], 
		 [ NR(2), NR(29) ]], 
		[ (CF(0, 0), I(0, 2)) ]
	);

	// 2 cases; each with preassignment; exact fit test and best fit test 
	t.assert_assignable(
		[[ NR(12), NR(5), NR(14) ], 
		 [ NR(2), NR(14), NR(15) ]], 
		[ (CF(0, 1), I(15, 20)), (CF(1, 0), I(1, 3)) ]
	);

	// 3 cases
	t.assert_assignable(
		[ [NR(2), NR(13), NR(15) ],
		 [ NR(11), NR(5), NR(2), NR(12) ], 
		 [ NR(16), NR(12), NR(2) ]],
		[ (CF(0, 0), I(0, 2)),  (CF(1, 1), I(15, 20)) ]
	);
}


def test_unify32(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(32, ScalarPatterns.TAGGED_PTR_32));
	
	// Simple test; 2 cases
	t.assert_assignable(
		[ [ NR(15), NR(15) ], 
		 [ R ]], 
		 []
	);
}

def test_unify64(t: NewPackingSolverTester) {
	t.useSolver(NewPackingSolver.new(64, ScalarPatterns.TAGGED_PTR_64));

	// Simple test; 2 cases
	t.assert_assignable(
		[ [ NR(32), NR(30) ], 
		 [ R, NR(16), NR(1) ]], 
		 []
	);

	// 3 cases; Upper tag filled
	t.assert_assignable(
		[ [ NR(32), NR(29) ], 
		 [ R, NR(16) ], 
		 [ NR(8), NR(8), R ]], 
		 []
	);
}
