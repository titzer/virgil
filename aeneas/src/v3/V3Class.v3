// The type constructor for user-declared class types.
class V3Class_TypeCon extends TypeCon {
	def classDecl: VstClass;
	var names: Record;
	var shortNames: Record;

	new(classDecl, typeCache: TypeCache)
		super(classDecl.fullName, classDecl.kind, Lists.length(classDecl.typeParams), typeCache) {
		if (classDecl.typeParams == null) singleton = ClassType.new(uid, classDecl, this, null);
	}
	def alloc(hash: int, nested: List<Type>) -> ClassType {
		return ClassType.new(hash, classDecl, this, nested);
	}
	def getNames(prog: Program) -> Record {
		if (names == null) {
			var total = if(classDecl.tagHi >= 0, classDecl.tagHi + 1, classDecl.cases.length);
			names = prog.newRecord(V3.stringArrayType, total);
			CaseNames.fillNames(names, classDecl, "", prog);
		}
		return names;
	}
	def getShortNames(prog: Program) -> Record {
		if (shortNames == null) {
			var total = if(classDecl.tagHi >= 0, classDecl.tagHi + 1, classDecl.cases.length);
			shortNames = prog.newRecord(V3.stringArrayType, total);
			CaseNames.fillShortNames(shortNames, classDecl, prog);
		}
		return shortNames;
	}
}
// Shared helpers for building case name arrays (used by both V3Class_TypeCon and EnumType).
component CaseNames {
	def fillNames(rec: Record, decl: VstClass, prefix: string, prog: Program) {
		for (c in decl.cases) {
			var tag = c.runtimeTag();
			if (tag < 0 || Strings.equal(c.name(), "_")) continue;
			var n = if(prefix.length == 0, c.name(), Strings.format2("%s.%s", prefix, c.name()));
			rec.values[tag] = Byte.boxString(n, prog);
		}
		var subtypes = Lists.reverse(decl.subtypeOrder);
		for (l = subtypes; l != null; l = l.tail) {
			var sub = l.head;
			var p = if(prefix.length == 0, sub.name(), Strings.format2("%s.%s", prefix, sub.name()));
			fillNames(rec, sub, p, prog);
		}
	}
	def fillShortNames(rec: Record, decl: VstClass, prog: Program) {
		for (c in decl.cases) {
			var tag = c.runtimeTag();
			if (tag < 0 || Strings.equal(c.name(), "_")) continue;
			rec.values[tag] = Byte.boxString(c.name(), prog);
		}
		var subtypes = Lists.reverse(decl.subtypeOrder);
		for (l = subtypes; l != null; l = l.tail) {
			fillShortNames(rec, l.head, prog);
		}
	}
}
// The type for user-declared classes.
// XXX: separate VariantType from ClassType and enum type.
class ClassType extends Type {
	def classDecl: VstClass;
	var superType: ClassType;
	var depth = -1;			// depth from root, to speed up commonSuperClass()
	var typeArgs: TypeArgs;

	new(hash: int, classDecl, typeCon: V3Class_TypeCon, nested: List<Type>) super(hash, typeCon, nested) { }

	def getSuperType() -> ClassType {
		if (superType != null) return superType;
		if (classDecl.superclass != null) {
			var superType = classDecl.superclass.getType();
			if (!ClassType.?(superType)) return null;  // ignore errors
			if (classDecl.typeParams != null) superType = superType.substitute(getTypeArgs());
			return this.superType = ClassType.!(superType);
		}
		// For open variant subtypes (no superclass), check the generic form's superType.
		if (classDecl.typeParams != null && nested != null) {
			var generic = ClassType.!(classDecl.getDeclaredType());
			if (generic != this && generic.superType != null) {
//				return this.superType = ClassType.!(generic.superType.classDecl.getDeclaredType());
				var superType = generic.superType.substitute(getTypeArgs());
				return this.superType = ClassType.!(superType);
			}
		}
		return null;
	}
	def getTypeArgs() -> TypeArgs {
		if (typeArgs != null) return typeArgs;
		if (classDecl.typeParams == null) return null;
		var typeArgs = TypeArgs.new(classDecl.typeEnv, Lists.toArray(nested));
		return this.typeArgs = typeArgs;
	}
	def lookupCase(name: string) -> VstCaseMember {
		var member = classDecl.memberMap[name];
		if (VstCaseMember.?(member)) return VstCaseMember.!(member);
		return null;
	}
	def getDepth() -> int {
		if (depth == -1) {
			var s = getSuperType();
			depth = if(s != null, s.getDepth() + 1);
		}
		return depth;
	}
	def getNameOperator() -> Operator {
		var types = [Type.!(this)];
		return V3Op.newVstSugar(VstOperator.VariantGetName, types, types, V3.stringType);
	}
	def getShortNameOperator() -> Operator {
		var types = [Type.!(this)];
		return V3Op.newVstSugar(VstOperator.VariantGetShortName, types, types, V3.stringType);
	}
}
