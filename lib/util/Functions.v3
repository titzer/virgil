// Utilities for Virgil functions.
component Functions {
	// Returns a function that commutes the inputs of {f} before applying {f}.
	def commute<A, B, R>(f: (A, B) -> R) => fun(b: B, a: A) => f(a, b);
	// Returns a closure that, when called, applies {f} to {a} and returns the result.
	def bind<A, B>(f: A -> B, a: A) => fun => f(a);
	// Returns a closure that, when called, applies {f} but drops its result.
	def voidify<A, B>(f: A -> B) => fun (a: A) => void(f(a));
}
