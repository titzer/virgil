// Entry point for native and JVM targets (main takes Array<string>).

def main(args: Array<string>) -> int {
	var test = if(args.length > 0, parseInt(args[0]), 0);
	var iters = if(args.length > 1, parseInt(args[1]), 10000000);
	return Bench.runTest(test, iters);
}

def parseInt(s: string) -> int {
	var r = 0;
	for (c in s) {
		if (c >= '0' && c <= '9') r = r * 10 + (c - '0');
	}
	return r;
}
